page 1 (
    name: Welcome
    alias: WELCOME
    title: Welcome
    appearance {
        pageTemplate: @/login
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }

    region background-image (
        name: Background Image
        type: staticContent
        layout {
            sequence: 50
            slot: backgroundImage
        }
        appearance {
            template: @/image
            templateOptions: [
                #DEFAULT#
                t-ImageRegion--auto
                t-ImageRegion--cover
                t-ImageRegion--square
                t-ImageRegion--noFilter
            ]
        }
        accessibility {
            useLandmark: false
        }
        image {
            fileUrl: #APP_FILES#background.jpg
        }
    )

    region welcome-image (
        name: Welcome Image
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/image
            templateOptions: [
                #DEFAULT#
                t-ImageRegion--auto
                t-ImageRegion--cover
                t-ImageRegion--square
                t-ImageRegion--noFilter
                margin-top-none
            ]
            cssClasses: [
                u-flex
                u-justify-content-center
            ]
        }
        accessibility {
            useLandmark: false
        }
        image {
            fileUrl: #APP_FILES#splash/splash-1.png
        }
    )

    region welcome-text (
        name: Welcome Text
        type: staticContent
        source {
            htmlCode: <p>Experience the first Oracle APEX sample application designed for mobile.</p>
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-top-md
                margin-bottom-lg
            ]
            cssClasses: u-textCenter
        }
        accessibility {
            useLandmark: false
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 40
            slot: contentBody
            column: 5
            columnSpan: 4
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--stretch
            ]
            cssClasses: [
                mxw320
                margin-auto
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

