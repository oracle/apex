page 10 (
    name: Order Details
    alias: ORDER-DETAILS
    title: Order Details
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region actions (
        name: Actions
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
        accessibility {
            useLandmark: false
        }
    )

    region order-details (
        name: Order Details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select order_id,
                       order_datetime,
                       initcap( order_status ) as order_status
                  from sample_restaurant_orders
                 where order_id = :P10_ORDER_ID
                 order by order_id
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                t-ContentBlock--lightBG
            ]
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
        }

        column ORDER_DATETIME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Ordered On
            }
            layout {
                sequence: 20
            }
            appearance {
                formatMask: FMMonth DD, YYYY
            }
            sorting {
                sortable: false
            }
        )

        column ORDER_ID (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Order ID
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            accessibility {
                valueIdentifiesRow: true
            }
            sorting {
                sortable: false
            }
        )

        column ORDER_STATUS (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

    )

    region order-summary (
        name: Order Summary
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select o.order_id,
                       o.item_id,
                       o.unit_price,
                       o.quantity,
                       i.name,
                       i.description,
                       i.image_url,
                       o.unit_price * o.quantity subtotal,
                       o.utensils,
                       o.note
                  from sample_restaurant_order_items o,
                       sample_restaurant_items i
                 where o.order_id = :P10_ORDER_ID
                   and o.item_id = i.id
                ```
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--padded
                t-ContentBlock--h3
                t-ContentBlock--lightBG
            ]
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &NAME.
            description:
                ```html
                <div>Utensils: &UTENSILS.</div>
                <div>&NOTE.</div>
                ```
            miscellaneous: Subtotal $&SUBTOTAL.
            displayAvatar: true
            displayBadge: true
        }
        plugin-avatar {
            type: image
            image: {
                type: url
                url: #APP_FILES#&IMAGE_URL.
            }
        }
        plugin-badge {
            label: Quantity
            value: QUANTITY
            shape: rounded
            size: medium
            columnWidth: auto
        }
        plugin-appearance {
            applyThemeColors: false
        }
        pagination {
            type: scroll
        }
        messages {
            whenNoDataFound: No Items Found!
        }

        column DESCRIPTION (
            layout {
                sequence: 90
            }
            source {
                databaseColumn: DESCRIPTION
                dataType: varchar2
            }
        )

        column IMAGE_URL (
            layout {
                sequence: 70
            }
            source {
                databaseColumn: IMAGE_URL
                dataType: varchar2
            }
        )

        column ITEM_ID (
            layout {
                sequence: 80
            }
            source {
                databaseColumn: ITEM_ID
                dataType: number
            }
        )

        column NAME (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
        )

        column NOTE (
            layout {
                sequence: 120
            }
            source {
                databaseColumn: NOTE
                dataType: varchar2
            }
        )

        column ORDER_ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ORDER_ID
                dataType: number
                primaryKey: true
            }
        )

        column QUANTITY (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: QUANTITY
                dataType: number
            }
        )

        column SUBTOTAL (
            layout {
                sequence: 100
            }
            source {
                databaseColumn: SUBTOTAL
                dataType: number
            }
        )

        column UNIT_PRICE (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: UNIT_PRICE
                dataType: number
            }
        )

        column UTENSILS (
            layout {
                sequence: 110
            }
            source {
                databaseColumn: UTENSILS
                dataType: varchar2
            }
            lov {
                type: staticValues
                staticValues: STATIC:Yes;Y,No;N
            }
        )

    )

    region order-total (
        name: Order Total
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select '$' || sum( unit_price * quantity ) as total
                  from sample_restaurant_order_items
                 where order_id = :P10_ORDER_ID
                 order by order_id
                ```
        }
        layout {
            sequence: 70
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
                t-ContentBlock--shadowBG
                t-Region--removeHeader js-removeLandmark
            ]
            renderComponents: belowContent
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--fixedLabelSmall
                t-AVPList--rightAligned
            ]
        }

        column TOTAL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Total
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            accessibility {
                valueIdentifiesRow: true
            }
            columnFormatting {
                htmlExpression: <strong>#TOTAL#</strong>
            }
            sorting {
                sortable: false
            }
        )

    )

    pageItem P10_ORDER_ID (
        type: hidden
        layout {
            sequence: 20
            slot: body
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button go-back (
        buttonName: GO_BACK
        label: Go Back
        layout {
            sequence: 10
            region: @actions
            slot: previous
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--iconLeft
                t-Button--hoverIconPush
            ]
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button invite-friends (
        buttonName: INVITE_FRIENDS
        label: Invite a friend
        layout {
            sequence: 80
            slot: body
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--simple
                t-Button--iconLeft
                t-Button--stretch
            ]
            icon: fa-cutlery
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction share-application (
        name: Share Application
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @invite-friends
        }

        action native-share (
            action: share
            settings {
                title: Invite Friends
                text: Check out this Oracle APEX mobile app
                type: url
                url: {
                    page: 1
                }
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

