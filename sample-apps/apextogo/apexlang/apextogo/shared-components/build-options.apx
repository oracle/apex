buildOption commented-out (
    name: Commented Out
)

buildOption feature-about-page (
    name: Feature: About Page
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_ABOUT_PAGE
    }
    comments {
        comments: About this application page.
    }
)

buildOption feature-push-notifications (
    name: Feature: Push Notifications
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_PUSH_NOTIFICATIONS
    }
    comments {
        comments: Allow users to subscribe to push notifications on their devices.
    }
)

buildOption feature-user-settings (
    name: Feature: User Settings
    status {
        status: include
    }
    advanced {
        featureIdentifier: APPLICATION_USER_SETTINGS
    }
    comments {
        comments: The user settings page is a drawer that links to all user settings pages.
    }
)

