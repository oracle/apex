customAttribute attribute_01 (
    apexlangName: orientation
    attribute: 1
    name: Orientation
    type: selectList
    validation {
        required: true
    }
    appearance {
        sequence: 10
    }
    default {
        value: Horizontal
    }

    entry horizontal (
        sequence: 10
        display: Horizontal
        return: horizintal
        advanced {
            quickPick: true
        }
    )

    entry vertical (
        sequence: 20
        display: Vertical
        return: vertical
        advanced {
            quickPick: true
        }
    )

)

