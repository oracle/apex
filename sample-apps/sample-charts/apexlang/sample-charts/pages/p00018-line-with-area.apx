        behavior {
            action: definedByDynamicAction
        }
    )

    button vertical (
        buttonName: Vertical
        label: Vertical
        layout {
            sequence: 40
            region: @line-with-area-chart-data-labels-line-styles
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-bar-chart
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction horizontal-orientation (
        name: Horizontal Orientation
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @horizontal
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("lineChart").widget().ojChart({orientation: 'horizontal'});
            }
            affectedElements {
                selectionType: region
                region: @line-with-area-chart-data-labels-line-styles
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction vertical-orientation (
        name: Vertical Orientation
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @vertical
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("lineChart").widget().ojChart({orientation: 'vertical'});
            }
            affectedElements {
                selectionType: region
                region: @line-with-area-chart-data-labels-line-styles
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

