    region plot-area-and-indicator-size-information (
        name: Plot Area and Indicator Size Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates the setting of the series-level attribute, <strong>Plot Area Color</strong>, to green, to color the empty part of the gauge.
                 The <strong>Indicator Size</strong> attribute has been changed from a default of 1 to .4, to reduce the size of the indicator in relation to the plot area.
                ```
        }
        layout {
            sequence: 10
            parentRegion: @plot-area-and-indicator-size
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: false
        }
    )

    region start-angle-and-angle-extent (
        name: Start Angle and Angle Extent
        type: chart
        layout {
            sequence: 30
            parentRegion: @circular
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        chart {
            type: statusMeterGauge
        }
        chartLayout {
            maxWidth: 90
            height: 100
        }
        gauge {
            innerRadius: 0.7
            startAngle: 180
            angleExtent: 180
        }
        value {
            valueType: percent
            format: percent
            decimalPlaces: 0
            formatScaling: none
        }

        series commission (
            name: Commission
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    SELECT sum(case when COMM is null 
                                         then 0 
                                    when COMM = 0 
                                         then 0 
                                    else 1 
                                    end) value, 
                           count(*) max_value,
                           10 low,
                           20 high
                    FROM   eba_demo_chart_emp
                    ```
            }
            columnMapping {
                value: VALUE
                maxValue: MAX_VALUE
            }
            appearance {
                color: #F50000
            }
            thresholds {
                display: onIndicator
            }
            referenceLines {
                values: 7,14
                colors: yellow
            }
            label {
                show: true
                position: start
            }
        )

    )

    region start-angle-and-angle-extent-information (
        name: Start Angle and Angle Extent Information
        type: staticContent
        source {
            htmlCode: This example demonstrates a variation of the <strong>Start Angle</strong> and <strong>Angle Extent</strong> attributes, to render a semi-circular Status Meter Gauge. <strong>Reference Lines</strong> are also declaratively defined at series-level, to identify value ranges on the chart.
        }
        layout {
            sequence: 40
            parentRegion: @start-angle-and-angle-extent
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region thresholds (
        name: Thresholds
        type: chart
        layout {
            sequence: 120
            parentRegion: @horizontal
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        chart {
            type: statusMeterGauge
        }
        chartLayout {
            maxWidth: 300
        }
        gauge {
            orientation: horizontal
            indicatorSize: 0.9
        }
        value {
            format: decimal
            decimalPlaces: 0
            formatScaling: none
        }

        series commission (
            name: Commission
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    SELECT sum(case when COMM is null 
                                         then 0 
                                    when COMM = 0 
                                         then 0 
                                    else 1 
                                    end) value, 
                           count(*) max_value,
                           'Sales' as my_label 
                    FROM   eba_demo_chart_emp
                    ```
            }
            columnMapping {
                value: VALUE
                maxValue: MAX_VALUE
            }
            thresholds {
                values: 4,12,20
                colors: #FF0000,#FFFF00,#008000
                display: all
            }
        )

    )

