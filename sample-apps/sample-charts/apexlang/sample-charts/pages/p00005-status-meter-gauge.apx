    region thresholds-using-custom-tooltip (
        name: Thresholds - Using Custom Tooltip
        type: chart
        layout {
            sequence: 80
            parentRegion: @circular
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        chart {
            type: statusMeterGauge
        }
        chartLayout {
            maxWidth: 90
            height: 100
        }
        gauge {
            indicatorSize: 0.5
            innerRadius: 0.8
            startAngle: 180
            angleExtent: 180
        }
        value {
            format: decimal
            decimalPlaces: 0
            formatScaling: none
        }

        series commission (
            name: Commission
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select value, 
                           max_value,
                           my_label,
                           'Value: '|| value || '<br/>' ||'Thresholds: Low: 4, Medium: 8, High: 14' my_tooltip
                    from ( select sum(case when COMM is null 
                                           then 0 
                                           when COMM = 0 
                                           then 0 
                                           else 1 
                                      end) value, 
                                  count(*) max_value,
                                 'Sales' as my_label 
                             from eba_demo_chart_emp )
                    ```
            }
            columnMapping {
                value: VALUE
                maxValue: MAX_VALUE
                customTooltip: MY_TOOLTIP
            }
            appearance {
                color: BLACK
            }
            thresholds {
                values: 4,8,14
                colors: red,yellow,green
                display: all
            }
            label {
                show: true
            }
        )

    )

    region value-and-label-information (
        name: Value and Label Information
        type: staticContent
        source {
            htmlCode: This example demonstrates the setting of the series-level <strong>Label</strong> column mapping, to display a label of 'Sales' in the center of the horizontal gauge, alongside the <strong>Value</strong> of the chart. The label <strong>Position</strong> attribute places the label in the center of the gauge.
        }
        layout {
            sequence: 10
            parentRegion: @value-and-label-positioned-in-center
            slot: subRegions
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

