page 5 (
    name: Status Meter Gauge
    alias: STATUS-METER-GAUGE
    title: Status Meter Gauge
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>&PRODUCT_NAME. native Status Meter Gauge chart, using Oracle JET Data Visualizations, is showcased on this page. Explore the wide range of chart attributes declaratively available with our native charts, to format and customise the style of your charts.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            icon: fa-dial-gauge-chart
        }
    )

    region breadcrumbs (
        name: breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region circular (
        name: Circular
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: <strong>For more information on the Status Meter Gauge chart settings, refer to the Oracle JET Cookbook <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=statusMeterGauge&demo=statusMeterGaugeCircular" target="_blank">Status Meter Gauge - Circular</a> example.</strong>
        }
    )

    region horizontal (
        name: Horizontal
        type: staticContent
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: <strong>For more information on the Status Meter Gauge chart settings, refer to the Oracle JET Cookbook <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=statusMeterGauge&demo=statusMeterGaugeHorizontal" target="_blank">Status Meter Gauge - Horizontal</a> example.</strong>
        }
    )

    region indicator-size (
        name: Indicator Size
        type: chart
        layout {
            sequence: 110
            parentRegion: @horizontal
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        chart {
            type: statusMeterGauge
        }
        chartLayout {
            maxWidth: 300
        }
        gauge {
            orientation: horizontal
            indicatorSize: 10
        }
        value {
            format: decimal
            decimalPlaces: 0
            formatScaling: none
        }

        series commission (
            name: Commission
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    SELECT sum(case when COMM is null 
                                         then 0 
                                    when COMM = 0 
                                         then 0 
                                    else 1 
                                    end) value, 
                           count(*) max_value,
                           'Sales' as my_label 
                    FROM   eba_demo_chart_emp
                    ```
            }
            columnMapping {
                label: MY_LABEL
                value: VALUE
                maxValue: MAX_VALUE
            }
            thresholds {
                display: onIndicator
            }
        )

    )

