            onDataChange: none
        }
        tooltip {
            showSeriesName: false
            showGroupName: false
        }
        legend {
            show: false
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function( options ){ 
                        
                    // Setup a callback function which gets called when data is retrieved, it allows to manipulate the series 
                    options.dataFilter = function( data ) { 
                        data.series[ 0 ].items[0].color = "red"; 
                        data.series[ 0 ].items[1].color = "blue"; 
                        data.series[ 0 ].items[2].color = "yellow"; 
                        data.series[ 0 ].items[3].color = "green"; 
                        data.series[ 0 ].items[4].color = "purple"; 
                        return data; 
                    };
                        
                    // Set chart initialization options 
                    return options; 
                }
                ```
        }

        series fruit-sales (
            name: Fruit Sales
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, b.quantity, b.customer
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Store A'
                    order by a.product_name desc
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            title: Quantity
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
                baselineScaling: min
            }
            minorTicks {
                show: true
            }
        )

    )

