        series jobs-by-department (
            name: Jobs By Department
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select job, deptno, avg(sal) avg_sal 
                      from eba_demo_chart_emp 
                     group by job, deptno 
                     order by deptno
                    ```
            }
            columnMapping {
                seriesName: JOB
                label: DEPTNO
                value: AVG_SAL
            }
            link {
                type: redirectThisApp
                target: {
                    page: 29
                    items: {
                        IG_DEPTNO: &DEPTNO.
                    }
                    action: clearRegions
                    request: "IG[emp]_emp_details"
                }
            }
            label {
                show: true
            }
        )

