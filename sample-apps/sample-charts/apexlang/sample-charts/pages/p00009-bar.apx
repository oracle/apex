    region sql-series-defined-colors (
        name: SQL Series-Defined Colors
        type: chart
        layout {
            sequence: 30
            parentRegion: @bar-chart-series-colors
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        headerAndFooter {
            headerText: * Labels Sorted Ascending
        }
        chartAppearance {
            orientation: horizontal
        }
        chartLayout {
            height: 340
        }
        multiSeriesChartData {
            fillGapsInChartData: false
        }
        animation {
            onDataChange: none
        }
        tooltip {
            showSeriesName: false
            showGroupName: false
        }
        legend {
            show: false
        }

        series fruit-sales (
            name: Fruit Sales
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, 
                           b.quantity, 
                           b.customer,
                           case when b.quantity > 50 then 'gold'
                                when b.quantity <= 30 then 'red' 
                             when b.quantity > 30 then 'green'
                             else 'blue'
                           end colors
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Store A'
                    order by a.product_name asc
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
            }
            appearance {
                color: &COLORS.
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            title: Quantity
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
                baselineScaling: min
            }
            minorTicks {
                show: true
            }
        )

    )

    button horizontal (
        buttonName: Horizontal
        label: Horizontal
        layout {
            sequence: 30
            region: @bar-chart-stack-label-stack-category
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-bars
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button stack (
        buttonName: Stack
        label: Stack
        layout {
            sequence: 10
            region: @bar-chart-stack-label-stack-category
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button unstack (
        buttonName: Unstack
        label: Unstack
        layout {
            sequence: 20
            region: @bar-chart-stack-label-stack-category
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button vertical (
        buttonName: Vertical
        label: Vertical
        layout {
            sequence: 40
            region: @bar-chart-stack-label-stack-category
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-bar-chart
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction horizontal-orientation (
        name: Horizontal Orientation
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @horizontal
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("stackCategoryChart").widget().ojChart({orientation: 'horizontal'});
            }
            affectedElements {
                selectionType: region
                region: @bar-chart-stack-label-stack-category
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction stack-chart (
        name: Stack Chart
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @stack
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("stackCategoryChart").widget().ojChart({stack: 'on'});
            }
            affectedElements {
                selectionType: region
                region: @bar-chart-stack-label-stack-category
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction unstack-chart (
        name: Unstack Chart
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @unstack
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("stackCategoryChart").widget().ojChart({stack: 'off'});
            }
            affectedElements {
                selectionType: region
                region: @bar-chart-stack-label-stack-category
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction vertical-orientation (
        name: Vertical Orientation
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @vertical
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("stackCategoryChart").widget().ojChart({orientation: 'vertical'});
            }
            affectedElements {
                selectionType: region
                region: @bar-chart-stack-label-stack-category
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

