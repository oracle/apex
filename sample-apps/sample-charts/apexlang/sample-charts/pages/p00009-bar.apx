    region bar-chart-stack-label-stack-category-information (
        name: Bar Chart (Stack Label & Stack Category) Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates 2 attributes of a Bar chart.<p/><p/>
                
                <strong>Stack Label</strong> - Use this chart-level attribute to display the total values of stacked data items on a chart.<p/>
                <strong>Stack Category</strong> - Set the series-level attribute to assign a series to a specific category on the chart.  This attribute allows you to render multiple stacks on a stacked chart, without the need to use JavaScript code.<p/>
                
                <p>
                For more information on the Stack Label and Stack Category attributes, refer to the Oracle JET Cookbook <a href="https://www.oracle.com/webfolder/technetwork/jet-800/jetCookbook.html?component=barChart&demo=dataLabels" target="_blank">Bar Chart: Data Labels</a> and <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=chart&demo=stackCategory" target="_blank">Stack Categories</a> examples, and the <a href="&OJCHART_API_URL.#stackLabel" target="_blank">stackLabel</a> attribute in the ojChart API guide.
                
                
                ```
        }
        layout {
            sequence: 10
            parentRegion: @bar-chart-stack-label-stack-category
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region bar-chart-stacked (
        name: Bar Chart (Stacked)
        type: chart
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       project as label,
                       NVL((select sum(t.budget) from eba_demo_chart_tasks t where t.project =  p.id and t.budget > t.cost),0) as value,
                       'under budget' as series ,
                       'green' as color
                  from eba_demo_chart_projects p
                union all
                select id,
                       project as label,
                       NVL((select sum(t.budget) from eba_demo_chart_tasks t where t.project =  p.id and t.budget <= t.cost),0) as value,
                       'over budget' as series ,
                       'red' as color
                  from eba_demo_chart_projects p
                ```
        }
        layout {
            sequence: 70
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        chartAppearance {
            stack: true
        }
        chartLayout {
            height: 450
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series new (
            name: New
            execution {
                sequence: 10
            }
            source {
                location: regionSource
            }
            columnMapping {
                seriesName: SERIES
                label: LABEL
                value: VALUE
                labelTooltip: LABEL
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

