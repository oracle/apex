    dynamicAction curved (
        name: Curved
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @curved
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("area2").widget().ojChart({styleDefaults:{lineType:'curved'}});
            }
            affectedElements {
                selectionType: region
                region: @area-chart-line-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction horizontal-orientation (
        name: Horizontal Orientation
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @horizontal
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("area1").widget().ojChart({orientation: 'horizontal'});
            }
            affectedElements {
                selectionType: region
                region: @area-chart-stacked
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

