        series acme-store (
            name: Acme Store
            type: area
            execution {
                sequence: 40
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, b.quantity, b.customer, a.product_description
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Acme Store'
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
                legendTooltip: CUSTOMER
                labelTooltip: PRODUCT_DESCRIPTION
            }
        )

