    dynamicAction segmented (
        name: Segmented
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @segmented
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("combo1").widget().ojChart({styleDefaults:{lineType:'centeredSegmented'}});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction skip-gap-off (
        name: Skip Gap Off
        execution {
            sequence: 110
        }
        when {
            selectionType: items
            items: P25_SKIP_GAP
        }
        clientSideCondition {
            type: item=value
            item: P25_SKIP_GAP
            value: N
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $("#regTime_jet").ojChart({timeAxisType:'enabled'});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction skip-gap-on (
        name: Skip Gap On
        execution {
            sequence: 100
        }
        when {
            selectionType: items
            items: P25_SKIP_GAP
        }
        clientSideCondition {
            type: item=value
            item: P25_SKIP_GAP
            value: Y
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $("#regTime_jet").ojChart({timeAxisType:'skipGaps'});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction stepped (
        name: Stepped
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @stepped
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("combo1").widget().ojChart({styleDefaults:{lineType:'stepped'}});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction straight (
        name: Straight
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @straight
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("combo1").widget().ojChart({styleDefaults:{lineType:'straight'}});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

