    dynamicAction curved (
        name: Curved
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @curved
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("combo1").widget().ojChart({styleDefaults:{lineType:'curved'}});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction none (
        name: None
        execution {
            sequence: 90
        }
        when {
            event: click
            selectionType: button
            button: @none
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("combo1").widget().ojChart({styleDefaults:{lineType:'none'}});
            }
            affectedElements {
                selectionType: region
                region: @combination-chart-data-label-positions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
