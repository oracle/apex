        series average-budget (
            name: Average Budget
            type: line
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select task_name, round(avg_budget,2) from (  
                        select task_name,
                           avg(budget) over () avg_budget
                      from eba_demo_chart_tasks
                     where budget > 2000
                    order by 2,1)
                    ```
            }
            columnMapping {
                label: TASK_NAME
                value: ROUND(AVG_BUDGET,2)
            }
            appearance {
                color: #4FB000
            }
            line {
                style: dashed
                width: 4
            }
        )

        series tasks-by-budget-cost (
            name: Tasks By Budget/Cost
            type: area
            execution {
                sequence: 10
