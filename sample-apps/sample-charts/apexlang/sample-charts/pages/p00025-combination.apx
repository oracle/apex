                    select task_name,
                           budget
                      from eba_demo_chart_tasks
                     where budget > 2000
                    order by 2,1
                    ```
            }
            columnMapping {
                label: TASK_NAME
                value: BUDGET
            }
            label {
                show: true
            }
        )

