page 1 (
    name: Sample Charts
    alias: HOME
    title: Sample Charts
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            div.featuredBlock{
            	-webkit-border-radius:3px;
            	-moz-border-radius:3px;
            	border-radius:3px;
            	-webkit-box-shadow:0 1px 2px rgba(0,0,0,0.05);
            	-moz-box-shadow:0 1px 2px rgba(0,0,0,0.05);
            	box-shadow:0 1px 2px rgba(0,0,0,0.05);
            	border:1px solid #E1E6EB;
            	margin-bottom:18px
            }
            div.featuredBlock div.featuredIcon{
            	background-image:url('data:image/svg+xml;base64,');
            	background-size:100%;
            	background-image:-webkit-gradient(linear, 50% 0%, 50% 100%, color-stop(0%, #ffffff), color-stop(40%, #ffffff), color-stop(60%, #f4f4f8), color-stop(100%, #ffffff));
            	background-image:-webkit-linear-gradient(top, #ffffff 0%,#ffffff 40%,#f4f4f8 60%,#ffffff 100%);
            	background-image:-moz-linear-gradient(top, #ffffff 0%,#ffffff 40%,#f4f4f8 60%,#ffffff 100%);
            	background-image:linear-gradient(top, #ffffff 0%,#ffffff 40%,#f4f4f8 60%,#ffffff 100%);
            	-webkit-border-radius:3px 3px 0 0;
            	-moz-border-radius:3px 3px 0 0;
            	border-radius:3px 3px 0 0;
            	padding:8px 0;
            	min-height: 90px;
            	text-align:center;
            }
            div.featuredBlock div.featuredIcon img{
            	display:block;
            	margin:0 auto 0 auto;
            	-webkit-box-reflect:below -20px -webkit-gradient(linear, left top, left bottom, from(transparent), color-stop(65%, transparent), to(rgba(255,255,255,0.2)));
            }
            div.featuredBlock div.featuredIcon h1{
            	font-size:12px;
            	line-height:12px;
            	color:#404040;
            	margin:0 8px;
            	padding:0;
            	text-align:center;
            }
            a.blockLink,a.blockLink:hover{
            	text-decoration:none
            }
            a.blockLink:hover div.featuredBlock{
            	border:1px solid #b1bbcb
            }
            a.blockLink:hover div.featuredBlock div.featuredIcon{
            	background: none #e5effb;
            	-webkit-box-shadow: 0 0 10px rgba(50,117,199,0.25);
            	-moz-box-shadow: 0 0 10px rgba(50,117,199,0.25);
            	box-shadow: 0 0 10px rgba(50,117,199,0.25);
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-sample-charts (
        name: About Sample Charts
        type: staticContent
        source {
            htmlCode: <p>&PRODUCT_NAME. has integrated charting based on Oracle JavaScript Extension Toolkit (JET) Data Visualizations.  For more information on Oracle JET and the Data Visualizations components, please refer to the <a href="&JET_GET_STARTED_URL." target="_blank">Oracle JET Get Started</a> documentation and <a href="&OJCHART_API_URL." target="_blank">ojChart API guide</a>.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
            ]
        }
    )

    region example-charts (
        name: Example Charts
        type: list
        source {
            list: @charts
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/cards
            templateOptions: [
                #DEFAULT#
                u-colors
                t-Cards--featured force-fa-lg
                t-Cards--displayIcons
                t-Cards--5cols
                t-Cards--hideBody
                t-Cards--animColorFill
            ]
        }
    )

    region footer (
        name: Footer
        type: plugin/sampleAppsFooter
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region sample-charts (
        name: Sample Charts
        type: staticContent
        source {
            htmlCode: <p>Charting examples for APEX applications</p>
        }
        layout {
            sequence: 50
            slot: breadcrumbBar
        }
        appearance {
            template: @/hero
            templateOptions: #DEFAULT#
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

