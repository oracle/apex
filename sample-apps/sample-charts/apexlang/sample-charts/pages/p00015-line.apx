    dynamicAction area (
        name: Area
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @area
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("lineChart").widget().ojChart({type: 'area'});
            }
            affectedElements {
                selectionType: region
                region: @line-chart-data-labels-line-styles
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction bar (
        name: Bar
        execution {
            sequence: 40
        }
