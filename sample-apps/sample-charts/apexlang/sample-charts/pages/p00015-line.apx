page 15 (
    name: Line
    alias: LINE
    title: Line
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>&PRODUCT_NAME. native Line charts, using Oracle JET Data Visualizations, are showcased on this page. Line charts are useful for visualizing trends in a set of values over time and comparing these values across series.  This chart type is recommended for visualizing mixed frequency time data.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            icon: fa-line-chart
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region line-chart-data-labels-line-styles (
        name: Line Chart (Data Labels & Line Styles)
        type: chart
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: lineChart
            regionDisplaySelector: true
        }
        chart {
            type: line
        }
        chartAppearance {
            stack: true
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDataChange: none
        }
        legend {
            position: top
        }

        series acme-store (
            name: Acme Store
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, b.quantity, b.customer
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Acme Store'
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
            }
            line {
                type: curved
            }
            marker {
                show: true
                shape: plus
            }
            label {
                show: true
                position: center
            }
        )

        series shop-c (
            name: Shop C
            execution {
                sequence: 30
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, b.quantity, b.customer
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Shop C'
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
            }
            line {
                style: dashed
                type: stepped
            }
            marker {
                show: true
                shape: diamond
            }
            label {
                show: true
                position: belowMarker
            }
            advanced {
                javaScriptStaticId: c_series
            }
        )

        series store-a (
            name: Store A
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.product_name, b.quantity, b.customer
                    from eba_demo_chart_products a, eba_demo_chart_orders b
                    where a.product_id = b.product_id
                    and customer = 'Store A'
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: QUANTITY
            }
            line {
                style: dotted
                type: centeredStepped
            }
            marker {
                show: true
                shape: star
            }
            label {
                show: true
                position: aboveMarker
            }
        )

        axis x (
            name: x
            minorTicks {
                show: true
            }
        )

        axis y (
            name: y
            title: Y1 Axis Title
            minorTicks {
                show: true
            }
        )

        axis y-2 (
            name: y2
            title: Y2 Axis Title
            minorTicks {
                show: false
            }
            dualYAxes {
                show: true
                splitterPosition: 0.7
            }
        )

    )

    region line-chart-data-labels-line-styles-information (
        name: Line Chart (Data Labels & Line Styles) Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates a Line chart with varying line types and styles.<p/>
                <strong>Maximum Width & Height</strong> - Chart-level attributes Maximum Width and Height have been set to 500px and 450px respectively, to size the chart within its region.  If you wish to default to using 100% width and height of the given region, simply remove these values, and utilitise the Template Options of the region to control the height as you wish.<p/> 
                <strong>Orientation</strong> - Through the use of Dynamic actions, use the Horizontal/Vertical button to the top left of the chart to change the orientiation of the data items on the charts.<p/>
                <strong>Chart Type</strong> - Through the use of Dynamic actions, use the Bar/Area/Line/Line with Area/Combo buttons to the top right of the chart to change the type of the chart.<p/>
                <strong>Line Style & Type</strong> - Use the series-level attributes to define various line styles, such as dotted, and types, such as curved, to the chart.<p/>
                <strong>Marker</strong> - Use the series-level attribute to define various markers to the data items rendered on the chart.<p/>
                <strong>Label Position</strong> - Use this series-level attribute to control the positioning of the labels on data items of the chart.<p/>
                For more information on the Line chart settings, refer to the Oracle JET Cookbook <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=lineChart&demo=dataLabels" target="_blank">Line Chart: Data Labels</a> and <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=lineChart&demo=lineTypes" target="_blank">Line Chart: Line Types</a> examples.
                ```
        }
        layout {
            sequence: 10
            parentRegion: @line-chart-data-labels-line-styles
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

