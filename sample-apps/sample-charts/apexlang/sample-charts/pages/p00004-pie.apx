page 4 (
    name: Pie
    alias: PIE
    title: Pie
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>&PRODUCT_NAME. native Pie and Donut charts, using Oracle JET Data Visualizations, are showcased on this page. Pie charts are useful for visualizing parts of a whole, but do not display zero or negative values, and are therefore not recommended for data sets that may have negative or null data. Explore the wide range of chart attributes declaratively available with our native charts, to format and customise the style of your charts.</p><br/>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            icon: fa-pie-chart
        }
    )

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 90
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region colors-set-via-js-code (
        name: Colors set via JS Code
        type: chart
        layout {
            sequence: 20
            parentRegion: @pie-chart-series-colors
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                i-h480
                t-Region--scrollBody
            ]
        }
        chart {
            type: pie
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            pieSelectionEffect: highlightAndExplode
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            position: top
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function( options ){
                    var myColors = ["red","yellow","orange","#791b19", "purple"];
                    
                    // Setup a callback function which gets called when data is retrieved, it allows to manipulate the series
                    options.dataFilter = function( data ) {
                        
                        for ( i = 0; i < data.series.length; i++ ) {
                            data.series[ i ].color = myColors [ i ];
                        }
                        return data;
                    };
                    
                    // Set chart initialization options
                    return options;
                }
                ```
        }

        series products (
            name: Products
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select product_id, 
                           product_name, 
                           list_price
                    from eba_demo_chart_products
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: LIST_PRICE
            }
            label {
                show: true
                position: outsideSlice
            }
        )

    )

    region colors-set-via-sql-query (
        name: Colors set via SQL Query
        type: chart
        layout {
            sequence: 10
            parentRegion: @pie-chart-series-colors
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                i-h480
                t-Region--scrollBody
            ]
        }
        chart {
            type: pie
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            pieSelectionEffect: highlightAndExplode
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            position: top
        }

        series products (
            name: Products
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select product_id, 
                           product_name, 
                           list_price,
                           case product_name
                               when 'Apples' then 'green'
                               when 'Bananas' then 'yellow'
                               when 'Grapes' then 'purple'
                               when 'Cantaloupe' then 'orange'
                               when 'Dates' then '#791b19'
                           end series_colors
                    from eba_demo_chart_products
                    ```
            }
            columnMapping {
                label: PRODUCT_NAME
                value: LIST_PRICE
            }
            appearance {
                color: &SERIES_COLORS.
            }
            label {
                show: true
                position: outsideSlice
            }
        )

    )

    region donut-chart-new-declarative-label-option (
        name: Donut Chart ( New Declarative Label Option )
        type: chart
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        chart {
            type: donut
        }
        chartLayout {
            height: 450
        }
        dataCursor {
            dimOnHover: false
        }
        value {
            pieChartOtherThreshold: 0.05
            format: currency
            decimalPlaces: 0
        }
        animation {
            onDisplay: alphaFade
            onDataChange: none
        }
        legend {
            position: top
        }

        series tasks (
            name: Tasks
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.id,
                           b.project label,
                           sum(a.cost) value
                      from eba_demo_chart_tasks a,
                           eba_demo_chart_projects b
                     where a.project = b.id
                     group by b.id, b.project
                    order by 3 desc
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            label {
                show: true
                position: outsideSlice
                displayAs: labelPercentageValue
            }
        )

    )

    region donut-chart-new-declarative-label-option-information (
        name: Donut Chart ( New Declarative Label Option ) Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates a Donut chart with labels defined via a new series-level declarative option, <strong>Display As</strong>.<p/>
                <strong>Display As</strong> - Use this series-level attribute to define the level of detail you wish to display on the labels of your pie and donut chart.  Prior to 18.1, customing the label required the use of JavaScript code.  With 18.1 and above, just select the option that best suits your requirements, from the following list: <br/>
                <ul>
                <li><strong>Label</strong>: the labels will display on the slices of the chart, based on the selected Label column mapping. For example, <strong><i>Bugs</i></strong>.</li>
                <li><strong>Percentage</strong>: the labels will display as values between 0% and 100%, based on the selected Value column mapping. The value is a percentage of the total values represented on the chart. For example, <strong><i>15%</i></strong>.</li>
                <li><strong>Value</strong>: the labels will display as numeric values, based on the selected Value column mapping.</li>
                <li><strong><i>Label - Percentage ( Value )</i></strong> : the labels will display the label, value and percentage information in the following format: label - percentage ( value ). For example, <strong><i>Bugs - 15% ( 18 )</i></strong>.</li>
                <li><strong>Percentage ( Value )</strong>: the labels will display as numeric values, based on the selected Value column mapping. For example, <strong><i>15% ( 18 )</i></strong>.</li>
                </ul>
                <p/>
                <strong>Label Position</strong> - The series-level attribute is set to Outside Slice, to ensure lengthy labels are visible, and rendered outside the slice of the donut.<p/>
                For more information on the custom label settings, refer to the Oracle JET Cookbook <a href="https://www.oracle.com/webfolder/technetwork/jet/jetCookbook.html?component=chart&demo=dataLabel" target="_blank">Chart: Data Label Callback</a> example.
                ```
        }
        layout {
            sequence: 20
            parentRegion: @donut-chart-new-declarative-label-option
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region donut-chart-sorting (
        name: Donut Chart (Sorting)
        type: chart
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: donut1
            regionDisplaySelector: true
        }
        chart {
            type: donut
        }
        chartLayout {
            height: 450
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            pieSelectionEffect: highlightAndExplode
        }
        value {
            pieChartOtherThreshold: 0.05
            format: decimal
            decimalPlaces: 0
        }
        animation {
            onDisplay: alphaFade
            onDataChange: none
        }
        legend {
            position: top
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function (options) {
                    // Set color of 'Other' slice to pink
                    $.extend( options.styleDefaults, { otherColor: '#e85d89' }) ;
                    return options;
                }
                ```
        }

        series tasks (
            name: Tasks
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.id,
                           b.project label,
                           sum(a.cost) value
                      from eba_demo_chart_tasks a,
                           eba_demo_chart_projects b
                     where a.project = b.id
                     group by b.id, b.project
                    order by 3 desc
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            label {
                show: true
                position: outsideSlice
                displayAs: percentageValue
            }
        )

    )

    region donut-chart-sorting-information (
        name: Donut Chart (Sorting) Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates a Donut chart with sorting options.<p/>
                <strong>Pie Other Threshold</strong> - Use this chart-level attribute to attribute to aggregate small slices of the chart into an "Other" node. The attribute can be used to specify the smallest slice that will be displayed as a ratio of the total pie value.<p/>
                <strong>Label Position</strong> - The series-level attribute is set to Outside Slice, rendering the label on the outside of each slice.<p/>
                <strong>Label Display As</strong> - The new series-level attribute is set to <strong>Percentage ( Value )</strong>, rendering the label in that format, without the need to use custom JavaScript code to acomplish it.<p/>
                <strong>Sort Order</strong> - Donut chart slices can be sorted based on the values. The new <strong>Sort Order</strong> chart-level attribute allows you to define the sort order of your chart. Through the use of Dynamic actions, you can allow your end users to toggle the sort order. Use the Ascending/Descending buttons to the top right of the chart to change the sorting of the data items on the charts.<p/>
                <strong>JavaScript Initialization Code</strong> - Use this chart-level attribute to customize the <a href="&OJCHART_API_URL.#styleDefaults.otherColor" target="_blank">otherColor</a> JET attribute, to set the color of the 'Other' slice of the chart.  By default, that slice will use the color black. Use the following code snippet to achieve this:<br/>
                <pre>
                function (options) {
                    // Set color of 'Other' slice to pink
                    $.extend( options.styleDefaults, { otherColor: '#e85d89' }) ;
                    return options;
                }
                </pre>
                <p/>
                For more information on the Pie chart sort settings, refer to the Oracle JET Cookbook <a href="&JET_COOKBOOK_URL.?component=pieChart&demo=sorting" target="_blank">Pie Chart: Sorting</a> example.
                ```
        }
        layout {
            sequence: 10
            parentRegion: @donut-chart-sorting
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

