    region master-detail-chart-links (
        name: Master Detail Chart Links
        type: staticContent
        source {
            htmlCode:
                ```html
                Drill into a slice of the Products pie chart on the left, to display its associated orders in the Orders bar chart on the right. To drill using the mouse, click on the chart slice.  To drill using the keyboard, navigate to the slice and hit Enter.<p/>
                For more information on the <a href="&OJCHART_API_URL.#drilling" target="_blank">drilling</a> attribute, refer to the ojChart API.
                ```
        }
        layout {
            sequence: 100
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region master-detail-chart-links-information (
        name: Master Detail Chart Links Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates a master-detail chart, through the use of the Link Target on the Master chart.<p/>
                <strong>Link Target</strong> - Use this series-level attribute to define a JavaScript call to set the value of a hidden page item to the currently selected product ID.<p/>
                <strong>Dynamic Action</strong> - Define a dynamic action, to be triggered upon a change to the hidden page item.  That action will trigger a refresh of the Orders bar chart, to reflect the orders associated with the selected product.<p/>
                <strong>Page Items To Submit</strong> - Ensure this series-level attribute is set to the name of the hidden page item, to ensure its value is used at the time of processing the chart SQL query.<p/>
                <strong>JavaScript Code</strong> - Use this chart-level attribute to define JavaScript code, to customise the pie chart attributes at initialization, to render the chart in 3D.  The <a href="&OJCHART_API_URL.#styleDefaults.threeDEffect" target="_blank">threeDEffect</a> attribute in the ojChart API should be set, using the following JavaScript code:</br/>
                <pre>
                function( options ) {
                
                    // Add new 3D effect to existing chart style defaults   
                    options.styleDefaults = $.extend( options.styleDefaults, {threeDEffect: "on"});
                    
                    return options;
                }
                </pre></p>
                ```
        }
        layout {
            sequence: 40
            parentRegion: @master-detail-chart-links
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region orders-detail-chart (
        name: Orders (Detail chart)
        type: chart
        layout {
            sequence: 30
            parentRegion: @master-detail-chart-links
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                i-h480
                t-Region--scrollBody
            ]
        }
        title {
            title: &P4_PRODUCT_NAME.
        }
        chartLayout {
            height: 380
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        tooltip {
            showSeriesName: false
        }
        legend {
            show: false
        }
        messages {
            whenNoDataFound: No product selected from Pie Chart (Master chart)
        }

        series order-per-product (
            name: Order Per Product
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select a.order_id, a.customer, a.sales_date, a.quantity, a.customer|| '<br/>Quantity: ' ||a.quantity tooltip
                      from eba_demo_chart_orders a, eba_demo_chart_products b
                     where a.product_id = :P4_PRODUCT_ID
                       and a.product_id = b.product_id
                    ```
                pageItemsToSubmit: P4_PRODUCT_ID
            }
            columnMapping {
                label: ORDER_ID
                value: QUANTITY
                customTooltip: TOOLTIP
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            title: Order ID
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            title: Quantity
            minorTicks {
                show: false
            }
        )

    )

    region pie-chart (
        name: Pie Chart
        type: chart
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: pie1
            regionDisplaySelector: true
        }
        chart {
            type: pie
        }
        chartLayout {
            height: 400
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            pieSelectionEffect: highlightAndExplode
        }
        value {
            formatScaling: none
        }

        series tasks (
            name: Tasks
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.id,
                           b.project label,
                           sum(a.cost) value
                      from eba_demo_chart_tasks a,
                           eba_demo_chart_projects b
                     where a.project = b.id
                     group by b.id, b.project
                    order by 3 desc
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 47
                    items: {
                        IG_ID: &ID.
                    }
                    action: clearRegions
                    request: "IG[tasksRep]_tasks"
                }
            }
            label {
                show: true
            }
        )

    )

    region pie-chart-information (
        name: Pie Chart Information
        type: staticContent
        source {
            htmlCode:
                ```html
                This example demonstrates a Pie chart with various animation options.<p/>
                <strong>Hide and Show Behavior</strong> - Use this chart-level attribute to allow allowing a user to hide and unhide a series by clicking the chart legend markers. Upon hiding/showing a series, the <strong>With Rescale</strong> setting will result in the pie chart automatically recalculating the percent values displayed on the label to factor in the selection change. Selecting a slice of the pie will highlight and explode the slice.<p/>
                
                <strong>Label Display As</strong> - To display the 'Label' column mapping information in the label on each pie slice, this new series-level attribute is set to <strong>Label</strong>.<p/>
                
                <strong>Legend size</strong> - To decrease the amount of space between the pie chart and legend, the legend <strong>size</strong> attribute can be set to a value, in pixels or percent. Click the <strong>Increase Legend Size</strong> or <strong>Decrease Legend Size</strong> buttons to trigger a change in the legend size in relation to the chart.  A dynamic action is used to update the region size.  Refer to the <a href="&OJCHART_API_URL.#legend.size" target="_blank">ojChart API guide</a> for more information on this setting.<p>
                
                <strong>Link</strong> - This series-level attribute can be set to define a link on the chart element.  For this example, the new Interactive Grid URL Filtering support is demonstrated here.  When you click on a chart element, the URL will redirect you to page 47 in the application, which contains an Interactive Grid saved report on the EBA_DEMO_CHART_TASKS table.  The report will filter information based upon the project (ID) associated with the selected chart element.  The URL Filtering is achieved by defining a link on the chart series, with the following settings:
                <ul>
                <li> <strong>Link Type</strong> = Redirect to Page</li>
                <li> <strong>Target</strong> = Page 47</li> 
                <li> <strong>Link Builder Target settings:</strong></i> 
                <ul>
                <li> <strong>Set Item Name</strong> = IG_ID     - using the <i>IG_</i> syntax to reference a column of the Interactive Grid</i> 
                <li> <strong>Set Item Value</strong> = &amp;ID.</i> 
                <li> <strong>Clear/Reset Action</strong> = 'Clear Regions'</li> 
                <li> <strong>Advanced Request</strong> = IG[<i>tasksRep</i>]_<i>tasks</i>  -  where <i>tasksRep</i> is the region static ID, and <i>tasks</i> is the saved report name.</li> 
                </ul>
                </ul>
                <p/><p/>
                
                For more information on the Pie chart settings, refer to the Oracle JET Cookbook <a href="&JET_COOKBOOK_URL.?component=pieChart&demo=hideShow" target="_blank">Pie Chart: Hide & Show</a> and <a href="&JET_COOKBOOK_URL.?component=pieChart&demo=animation" target="_blank">Pie Chart: Animations</a> examples.
                ```
        }
        layout {
            sequence: 10
            parentRegion: @pie-chart
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region pie-chart-series-colors (
        name: Pie Chart (Series Colors)
        type: staticContent
        layout {
            sequence: 80
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region pie-chart-series-colors-information (
        name: Pie Chart (Series Colors) Information
        type: staticContent
        source {
            htmlCode:
                ```html
                These examples demonstrate the various ways to control the colors used for the chart series.<p/><p/>
                
                <strong>Colors set via SQL Query</strong> - This example demonstrates a Pie chart with the series colors defined via the SQL query, and the column is then referenced in the Color attribute. Use the chart SQL query to define the colors to be applied to each slice of the pie, based on the product_name being displayed. Then set the <strong>Color</strong> attribute, referencing the column alias using &amp;COLUMN_VALUE. syntax, to use a column value for the setting of the pie slice colors.<p/><p/>
                
                <strong>Colors set via JS Code</strong> - Use the chart-level advanced attribute <b>JavaScript Code</b> to customize the chart colors at chart initialization. For example,:<p/>
                <pre>
                function( options ){
                    var myColors = ["red","yellow","orange","#791b19", "purple"];
                    
                    // Setup a callback function which gets called when data is retrieved, it allows to manipulate the series
                    options.dataFilter = function( data ) {
                        
                        for ( i = 0; i < data.series.length; i++ ) {
                            data.series[ i ].color = myColors [ i ];
                        }
                        return data;
                    };
                    
                    // Set chart initialization options
                    return options;
                }
                </pre>
                
                ```
        }
        layout {
            sequence: 30
            parentRegion: @pie-chart-series-colors
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region products-master-chart (
        name: Products (Master chart)
        type: chart
        layout {
            sequence: 10
            parentRegion: @master-detail-chart-links
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                i-h480
                t-Region--scrollBody
            ]
        }
        chart {
            type: pie
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            pieSelectionEffect: explode
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function( options ){
                    // Add new 3D effect to existing chart style defaults   
                    options.styleDefaults = $.extend( options.styleDefaults, {threeDEffect: "on"});
                    return options;
                }
                ```
        }

        series products (
            name: Products
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery: select product_id, product_name, list_price from eba_demo_chart_products
            }
            columnMapping {
                label: PRODUCT_NAME
                value: LIST_PRICE
            }
            link {
                type: redirectUrl
                targetUrl: javascript:$s('P4_PRODUCT_ID',&PRODUCT_ID.);
            }
            label {
                show: true
                position: outsideSlice
            }
        )

    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: body
        }
        settings {
            rememberSelection: false
        }
    )

    pageItem P4_PRODUCT_ID (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 10
            region: @products-master-chart
            slot: regionBody
        }
    )

    pageItem P4_PRODUCT_NAME (
        type: displayOnly
        label {
            label: Product:
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 10
            region: @orders-detail-chart
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button ascending (
        buttonName: Ascending
        label: Ascending
        layout {
            sequence: 20
            region: @donut-chart-sorting
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-sort-numeric-asc
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button decrease (
        buttonName: DECREASE
        label: Decrease Legend Size
        layout {
            sequence: 20
            region: @pie-chart
            slot: belowBox
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button descending (
        buttonName: Descending
        label: Descending
        layout {
            sequence: 10
            region: @donut-chart-sorting
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pill
            ]
            icon: fa-sort-numeric-desc
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button increase (
        buttonName: INCREASE
        label: Increase Legend Size
        layout {
            sequence: 10
            region: @pie-chart
            slot: belowBox
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction apply-other-threshold (
        name: Apply Other Threshold
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P4_OTHER
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var lOther = apex.item('P4_OTHER').getValue();
                    
                    var num = 0.3
                    $("#donut1_jet").ojChart({otherThreshold:num});
                    
                    ```
            }
            affectedElements {
                selectionType: region
                region: @donut-chart-sorting
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction decrease (
        name: Decrease
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @decrease
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("pie1").widget().ojChart({legend:{size:'30%'}});
            }
            affectedElements {
                selectionType: region
                region: @pie-chart
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction increase (
        name: Increase
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @increase
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("pie1").widget().ojChart({legend:{size:'50%'}});
            }
            affectedElements {
                selectionType: region
                region: @pie-chart
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-orders-chart (
        name: Refresh Orders Chart
        execution {
            sequence: 60
        }
        when {
            selectionType: items
            items: P4_PRODUCT_ID
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @orders-detail-chart
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-product-name (
        name: Set Product Name
        execution {
            sequence: 70
        }
        when {
            selectionType: items
            items: P4_PRODUCT_ID
        }

        action native-set-value (
            action: setValue
            settings {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select product_name from eba_demo_chart_products
                    where product_id = :P4_PRODUCT_ID
                    ```
                itemsToSubmit: P4_PRODUCT_ID
            }
            affectedElements {
                selectionType: items
                items: P4_PRODUCT_NAME
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction sort-ascending (
        name: Sort Ascending
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @ascending
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("donut1").widget().ojChart({sorting:'ascending'});
            }
            affectedElements {
                selectionType: region
                region: @pie-chart
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction sort-descending (
        name: Sort Descending
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @descending
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.region("donut1").widget().ojChart({sorting:'descending'});
            }
            affectedElements {
                selectionType: region
                region: @pie-chart
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

