    region information (
        name: Information
        type: staticContent
        source {
            htmlCode:
                ```html
                <p/><p/><p/><p/>
                The underlying table structure is not normalised, storing the results of each new sample in a new column.  This structure may be common to some customers, so this example demonstrates how to generate a Box Plot on such a table structure.  This chart also uses the 'Series Name' column mapping, to treat each row returned as a separate series, thus applying a different colour to each series represented on the chart.
                <p/>
                The sample data used here has been obtained from an external Box Plot utility site.<p/>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @survey-results
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--textContent
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 30
            slot: body
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: false
        }
    )

    region samples-report-data (
        name: Samples Report Data
        type: classicReport
        source {
            location: localDatabase
            tableName: EBA_DEMO_CHART_SAMPLES
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            parentRegion: @survey-results
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 5
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: -
        }
        pagination {
            type: setPaginationSelectList
        }

        column SAMPLE1 (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Sample1
                alignment: center
            }
            layout {
                sequence: 1
            }
        )

        column SAMPLE2 (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Sample2
                alignment: center
            }
            layout {
                sequence: 2
            }
        )

        column SAMPLE3 (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Sample3
                alignment: center
            }
            layout {
                sequence: 3
            }
        )

        column SAMPLE4 (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Sample4
                alignment: center
            }
            layout {
                sequence: 4
            }
        )

        column SAMPLE5 (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Sample5
                alignment: center
            }
            layout {
                sequence: 5
            }
        )

    )

    region survey-results (
        name: Survey Results
        type: chart
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        chart {
            type: boxPlot
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series samples (
            name: Samples
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select * from eba_demo_chart_samples 
                    unpivot (value for sample in (sample1 as 'Sample 1', 
                                                  sample2 as 'Sample 2' , 
                                                  sample3 as 'Sample 3', 
                                                  sample4 as 'Sample 4', 
                                                  sample5 as 'Sample 5'))
                    ```
            }
            columnMapping {
                seriesName: SAMPLE
                label: SAMPLE
                value: VALUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 1
                    action: resetPagination
                }
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

    region survey-results-normalised-tables (
        name: Survey Results - Normalised Tables
        type: chart
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: The underlying table structure is normalised, storing the results of each new sample in one column, identified by a unique ID. This example demonstrates how to generate a Box Plot on such a table structure.<p/>
        }
        chart {
            type: boxPlot
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series survey (
            name: "Survey "
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.sample_name, a.response 
                    from eba_demo_chart_sample_data a, eba_demo_chart_sample_names b
                    where a.sample_id = b.id
                    ```
            }
            columnMapping {
                label: SAMPLE_NAME
                value: RESPONSE
            }
            appearance {
                color: #93F0B8
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

    region survey-sample-data-time-axis (
        name: Survey Sample Data - Time Axis
        type: chart
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: The underlying table structure is  normalised, storing the results of each new sample in one column, identified by a unique ID date.  This example demonstrates how to generate a Box Plot, with Time Axis enabled.
        }
        chart {
            type: boxPlot
        }
        dataCursor {
            dimOnHover: false
        }
        settings {
            timeAxisType: enabled
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series surveys-by-date (
            name: Surveys by Date
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select b.sample_date, a.response 
                    from eba_demo_chart_sample_data a, eba_demo_chart_sample_names b
                    where a.sample_id = b.id
                    ```
            }
            columnMapping {
                label: SAMPLE_DATE
                value: RESPONSE
            }
            appearance {
                color: #3589e3
                q2Color: #b0dea6
                q3Color: #edd976
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

)

