page 41 (
    name: Box Plot
    alias: BOX-PLOT
    title: Box Plot
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>&PRODUCT_NAME. native Box Plot charts, using Oracle JET Data Visualizations, are showcased on this page. The Box Plot chart is useful for reading statistical data, and follows a specific formula for representing the data on the chart.</p><br/><strong>How to Read a Box Plot chart</strong><p/>
                Review the image explaining the sections of a <a href="#APP_IMAGES#box-plot-explained.gif" target="_blank">Box Plot chart</a>.
                Here are the main components of a Box Plot:<p/>
                
                <ul>
                <li><strong>High/Maximum Value</strong><br/>
                <li><strong>1st Quartile</strong> - i.e. the 25% percentile of data. This means that 25% of the data are below this value.</li>
                <li><strong>Median/2nd Quartile</strong> - middle of the dataset i.e 50% of the data is greater than this value.</li>
                <li><strong>3rd Quartile</strong> - i.e. the 75% percentile of data. This means that 25% of the data are above this value.</li>
                <li><strong>Low/Minimum Value</strong></li>
                <li><strong>Outliers</strong> - values that fall outside of the quartile ranges. The Upper Outliers are more than 3/2 of the 3rd Quartile. The Lower Outliers are less than 3/2 times the 1st Quartile.</li>
                </ul>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            icon: fa-box-plot-chart
            renderComponents: belowContent
        }
    )

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region grades-custom-q2-q3-colours (
        name: Grades - Custom Q2 & Q3 Colours
        type: chart
        layout {
            sequence: 100
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: The Q2 and Q3 segments of the Box Plot can have custom colours defined, via columns of the series SQL query. The <strong>Q2 Color</strong> and <strong>Q3 Color</strong> series-level attributes reference the columns using &amp;COLUMN_VALUE. syntax.  Where those series-level attribute are not set, then the default series colour will be applied to them.  The y-axis Format has also be set, to apply formatting to the values rendered in the tooltip - without decimal places.
        }
        chart {
            type: boxPlot
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series median-grades (
            name: Median Grades
            type: line
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select course, median(schoola) 
                    from eba_demo_chart_grades
                    group by course
                    ```
            }
            columnMapping {
                label: COURSE
                value: MEDIAN(SCHOOLA)
            }
            line {
                type: curved
            }
        )

        series school-a (
            name: School A
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery: select course, schoola, 'navy' q2_color, 'gold' q3_color from eba_demo_chart_grades
            }
            columnMapping {
                label: COURSE
                value: SCHOOLA
            }
            appearance {
                q2Color: &Q2_COLOR.
                q3Color: &Q3_COLOR.
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
            }
            minorTicks {
                show: false
            }
        )

    )

    region grades-mixed-series-types (
        name: Grades - Mixed Series Types
        type: chart
        layout {
            sequence: 90
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            headerText: The visibility of the joined line will only work when there is 1 x 'Box Plot' series defined for the given chart.  Where there is more than 1 series of type 'Box Plot', alongside a 'Line' series, then the line will not be joined.
        }
        chart {
            type: boxPlot
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series median-grades (
            name: Median Grades
            type: line
            execution {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select course, median(schoola) 
                    from eba_demo_chart_grades
                    group by course
                    ```
            }
            columnMapping {
                label: COURSE
                value: MEDIAN(SCHOOLA)
            }
            line {
                type: curved
            }
            marker {
                show: true
            }
        )

        series school-a (
            name: School A
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery: select course, schoola from eba_demo_chart_grades
            }
            columnMapping {
                label: COURSE
                value: SCHOOLA
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

