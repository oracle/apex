        }
    )

    dataProfileColumn col-5 (
        columnName: COL5
        source {
            sequence: 6
            dataType: varchar2
        }
        parsing {
            selectorType: sequence
            columnNumber: 5
        }
    )

    dataProfileColumn col-6 (
        columnName: COL6
        source {
            sequence: 7
            dataType: varchar2
        }
        parsing {
            selectorType: sequence
            columnNumber: 6
        }
    )

    dataProfileColumn col-7 (
        columnName: COL7
        source {
            sequence: 8
            dataType: varchar2
        }
        parsing {
            selectorType: sequence
            columnNumber: 7
        }
    )

    dataProfileColumn col-8 (
        columnName: COL8
        source {
            sequence: 9
            dataType: varchar2
        }
        parsing {
            selectorType: sequence
            columnNumber: 8
        }
    )

    dataProfileColumn col-9 (
        columnName: COL9
        source {
            sequence: 10
            dataType: varchar2
        }
        parsing {
            selectorType: sequence
            columnNumber: 9
        }
    )

    dataProfileColumn embedding-vector (
        columnName: EMBEDDING_VECTOR
        source {
            sequence: 21
            type: sqlExpression
            dataType: varchar2
        }
        computation {
            sqlExpression: NULL
        }
    )

)

