searchConfig OCI_ADVANCED_VECTOR_SEARCH (
    name: OCI-BASIC-VECTOR-SEARCH-DATATABLE
    type: vector
    source {
        tableName: EBA_VECTOR_DATATABLE
    }
    vectorAttributes {
        provider: @EBA_VECTOR_OCI
        columnName: EMBEDDING_VECTOR
        distanceMetric: dot
    }
    columnMapping {
        primaryKey1Column: ID
        titleColumn: COL1
        subtitleColumn: COL2
        descriptionColumn: COL3
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-sitemap-vertical
    }
    performance {
        maxRowsToReturn: 10
    }
)

searchConfig OCI_BASIC_VECTOR_SEARCH (
    name: OCI-BASIC-VECTOR-SEARCH-MOVIEDATA
    type: vector
    source {
        tableName: EBA_VECTOR_MOVIEDATA
    }
    vectorAttributes {
        provider: @EBA_VECTOR_OCI
        columnName: EMBEDDING_VECTOR
        distanceMetric: dot
    }
    columnMapping {
        primaryKey1Column: ID
        titleColumn: TITLE
        subtitleColumn: ACTORS
        descriptionColumn: MOVIEDESCRIPTION
        badgeColumn: RATING
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-film
    }
    performance {
        maxRowsToReturn: 10
    }
)

searchConfig OCI_MOVIE_RECOMMENDATION (
    name: OCI-MOVIE-RECOMMENDATION
    type: vector
    source {
        whereClause: SUBSTR(moviedescription, 1, 40) <> SUBSTR(:P41_SEARCH, 1, 40)
        tableName: EBA_VECTOR_MOVIEDATA
    }
    vectorAttributes {
        provider: @EBA_VECTOR_OCI
        columnName: EMBEDDING_VECTOR
        distanceMetric: dot
    }
    columnMapping {
        primaryKey1Column: ID
        titleColumn: TITLE
        subtitleColumn: ACTORS
        descriptionColumn: MOVIEDESCRIPTION
        badgeColumn: RATING
    }
    link {
        type: redirectThisApp
        target: {
            page: 49
            items: {
                P49_SEARCH_ID: &ID.
            }
            clearCache: 49
        }
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-film
    }
    performance {
        maxRowsToReturn: 5
    }
)

