    pageItem P54_OCI_FINGERPRINT (
        type: textField
        label {
            label: OCI Public Key Fingerprint
            alignment: left
        }
        layout {
            sequence: 70
            region: @web-credentials
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 80
