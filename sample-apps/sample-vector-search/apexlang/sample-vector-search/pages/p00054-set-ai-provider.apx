        }
        validation {
            type: itemIsNotNull
            item: P54_OCI_USER_ID
        }
        error {
            errorMessage: #LABEL# must have a value.
            associatedItem: @P54_OCI_USER_ID
        }
        serverSideCondition {
            whenButtonPressed: @complete-oci
            type: item=value
            item: P54_SHOW_WEB_CREDENTIALS
            value: Y
        }
    )

    validation p54-openai-api-key-not-null (
        name: P54_OPENAI_API_KEY not null
        execution {
            sequence: 50
        }
        validation {
            type: itemIsNotNull
