            helpText: <p>Enter the <em>public RSA key fingerprint</em> for OCI authentication. </p><p><a rel="noopener noreferrer" target="_blank" href="https://docs.cloud.oracle.com/iaas/Content/API/Concepts/apisigningkey.htm">Oracle Cloud Infrastructure Documentation</a></p>
        }
    )

    pageItem P54_OCI_PRIVATE_KEY (
        type: textarea
        label {
            label: OCI Private Key
            alignment: left
        }
        layout {
            sequence: 40
            region: @web-credentials
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 80
            height: 5
        }
        validation {
            maxLength: 4000
        }
        sessionState {
            storage: request
        }
        help {
            helpText: <p>Enter the private key in PEM format for OCI authentication. &PRODUCT_NAME. stores this information encrypted and secure, so it cannot be retrieved back in clear text.</p><p><a rel="noopener noreferrer" target="_blank" href="https://docs.cloud.oracle.com/iaas/Content/API/Concepts/apisigningkey.htm">Oracle Cloud Infrastructure Documentation</a></p>
        }
    )

    pageItem P54_OCI_REGION (
        type: textField
        label {
            label: Region
            alignment: left
        }
        layout {
            sequence: 20
            region: @enter-oci-web-credentials
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 80
        }
        default {
            type: static
            staticValue: us-chicago-1
        }
        quickPicks {
            type: static
            label1: US Midwest (Chicago)
            value1: us-chicago-1
            label2: US East (Ashburn)
            value2: us-ashburn-1
            label3: US West (Phoenix)
            value3: us-phoenix-1
            label4: Germany Central (Frankfurt)
            value4: eu-frankfurt-1
            label5: UK South (London)
            value5: uk-london-1
        }
        help {
            helpText: The Oracle Cloud Infrastructure Region. The default is us-chicago-1
        }
    )

