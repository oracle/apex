            label: AI Provider
            alignment: left
        }
        settings {
            noOfCols: 2
        }
        lov {
            type: staticValues
            staticValues: STATIC:OCI Generative AI;OCI,Open AI;OPENAI
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @select-provider
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        source {
            type: item
            item: CURRENT_AI_PROVIDER
            used: always
        }
