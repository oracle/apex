    dynamicAction change-ai-provider (
        name: Change AI Provider
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P54_AI_PROVIDER
        }

        action hide-complete-button-oci (
            name: Hide Complete Button OCI
            action: hide
            affectedElements {
                selectionType: region
                region: @button-oci
            }
            execution {
                sequence: 40
            }
        )

        action hide-complete-button-openai (
            name: Hide Complete Button OPENAI
            action: hide
            affectedElements {
                selectionType: region
                region: @button-openai
            }
            execution {
                sequence: 50
            }
        )

        action hide-oci-web-credentials (
            name: Hide OCI Web Credentials
            action: hide
            affectedElements {
                selectionType: region
                region: @enter-oci-web-credentials
            }
            execution {
                sequence: 20
            }
        )

        action hide-openai-web-credentials (
            name: Hide OpenAI Web Credentials
            action: hide
            affectedElements {
                selectionType: region
                region: @enter-openai-web-credentials
            }
            execution {
                sequence: 30
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    apex_app_setting.set_value('AI_PROVIDER', :P54_AI_PROVIDER);
                    :CURRENT_AI_PROVIDER := :P54_AI_PROVIDER;
                    ```
                itemsToSubmit: P54_AI_PROVIDER
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action show-complete-button-oci (
            name: Show Complete Button OCI
            action: show
            affectedElements {
                selectionType: region
                region: @button-oci
            }
            execution {
                sequence: 80
            }
            clientSideCondition {
                type: item=value
                item: P54_AI_PROVIDER
                value: OCI
            }
        )

        action show-complete-button-openai (
            name: Show Complete Button OpenAI
            action: show
            affectedElements {
                selectionType: region
                region: @button-openai
            }
            execution {
                sequence: 90
            }
            clientSideCondition {
                type: item=value
                item: P54_AI_PROVIDER
                value: OPENAI
            }
        )

        action show-oci-web-credentials (
            name: Show OCI Web Credentials
            action: show
            affectedElements {
                selectionType: region
                region: @enter-oci-web-credentials
            }
            execution {
                sequence: 60
            }
            clientSideCondition {
                type: item=value
                item: P54_AI_PROVIDER
                value: OCI
            }
        )

        action show-openai-web-credentials (
            name: Show OpenAI Web Credentials
            action: show
            affectedElements {
                selectionType: region
                region: @enter-openai-web-credentials
            }
            execution {
                sequence: 70
            }
            clientSideCondition {
                type: item=value
                item: P54_AI_PROVIDER
                value: OPENAI
            }
        )

    )

    dynamicAction toggle-switch-visibility (
        name: Toggle Switch Visibility
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P54_SHOW_WEB_CREDENTIALS
        }
        clientSideCondition {
            type: item=value
            item: P54_SHOW_WEB_CREDENTIALS
            value: Y
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @web-credentials
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @web-credentials
            }
            execution {
                sequence: 10
            }
        )

    )

    validation p54-oci-compartment-id-not-null (
