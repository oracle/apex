page 31 (
    name: Basic Vector Search
    alias: BASIC-VECTOR-SEARCH
    title: Basic Vector Search
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-basic-vector-search (
        name: About Basic Vector Search
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Search using vectors including all data fields of the uploaded data for deeper and broader results.</p>
                
                <p>All data fields are combined into a single vector, allowing the search to find <strong>matches across multiple columns</strong> at once.</p>
                
                <p>Note that performing a vector search will always yield results, regardless of the quality of the match. The best matches will be displayed at the top of the resultset.</p>
                
                <p>To search, start typing your query, and the results will be displayed immediately. Here are a few example search terms to get started:</p>
                
                <ul>
                    <li>Testing</li>
                    <li>Results that include errors.</li>
                </ul>
                ```
        }
        layout {
            sequence: 20
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--textContent
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: complementary
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region content (
        name: Content
        type: staticContent
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region search (
        name: Search
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: search
            landmarkLabel: Basic Vector
        }
    )

    region search-results-oci (
        name: Search Results OCI
        type: search
        source {
            pageItemsToSubmit: P31_SEARCH
        }
        layout {
            sequence: 20
            parentRegion: @content
            slot: subRegions
        }
        appearance {
            template: @/search-results-container
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: CURRENT_AI_PROVIDER
            value: OCI
        }
        settings {
            searchPageItem: P31_SEARCH
        }
        messages {
            noQueryEnteredMessage: Please enter your search term.
            noResultsFoundMessage: No results found.
        }

        searchSource basic-vector-search-oci-datatable (
            name: Basic Vector Search OCI Datatable
            searchConfig: @OCI_ADVANCED_VECTOR_SEARCH
            layout {
                sequence: 10
            }
        )

    )

    region search-results-openai (
        name: Search Results OPENAI
        type: search
        source {
            pageItemsToSubmit: P31_SEARCH
        }
        layout {
            sequence: 30
            parentRegion: @content
            slot: subRegions
        }
        appearance {
            template: @/search-results-container
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: CURRENT_AI_PROVIDER
            value: OPENAI
        }
        settings {
            searchPageItem: P31_SEARCH
        }
        messages {
            noQueryEnteredMessage: Please enter your search term.
            noResultsFoundMessage: No results found.
        }

        searchSource basic-vector-search-openai-datatable (
            name: Basic Vector Search OPENAI Datatable
            searchConfig: @OPENAI_ADVANCED_VECTOR_SEARCH
            layout {
                sequence: 10
            }
        )

    )

    pageItem P31_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            subtype: search
        }
        layout {
            sequence: 10
            region: @search
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--xlarge
            ]
            cssClasses: [
                mxw800
                t-Form-fieldContainer--noPadding
            ]
            icon: fa-search
            valuePlaceholder: Enter your search term, e.g. Testing
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
    )

)

