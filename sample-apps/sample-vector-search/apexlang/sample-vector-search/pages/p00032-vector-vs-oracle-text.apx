page 32 (
    name: Vector vs. Oracle Text
    alias: VECTOR-VS-ORACLE-TEXT
    title: Vector vs. Oracle Text
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-vector-vs-oracle-text-search (
        name: About Vector vs. Oracle Text Search
        type: staticContent
        source {
            htmlCode:
                ```html
                <p><strong>Compare</strong> vector search (focused on meaning) with Oracle Text search (focused on keywords and phrases) <strong>to see their differences</strong>.</p>
                
                <p>Note that performing a vector search will always yield results, regardless of the quality of the match. The best matches will be displayed at the top of the resultset.</p>
                
                <p>To search, start typing your query, and the results will be displayed immediately. Here are a few example search terms to get started:</p>
                
                <ul>
                    <li>Testing</li>
                    <li>Results that include errors.</li>
                </ul>
                ```
        }
        layout {
            sequence: 30
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--textContent
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: complementary
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region content (
        name: Content
        type: staticContent
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region oracle-text (
        name: Oracle Text
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @content
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
    )

    region oracle-text-not-available (
        name: Oracle Text not available
        type: staticContent
        source {
            htmlCode: <p>This feature cannot be used because Oracle Text is not available in this instance.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--danger
            ]
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1 
                  from sys.all_objects
                 where owner       = 'CTXSYS' 
                   and object_name = 'CTX_DDL' 
                   and rownum      = 1;
                ```
        }
    )

    region search (
        name: Search
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: search
            landmarkLabel: Vector vs. Oracle Text
        }
    )

    region search-results (
        name: Search Results
        type: search
        source {
            pageItemsToSubmit: P32_SEARCH
        }
        layout {
            sequence: 10
            parentRegion: @oracle-text
            slot: subRegions
        }
        appearance {
            template: @/search-results-container
            templateOptions: #DEFAULT#
        }
        settings {
            searchPageItem: P32_SEARCH
        }
        messages {
            noQueryEnteredMessage: Please enter your search term.
            noResultsFoundMessage: No results found.
        }

        searchSource oracle-text-search (
            name: Oracle Text Search
            searchConfig: @ORACLE_TEXT_SEARCH
            layout {
                sequence: 22
            }
        )

    )

    region search-results-oci (
        name: Search Results OCI
        type: search
        source {
            pageItemsToSubmit: P32_SEARCH
        }
        layout {
            sequence: 10
            parentRegion: @vector
            slot: subRegions
        }
        appearance {
            template: @/search-results-container
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: CURRENT_AI_PROVIDER
            value: OCI
        }
        settings {
            searchPageItem: P32_SEARCH
        }
        messages {
            noQueryEnteredMessage: Please enter your search term.
            noResultsFoundMessage: No results found.
        }

        searchSource basic-vector-search-oci-datatable (
            name: Basic Vector Search OCI Datatable
            searchConfig: @OCI_ADVANCED_VECTOR_SEARCH
            layout {
                sequence: 20
            }
        )

    )

    region search-results-openai (
        name: Search Results OPENAI
        type: search
        source {
            pageItemsToSubmit: P32_SEARCH
        }
        layout {
            sequence: 20
            parentRegion: @vector
            slot: subRegions
        }
        appearance {
            template: @/search-results-container
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: CURRENT_AI_PROVIDER
            value: OPENAI
        }
        settings {
            searchPageItem: P32_SEARCH
        }
        messages {
            noQueryEnteredMessage: Please enter your search term.
            noResultsFoundMessage: No results found.
        }

        searchSource basic-vector-search-openai-datatable (
            name: Basic Vector Search OPENAI Datatable
            searchConfig: @OPENAI_ADVANCED_VECTOR_SEARCH
            layout {
                sequence: 10
            }
        )

    )

    region vector (
        name: Vector
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
    )

    pageItem P32_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            subtype: search
        }
        layout {
            sequence: 20
            region: @search
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--xlarge
            ]
            cssClasses: [
                mxw800
                t-Form-fieldContainer--noPadding
            ]
            icon: fa-search
            valuePlaceholder: Enter your search term, e.g. Testing
        }
        advanced {
            warnOnUnsavedChanges: ignore
        }
    )

)

