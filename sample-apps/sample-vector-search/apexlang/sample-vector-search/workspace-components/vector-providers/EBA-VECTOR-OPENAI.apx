vectorProvider EBA_VECTOR_OPENAI (
    name: OpenAI Vector Service
    type: genAIService
    genAIService {
        provider: openai
        modelName: text-embedding-3-small
    }
    endpointUrl {
        url: https://api.openai.com/v1
    }
    authentication {
        credentials: @EBA_CREDENTIALS_OPENAI
    }
)

