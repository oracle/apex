            label: Description
            alignment: left
        }
        layout {
            sequence: 40
            region: @edit-eba-demo-md-milestones
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 70
            height: 5
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @edit-eba-demo-md-milestones
            column: DESCRIPTION
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
