page 7 (
    name: Milestone Detail
    alias: MILESTONE-DETAIL
    title: Milestone Detail
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-details (
        name: Audit Details
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @edit-eba-demo-md-milestones
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P7_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region edit-eba-demo-md-milestones (
        name: Edit EBA_DEMO_MD_MILESTONES
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_MD_MILESTONES
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P7_CREATED (
        type: displayOnly
        label {
            label: Created
            alignment: left
        }
        layout {
            sequence: 110
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @edit-eba-demo-md-milestones
            column: CREATED
            dataType: timestampWithTimeZone
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    pageItem P7_CREATED_BY (
        type: selectList
        label {
            label: Created By
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @username
        }
        layout {
            sequence: 120
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @edit-eba-demo-md-milestones
            column: CREATED_BY
            dataType: varchar2
        }
        readOnly {
            type: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    pageItem P7_DESCRIPTION (
        type: textarea
