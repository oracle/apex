                    width: 259
                    sequence: 4
                }
            )

            displayColumn (
                column: @DESCRIPTION
                layout {
                    width: 539
                    sequence: 10
                }
            )

            displayColumn (
                column: @ASSIGNEE
                layout {
                    sequence: 5
                }
            )

            displayColumn (
                column: @START_DATE
                layout {
                    width: 99
                    sequence: 6
                }
            )

            displayColumn (
                column: @END_DATE
                layout {
                    width: 77
                    sequence: 7
                }
            )

            displayColumn (
                column: @IS_COMPLETE_YN
                layout {
                    width: 99
                    sequence: 8
                }
            )

            sort (
                column: @START_DATE
                sort {
                    nulls: last
                    sequence: 1
                }
            )

        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column ASSIGNEE (
            type: selectList
            heading {
                heading: Assignee
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select full_name d, id r
                    from eba_demo_md_team_members
                    order by 1
                    ```
                displayExtraValues: false
                nullDisplayValue: - Select Assignee -
            }
            layout {
                sequence: 80
            }
            source {
                databaseColumn: ASSIGNEE
                dataType: number
            }
        )

        column DESCRIPTION (
            type: textarea
            heading {
                heading: Description
            }
            layout {
                sequence: 140
            }
            validation {
                maxLength: 4000
            }
            source {
                databaseColumn: DESCRIPTION
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column END_DATE (
            type: datePickerJquery
            heading {
                heading: End Date
            }
            layout {
                sequence: 120
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: END_DATE
                dataType: date
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 40
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column IS_COMPLETE_YN (
            type: switch
            heading {
                heading: Is Complete?
            }
            layout {
                sequence: 130
            }
            source {
                databaseColumn: IS_COMPLETE_YN
                dataType: varchar2
            }
            default {
                type: static
                staticValue: N
                duplicateCopiesExistingValue: false
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column MILESTONE_ID (
            type: selectList
            heading {
                heading: Milestone
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select name d, id r
                    from eba_demo_md_milestones
                    --where project_id = :PROJECT_ID
                    order by 1
                    ```
                displayExtraValues: false
                nullDisplayValue: - Select Milestone -
            }
            layout {
                sequence: 90
            }
            source {
                databaseColumn: MILESTONE_ID
                dataType: number
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 70
            }
            validation {
                valueRequired: true
                maxLength: 255
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column PROJECT_ID (
            type: hidden
            layout {
                sequence: 50
            }
            source {
                databaseColumn: PROJECT_ID
                dataType: number
            }
            masterDetail {
                masterColumn: @ID
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column START_DATE (
            type: datePickerJquery
            heading {
                heading: Start Date
            }
            layout {
                sequence: 110
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: START_DATE
                dataType: date
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        columnHeadings {
            fontWeight: normal
            backgroundColor: #9bafde
        }
        columns {
            backgroundColor: #efefef
        }
    )

    button calendar (
        buttonName: CALENDAR
        label: Calendar
        layout {
            sequence: 10
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-calendar
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10
                items: {
                    P10_PROJECT_ID: &P33_PROJECT_ID.
                }
                clearCache: 10
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: never
        }
    )

    button save (
        buttonName: SAVE
        label: Save
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-comment-dialog-closed (
        name: Edit Comment - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @comments
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation start-date-end-date (
        name: Start Date <= End Date
        execution {
            sequence: 10
        }
        validation {
            editableRegion: @tasks
            plsqlExpression: :START_DATE <= :END_DATE
        }
        error {
            errorMessage: Start Date can not be after End Date
            displayLocation: inlineInNotification
            associatedColumn: END_DATE
        }
    )

    process comments-save-interactive-grid-data (
        name: Comments - Save Interactive Grid Data
        type: interactiveGridAutoRowProcessing
        editableRegion: @comments
        execution {
            sequence: 40
        }
        successMessage {
            successMessage: Comment(s) saved: Inserted = #MRI_COUNT#, Updated = #MRU_COUNT#, Deleted = #MRD_COUNT#.<br />
