    region milestones (
        name: Milestones
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select m.id
                , m.project_id
                , m.name
                , m.description
                , m.due_date
                , (select count(*)
                   from eba_demo_md_tasks t
                   where t.milestone_id = m.id
                  ) tasks
                from eba_demo_md_milestones m
                
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        masterDetail {
            masterRegion: @projects
        }
        advanced {
            htmlDomId: milestones
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
            addRowIfEmpty: false
        }
        componentAppearance {
            showNullValuesAs: -
        }
        messages {
            whenNoDataFound: No milestones for this project.
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
            addButtonLabel: Add Milestone
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 1827254700800385265
        }

