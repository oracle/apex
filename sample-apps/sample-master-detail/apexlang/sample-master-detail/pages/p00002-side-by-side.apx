                lov: @p18-milestones
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column NAME (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
        )

        column START_DATE (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Start Date
            }
            layout {
                sequence: 7
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED (
            reportColumnQueryId: 12
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 12
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Updated By
            }
            layout {
                sequence: 13
            }
            sorting {
                sortable: false
            }
        )

    )

    pageItem P2_ID (
        type: hidden
        layout {
            sequence: 40
            region: @project-details
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P2_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        layout {
            sequence: 10
            region: @search
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
                t-Form-fieldContainer--postTextBlock
            ]
            icon: fa-search
            width: 30
            valuePlaceholder: Search...
        }
    )

    button create (
        buttonName: CREATE
        label: Add Project
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10
                clearCache: 10
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button edit (
        buttonName: EDIT
        label: Edit Project
        layout {
            sequence: 20
            region: @project-details
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-pencil-square-o
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10
                items: {
                    P10_ID: &P2_ID.
                }
                clearCache: 10
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            htmlDomId: edit_master_btn
        }
    )

