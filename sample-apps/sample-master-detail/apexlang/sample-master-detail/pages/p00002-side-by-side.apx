    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
                t-Button--gapRight
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
                clearCache: 2
                action: resetPagination
                request: RESET
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-master-record (
        name: Edit Master Record
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @project-details
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Eba\u0020Demo\u0020Md\u0020Projects\u0020updated');
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @project-details
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction perform-search (
        name: Perform Search
        execution {
            sequence: 150
        }
        when {
            event: keypress
            selectionType: items
            items: P2_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.browserEvent.which === apex.jQuery.ui.keyCode.ENTER
        }

        action native-cancel-event (
            action: cancelEvent
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @master-records
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

