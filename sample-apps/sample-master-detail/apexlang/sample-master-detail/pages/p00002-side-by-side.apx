    region master-records (
        name: Master Records
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select "ID",
                    null link_class,
                    apex_page.get_url(p_items => 'P2_ID', p_values => "ID") link,
                    null icon_class,
                    null link_attr,
                    null icon_color_class,
                    case when nvl(:P2_ID,'0') = "ID"
                      then 'is-active' 
                      else ' '
                    end list_class,
                    substr("NAME", 1, 50)||( case when length("NAME") > 50 then '...' end ) list_title,
                    substr("STATUS_CD", 1, 50)||( case when length("STATUS_CD") > 50 then '...' end ) list_text,
                    null list_badge
                from "EBA_DEMO_MD_PROJECTS" x
                where (:P2_SEARCH is null
                        or upper(x."NAME") like '%'||upper(:P2_SEARCH)||'%'
                        or upper(x."STATUS_CD") like '%'||upper(:P2_SEARCH)||'%'
                    )
                order by "NAME"
                ```
            pageItemsToSubmit: P2_SEARCH
        }
        layout {
            sequence: 20
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: search-results
        }
        reportLayout {
            numberOfRows: 1000
        }
        componentAppearance {
            template: @/media-list
            templateOptions: [
                t-MediaList--showDesc
                t-MediaList--stack
            ]
            showNullValuesAs: -
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: <div class="u-tC">No Records Found</div>
        }

