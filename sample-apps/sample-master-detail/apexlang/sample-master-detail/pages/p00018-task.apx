page 18 (
    name: Task
    alias: TASK
    title: Task
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region task (
        name: Task
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_MD_TASKS
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--stretchInputs
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P18_ASSIGNEE (
        type: selectList
        label {
            label: Assignee
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @team-members
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 40
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @task
            column: ASSIGNEE
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 60
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @task
            column: DESCRIPTION
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_END_DATE (
        type: datePicker
        label {
            label: End Date
            alignment: left
        }
        layout {
            sequence: 80
            region: @task
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 20
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @task
            column: END_DATE
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_ID (
        type: hidden
        layout {
            sequence: 10
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_IS_COMPLETE_YN (
        type: switch
        label {
            label: Is Complete
            alignment: left
        }
        layout {
            sequence: 90
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @task
            column: IS_COMPLETE_YN
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_MILESTONE_ID (
        type: selectList
        label {
            label: Milestone
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @p18-milestones
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 30
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @task
            column: MILESTONE_ID
            dataType: number
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_demo_md_milestones
                where project_id = :P18_PROJECT_ID
                ```
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        layout {
            sequence: 50
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @task
            column: NAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_PROJECT_ID (
        type: hidden
        layout {
            sequence: 20
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: PROJECT_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P18_START_DATE (
        type: datePicker
        label {
            label: Start Date
            alignment: left
        }
        layout {
            sequence: 70
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 20
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @task
            column: START_DATE
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Task
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P18_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P18_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P18_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            itemsToReturn: [
                P18_ID
                REQUEST
            ]
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 76207446440660544
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process fetch-row-from-eba-demo-md-tasks (
        name: Fetch Row from EBA_DEMO_MD_TASKS
        type: formInitialization
        formRegion: @task
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 76206254465660544
        }
    )

    process process-row-of-eba-demo-md-tasks (
        name: Process Row of EBA_DEMO_MD_TASKS
        type: formAutoRowProcessing
        formRegion: @task
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 76206606449660544
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 76207041868660544
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

