                sequence: 20
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: item
            itemName: APP_PAGE_ID
        }
    )

    computation p11-project-name (
        itemName: P11_PROJECT_NAME
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            sqlQuery:
                ```sql
                select name
                from eba_demo_md_projects
                where id = :P11_PROJECT_ID
                ```
        }
    )

)

