    dynamicAction add-comments (
        name: Add Comments
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: jQuerySelector
            jquerySelector: #add_comment, #actions
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId == "13"
        }
    )

    dynamicAction comments-region-dialog-closed (
        name: Comments Region - Dialog Closed
        execution {
            sequence: 50
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @comments
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: null;
                itemsToSubmit: P11_PROJECT_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction milestone-updates (
        name: Milestone Updates
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: jQuerySelector
            jquerySelector: #milestones, #add-milestone, #actions
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId == "7"
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @milestones
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction project-updates (
        name: Project Updates
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @edit-project
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-reports-on-add (
        name: Refresh reports on add
        execution {
            sequence: 60
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @project-actions
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @milestones
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @tasks
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-3 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction task-region-dialog-closed (
        name: Task Region - Dialog Closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @tasks
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
