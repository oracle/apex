    region master-project (
        name: Master Project
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.description
                , (select full_name from eba_demo_md_team_members tm where tm.id = p.project_lead) project_lead
                , p.completed_date
                , p.status_cd
                , p.created
                , p.updated last_updated
                from eba_demo_md_projects p
                where p.id = :P11_PROJECT_ID
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No data found.
        }
        componentAdvanced {
            stripHtml: true
        }

