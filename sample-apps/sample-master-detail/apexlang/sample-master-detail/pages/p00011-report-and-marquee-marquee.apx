    button add-comment (
        buttonName: ADD_COMMENT
        label: Add comment
        layout {
            sequence: 10
            region: @comments
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                items: {
                    P13_PROJECT_ID: &P11_PROJECT_ID.
                }
                clearCache: 13
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            htmlDomId: add-comment
        }
    )

