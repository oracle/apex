page 11 (
    name: Report and Marquee - Marquee
    alias: REPORT-AND-MARQUEE-MARQUEE
    title: Report and Marquee - Marquee
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .a-MediaBlock-graphic img {
            width: 100%;
            }
            .t-Comments-userIcon {
            border-color: rgba(0,0,0,.25);
            }
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region comments (
        name: Comments
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id comment_id
                , 'u-color-' || ora_hash(c.created_by, 29) || ' u-color-' || ora_hash(c.created_by, 29) || '-bd' icon_modifier
                , c.comment_text
                , c.created comment_date
                ,  apex_string.get_initials(c.created_by) user_icon
                , c.created_by user_name
                , apex_page.get_url(p_page => 13, p_items => 'P13_ID', p_values => id) actions
                , null attribute_1
                , null attribute_2
                , null attribute_3
                , null attribute_4
                from eba_demo_md_comments c
                where c.project_id = :P11_PROJECT_ID
                order by c.created
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: comments
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: currentPageInList
            pages: [
                11
                49
            ]
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
            showNullValuesAs: &nbsp;
        }
        messages {
            whenNoDataFound: No comments for this project.
        }

        column ACTIONS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
