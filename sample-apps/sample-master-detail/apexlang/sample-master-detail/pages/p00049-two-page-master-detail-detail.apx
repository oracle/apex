    dynamicAction comment-region-dialog-closed (
        name: Comment Region - Dialog Closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @comments
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction show-completed-date (
        name: Show Completed Date
        execution {
            sequence: 60
        }
        when {
            selectionType: items
            items: P49_STATUS_CD
        }
        clientSideCondition {
            type: item=value
            item: P49_STATUS_CD
            value: COMPLETED
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: P49_COMPLETED_DATE
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P49_COMPLETED_DATE
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction tasks-region-dialog-closed (
        name: Tasks Region - Dialog Closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @tasks
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @tasks
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
