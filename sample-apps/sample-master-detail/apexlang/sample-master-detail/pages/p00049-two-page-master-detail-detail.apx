page 49 (
    name: Two Page Master Detail - Detail
    alias: TWO-PAGE-MASTER-DETAIL-DETAIL
    title: Two Page Master Detail - Detail
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            var htmldb_ch_message='"OK_TO_GET_NEXT_PREV_PK_VALUE"';
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region audit-details (
        name: Audit Details
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @project-details-2
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P49_ROWID
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--compactTitle
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <strong>&P49_ROWID_COUNT.</strong>
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
                margin-left-md
                margin-right-md
            ]
        }
    )

    region comments (
        name: Comments
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id comment_id
                , 'u-color-' || ora_hash(c.created_by, 29) || ' u-color-' || ora_hash(c.created_by, 29) || '-bd' icon_modifier
                , c.comment_text
                , c.created comment_date
                ,  apex_string.get_initials(c.created_by) user_icon
                , c.created_by user_name
                , apex_page.get_url(p_page => 13, p_items => 'P13_ID', p_values => id) actions
                , null attribute_1
                , null attribute_2
                , null attribute_3
                , null attribute_4
                from eba_demo_md_comments c
                where c.project_id = :P49_ID
                order by c.created
                ```
            pageItemsToSubmit: P49_ID
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: comments
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: currentPageInList
            pages: [
                11
                49
            ]
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
            showNullValuesAs: &nbsp;
        }
        messages {
            whenNoDataFound: No comments for this project.
        }

        column ACTIONS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Actions
            }
            layout {
                sequence: 7
            }
            columnFormatting {
                htmlExpression: <a href="#ACTIONS#" class="t-Button t-Button--small t-Button--simple">Edit</a>
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_1 (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Attribute 1
            }
            layout {
                sequence: 8
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_2 (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Attribute 2
            }
            layout {
