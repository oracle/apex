                heading: Attribute 4
            }
            layout {
                sequence: 11
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_DATE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Comment date
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_ID (
            reportColumnQueryId: 1
            derivedColumn: N
