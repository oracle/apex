    region tasks (
        name: Tasks
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.id
                , t.project_id
                , t.name
                , t.description
                , t.is_complete_yn
                , t.milestone_id
                , t.assignee
                , t.start_date
                , t.end_date
                , (select count('x')
                   from eba_demo_md_task_todos td
                   where td.task_id = t.id
                  ) todos
                , (select count('x')
                   from eba_demo_md_task_links l
                   where l.task_id = t.id
                  ) links
                from eba_demo_md_tasks t
                where t.project_id = :P49_ID
                ```
            pageItemsToSubmit: P49_ID
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
