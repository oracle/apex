    button add-comment (
        buttonName: ADD_COMMENT
        label: Add comment
        layout {
            sequence: 10
            region: @comments
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                items: {
                    P13_PROJECT_ID: &P49_ID.
                }
                clearCache: 13
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            htmlDomId: add-comment
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
