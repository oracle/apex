                sequence: 6
            }
            sorting {
                sortable: false
            }
        )

    )

    region milestones (
        name: Milestones
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select m.id
                , m.project_id
                , m.name
                , m.description
                , m.due_date
                , (select count(*)
                   from eba_demo_md_tasks t
                   where t.milestone_id = m.id
                  ) tasks
                from eba_demo_md_milestones m
                where m.project_id = :P49_ID
                ```
            pageItemsToSubmit: P49_ID
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        messages {
            whenNoDataFound: No milestones for this project.
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
            addButtonLabel: Add Milestone
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 649654729201155245
        }

