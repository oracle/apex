    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 40
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button create (
        buttonName: CREATE
        label: Add Task
        layout {
            sequence: 20
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P9_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 30
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Save
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction get-due-date (
        name: Get Due Date
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P9_MILESTONE_ID
        }

        action native-set-value (
            action: setValue
            settings {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select due_date
                    from eba_demo_md_milestones
                    where id = :P9_MILESTONE_ID
                    ```
                itemsToSubmit: P9_MILESTONE_ID
            }
            affectedElements {
                selectionType: items
                items: P9_MILESTONE_DUE_DATE
            }
            execution {
                sequence: 10
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 11
        }
        advanced {
            executionMappingIdentifier: 1919911457766017367
        }
    )

    process fetch-row-from-eba-demo-md-tasks (
        name: Fetch Row from EBA_DEMO_MD_TASKS
        type: formInitialization
        formRegion: @edit-eba-demo-md-tasks
        execution {
            sequence: 1
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 48358408665036029230
        }
    )

    process process-row-of-eba-demo-md-tasks (
        name: Process Row of EBA_DEMO_MD_TASKS
        type: formAutoRowProcessing
        formRegion: @edit-eba-demo-md-tasks
        target {
            returnPksAfterInsert: false
        }
        execution {
            sequence: 1
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 48358408801394029232
        }
    )

)

