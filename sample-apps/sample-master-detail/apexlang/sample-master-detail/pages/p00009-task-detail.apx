        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @edit-eba-demo-md-tasks
            column: ASSIGNEE
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
