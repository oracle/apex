    pageItem P9_MILESTONE_ID (
        type: selectList
        label {
            label: Milestone
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select name as display
                , id as return
                from eba_demo_md_milestones
                where project_id = :P9_PROJECT_ID
                order by 1
                ```
            displayExtraValues: false
            nullDisplayValue: - Select Milestone -
        }
        cascadingLov {
            parentItems: P9_PROJECT_ID
        }
        layout {
            sequence: 30
            region: @edit-eba-demo-md-tasks
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
