page 10 (
    name: Project
    alias: PROJECT
    title: Project
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region project (
        name: Project
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_MD_PROJECTS
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--stretchInputs
            ]
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P10_COMPLETED_DATE (
        type: datePicker
        label {
            label: Completed Date
            alignment: left
        }
        layout {
            sequence: 60
            region: @project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @project
            column: COMPLETED_DATE
            dataType: date
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: right
        }
        layout {
            sequence: 40
            region: @project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @project
            column: DESCRIPTION
            dataType: varchar2
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10_ID (
        type: hidden
        layout {
            sequence: 10
            region: @project
            slot: regionBody
        }
        source {
            formRegion: @project
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P10_NAME (
        type: textarea
        label {
            label: Name
            alignment: right
        }
        layout {
            sequence: 30
            region: @project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @project
            column: NAME
            dataType: varchar2
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10_PROJECT_LEAD (
        type: selectList
        label {
            label: Project Lead
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @team-members
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 20
            region: @project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @project
            column: PROJECT_LEAD
            dataType: number
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P10_STATUS_CD (
        type: selectList
        label {
            label: Status
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @status
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 50
            region: @project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @project
            column: STATUS_CD
            dataType: varchar2
        }
        security {
            encryptSessionState: false
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Project
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P10_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 76138441948660460
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

    process fetch-row-from-eba-demo-md-projects (
        name: Fetch Row from EBA_DEMO_MD_PROJECTS
        type: formInitialization
        formRegion: @project
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 76137217838660460
        }
    )

    process process-row-of-eba-demo-md-projects (
        name: Process Row of EBA_DEMO_MD_PROJECTS
        type: formAutoRowProcessing
        formRegion: @project
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 76137647203660460
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 76138041241660460
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    branch (
        name: Redirect to new
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 2
                items: {
                    P2_ID: &P10_ID.
                }
                action: resetPagination
            }
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    branch (
        name: Redirect to all
        execution {
            sequence: 20
        }
        behavior {
            target: {
                page: 2
                clearCache: 2
                action: resetPagination
            }
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

