    dynamicAction edit-comment-dialog-closed (
        name: Edit Comment - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @comments
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation new (
        name: New
        execution {
            sequence: 20
        }
        validation {
            editableRegion: @links
            type: columnMatchesRegexp
            column: URL
            regexp: "^http[s]?://[-a-zA-Z0-9_.:]+[-a-zA-Z0-9_:@&?=+,.!/~*'%$]*$"
        }
        error {
            errorMessage: #COLUMN_HEADER# must have a value.
            associatedColumn: URL
        }
    )

    validation start-date-end-date (
        name: Start Date <= End Date
        execution {
            sequence: 10
        }
        validation {
            editableRegion: @tasks-2
            plsqlExpression: :START_DATE <= :END_DATE
        }
        error {
            errorMessage: Start Date can not be after End Date
            displayLocation: inlineInNotification
            associatedColumn: END_DATE
        }
    )

