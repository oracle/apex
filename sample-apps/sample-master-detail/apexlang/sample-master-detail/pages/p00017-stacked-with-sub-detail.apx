    region overview-stacked-with-sub-detail (
        name: Overview: Stacked with Sub Detail
        type: staticContent
        source {
            htmlCode: This example displays master-detail-subdetail Interactive Grids on the same page.  It shows you can build unlimited level of master detail layouts of any complexity using Interactive Grids.
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
    )

    region project-details (
        name: Project Details
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                "ID",
                "NAME",
                "DESCRIPTION",
                "PROJECT_LEAD",
                "COMPLETED_DATE",
                "STATUS_CD"
                from eba_demo_md_projects p
                
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: Projects
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            showTotalCount: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
        }
        enableUsersTo {
            savePublicReport: true
            defineChartView: false
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    var toolbarData = $.apex.interactiveGrid.copyDefaultToolbar();
                
                    // new getNestedObject function makes it easy to set a property
                    // on a nested object that may or may not yet exist.
                    // If all nested objects always existed could just do this
                    //    config.views.grid.features.gridView = false;
                    // but they don't
                    apex.util.getNestedObject(config, "views.grid.features").gridView = false;
                
                    // remove some toolbar action menu items that don't make sense
                    toolbarData.toolbarRemove( "show-aggregate-dialog" );
                    toolbarData.toolbarRemove( "format_submenu" );
                    toolbarData.toolbarRemove( "selection_submenu" );
                    config.toolbarData = toolbarData;
                
                    return config; // don't forget to return this!
                }
                ```
        }
        advanced {
            savedReportMappingIdentifier: 5432283599051091340
        }

