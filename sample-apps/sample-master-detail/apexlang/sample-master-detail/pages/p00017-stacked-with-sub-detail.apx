    region milestones (
        name: Milestones
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select m.id
                , m.project_id
                , m.name
                , m.description
                , m.due_date
                , (select count(*)
                   from eba_demo_md_tasks t
                   where t.milestone_id = m.id
                  ) tasks
                from eba_demo_md_milestones m
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
