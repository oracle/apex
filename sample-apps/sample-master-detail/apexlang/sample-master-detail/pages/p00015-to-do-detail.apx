page 15 (
    name: To Do Detail
    alias: TO-DO-DETAIL
    title: To Do Detail
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-details (
        name: Audit Details
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region form-on-eba-demo-md-task-todos (
        name: Form on EBA_DEMO_MD_TASK_TODOS
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_MD_TASK_TODOS
            includeRowidColumn: true
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P15_ASSIGNEE (
        type: selectList
        label {
            label: Assignee
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @team-members
            displayExtraValues: false
            nullDisplayValue: - Select Assignee -
        }
        layout {
            sequence: 40
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: ASSIGNEE
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P15_CREATED (
        type: displayOnly
        label {
            label: Created
            alignment: left
        }
        layout {
            sequence: 110
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: CREATED
            dataType: timestampWithTimeZone
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    pageItem P15_CREATED_BY (
        type: selectList
        label {
            label: Created By
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @username
        }
        layout {
            sequence: 120
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: CREATED_BY
            dataType: varchar2
        }
        readOnly {
            type: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    pageItem P15_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 60
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 70
            height: 5
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: DESCRIPTION
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P15_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P15_IS_COMPLETE_YN (
        type: switch
        label {
            label: Completed?
            alignment: left
        }
        layout {
            sequence: 70
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: IS_COMPLETE_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: N
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P15_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        layout {
            sequence: 50
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 70
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: NAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P15_PROJECT_ID (
        type: selectList
        label {
            label: Project
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @projects
            displayExtraValues: false
            nullDisplayValue: - Select Project -
        }
        layout {
            sequence: 20
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: PROJECT_ID
            dataType: number
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P15_TASK_ID (
        type: selectList
        label {
            label: Task
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select name || ' [' || start_date || ' - ' || end_date || ']' d, id r
                from eba_demo_md_tasks
                where project_id = :P15_PROJECT_ID
                order by start_date
                
                ```
            displayExtraValues: false
            nullDisplayValue: - Select Task -
        }
        cascadingLov {
            parentItems: P15_PROJECT_ID
        }
        layout {
            sequence: 30
            region: @form-on-eba-demo-md-task-todos
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: TASK_ID
            dataType: number
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P15_UPDATED (
        type: displayOnly
        label {
            label: Updated
            alignment: left
        }
        layout {
            sequence: 130
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: UPDATED
            dataType: timestampWithTimeZone
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    pageItem P15_UPDATED_BY (
        type: selectList
        label {
            label: Updated By
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @username
        }
        layout {
            sequence: 140
            region: @audit-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @form-on-eba-demo-md-task-todos
            column: UPDATED_BY
            dataType: varchar2
        }
        readOnly {
            type: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
        help {
            helpText: No help available for this page item.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add To Do
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P15_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 1858850744275597576
        }
    )

    process fetch-row-from-eba-demo-md-task-todos (
        name: Fetch Row from EBA_DEMO_MD_TASK_TODOS
        type: formInitialization
        formRegion: @form-on-eba-demo-md-task-todos
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 4904842242184528140
        }
    )

    process process-row-of-eba-demo-md-task-todos (
        name: Process Row of EBA_DEMO_MD_TASK_TODOS
        type: formAutoRowProcessing
        formRegion: @form-on-eba-demo-md-task-todos
        target {
            returnPksAfterInsert: false
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Errorr!
        }
        advanced {
            executionMappingIdentifier: 4904842676100528140
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 4904843015158528141
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

