customAttribute attribute_01 (
    apexlangName: itemForLongitudeValue
    attribute: 1
    name: Item for Longitude value
    type: pageItem
    validation {
        required: true
    }
    appearance {
        sequence: 5
    }
    help {
        helpText: Specify Item to store the longitude value.
    }
)

