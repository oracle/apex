page 111 (
    name: Airports Map
    alias: AIRPORTS-MAP
    title: &APP_NAME. - Airports Map
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-this-page (
        name: About This Page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                This map visualizes US airports (with the "COMMERCIAL_OPS" column being NOT NULL) as 
                 a <em>Point Layer</em>. Each airport is visualized with a <em>Map Marker</em>. Clicking the map marker reveals come detail information about the airport. One map region shows usage of <em>Default Map Markers</em>, which are provided by APEX, the other one illustrates how to use <em>Custom Map Markers</em>, which are configured in <strong>Map Region</strong>, <strong>Attributes</strong>, <strong>Custom SVG Styles</strong>.</p>
                
                ```
        }
        layout {
            sequence: 10
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-popup-noOverlay
                js-popup-callout
                js-dialog-size480x320
            ]
        }
        advanced {
            htmlDomId: about_this_page
            customAttributes: data-parent-element="#help_button"
            regionDisplaySelector: true
        }
    )

    region custom-map-markers (
        name: Custom Map Markers
        type: map
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: custom-map-region
            regionDisplaySelector: true
        }
        map {
            background: builtIn
            standard: openstreetmapBright
            darkMode: openstreetmapBright
        }
        controls {
            options: [
                scaleBar
                infiniteMap
                rectangleZoom
            ]
        }
        initialPositionAndZoom {
            type: staticValues
            longitude: -90
            latitude: 35
            zoomLevel: 3
        }
        attributes {
            messagesPosition: below
        }
        componentAdvanced {
            customSvgStyles:
                ```
                [
                    {
                        "name": "Airport",
                        "width": 20,
                        "height": 20,
