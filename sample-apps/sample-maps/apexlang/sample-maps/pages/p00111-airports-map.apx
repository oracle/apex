                ```
        }

        layer large-airports (
            name: Large Airports
            layout {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ID,
                           IATA_CODE,
                           CITY,
                           initcap(AIRPORT_NAME) airport_name,
                           AIRPORT_TYPE,
                           STATE_NAME,
                           ELEVATION,
                           DIST_CITY_TO_AIRPORT,
                           LAND_AREA_COVERED,
                           to_char(ACTIVATION_DATE_DT,'fmDDfm-MON-YYYY') as ACTIVATION_DATE,
                           COMMERCIAL_OPS,
                           to_char(COMMERCIAL_OPS,'999G999G999G999') as com_ops_fmtd,
                           AIR_TAXI_OPS,
                           to_char(AIR_TAXI_OPS,'999G999G999G999') as air_ops_fmtd,
                           GEOMETRY
                      from EBA_SAMPLE_MAP_AIRPORTS
                     where COMMERCIAL_OPS > 100000
                       and airport_type = 'AIRPORT'
                    ```
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Airport
                shapeScale: 2
            }
            appearance {
                fillColor: #ea3324
                strokeColor: #ffffff
                strokeWidth: 2
            }
            tooltip {
                column: IATA_CODE
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <h3>&CITY. (&IATA_CODE.)</h3>
                    <p>
                    <strong>&STATE_NAME.</strong><br>
                    {if ACTIVATION_DATE/}
                    Activation Date: &ACTIVATION_DATE.<br>
                    {endif/}
                    {if COMMERCIAL_OPS/}
                    Commercial Operations: &COM_OPS_FMTD.<br>
                    {endif/}
                    {if AIR_TAXI_OPS/}
                    Taxi Operations: &AIR_OPS_FMTD.<br>
                    {endif/}
                    ```
            }
        )

        layer small-airports (
            name: Small Airports
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ID,
                           IATA_CODE,
                           initcap(AIRPORT_NAME) airport_name,
                           AIRPORT_TYPE,
                           case airport_type
                               when 'HELIPORT' then 'Heliport'
                               else                 'Small Airport' end as marker_type,
                           case airport_type
                               when 'HELIPORT' then '#1e77b5'
                               else                 '#392423' end as marker_color,
                           CITY,
                           STATE_NAME,
                           ELEVATION,
                           DIST_CITY_TO_AIRPORT,
                           LAND_AREA_COVERED,
                           to_char(ACTIVATION_DATE_DT,'fmDDfm-MON-YYYY') as ACTIVATION_DATE,
                           COMMERCIAL_OPS,
                           to_char(COMMERCIAL_OPS,'999G999G999G999') as com_ops_fmtd,
                           AIR_TAXI_OPS,
                           to_char(AIR_TAXI_OPS,'999G999G999G999') as air_ops_fmtd,
                           GEOMETRY
                      from EBA_SAMPLE_MAP_AIRPORTS
                     where COMMERCIAL_OPS between 0 and 100000
                    
                    ```
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: &MARKER_TYPE.
            }
            appearance {
                fillColor: &MARKER_COLOR.
                fillOpacity: .8
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &AIRPORT_NAME. (&IATA_CODE.)
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <strong>&AIRPORT_NAME. (&IATA_CODE.)</strong><br>
                    &CITY., &STATE_NAME.
                    ```
            }
        )

    )

    dynamicAction on-click-point (
        name: On Click Point
        execution {
            sequence: 10
        }
        when {
            event: region/map/spatialmapobjectclick
            selectionType: region
            region: @custom-map-markers
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const { lng, lat } = this.data;
                    
                    apex.region("custom-map-region").call( "getMapObject" ).flyTo({ 
                        center: [ lng, lat ],
                        screenSpeed: 0.8
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

