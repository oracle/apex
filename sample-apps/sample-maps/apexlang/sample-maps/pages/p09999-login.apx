page 9999 (
    name: Login Page
    alias: LOGIN
    title: &APP_NAME. - Sign In
    appearance {
        pageTemplate: @/login
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authentication: public
        pageAccessProtection: noArgumentsSupported
        formAutoComplete: false
    }

    region language-selector (
        name: Language Selector
        type: plSqlDynamicContent
        source {
            plsqlCode: apex_lang.emit_language_selector_list;
        }
        layout {
            sequence: 20
            parentRegion: @sample-maps
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region sample-maps (
        name: Sample Maps
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/login
            templateOptions: #DEFAULT#
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
        settings {
            outputAs: text
        }
    )

    pageItem P9999_PASSWORD (
        type: password
        label {
            label: Password
            alignment: right
        }
        layout {
            sequence: 20
            region: @sample-maps
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-key
            width: 40
            valuePlaceholder: Password
        }
        validation {
            maxLength: 100
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P9999_REMEMBER (
        type: checkboxGroup
        label {
            label: Remember username
            alignment: right
        }
        lov {
            type: sharedComponent
            lov: @login-remember-username
            displayExtraValues: false
        }
        layout {
            sequence: 30
            region: @sample-maps
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        sessionState {
            storage: request
        }
        serverSideCondition {
            type: expression
            plsqlExpression: apex_authentication.persistent_cookies_enabled
        }
        security {
            encryptSessionState: false
        }
        help {
            helpText:
                ```html
                <p>
                If you select this checkbox, the application will save your username in a persistent browser cookie named "LOGIN_USERNAME_COOKIE".
                When you go to the login page the next time,
                the username field will be automatically populated with this value.
                </p>
                <p>
                If you deselect this checkbox and your username is already saved in the cookie,
                the application will overwrite it with an empty value.
                You can also use your browser's developer tools to completely remove the cookie.
                </p>
                ```
        }
    )

    pageItem P9999_USERNAME (
        type: textField
        label {
            label: Username
            alignment: right
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 10
            region: @sample-maps
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-user
            width: 40
            valuePlaceholder: Username
        }
        validation {
            maxLength: 100
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    button login (
        buttonName: LOGIN
        label: Sign In
        layout {
            sequence: 40
            region: @sample-maps
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process clear-page-s-cache (
        name: Clear Page(s) Cache
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 1548472901853069786
        }
    )

    process get-username-cookie (
        name: Get Username Cookie
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                :P9999_USERNAME := apex_authentication.get_login_username_cookie;
                :P9999_REMEMBER := case when :P9999_USERNAME is not null then 'Y' end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 1548472491264069785
        }
    )

    process login (
        name: Login
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                apex_authentication.login(
                    p_username => :P9999_USERNAME,
                    p_password => :P9999_PASSWORD );
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 1548471706739069781
        }
    )

    process set-username-cookie (
        name: Set Username Cookie
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                apex_authentication.send_login_username_cookie (
                    p_username => lower(:P9999_USERNAME),
                    p_consent  => :P9999_REMEMBER = 'Y' );
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 1548472172671069784
        }
    )

)

