    dynamicAction click-on-map (
        name: Click on Map
        execution {
            sequence: 30
        }
        when {
            event: region/map/spatialmapclick
            selectionType: region
            region: @map
        }

        action native-set-value (
            action: setValue
            settings {
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P124_SEARCH_FROM
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-set-value-2 (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: "JSON.stringify({\"type\":\"Point\", \"coordinates\": [this.data.lng, this.data.lat]})"
            }
            affectedElements {
                selectionType: items
                items: P124_CLICK_POSITION
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-after-change (
        name: Refresh after Change
        execution {
            sequence: 40
        }
        when {
            selectionType: items
            items: [
                P124_AIRPORT_TYPE
                P124_COMMERCIAL_OPS_MIN
                P124_NEIGHBOR_COUNT
                P124_MAX_DISTANCE
                P124_CLICK_POSITION
            ]
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @map
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @airports
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-airports-irr-if-neighbors-legend-is-toggled (
        name: Refresh Airports IRR if neighbors legend is toggled
        execution {
            sequence: 50
        }
        when {
            event: region/map/spatialmapchanged
            selectionType: region
            region: @map
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.changeType === "toggle-layer"
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    -- This true action just ensures the hidden P124_NEIGHBORS value gets into session state
                    -- before refreshing the Airports IRR
                    null;
                    ```
                itemsToSubmit: P124_NEIGHBORS
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // the "map-changed" event sends the type of change as the "changeType" attribute. "toggle-layer" indicates
                    // that the layer visibility has been toggled by clicking the layer entry in the legend.
                    // "copy" the layer visibility information from the dynamic action "payload" object to the
                    // P124_NEIGHBORS page item, which are then picked up by the
                    // report query.
                    for ( l = 0; l < this.data.layers.length; l++) {
                        if ( this.data.layers[ l ].name === "Neighbors" ) {
                            apex.item( "P124_NEIGHBORS" ).setValue( ( this.data.layers[ l ].visible ? 'Y' : 'N' ) );
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @airports
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

)

