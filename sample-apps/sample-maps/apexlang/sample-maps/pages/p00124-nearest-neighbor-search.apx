page 124 (
    name: Nearest Neighbor Search
    alias: NEAREST-NEIGHBOR-SEARCH
    title: &APP_NAME. - Nearest Neighbor Search
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            function showFeature( pId ) {
                var lMapRegion   = apex.region("airport-map-region"),
                    // important: Use the layer name exactly as specified in the "name" attribute in Page Designer
                    lLayerId     = lMapRegion.call("getLayerIdByName", "Neighbors"),
                    lFeature     = lMapRegion.call("getFeature", lLayerId, pId );
            
                if ( lFeature.geometry ) {
                    lMapRegion.call( "closeAllInfoWindows" );
                    lMapRegion.call( "displayPopup", "infoWindow", lLayerId, pId.toString(), false );
                }
            }
            ```
        executeWhenPageLoads:
            ```javascript-browser
            
            
            
            ```
    }
    css {
        inline:
            ```css
            .popup-left {
                transform: translate(0, -10%) !important;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-this-page (
        name: About This Page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This page demonstrates a <em>Nearest Neighbor Search</em>. After the user clicked a position on the map and adjusted the filter settings, the application looks up <em>nearest neighbors</em> to the clicked position and shows them on the map as well as in the interactive report below the map.</p>
                <p>This functionality is built on top of the <strong>SDO_NN</strong> Spatial SQL function, which walks through the spatial index and returns nearest neighbors based on the given position. Additional relational filters are respected, so that the returned neighbors are typically farther away as the filter selectivity increases.</p>
                ```
        }
        layout {
            sequence: 10
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-popup-noOverlay
                js-popup-callout
                js-dialog-size480x320
            ]
        }
        advanced {
            htmlDomId: about_this_page
            customAttributes: data-parent-element="#help_button"
            regionDisplaySelector: true
        }
    )

    region airports (
        name: Airports
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       iata_code,
                       initcap( city ) as city,
                       initcap( airport_name ) as airport_name,
                       initcap( airport_type ) as airport_type,
                       state_name,
                       elevation,
                       dist_city_to_airport,
                       land_area_covered,
                       activation_date_dt as activation_date,
                       commercial_ops,
                       air_taxi_ops,
                       geometry,
                       sdo_nn_distance( 1 ) as distance
                  from eba_sample_map_airports
                 where sdo_nn( geometry, mdsys.sdo_util.from_geojson (:P124_CLICK_POSITION ), case when :P124_MAX_DISTANCE is not null then 'distance=' || :P124_MAX_DISTANCE || ' ' end || 'unit=km',   1 ) = 'TRUE'
                   and airport_type = :P124_AIRPORT_TYPE
                   and nvl( commercial_ops, 0 ) >= nvl( :P124_COMMERCIAL_OPS_MIN, 0)
                   and :P124_CLICK_POSITION is not null and :P124_AIRPORT_TYPE is not null
                   and 'Y' = nvl(:P124_NEIGHBORS,'Y')
                   and rownum <=   :P124_NEIGHBOR_COUNT
                ```
            pageItemsToSubmit: [
                P124_AIRPORT_TYPE
                P124_CLICK_POSITION
                P124_COMMERCIAL_OPS_MIN
                P124_NEIGHBOR_COUNT
                P124_MAX_DISTANCE
            ]
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: style="height: 640px"
            regionDisplaySelector: true
        }
        link {
            linkColumn: customTarget
            target: {
                type: url
                url: javascript:showFeature('#ID#')
            }
            linkIcon: <center><span class="t-Icon fa fa-lg fa-map-marker-s u-danger-text" aria-hidden="true"></span></center>
        }
        pagination {
            type: rowRangesXToYOfZ
        }
        messages {
            whenNoDataFound: No nearest neighbors found. Click a position on the map to begin.
        }
