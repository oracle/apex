        layer clicked-position (
            name: Clicked Position
            label {
                label: my Position
            }
            layout {
                sequence: 50
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 0 as id, mdsys.sdo_util.from_geojson( :P124_CLICK_POSITION ) as geometry 
                      from sys.dual
                     where :P124_CLICK_POSITION is not null
                    ```
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Pin Circle
                shapeScale: 2
            }
            appearance {
                fillColor: #007aff
                strokeColor: #ffffff
                strokeWidth: 1
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: This is the position you have clicked on the map.
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression: Your Position
            }
        )

        layer distance-circle (
            name: Distance Circle
            layerType: polygons
            layout {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 0 as id,
                           mdsys.sdo_util.circle_polygon(
                            point         => mdsys.sdo_util.from_geojson( :P124_CLICK_POSITION ),
                            radius        => :P124_MAX_DISTANCE * 1000,
                            arc_tolerance => 1 ) as geometry
                      from sys.dual
                     where :P124_MAX_DISTANCE is not null and :P124_CLICK_POSITION is not null  
                    ```
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            appearance {
                fillColor: #d8aa12
                fillOpacity: .2
                strokeColor: #101010
            }
        )

        layer large-airports (
            name: Large Airports
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ID,
                           IATA_CODE,
                           CITY,
                           STATE_NAME,
                           AIRPORT_NAME,
                           AIRPORT_TYPE,
                           ELEVATION,
                           DIST_CITY_TO_AIRPORT,
                           LAND_AREA_COVERED,
                           ACTIVATION_DATE,
                           COMMERCIAL_OPS,
                           AIR_TAXI_OPS,
                           GEOMETRY
                      from EBA_SAMPLE_MAP_AIRPORTS
                     where COMMERCIAL_OPS > 100000
                    ```
                pageItemsToSubmit: P121_ID
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Airport
                shapeScale: 2
            }
            appearance {
                fillColor: #363434
                fillOpacity: .2
                strokeColor: #000000
                strokeWidth: .4
            }
            tooltip {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <p><strong>&AIRPORT_NAME. (&IATA_CODE.)</strong><br>
                    &CITY., &STATE_NAME.</p>
                    ```
            }
        )

        layer neighbors (
            name: Neighbors
            layout {
                sequence: 40
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select id,
                           IATA_CODE,
                           CITY,
                           STATE_NAME,
                           AIRPORT_NAME,
                           AIRPORT_TYPE,
                           ELEVATION,
                           DIST_CITY_TO_AIRPORT,
                           LAND_AREA_COVERED,
                           ACTIVATION_DATE,
                           COMMERCIAL_OPS,
                           AIR_TAXI_OPS,
                           GEOMETRY,
                           case 
                               when sdo_nn_distance(1) < 50                 then '#e06060'
                               when sdo_nn_distance(1) between 50  and 100  then '#c05050'
                               when sdo_nn_distance(1) between 100 and 200  then '#a04040'
                               when sdo_nn_distance(1) between 200 and 500  then '#803030'
                               when sdo_nn_distance(1) between 500 and 1000 then '#601010'
                               else                                              '#200000'
                           end as color
                      from EBA_SAMPLE_MAP_AIRPORTS
                     where sdo_nn( geometry, mdsys.sdo_util.from_geojson (:P124_CLICK_POSITION ), case when :P124_MAX_DISTANCE is not null then 'distance=' || :P124_MAX_DISTANCE || ' ' end || 'unit=km', 1 ) = 'TRUE'
                       and airport_type = :P124_AIRPORT_TYPE
                       and nvl(commercial_ops,0) >= nvl( :P124_COMMERCIAL_OPS_MIN, 0)
                       and :P124_CLICK_POSITION is not null and :P124_AIRPORT_TYPE is not null 
                       and rownum <=   :P124_NEIGHBOR_COUNT
                    ```
                pageItemsToSubmit: [
                    P124_COMMERCIAL_OPS_MIN
                    P124_NEIGHBOR_COUNT
                    P124_CLICK_POSITION
                    P124_AIRPORT_TYPE
                    P124_MAX_DISTANCE
                ]
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Circle
                shapeScale: 1.5
            }
            appearance {
                fillColor: &COLOR.
                strokeColor: #ffffff
                strokeWidth: 2
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &AIRPORT_NAME. (&IATA_CODE.)
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <h3>&AIRPORT_NAME. (&IATA_CODE.)</h3>
                    <p>&AIRPORT_TYPE.<br>
                    <strong>&CITY., &STATE_NAME.</strong><br>
                    {if ACTIVATION_DATE/}
                    Activation Date: &ACTIVATION_DATE.<br>
                    {endif/}
                    {if COMMERCIAL_OPS/}
                    Commercial Operations: &COMMERCIAL_OPS.<br>
                    {endif/}
                    {if AIR_TAXI_OPS/}
                    Taxi Operations: &AIR_TAXI_OPS.<br>
                    {endif/}
                    ```
            }
        )

    )

