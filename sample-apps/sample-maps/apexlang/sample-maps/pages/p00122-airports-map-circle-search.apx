        layer search-circle (
            name: Search Circle
            layerType: polygons
            layout {
                sequence: 20
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select 0 as id,
                           mdsys.sdo_util.from_geojson( to_clob( :P122_CIRCLE_GEOJSON )) as geometry
                      from sys.dual
                     where :P122_CIRCLE_GEOJSON is not null
                    ```
                pageItemsToSubmit: P122_CIRCLE_GEOJSON
            }
            columnMapping {
                geometryColumn: GEOMETRY
            }
            appearance {
                fillColor: #d8aa12
                fillOpacity: .2
                strokeColor: #101010
            }
        )

