        layer large-airports (
            name: Large Airports
            layout {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ID,
                           IATA_CODE,
                           CITY,
                           AIRPORT_NAME,
                           AIRPORT_TYPE,
                           STATE_NAME,
                           ELEVATION,
                           DIST_CITY_TO_AIRPORT,
                           LAND_AREA_COVERED,
                           to_char(ACTIVATION_DATE_DT,'fmDDfm-MON-YYYY') as ACTIVATION_DATE,
                           COMMERCIAL_OPS,
                           to_char(COMMERCIAL_OPS,'999G999G999G999') as com_ops_fmtd,
                           AIR_TAXI_OPS,
                           to_char(AIR_TAXI_OPS,'999G999G999G999') as air_ops_fmtd,
                           GEOMETRY,
                           2 as scale
                      from EBA_SAMPLE_MAP_AIRPORTS
                     where COMMERCIAL_OPS > 100000
                    ```
                pageItemsToSubmit: P122_CIRCLE_GEOJSON
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Airport
                shapeScale: 2
            }
            appearance {
                fillColor: #ff0000
                strokeColor: #ffffff
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: <strong>&AIRPORT_NAME. (&IATA_CODE.)</strong>
