    dynamicAction circle-finished (
        name: Circle Finished
        execution {
            sequence: 10
            eventScope: dynamic
        }
        when {
            event: region/map/spatialmapchanged
            selectionType: region
            region: @us-airports
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.changeType === "circle-drawn"
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    apex.region( "airport-map-region" ).call ( "clearCircle" );
                    
                    ```
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @selected-airports
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @us-airports
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: ( this.data.circle ? JSON.stringify( this.data.circle.data.geometry ) : "" )
            }
            affectedElements {
                selectionType: items
                items: P122_CIRCLE_GEOJSON
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction on-click-point (
        name: On Click Point
        execution {
            sequence: 30
        }
        when {
            event: region/map/spatialmapobjectclick
            selectionType: region
            region: @us-airports
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const { lng, lat } = this.data;
                    
                    apex.region("airport-map-region").call( "getMapObject" ).flyTo({ 
                        center: [ lng, lat ],
                        screenSpeed: 0.8
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-selected-airports-classic-report (
        name: Refresh Selected Airports Classic Report
        execution {
            sequence: 20
        }
        when {
            event: region/map/spatialmapchanged
            selectionType: region
            region: @us-airports
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.changeType === "toggle-layer"
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // the "map-changed" event sends the type of change as the "changeType" attribute. "toggle-layer" indicates
                    // that the layer visibility has been toggled by clicking the layer entry in the legend.
                    // so "copy" the layer visibility information from the dynamic action "payload" object to the
                    // P122_LARGE_VISIBLE and P122_SMALL_VISIBLE page items, which are then picked up by the
                    // report query.
                    for ( l = 0; l < this.data.layers.length; l++) {
                        if ( this.data.layers[ l ].name === "Small Airports" ) {
                            apex.item( "P122_SMALL_VISIBLE" ).setValue( ( this.data.layers[ l ].visible ? 'Y' : 'N' ) );
                        } else if ( this.data.layers[ l ].name === "Large Airports" ) {
                            apex.item( "P122_LARGE_VISIBLE" ).setValue( ( this.data.layers[ l ].visible ? 'Y' : 'N' ) );
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @selected-airports
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

