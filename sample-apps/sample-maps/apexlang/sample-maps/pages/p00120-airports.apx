                                "fill":"#ffffff",
                                "stroke": "none"
                            },
                            {
                                "type":"path",
                                "d": "M13.076,9a.2.2,0,0,1-.2-.2V7.2a.2.2,0,1,1,.4,0V8.8A.2.2,0,0,1,13.076,9Z",
                                "fill":"#ffffff",
                                "stroke": "none"
                            }
                        ]
                    }
                ]
                ```
        }

        layer all-airports (
            name: All Airports
            layerType: heatMap
            label {
                label: Airport Density
            }
            layout {
                sequence: 10
            }
            source {
                location: regionSource
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            appearance {
                colorScheme: sequential
                schemeName: sunset
            }
            zoomLevels {
                max: 4
            }
            serverSideCondition {
                type: never
            }
        )

        layer larger-airports (
            name: Larger Airports
            layout {
                sequence: 30
            }
            source {
                location: regionSource
            }
            rowAssignment {
                column: TINY_AIRPORT
                valueForThisLayer: N
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Airport
                shapeScale: &MARKER_SIZE.
            }
            appearance {
                fillColor: #ff0000
                strokeColor: #ffffff
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: <strong>&AIRPORT_NAME. (&IATA_CODE.)</strong>
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <h3>&AIRPORT_NAME. (&IATA_CODE.)</h3>
                    <p><strong>&CITY., &STATE_NAME.</strong><br>
                    {if ACTIVATION_DATE/}
                    Activation Date: &ACTIVATION_DATE.<br>
                    {endif/}
                    {if COMMERCIAL_OPS/}
                    Commercial Operations: &COM_OPS_FMTD.<br>
                    {endif/}
                    {if AIR_TAXI_OPS/}
                    Taxi Operations: &AIR_OPS_FMTD.<br>
                    {endif/}
                    ```
            }
        )

        layer smaller-airports (
            name: Smaller Airports
            layout {
                sequence: 20
            }
            source {
                location: regionSource
            }
            rowAssignment {
                column: TINY_AIRPORT
                valueForThisLayer: Y
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: Flag Pennant
                shapeScale: 0.9
            }
            appearance {
                fillColor: #392423
                fillOpacity: .8
                strokeColor: #ffffff
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &AIRPORT_NAME. (&IATA_CODE.)
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <h3>&AIRPORT_NAME. (&IATA_CODE.)</h3>
                    <p><strong>&CITY., &STATE_NAME.</strong><br>
                    {if ACTIVATION_DATE/}
                    Activation Date: &ACTIVATION_DATE.<br>
                    {endif/}
                    {if COMMERCIAL_OPS/}
                    Commercial Operations: &COM_OPS_FMTD.<br>
                    {endif/}
                    {if AIR_TAXI_OPS/}
                    Taxi Operations: &AIR_OPS_FMTD.<br>
                    {endif/}
                    ```
            }
        )

    )

    region facets (
        name: Facets
        type: staticContent
        source {
            htmlCode: <div id="current-facets"></div>
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @airports-map
        }
        layout {
            sequence: 10
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #current-facets
            showTotalRowCount: true
            totalRowCountLabel: Airport Count:
            displayChartForTopNValues: 10
        }

        facet P120_ACTIVATION_DATE (
            type: range
            label {
                label: Opened
            }
            settings {
                selectMultiple: true
            }
            lov {
                type: staticValues
                staticValues: STATIC2:before 1950;|19500101000000,1950 - 1970;19500101000000|19700101000000,1970 - 1990;19700101000000|19900101000000,1990 - 2005;19900101000000|20050101000000,since 2005;20050101000000|
            }
            layout {
                sequence: 30
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 100
            }
            source {
                databaseColumn: ACTIVATION_DATE
                dataType: date
            }
        )

        facet P120_AIRPORT_TYPE (
            type: checkboxGroup
            label {
                label: Airport Type
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            actionsMenu {
                filter: false
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: AIRPORT_TYPE
            }
        )

        facet P120_COMMERCIAL_OPS (
            type: range
            label {
                label: Operations
            }
            settings {
                selectMultiple: true
            }
            lov {
                type: staticValues
                staticValues: STATIC2:none;|1,less than 1000;1|1000,1000 to 10K;1000|10000,10K to 100K;10000|100000,more than 100K;100000|
            }
            layout {
                sequence: 50
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 100
            }
            source {
                databaseColumn: COMMERCIAL_OPS
                dataType: number
            }
        )

        facet P120_STATE (
            type: checkboxGroup
            label {
                label: State
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                sortByTopCounts: false
                showSelectedFirst: true
                maxDisplayedEntries: 5
                displayFilterInitially: true
            }
            actionsMenu {
                filter: false
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: STATE_NAME
            }
        )

    )

    dynamicAction on-click-point (
        name: On Click Point
        execution {
            sequence: 10
        }
        when {
            event: region/map/spatialmapobjectclick
            selectionType: region
            region: @airports-map
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    const { lng, lat } = this.data;
                    
                    apex.region("airport-map-region").call( "getMapObject" ).flyTo({ 
                        center: [ lng, lat ],
                        screenSpeed: 0.8
                    });
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

