    region map (
        name: Map
        type: map
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       IATA_CODE,
                       CITY,
                       STATE_NAME,
                       AIRPORT_NAME,
                       AIRPORT_TYPE,
                       ELEVATION,
                       DIST_CITY_TO_AIRPORT,
                       LAND_AREA_COVERED,
                       to_char(ACTIVATION_DATE_DT,'fmDDfm-MON-YYYY') as ACTIVATION_DATE,
                       COMMERCIAL_OPS,
                       to_char(COMMERCIAL_OPS,'999G999G999G999') as com_ops_fmtd,
                       AIR_TAXI_OPS,
                       to_char(AIR_TAXI_OPS,'999G999G999G999') as air_ops_fmtd,
                       GEOMETRY,
                       case when commercial_ops > 100000 then 'Airport' else 'Flag Pennant' end as shape,
                       case when commercial_ops > 100000 then 'red' else 'gray' end as color,
                       case when commercial_ops > 100000 then 'fa-map-marker-s' else 'fa-flag-pennant' end as icon,
                       case when commercial_ops > 100000 then 2 else 1 end as scale
                  from EBA_SAMPLE_MAP_AIRPORTS
                 where COMMERCIAL_OPS > 1000
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: airport-map-region
            regionDisplaySelector: true
        }
        controls {
            options: [
                scaleBar
                infiniteMap
                rectangleZoom
            ]
        }
        initialPositionAndZoom {
            type: staticValues
            longitude: -110
            latitude: 35
            zoomLevel: 4
        }
        boundingBox {
            currentBoundsItem: P123_BBOX
        }
        attributes {
            messagesPosition: below
        }

        layer large-airports (
            name: Large Airports
            layout {
                sequence: 20
            }
            source {
                location: regionSource
            }
            rowAssignment {
                column: SCALE
                valueForThisLayer: 2
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: &SHAPE.
                shapeScale: &SCALE.
            }
            appearance {
                fillColor: &COLOR.
                fillOpacity: .8
                strokeColor: #ffffff
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: <strong>&AIRPORT_NAME. (&IATA_CODE.)</strong>
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <h3>&AIRPORT_NAME. (&IATA_CODE.)</h3>
                    <p>&AIRPORT_TYPE.<br>
                    <strong>&CITY., &STATE_NAME.</strong><br>
                    {if ACTIVATION_DATE/}
                    Activation Date: &ACTIVATION_DATE.<br>
                    {endif/}
                    {if COMMERCIAL_OPS/}
                    Commercial Operations: &COM_OPS_FMTD.<br>
                    {endif/}
                    {if AIR_TAXI_OPS/}
                    Taxi Operations: &AIR_OPS_FMTD.<br>
                    {endif/}
                    ```
            }
            legend {
                iconCssClasses: fa-map-marker-s
            }
        )

        layer small-airports (
            name: Small Airports
            layout {
                sequence: 10
            }
            source {
                location: regionSource
            }
            rowAssignment {
                column: SCALE
                valueForThisLayer: 1
            }
            columnMapping {
                geometryColumn: GEOMETRY
                primaryKeyColumn: ID
            }
            pointObjects {
                shape: &SHAPE.
                shapeScale: &SCALE.
            }
            appearance {
                fillColor: &COLOR.
                fillOpacity: .8
                strokeColor: #ffffff
            }
            tooltip {
                advancedFormatting: true
                htmlExpression: &AIRPORT_NAME. (&IATA_CODE.)
            }
            infoWindow {
                advancedFormatting: true
                htmlExpression:
                    ```html
                    <strong>&AIRPORT_NAME. (&IATA_CODE.)</strong><br>
                    &CITY., &STATE_NAME.
                    ```
            }
            legend {
                iconCssClasses: fa-flag-pennant
            }
        )

    )

