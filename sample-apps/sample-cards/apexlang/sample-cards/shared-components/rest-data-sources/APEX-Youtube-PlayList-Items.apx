restDataSource APEX_Youtube_PlayList_Items (
    name: APEX YouTube Play List Items
    source {
        type: http
        remoteServer: @www_googleapis_com_youtube_v3
        urlPathPrefix: playlistItems
    }
    authentication {
        credentials: @google_api_key
    }
    advanced {
        passEcid: Y
    }

    operation get (
        label: GET
        operation {
            urlPattern: .
            httpMethod: get
            databaseOperation: fetchRows
        }
        remoteCache {
            caching: allUsers
            timeout: 10080
        }
    )

    parameter maxresults (
        name: maxResults
        parameter {
            type: urlQueryString
        }
        value {
            defaultValueType: staticValue
            staticValue: 25
        }
    )

    parameter part (
        name: part
        parameter {
            type: urlQueryString
        }
        value {
            defaultValueType: staticValue
            staticValue: snippet,contentDetails
        }
    )

    parameter playlistid (
        name: playlistId
        parameter {
            type: urlQueryString
        }
        value {
            defaultValueType: staticValue
            staticValue: PLUo-NIMouZ_vsHnHudl3W0JfeB-3F4J8_
        }
    )

    dataProfile {
        name: APEX Youtube Play List Item
        rowSelector: items
    }

    dataProfileColumn channelid (
        columnName: CHANNELID
        source {
            sequence: 6
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.channelId
        }
    )

    dataProfileColumn description (
        columnName: DESCRIPTION
        source {
            sequence: 25
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.description
        }
    )

    dataProfileColumn etag (
        columnName: ETAG
        source {
            sequence: 2
            dataType: varchar2
        }
        parsing {
            pathExpression: etag
        }
    )

    dataProfileColumn height (
        columnName: HEIGHT
        source {
            sequence: 12
            dataType: number
        }
        parsing {
            pathExpression: snippet.thumbnails.high.height
        }
    )

    dataProfileColumn id (
        columnName: ID
        source {
            sequence: 1
            dataType: varchar2
        }
        parsing {
            pathExpression: id
        }
    )

    dataProfileColumn kind (
        columnName: KIND
        source {
            sequence: 3
            dataType: varchar2
        }
        parsing {
            pathExpression: kind
        }
    )

    dataProfileColumn playlistid (
        columnName: PLAYLISTID
        source {
            sequence: 7
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.playlistId
        }
    )

    dataProfileColumn publishedat (
        columnName: PUBLISHEDAT
        source {
            sequence: 26
            dataType: timestampWithTimeZone
        }
        parsing {
            pathExpression: snippet.publishedAt
            formatMask: YYYY"-"MM"-"DD"T"HH24":"MI:SSTZR
        }
    )

    dataProfileColumn title (
        columnName: TITLE
        source {
            sequence: 4
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.title
        }
    )

    dataProfileColumn url (
        columnName: URL
        source {
            sequence: 10
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.thumbnails.high.url
        }
    )

    dataProfileColumn videoid (
        columnName: VIDEOID
        source {
            sequence: 9
            dataType: varchar2
        }
        parsing {
            pathExpression: snippet.resourceId.videoId
        }
    )

    dataProfileColumn videopublishedat (
        columnName: VIDEOPUBLISHEDAT
        source {
            sequence: 29
            dataType: timestampWithTimeZone
        }
        parsing {
            pathExpression: contentDetails.videoPublishedAt
            formatMask: YYYY"-"MM"-"DD"T"HH24":"MI:SSTZR
        }
    )

    dataProfileColumn width (
        columnName: WIDTH
        source {
            sequence: 11
            dataType: number
        }
        parsing {
            pathExpression: snippet.thumbnails.high.width
        }
    )

)

