restDataSource Movie_Database (
    name: Movie Database
    source {
        type: http
        remoteServer: @api_themoviedb_org_3_list
        urlPathPrefix: /10
    }
    authentication {
        credentials: @Moviedb_API_Key
    }
    advanced {
        passEcid: Y
    }

    operation get (
        label: GET
        operation {
            urlPattern: .
            httpMethod: get
            databaseOperation: fetchRows
        }
        remoteCache {
            caching: allUsers
            timeout: 3600
        }
    )

    parameter language (
        name: language
        parameter {
            type: urlQueryString
        }
        value {
            defaultValueType: staticValue
            staticValue: en-US
        }
    )

    dataProfile {
        name: Movie Database
        rowSelector: items
    }

    dataProfileColumn adult (
        columnName: ADULT
        source {
            sequence: 2
            dataType: varchar2
        }
        parsing {
            pathExpression: adult
        }
    )

    dataProfileColumn backdrop-path (
        columnName: BACKDROP_PATH
        source {
            sequence: 12
            dataType: varchar2
        }
        parsing {
            pathExpression: backdrop_path
        }
    )

    dataProfileColumn id (
        columnName: ID
        source {
            sequence: 1
            dataType: number
            primaryKey: true
        }
        parsing {
            pathExpression: id
        }
    )

    dataProfileColumn media-type (
        columnName: MEDIA_TYPE
        source {
            sequence: 6
            dataType: varchar2
        }
        parsing {
            pathExpression: media_type
        }
    )

    dataProfileColumn original-language (
        columnName: ORIGINAL_LANGUAGE
        source {
            sequence: 14
            dataType: varchar2
        }
        parsing {
            pathExpression: original_language
        }
    )

    dataProfileColumn original-title (
        columnName: ORIGINAL_TITLE
        source {
            sequence: 13
            dataType: varchar2
        }
        parsing {
            pathExpression: original_title
        }
    )

    dataProfileColumn overview (
        columnName: OVERVIEW
        source {
            sequence: 5
            dataType: varchar2
        }
        parsing {
            pathExpression: overview
        }
    )

    dataProfileColumn popularity (
        columnName: POPULARITY
        source {
            sequence: 7
            dataType: number
        }
        parsing {
            pathExpression: popularity
        }
    )

    dataProfileColumn poster-path (
        columnName: POSTER_PATH
        source {
            sequence: 9
            dataType: varchar2
        }
        parsing {
            pathExpression: poster_path
        }
    )

    dataProfileColumn release-date (
        columnName: RELEASE_DATE
        source {
            sequence: 10
            dataType: date
        }
        parsing {
            pathExpression: release_date
            formatMask: YYYY"-"MM"-"DD
            hasTimeZone: false
        }
    )

    dataProfileColumn title (
        columnName: TITLE
        source {
            sequence: 3
            dataType: varchar2
        }
        parsing {
            pathExpression: title
        }
    )

    dataProfileColumn video (
        columnName: VIDEO
        source {
            sequence: 4
            dataType: varchar2
        }
        parsing {
            pathExpression: video
        }
    )

    dataProfileColumn vote-average (
        columnName: VOTE_AVERAGE
        source {
            sequence: 11
            dataType: number
        }
        parsing {
            pathExpression: vote_average
        }
    )

    dataProfileColumn vote-count (
        columnName: VOTE_COUNT
        source {
            sequence: 8
            dataType: number
        }
        parsing {
            pathExpression: vote_count
        }
    )

)

