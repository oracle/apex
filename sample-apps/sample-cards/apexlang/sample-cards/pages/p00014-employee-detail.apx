page 14 (
    name: Employee Detail
    alias: EMPLOYEE-DETAIL
    title: Employee Detail
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region employee-detail (
        name: Employee Detail
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_CARD_EMP
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        editAuthorization {
            add: mustNotBePublicUser
            update: mustNotBePublicUser
            delete: mustNotBePublicUser
        }
    )

    pageItem P14_COMM (
        type: numberField
        label {
            label: Comm
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @employee-detail
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @employee-detail
            column: COMM
            dataType: number
        }
        readOnly {
            type: always
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P14_DEPTNO (
        type: selectList
        label {
            label: Deptno
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @dept-dname
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 80
            region: @employee-detail
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            formRegion: @employee-detail
            column: DEPTNO
            dataType: number
        }
        readOnly {
            type: always
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P14_EMPNO (
        type: hidden
        layout {
            sequence: 10
            region: @employee-detail
            slot: regionBody
        }
        source {
            formRegion: @employee-detail
            column: EMPNO
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

