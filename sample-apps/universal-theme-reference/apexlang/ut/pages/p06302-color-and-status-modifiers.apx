            }
            columnFormatting {
                htmlExpression: <span class="color-border u-color-29-border u-flex u-margin-block-#SHADOW_SIZE# u-justify-content-center u-padding-lg u-shadow-#SHADOW_SIZE#">u-shadow-#SHADOW_SIZE#</span>
            }
            sorting {
                sortable: false
            }
        )

    )

