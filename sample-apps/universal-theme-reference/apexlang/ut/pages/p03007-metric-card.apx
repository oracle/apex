page 3007 (
    name: Components: Metric Card
    alias: METRIC-CARD
    title: Metric Card
    pageGroup: @components
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .class, .class-value, .class-desc {
              display: inline-block;
              font-size: 12px;
              font-family: 'Menlo', 'Consolas', monospace;
            }
            .class {
              color: #9C27B0;
            }
            ```
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region MetricCardDemo (
        name: Instructions
        type: plugin/componentInstructions
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
                t-ContentBlock--shadowBG
            ]
        }
        advanced {
            htmlDomId: METRIC_CARD
            regionDisplaySelector: true
        }
        settings {
            staticId: MetricCardDemo
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region configuration (
        name: Configuration
        type: staticContent
        source {
            htmlCode:
                ```html
                <h4>Region</h4>
                <b>Type</b>: Metric Card<br>
                <br>
                <h4>Settings</h4>
                Utilizes Title, Metric and Meta with the 3 Column Layout. Metric CSS Classes set with <span class="class">u-bold</span> utility class.<br>
                <br>
                <h4>Avatar</h4>
                <b>Type</b>: Icon<br>
                <b>Position</b>: Inline<br>
                <br>
                <h4>Badge</h4>
                Utilizes State and Icon with the Subtle Style set.<br>
                ```
        }
        layout {
            sequence: 30
            parentRegion: @inline-avatar-and-3-column-layout
            slot: subRegions
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
                margin-bottom-lg
            ]
        }
    )

