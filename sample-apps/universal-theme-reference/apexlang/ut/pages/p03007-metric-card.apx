    region default-layout (
        name: Default Layout with Avatar and Badge
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @demo
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
    )

    region demo (
        name: Demo
        title: Demo
        type: staticContent
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region inline-avatar-and-3-column-layout (
        name: Inline Avatar and 3 Column Layout
        type: staticContent
        layout {
            sequence: 70
            parentRegion: @demo
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
    )

    region new (
        name: Metric Card
        title: Demo
        type: themeTemplateComponent/metricCard
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT                                                         
                      company_name,                                                         
                      ticker,
                      '$' || TO_CHAR(current_price, 'FM999,990.00')       AS     
                  stock_price,          
                      TO_CHAR(ABS(pct_change), 'FM990.00') || '%'         AS
                  stock_change,
                      CASE
                          WHEN pct_change > 0  THEN 'success'
                          WHEN pct_change < 0  THEN 'danger'
                      END                                                  AS
                  state,
                      CASE
                          WHEN pct_change > 0  THEN 'fa-arrow-up'
                          WHEN pct_change < 0  THEN 'fa-arrow-down'
                      END                                                  AS
                  icon_class
                  FROM (
                      SELECT 'Apple'     AS company_name, 'AAPL'  AS ticker,
                  189.45 AS current_price,  2.34 AS pct_change FROM dual UNION
                  ALL
                      SELECT 'Microsoft' AS company_name, 'MSFT'  AS ticker,
                  415.80 AS current_price, -0.87 AS pct_change FROM dual UNION
                  ALL
                      SELECT 'Google'    AS company_name, 'GOOGL' AS ticker,
                  175.20 AS current_price,  1.12 AS pct_change FROM dual UNION
                  ALL
                      SELECT 'Amazon'    AS company_name, 'AMZN'  AS ticker,
                  198.60 AS current_price, -3.45 AS pct_change FROM dual UNION
                  ALL
                      SELECT 'Tesla'     AS company_name, 'TSLA'  AS ticker,
                  245.10 AS current_price,  1.00 AS pct_change FROM dual
                  )
                ```
        }
        layout {
            sequence: 10
            parentRegion: @stacked-layout
            slot: subRegions
            columnSpan: 4
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: MetricCardDemo
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &TICKER.
            metric: &STOCK_PRICE.
            metricCssClasses: u-text-title-5
            meta: &COMPANY_NAME.
            layout: stacked
        }
        plugin-avatar {
            displayAvatar: true
            style: subtle
            shape: square
            position: inline
            alignment: center
        }
        plugin-badge {
            displayBadge: true
            label: &VALUE_DESCRIPTION.
            value: STOCK_CHANGE
            state: STATE
            icon: &ICON_CLASS.
            size: large
        }
        pagination {
            entitiesPerPage: 50
        }

        column COMPANY_NAME (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: COMPANY_NAME
                dataType: varchar2
            }
        )

        column ICON_CLASS (
            layout {
                sequence: 90
            }
            source {
                databaseColumn: ICON_CLASS
                dataType: varchar2
            }
        )

        column STATE (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: STATE
                dataType: varchar2
            }
        )

        column STOCK_CHANGE (
            layout {
                sequence: 80
            }
            source {
                databaseColumn: STOCK_CHANGE
                dataType: varchar2
            }
        )

        column STOCK_PRICE (
            layout {
                sequence: 70
            }
            source {
                databaseColumn: STOCK_PRICE
                dataType: varchar2
            }
        )

        column TICKER (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: TICKER
                dataType: varchar2
            }
        )

    )

