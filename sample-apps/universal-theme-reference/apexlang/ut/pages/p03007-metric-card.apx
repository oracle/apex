        name: Configuration
        type: staticContent
        source {
            htmlCode:
                ```html
                <h4>Region</h4>
                <b>Type</b>: Metric Card<br>
                <br>
                <h4>Settings</h4>
                Utilizes Title, Metric and Meta with the Default Layout.<br>
                <br>
                <h4>Avatar</h4>
                <b>Type</b>: Icon<br>
                <b>Position</b>: Top<br>
                <b>Shape</b>: Circular<br>
                <br>
                <h4>Badge</h4>
                Utilizes State and Icon with the Outline Style set.<br>
                ```
        }
        layout {
            sequence: 50
            parentRegion: @default-layout
            slot: subRegions
            startNewRow: false
            columnSpan: 3
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region configuration_2 (
        name: Configuration
        type: staticContent
        source {
            htmlCode:
                ```html
                <h4>Region</h4>
                <b>Type</b>: Metric Card<br>
                <br>
                <h4>Settings</h4>
                Utilizes Title, Metric and Meta with the Stacked Layout. Metric CSS Classes set with <span class="class">u-text-title-5</span> utility class<br>
                <br>
                <h4>Avatar</h4>
                <b>Type</b>: Icon<br>
                <b>Position</b>: Top<br>
                <b>Alignment</b>: Center<br>
                <br>
                <h4>Badge</h4>
