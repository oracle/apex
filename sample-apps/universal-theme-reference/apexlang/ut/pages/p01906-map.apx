                        "width": 20,
                        "height": 20,
                        "paint-order": "stroke",
                        "viewBox": "0 0 20 20",
                        "elements": [
                            {
                                "type": "path",
                                "d": "M10,19a1.5,1.5,0,0,1-1.106-.487C8.291,17.855,3,11.967,3,8A7,7,0,0,1,17,8c0,3.967-5.291,9.855-5.894,10.514A1.506,1.506,0,0,1,10,19Z",
