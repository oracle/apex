page 1206 (
    name: Region - Collapsible
    alias: COLLAPSIBLE-REGION
    title: Collapsible Region - &APP_TITLE.
    pageGroup: @components
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: [
            dm-Page
            dm-Page--center
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region 1-default (
        name: 1. Default
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @demo
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region 2-collapsed-state (
        name: 2. Collapsed State
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @demo
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region 3-scrolling-body (
        name: 3. Scrolling Body
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @demo
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-positions (
        name: Button Positions
        type: staticContent
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region collapsible-region (
        name: Collapsible Region
        type: staticContent
        source {
            htmlCode:
                ```html
                <div class="dm-Placeholder h180"> 
                <span class="a-Icon icon-template-region"></span>
                <h3>Region Body</h3>
                </div>
                ```
        }
        layout {
            sequence: 480
            parentRegion: @1-default
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Default Collapsible Region
        }
        advanced {
            htmlDomId: Demo1
        }
    )

    region collapsible-region-2 (
        name: Collapsible Region
        type: staticContent
        source {
            htmlCode:
                ```html
                <div class="dm-Placeholder h180"> 
                <span class="a-Icon icon-template-region"></span>
                <h3>Region Body</h3>
                </div>
                ```
        }
        layout {
            sequence: 510
            parentRegion: @2-collapsed-state
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Collapsed Collapsible Region
        }
        advanced {
            htmlDomId: Demo2
        }
    )

    region collapsible-region-3 (
        name: Collapsible Region
        type: staticContent
        source {
            htmlCode:
                ```html
                <div class="dm-Placeholder h180"> 
                <span class="a-Icon icon-template-region"></span>
                <h3>Region Body</h3>
                </div>
                <div class="dm-Placeholder h180"> 
                <span class="a-Icon icon-template-region"></span>
                <h3>Region Body</h3>
                </div>
                <div class="dm-Placeholder h180"> 
                <span class="a-Icon icon-template-region"></span>
                <h3>Region Body</h3>
                </div>
                ```
        }
        layout {
            sequence: 540
            parentRegion: @3-scrolling-body
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                i-h240
                is-expanded
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Scrolling Collapsible Region
        }
        advanced {
            htmlDomId: Demo3
        }
    )

    region collapsible-region-with-buttons (
        name: Collapsible Region With Buttons
        type: staticContent
        source {
            htmlCode: <p>Region Body</p>
        }
        layout {
            sequence: 480
            parentRegion: @button-positions
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
    )

    region demo (
        name: Demo
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region instructions (
        name: Instructions
        type: plugin/componentInstructions
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--shadowBG
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            staticId: Demo1
        }
    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode: <p>Allow your users to toggle the visibility of a region's content on the page.</p>
        }
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region template-options (
        name: Template Options
        type: plugin/previewTemplateOptions
        layout {
            sequence: 15
            parentRegion: @demo
            slot: subRegions
            startNewRow: false
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                t-ContentBlock--shadowBG
                js-headingLevel-3
            ]
        }
        accessibility {
            landmarkLabel: Default Template Options
        }
        settings {
            staticId: Demo1
        }
    )

    region template-options-2 (
        name: Template Options
        type: plugin/previewTemplateOptions
        layout {
            sequence: 25
            parentRegion: @demo
            slot: subRegions
            startNewRow: false
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                t-ContentBlock--shadowBG
                js-headingLevel-3
            ]
        }
        accessibility {
            landmarkLabel: Collapsed State Template Options
        }
        settings {
            staticId: Demo2
        }
    )

    region template-options-3 (
        name: Template Options
        type: plugin/previewTemplateOptions
        layout {
            sequence: 35
            parentRegion: @demo
            slot: subRegions
            startNewRow: false
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                t-ContentBlock--shadowBG
                js-headingLevel-3
            ]
        }
        accessibility {
            landmarkLabel: Scrolling Body Template Options
        }
        settings {
            staticId: Demo3
        }
    )

    button change (
        buttonName: CHANGE
        label: Change
        layout {
            sequence: 10
            region: @collapsible-region-with-buttons
            slot: change
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button close (
        buttonName: CLOSE
        label: Close
        layout {
            sequence: 40
            region: @collapsible-region-with-buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button copy (
        buttonName: COPY
        label: Copy
        layout {
            sequence: 20
            region: @collapsible-region-with-buttons
            slot: copy
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 30
            region: @collapsible-region-with-buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button edit (
        buttonName: EDIT
        label: Edit
        layout {
            sequence: 50
            region: @collapsible-region-with-buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 60
            region: @collapsible-region-with-buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 70
            region: @collapsible-region-with-buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

)

