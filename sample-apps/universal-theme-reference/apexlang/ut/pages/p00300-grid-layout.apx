                <p><small>Note: These helper utilities are available in Oracle APEX 18.2 and later.</small></p>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @responsive-design
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    button toggle-grid-layout (
        buttonName: TOGGLE_GRID_LAYOUT
        label: Toggle Layout Columns
        layout {
            sequence: 10
            region: @toggle-layout-columns
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction toggle-grid-layout (
        name: Toggle Grid Layout
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @toggle-grid-layout
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: apex.jQuery('body').hasClass('grid-debug-on')
        }

        action native-add-class (
            action: addClass
            settings {
                class: is-active
            }
            affectedElements {
                selectionType: button
                button: @toggle-grid-layout
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-add-class-2 (
            action: addClass
            settings {
                class: grid-debug-on
            }
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: body
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-remove-class (
            action: removeClass
            settings {
                class: grid-debug-on
            }
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: body
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-remove-class-2 (
            action: removeClass
            settings {
                class: is-active
            }
            affectedElements {
                selectionType: button
                button: @toggle-grid-layout
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

