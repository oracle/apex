page 1721 (
    name: Column Toggle Report - Mobile Examples
    alias: COLUMN-TOGGLE-REPORT-MOBILE-EXAMPLES
    title: Column Toggle Report - Mobile Examples
    pageGroup: @components
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: [
            dm-Page
            dm-Page--center
        ]
    }
    navigationMenu {
        overrideUserInterfaceLevel: true
        list: @ut-application-navigation
        listPosition: top
        listTemplate: @/top-navigation-tabs
        templateOptions: [
            #DEFAULT#
            t-NavTabs--inlineLabels-lg
            t-NavTabs--hiddenLabels-sm
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .example1 button.a-Table-columntoggleBtn {
                margin: 12px;
                display: block;
                width: calc(100% - 24px);
            }
            ```
    }
    security {
        authentication: public
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region example (
        name: Example 2
        type: columnToggleReport
        source {
            location: localDatabase
            tableName: EBA_UT_CHART_TASKS
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: request=Value
            value: sample2
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
            colButtonText: Select Columns
        }

        column ASSIGNED_TO (
