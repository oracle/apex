        }
    )

    region mobile-ui-patterns-2 (
        name: Mobile UI Patterns
        type: list
        source {
            list: @ut-mobile-patterns
        }
        layout {
            sequence: 90
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
