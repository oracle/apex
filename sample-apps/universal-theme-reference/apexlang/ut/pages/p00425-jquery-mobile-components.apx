        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.theme42demo.openMobileSamplePage('f?p=&APP_ID.:1721:&APP_SESSION.:sample1','Column Toggle Report');
            warnOnUnsavedChanges: doNotCheck
