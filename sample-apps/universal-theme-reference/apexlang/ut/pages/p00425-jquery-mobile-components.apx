    region mobile-ui-patterns (
        name: Mobile UI Patterns
        type: staticContent
        source {
            htmlCode: <p>Here are a number of Mobile UI Patterns you can follow as you build your next mobile app.</p>
        }
        layout {
            sequence: 80
            slot: body
            columnSpan: 8
        }
        appearance {
