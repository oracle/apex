    region stateful-color-variables (
        name: Stateful Color Variables
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT 1 seq,
                       'primary' class, 
                       null variable, 
                       null preview, 
                       null variable_contrast,
                       null preview_contrast,
                       null variable_shade,
                       null preview_shade,
                       null color_block
                  FROM DUAL
                union all
                SELECT 2 seq,
                       'danger' class, 
                       null variable, 
                       null preview, 
                       null variable_contrast,
                       null preview_contrast,
                       null variable_shade,
                       null preview_shade,
                       null color_block
                  FROM DUAL
                union all
                SELECT 3 seq,
                       'warning' class, 
                       null variable, 
                       null preview, 
                       null variable_contrast,
                       null preview_contrast,
                       null variable_shade,
                       null preview_shade,
                       null color_block
                  FROM DUAL
                union all
                SELECT 4 seq,
                       'success' class, 
                       null variable, 
                       null preview, 
                       null variable_contrast,
                       null preview_contrast,
                       null variable_shade,
                       null preview_shade,
                       null color_block
                  FROM DUAL
                union all
                SELECT 5 seq,
                       'info' class, 
                       null variable, 
                       null preview, 
                       null variable_contrast,
                       null preview_contrast,
                       null variable_shade,
                       null preview_shade,
                       null color_block
                  FROM DUAL
                order by 1
                ```
        }
        layout {
            sequence: 40
            parentRegion: @color-variables
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                t-ContentBlock--lightBG
                js-headingLevel-3
            ]
        }
        reportLayout {
            numberOfRows: 999
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlightOff
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column CLASS (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 20
            }
        )

        column COLOR_BLOCK (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 90
            }
        )

        column PREVIEW (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Preview
            }
            layout {
                sequence: 40
            }
            columnFormatting {
                htmlExpression: <span class="preview" style="background-color: var(--ut-palette-#CLASS#)"></span>
            }
            sorting {
                sortable: false
            }
        )

        column PREVIEW_CONTRAST (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Preview Contrast
            }
            layout {
                sequence: 60
            }
            columnFormatting {
                htmlExpression: <span class="preview" style="background-color: var(--ut-palette-#CLASS#);  color: var(--ut-palette-#CLASS#-contrast)">Abc</span>
            }
            sorting {
                sortable: false
            }
        )

        column PREVIEW_SHADE (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Preview Shade
            }
            layout {
                sequence: 80
            }
            columnFormatting {
                htmlExpression: <span class="preview" style="background-color: var(--ut-palette-#CLASS#-shade)"></span>
            }
            sorting {
                sortable: false
            }
        )

        column SEQ (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column VARIABLE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Variable
            }
            layout {
                sequence: 30
