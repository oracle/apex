    region flex (
        name: Flex
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>These utility classes can be added to help arrange items in rows, columns or more "flexible" layouts. They can 
                    also help with item alignment, content justification, content ordering, and content spacing.</p>
                ```
        }
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region floats (
        name: Floats
        type: staticContent
        source {
            htmlCode: <p>To float an element, you can use the <span class="class tag">u-pull<span class="class-var">Direction</span></span> utility classes.</p>
        }
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region gap (
        name: Gap
        type: staticContent
        source {
            htmlCode: <p>Gap classes help to set the spacing between flex or grid items, controlling both row and column gaps in a single property. To use these utility classes make sure the parent element has the display property set to flex, inline-flex, or grid.</p>
        }
        layout {
            sequence: 100
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region height (
        name: Height
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Text</p>
                
                ```
        }
        layout {
            sequence: 95
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region introduction (
        name: Introduction
        type: staticContent
        source {
            htmlCode: <p>You can use the following utility classes anywhere in your app to fine-tune the layout of your page and components. For most Oracle APEX components, you can simply populate the <b>CSS Classes</b> property to apply these modifiers to your page components.</p>
        }
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region margin (
        name: Margin
        type: staticContent
        source {
            htmlCode: <p>Margin classes can be added to help add spacing around your elements. As of Universal Theme 24.2 we added the "u-" prefix to margin utility classes.</p>
        }
        layout {
            sequence: 65
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region options (
        name: Options
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Set the order to lay out an item in a flex container. Items in a container are sorted by ascending order value and then by their source code order.</p>
                
                <table class="u-Report u-Report--staticBG u-Report--stretch dm-Report--doc">
                  <thead>
                    <tr>
                      <th style="width: 30%" class="u-textStart">Class</th>
                      <th class="u-textStart">Values</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                        <td><span class="class">u-order-</span></td>
                        <td>
                            <span class="class-value">0</span> <br />
                            <span class="class-value">1</span> <br />
                            <span class="class-value">2</span> <br />
                            <span class="class-value">3</span> <br />
                            <span class="class-value">4</span> <br />
                            <span class="class-value">5</span>
                        </td>
                    </tr>
                
                  </tbody>
                </table>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @order
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
    )

    region options-2 (
        name: Options
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Use the following class name structure with the options listed below to add spacing around your element.</p>
                <p><span class="class tag">u-margin-<span class="class-var">direction</span>-<span class="class-var">spacing</span></span></p>
                
                <table class="u-Report u-Report--staticBG u-Report--stretch dm-Report--doc">
                  <thead>
                    <tr>
                      <th style="width: 30%" class="u-textStart">Variable</th>
                      <th class="u-textStart">Values</th>
                      <th class="u-textStart">Description</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                        <td>Direction</td>
                        <td>
                            <span class="class-value">top</span> <br />
                            <span class="class-value">right</span> <br />
                            <span class="class-value">bottom</span> <br />
                            <span class="class-value">left</span> <br />
                            <span class="class-value">block</span> <br />
                            <span class="class-value">inline</span>
                        </td>
                        <td>Where the margin should be positioned</td>
                    </tr>
                    <tr>
                        <td>Spacing</td>
                        <td>
                            <span class="class-value">none</span> <span class="class-desc">0 px</span><br />
                            <span class="class-value">xs</span>   <span class="class-desc">4 px</span><br />
                            <span class="class-value">sm</span>   <span class="class-desc">8 px</span><br />
                            <span class="class-value">md</span>   <span class="class-desc">16 px</span><br />
                            <span class="class-value">lg</span>   <span class="class-desc">32 px</span><br />
                            <span class="class-value">xl</span>   <span class="class-desc">48 px</span>
                        </td>
                        <td>
                            The amount of spacing in pixels. 
                        </td>
                    </tr>
                
                  </tbody>
                </table>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @margin
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
        accessibility {
            landmarkLabel: Margin Options
        }
    )

