    region example-markup (
        name: Example Markup
        type: staticContent
        source {
            htmlCode:
                ```html
                <pre class="dm-Code lang-html"><code>
                &lt;div class="u-flex"&gt;
                    &lt;div class="u-order-3"&gt;This column will appear as the 3rd column&lt;/div&gt;
                    &lt;div class="u-order-1"&gt;This column will be first&lt;/div&gt;
                    &lt;div class="u-order-2 u-order-xxs-1"&gt;<br />
                    &nbsp;&nbsp;This column will appear first when the viewport is below 479px wide.<br />
                    &nbsp;&nbsp;And will appear as the second column when the viewport is 480px and wider.<br />
                    &lt;/div&gt;
                &lt;/div&gt;
                </code>
                </pre>
                ```
        }
        layout {
            sequence: 30
            parentRegion: @order
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
    )

