page 1711 (
    name: Reflow Report - Mobile Examples
    alias: REFLOW-REPORT-MOBILE-EXAMPLES
    title: Reflow Report - Mobile Examples
    pageGroup: @components
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: [
            dm-Page
            dm-Page--center
        ]
    }
    navigationMenu {
        overrideUserInterfaceLevel: true
        list: @ut-application-navigation
        listPosition: top
        listTemplate: @/top-navigation-tabs
        templateOptions: [
            #DEFAULT#
            t-NavTabs--inlineLabels-lg
            t-NavTabs--hiddenLabels-sm
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authentication: public
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region tasks (
        name: Tasks
        type: reflowReport
        source {
            location: localDatabase
            tableName: EBA_UT_CHART_TASKS
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: request=Value
            value: sample2
        }
        settings {
            layoutOptions: [
                stripes
                stroke
            ]
        }

        column ASSIGNED_TO (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Assigned To
            }
            layout {
                sequence: 130
            }
        )

        column BUDGET (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Budget
                alignment: end
            }
            layout {
                sequence: 150
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
        )

        column COST (
            source {
                dataType: NUMBER
            }
            heading {
                heading: Cost
                alignment: end
            }
            layout {
                sequence: 140
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
        )

        column CREATED (
            show: false
            source {
                dataType: TIMESTAMP_LTZ
            }
            layout {
                sequence: 40
            }
        )

        column CREATED_BY (
            show: false
            source {
                dataType: VARCHAR2
            }
            layout {
                sequence: 50
            }
        )

        column END_DATE (
            source {
                dataType: DATE
            }
            heading {
                heading: End Date
                alignment: center
            }
            layout {
                sequence: 110
                columnAlignment: center
            }
        )

        column ID (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 10
            }
        )

        column PARENT_TASK (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 80
            }
        )

        column PROJECT (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 20
            }
        )

        column ROW_VERSION_NUMBER (
            show: false
            source {
                dataType: NUMBER
            }
            layout {
                sequence: 30
            }
        )

        column START_DATE (
            source {
                dataType: DATE
            }
            heading {
                heading: Start Date
                alignment: center
            }
            layout {
                sequence: 100
                columnAlignment: center
            }
        )

        column STATUS (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Status
            }
            layout {
                sequence: 120
            }
        )

        column TASK_NAME (
            source {
                dataType: VARCHAR2
            }
            heading {
                heading: Task Name
            }
            layout {
                sequence: 90
            }
        )

        column UPDATED (
            show: false
            source {
                dataType: TIMESTAMP_LTZ
            }
            layout {
                sequence: 60
            }
        )

        column UPDATED_BY (
            show: false
            source {
                dataType: VARCHAR2
            }
            layout {
                sequence: 70
            }
        )

    )

