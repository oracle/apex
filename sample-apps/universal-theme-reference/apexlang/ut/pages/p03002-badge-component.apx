page 3002 (
    name: Components - Badge
    alias: BADGE-COMPONENT
    title: Badge - Universal Theme
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region configuration-classic-report (
        name: Configuration: Classic Report
        type: staticContent
        source {
            htmlCode:
                ```html
                <h4>Region</h4>
                <strong>Type:</strong> Classic Report
                
                <h4>Status Column</h4>
                <p>The <strong>Status</strong> column uses the with-apply syntax in the HTML Expression attribute under Column Formatting to access the <em>Badge</em> partial and display a badge in each row.</p>
                
                <strong>Type:</strong> Plain Text<br>
                <strong>HTML Expression:</strong>
                <code>
                    {with/}
                        LABEL:=STATUS
                        VALUE:=#STATUS#
                        STATE:=#BADGE_STATE#
                        ICON:=#BADGE_ICON#
                        LABEL_DISPLAY:=N
                        STYLE:=t-Badge--subtle
                        SHAPE:=t-Badge--circle
                    {apply THEME$BADGE/}
                </code>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @demo-classic-report
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region configuration-interactive-report (
        name: Configuration: Interactive Report
        type: staticContent
        source {
            htmlCode:
                ```html
                <h4>Region</h4>
                <strong>Type:</strong> Interactive Report
                
                <h4>Status Column</h4>
                <p>In Interactive Reports, the <em>Badge</em> partial is available for use as a column Type. The <strong>Status</strong> column in this demo uses the Badge column type and associated Partial settings to display a badge in each row.</p>
                
                <h4>Badge</h4>
                <strong>Label:</strong> Status<br>
                <strong>Value:</strong> #STATUS#<br>
                <strong>Icon:</strong> <em>None</em><br>
                <strong>Display Label:</strong> No<br>
                <strong>Style:</strong> Default<br>
                <strong>Shape:</strong> Default<br>
                <strong>Size:</strong> Default
                ```
        }
        layout {
            sequence: 20
            parentRegion: @demo-interactive-report
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--scrollBody
            ]
        }
    )

    region cr (
        name: CR
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       TASK_NAME,
                       START_DATE,
                       END_DATE,
                       STATUS,
                       ASSIGNED_TO,
                       COST,
                       BUDGET,
                       case STATUS
                         when 'Closed'  then 'success'
                         when 'Open'    then 'danger'
                         when 'Pending' then 'warning'
                         else 'info'
                       end as BADGE_STATE,
                       case STATUS
                         when 'Closed'  then 'fa-check'
                         when 'Open'    then 'fa-exclamation'
                         when 'Pending' then 'fa-question'
                         else 'fa-info'
                       end as BADGE_ICON
                  from EBA_UT_CHART_TASKS
                ```
        }
        layout {
            sequence: 10
            parentRegion: @demo-classic-report
            slot: subRegions
            columnSpan: 8
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: CRDemo
        }
        reportLayout {
            numberOfRows: 10
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlightOff
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column ASSIGNED_TO (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 70
            }
        )

        column BADGE_ICON (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 110
            }
        )

        column BADGE_STATE (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 100
            }
        )

        column BUDGET (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Budget
                alignment: end
            }
            layout {
                sequence: 90
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
        )

        column COST (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 80
            }
        )

        column END_DATE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: End Date
            }
            layout {
                sequence: 60
            }
            appearance {
                formatMask: DD-MON
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column START_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Start Date
            }
            layout {
                sequence: 50
            }
            appearance {
                formatMask: DD-MON
            }
        )

        column STATUS (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Status
                alignment: center
            }
            layout {
                sequence: 120
                columnAlignment: center
            }
            columnFormatting {
                htmlExpression:
                    ```html
                    {with/}
                    LABEL:=STATUS
                    VALUE:=#STATUS#
                    STATE:=#BADGE_STATE#
                    ICON:=#BADGE_ICON#
                    LABEL_DISPLAY:=N
                    STYLE:=t-Badge--subtle
                    SHAPE:=t-Badge--circle
                    {apply THEME$BADGE/}
                    ```
            }
        )

        column TASK_NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Task Name
            }
            layout {
                sequence: 40
            }
        )

    )

