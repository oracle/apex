    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                    The <strong>Badge</strong> partial is useful for displaying badges or counters. 
                    This partial can be used to display a single badge, or can be applied in report templates to display a badge for each report row.
                </p>
                ```
        }
