    button hot (
        buttonName: HOT
        label: Button
        layout {
            sequence: 10
            region: @demo-4
            slot: regionBody
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
        advanced {
            htmlDomId: Button4
        }
    )

    button icon (
        buttonName: ICON
        label: Button
        layout {
            sequence: 10
            region: @demo
            slot: regionBody
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-check
        }
        behavior {
            action: definedByDynamicAction
