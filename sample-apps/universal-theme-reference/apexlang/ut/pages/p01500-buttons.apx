page 1500 (
    name: Buttons
    alias: BUTTONS
    title: Buttons - &APP_TITLE.
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .ts-Placeholder {
            height: 240px;
            line-height: 240px;
            text-align: center;
            background-color: #D0D0D0;
            color: #404040;
            border-radius: 2px;
            margin-bottom: 48px;
            }
            .ts-Container {
            max-width: 1024px;
            min-height: 50vh;
            }
            
            .a-HowTo-value ul {
             margin-top: 0px;
            }
            .a-ButtonTemplate {
             width: 90%;
             margin:auto;
            }
            ```
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region demo (
        name: Demo
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @icon-only
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
        accessibility {
            landmarkLabel: Demo Icon Only
        }
    )

    region demo-2 (
