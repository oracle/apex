    button icon-dialog-button (
        buttonName: ICON_DIALOG_BUTTON
        label: Icon dialog button
        layout {
            sequence: 40
            region: @appearance
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 6101
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: never
        }
    )

    dynamicAction populate-link-text (
        name: Populate Link Text
        execution {
            sequence: 20
        }
        when {
            event: keyup
            selectionType: items
            items: P6100_BUTTON_LABEL
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var $j = apex.jQuery,
                        v = $j(this.triggeringElement).val();
                    $j('.icon-preview .t-Button').first().text(v);
                    $j('.icon-preview .t-Button').last().contents().filter(function(){ 
                      return this.nodeType == 3; 
                    })[0].nodeValue = v
                    $j('#button_code_link_text').text(v);
                    apex.theme42demo.renderButtons();
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction render-button (
        name: Render Button
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: [
                "P6100_BUTTON_TEMPLATE "
                "P6100_SIZE "
                "P6100_BUTTON_SET "
                "P6100_HOT "
                "P6100_TYPE "
                "P6100_WIDTH "
                "P6100_STYLE "
                "P6100_SPACING_LEFT "
                "P6100_ICON_CLASS "
                "P6100_SPACING_RIGHT "
                "P6100_SPACING_TOP "
                P6100_SPACING_BOTTOM
                P6100_ICON_POSITION
                P6100_BUTTON_LABEL
            ]
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.theme42demo.renderButtons();
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction show-icon-dialog (
        name: Show Icon Dialog
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: #open_dialog
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    apex.jQuery('#icon_picker_dialog').dialog('open');
                    apex.theme42demo.renderIcons({filterString: $v('P6100_SEARCH')});
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

