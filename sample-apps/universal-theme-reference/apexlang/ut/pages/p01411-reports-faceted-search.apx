page 1411 (
    name: Reports - Faceted Search
    alias: REPORTS-FACETED-SEARCH
    title: Faceted Search - &APP_TITLE.
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            parentRegion: @demo
            slot: subRegions
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region demo (
        name: Demo
        type: staticContent
        layout {
            sequence: 40
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region filters (
        name: Filters
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 20
            parentRegion: @demo
            slot: subRegions
            columnSpan: 3
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: Demo1
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P1411_ASSIGNED_TO (
            type: checkboxGroup
            label {
                label: Assigned To
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ASSIGNED_TO
            }
        )

        facet P1411_BUDGET (
            type: range
            label {
                label: Budget
            }
            lov {
                type: staticValues
                staticValues: STATIC2:<120;|120,120 - 300;120|300,300 - 1#G#000;300|1000,1#G#000 - 2#G#000;1000|2000,>=2#G#000;2000|
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: BUDGET
                dataType: number
            }
        )

        facet P1411_COST (
            type: range
            label {
                label: Cost
            }
            lov {
                type: staticValues
                staticValues: STATIC2:<100;|100,100 - 200;100|200,200 - 1#G#000;200|1000,>=1#G#000;1000|
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: COST
                dataType: number
            }
        )

        facet P1411_PROJECT (
            type: checkboxGroup
            label {
                label: Project
            }
            lov {
                type: sharedComponent
                lov: @eba-ut-chart-projects-project
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: PROJECT
                dataType: number
            }
        )

        facet P1411_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: STATUS,ASSIGNED_TO,PROJECT,TASK_NAME
            }
        )

        facet P1411_STATUS (
            type: checkboxGroup
            label {
                label: Status
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: STATUS
            }
        )

    )

    region instructions (
        name: Instructions
        type: plugin/componentInstructions
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--shadowBG
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            staticId: Demo1
        }
    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Faceted search allows you to filter different columns on the left side of the page and report on the right side of the page, to get only the data that you need.</p>
                <p>You can create a faceted search page with either the Create Application Wizard or Create Page Wizard.</p>
                ```
        }
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            tableName: EBA_UT_CHART_TASKS
        }
        layout {
            sequence: 40
            parentRegion: @demo
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: no data found
        }

        column ASSIGNED_TO (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Assigned To
                alignment: center
            }
            layout {
                sequence: 100
            }
        )

        column BUDGET (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 120
            }
        )

        column COST (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Cost
                alignment: center
            }
            layout {
                sequence: 110
            }
        )

        column CREATED (
            reportColumnQueryId: 12
            derivedColumn: N
            type: hidden
            layout {
                sequence: 130
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 13
            derivedColumn: N
            type: hidden
            layout {
                sequence: 140
            }
        )

        column END_DATE (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: End Date
                alignment: center
            }
            layout {
                sequence: 70
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column PARENT_TASK (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Parent Task
                alignment: center
            }
            layout {
                sequence: 30
            }
        )

        column PROJECT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Project
                alignment: center
            }
            layout {
                sequence: 20
            }
        )

        column ROW_VERSION_NUMBER (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Row Version Number
                alignment: center
            }
            layout {
                sequence: 50
            }
        )

        column START_DATE (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Start Date
                alignment: center
            }
            layout {
                sequence: 60
            }
        )

        column STATUS (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Status
                alignment: center
            }
            layout {
                sequence: 80
            }
        )

        column TASK_NAME (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Task Name
                alignment: center
            }
            layout {
                sequence: 40
            }
        )

        column UPDATED (
            reportColumnQueryId: 14
            derivedColumn: N
            type: hidden
            layout {
                sequence: 150
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 15
            derivedColumn: N
            type: hidden
            layout {
                sequence: 160
            }
        )

    )

    region template-options (
        name: Template Options
        type: plugin/previewTemplateOptions
        layout {
            sequence: 50
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--shadowBG
                js-headingLevel-3
            ]
        }
        settings {
            staticId: Demo1
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1411
                clearCache: 1411
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

