    region icon-builder (
        name: Icon Builder
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @icon-builder-dialog
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: dm-IconDialog-builder
        }
    )

    region icon-builder-dialog (
        name: Icon Builder Dialog
        type: staticContent
        layout {
            sequence: 10
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-dialog
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-dialog-size720x480
            ]
            cssClasses: dm-IconDialog
        }
        advanced {
            htmlDomId: icon_dialog
            regionDisplaySelector: true
        }
    )

    region icon-form (
        name: Icon Form
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @icon-builder
            slot: subRegions
            startNewRow: false
            columnSpan: 6
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--stretchInputs
            ]
        }
    )

    region icon-instructions (
        name: Icon Instructions
        type: staticContent
        source {
            htmlCode:
                ```html
                <div class="dm-IconDialog-info row">
                    <span class="dm-IconDialog-infoTitle col col-3">HTML <button type="button" title="Copy HTML Markup" class="t-Button t-Button--icon t-Button--tiny t-Button--link t-Button--iconLeft" data-clipboard-source="#icon_code"><span aria-hidden="true" class="t-Icon t-Icon--left fa fa-synonym"></span>Copy</button></span>
                    <div class="dm-IconDialog-infoBody col col-9">
                        <code id="icon_code"></code>
                    </div>
                </div>
                <div class="dm-IconDialog-info row">
                    <span class="dm-IconDialog-infoTitle col col-3">Icon <button type="button" title="Copy Icon Class" class="t-Button t-Button--icon t-Button--tiny t-Button--link t-Button--iconLeft" data-clipboard-source="#icon_classes"><span aria-hidden="true" class="t-Icon t-Icon--left fa fa-synonym"></span>Copy</button> </span>
                    <div class="dm-IconDialog-infoBody col col-9">
                        <code id="icon_classes"></code>
                        <small>Enter in the Icon property for Buttons, Regions, and other components.</small>
                    </div>
                </div>
                ```
        }
        layout {
            sequence: 40
            parentRegion: @icon-builder
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
