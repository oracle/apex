    pageItem P4000_SIZE (
        type: radioGroup
        label {
            label: Size
            alignment: left
        }
        settings {
            noOfCols: 2
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Small;SMALL,Large;LARGE
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @search
            slot: regionBody
            alignment: left
            startNewRow: false
            columnSpan: 3
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--xlarge
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        default {
            type: static
            staticValue: SMALL
        }
    )

    button about (
        buttonName: ABOUT
        label: About Font APEX
        layout {
            sequence: 10
            region: @icons-2
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-info-circle
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button reset-icon (
        buttonName: RESET_ICON
        label: Reset Icon
        layout {
            sequence: 10
            region: @icon-preview
            slot: regionBody
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--small
                t-Button--noUI
                t-Button--iconLeft
            ]
            cssClasses: dm-IconDialog-resetButton
            icon: fa-refresh
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction apply-modifier-to-icon (
        name: Apply Modifier to Icon
        execution {
            sequence: 30
            eventScope: dynamic
        }
        when {
            selectionType: items
            items: [
                P4000_ICON_SIZE
                P4000_ANIMATION
                P4000_ROTATE
                P4000_MODIFIER
                P4000_MODIFIER_STATUS
            ]
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.theme42demo.renderIconPreview();
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction cancel-enter (
        name: Cancel Enter
        execution {
            sequence: 10
        }
        when {
            event: keypress
            selectionType: items
            items: P4000_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.browserEvent.keyCode == 13
        }

        action native-cancel-event (
            action: cancelEvent
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction open-about-dialog (
        name: Open About Dialog
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @about
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @about-font-apex
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction reset-icon-settings (
        name: Reset Icon Settings
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @reset-icon
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: [
                    P4000_ANIMATION
                    P4000_ROTATE
                    P4000_MODIFIER
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $s('P4000_ICON_SIZE','null');
                    apex.theme42demo.renderIconPreview();
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction set-icon-size (
        name: Set Icon Size
        execution {
            sequence: 100
        }
        when {
            selectionType: items
            items: P4000_FA_SIZE
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $s('P4000_SIZE',$v('P4000_FA_SIZE'));
                    apex.theme42demo.renderIconPreview();
                    
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction show-icon-preview-dialog (
        name: Show Icon Preview Dialog
        execution {
            sequence: 20
            eventScope: dynamic
            staticContainer: #icons
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: .dm-Search-result
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var $j = apex.jQuery,
                        iconClass = $j(this.triggeringElement).find('.dm-Search-class').text();
                    $s('P4000_ICONCLASS',iconClass);
                    $j("#icon_dialog").dialog({
                        title: "Icon: " + iconClass
                    }).dialog("open");
                    apex.theme42demo.renderIconPreview();
                    $j('#P4000_ICON_SIZE').focus();
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction toggle-icon-size (
        name: Toggle Icon Size
        execution {
            sequence: 90
        }
        when {
            selectionType: items
            items: P4000_SIZE
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var size = $v('P4000_SIZE'),
                        icons$ = $( '#icons' ),
                        L_CLASS = 'force-fa-lg';
                    if ( size === 'LARGE' ) {
                        icons$.addClass( L_CLASS );
                    } else {
                        icons$.removeClass( L_CLASS );
                    }
                    ```
            }
            execution {
                sequence: 10
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: $v('P4000_SIZE');
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P4000_FA_SIZE
            }
            execution {
                sequence: 40
            }
        )

    )

    dynamicAction toggle-modifier-status (
        name: Toggle Modifier Status
        execution {
            sequence: 70
        }
        when {
            selectionType: items
            items: P4000_MODIFIER
        }
        clientSideCondition {
            type: itemIsNull
            item: P4000_MODIFIER
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: P4000_MODIFIER_STATUS
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: P4000_MODIFIER_STATUS
            }
            execution {
                sequence: 10
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P4000_MODIFIER_STATUS
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

    )

)

