                ```
        }
        layout {
            sequence: 430
            parentRegion: @carousel-region
            slot: slides
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: [
                u-color-2
                h200
                u-flex
                u-justify-content-center
                u-align-items-center
            ]
        }
    )

    region region-b-2 (
        name: Region B
        type: staticContent
        source {
            htmlCode:
                ```html
                <span class="a-Icon icon-template-region"></span>
                <h3>Region B</h3>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @carousel-region-with-buttons
            slot: slides
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: [
                u-color-8
                h200
                u-flex
                u-justify-content-center
                u-align-items-center
            ]
        }
    )

    region region-c (
        name: Region C
        type: staticContent
        source {
            htmlCode:
                ```html
                <span class="a-Icon icon-template-region"></span>
                <h3>Region C</h3>
                ```
        }
        layout {
            sequence: 440
            parentRegion: @carousel-region
            slot: slides
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: [
                u-color-3
                h200
                u-flex
                u-justify-content-center
                u-align-items-center
            ]
        }
    )

    region region-c-2 (
        name: Region C
        type: staticContent
        source {
            htmlCode:
                ```html
                <span class="a-Icon icon-template-region"></span>
                <h3>Region C</h3>
                ```
        }
        layout {
            sequence: 30
            parentRegion: @carousel-region-with-buttons
