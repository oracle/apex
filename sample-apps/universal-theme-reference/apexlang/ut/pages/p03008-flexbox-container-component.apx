    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region right-column (
        name: Right Column
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @flexbox-demo
            slot: plugin-body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region row (
        name: Flexbox Container - Row
        type: themeTemplateComponent/flexboxContainer
        layout {
            sequence: 20
            parentRegion: @demo-direction
            slot: subRegions
            startNewRow: false
        }
        componentAppearance {
            display: regionOnly
        }
        settings {
            gap: lg
            flexBehavior: growIfNeeded
        }
    )

    region stretching (
        name: Stretching
        type: staticContent
        layout {
