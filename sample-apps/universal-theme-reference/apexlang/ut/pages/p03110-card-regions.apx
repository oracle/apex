            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region grid-layout-cards (
        name: Grid Layout Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       category,
                       title,
                       subtitle,
                       substr(body,1,100)||'...' as agenda,
                       secondary_body as speakers,
                       icon_class,
                       badge,
                       '#APP_FILES#' || image_url as image,
                       to_char(start_date, 'fmDDfm Month YYYY fmHHfm:MI PM') as start_date,
                       to_char(end_date, 'fmHHfm:MI PM') as end_date
                  from eba_ut_demo_cards
                 where category = 'workshop'
                   and id >= 9
                ```
        }
        layout {
            sequence: 10
            parentRegion: @with-grid-layout
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                t-CardsRegion--styleB
            ]
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: TITLE
        }
        subtitle {
            column: SUBTITLE
        }
        iconAndBadge {
            iconSource: iconClassColumn
            iconColumn: ICON_CLASS
            iconCssClasses: fa
            iconPosition: top
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: #
            }
        )

    )

    region image-first-cards (
        name: Image First Cards
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       category,
                       title,
                       subtitle,
                       substr(body,1,100)||'...' as agenda,
                       secondary_body as speakers,
                       icon_class,
                       badge,
                       '#APP_FILES#' || image_url as image,
                       to_char(start_date, 'fmDDfm Month YYYY fmHHfm:MI PM') as start_date,
                       to_char(end_date, 'fmHHfm:MI PM') as end_date
                  from eba_ut_demo_cards
                 where category = 'workshop'
                   and id < 10
                ```
        }
        layout {
            sequence: 10
            parentRegion: @with-image-first
            slot: subRegions
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/cards-container
            templateOptions: [
                #DEFAULT#
                t-CardsRegion--styleB
            ]
        }
        componentAppearance {
            gridColumns: 3
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: TITLE
        }
        body {
            column: AGENDA
        }
        iconAndBadge {
            iconSource: iconClassColumn
            iconColumn: ICON_CLASS
            iconCssClasses: fa
            badgeColumn: BADGE
            badgeLabel: Fee:
        }
        media {
            source: urlColumn
            urlColumn: IMAGE
            position: first
            appearance: widescreen
            sizing: cover
            imageDescription: &TITLE.
        }
    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Cards Regions are useful for presenting a variety of information in small blocks and can be heavily customized. They can be displayed in three styles, with icons or initials, images as part of the body or as the background, to enhance each card presentation and you can control the layout.</p>
                <p>Actions can be added to each card's image, title, subtitle, as new buttons or even using the entire card to enhance user experience.</p>
                ```
        }
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 70
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region sample-sql-query (
        name: Sample SQL Query
        type: staticContent
        source {
            htmlCode:
                ```html
                <pre class="dm-Code lang-sql te_padding"><code>select
                  -- data
                  card_primary_key,    -- primary key
                  card_secondary_key,  -- secondary key if needed
                  card_title,          -- title
                  card_subtitle,       -- subtitle
                  card_body,           -- card body text
                  card_secondary_body, -- card secondary text, positioned near bottom
                
                  -- ui and other attributes
                  card_icon,           -- icon class, e.g. fa-cloud
                  card_badge,          -- badge, can be a small text
                  card_image           -- image url, url or blob columns
                from dual</code></pre>
                ```
        }
        layout {
            sequence: 80
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--lightBG
                js-headingLevel-2
            ]
            renderComponents: belowContent
        }
        advanced {
            regionDisplaySelector: true
        }
    )

