    region colors (
        name: Colors
        type: staticContent
        source {
            htmlCode: <!-- <p>Use these classes as simple modifiers to restrict a block of text control to a specified number of lines. If a block of text surpasses the specified number of lines then an ellipses (...) is added and the remaining text is hidden.</p> -->
        }
        layout {
            sequence: 90
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region content (
        name: Content
        type: staticContent
        source {
            htmlCode: <!-- <p>Use these classes to set the font size, font weight, and line height properties of your text elements.</p> -->
        }
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region headings (
        name: Headings
        type: staticContent
        source {
            htmlCode: <!-- <p>Use these classes to set the font size, font weight, and line height properties of your text elements.</p> -->
        }
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region introduction (
        name: Introduction
        type: staticContent
        source {
            htmlCode: <p>You can use the following utility classes anywhere in your app to fine-tune the layout of your page and components. For most Oracle APEX components, you can simply populate the <b>CSS Classes</b> property to apply these modifiers to your page components.</p>
        }
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region line-clamp-truncate-hyphenate (
        name: Line Clamp, Truncate & Hyphenate
        type: staticContent
        source {
            htmlCode: <!-- <p>Use these classes as simple modifiers to restrict a block of text control to a specified number of lines. If a block of text surpasses the specified number of lines then an ellipses (...) is added and the remaining text is hidden.</p> -->
        }
        layout {
            sequence: 80
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: false
        }
    )

    region text-alignment (
        name: Text Alignment
        type: staticContent
        source {
            htmlCode: <p>These classes are direction aware, meaning the text direction will be based on the direction of the language. For example, text using the <span class="class tag">u-text<span class="class-var">Start</span></span> class will align text to the left for Left-to-Right languages, and will align text to the right for Right-to-Left languages.</p>
        }
        layout {
            sequence: 40
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region text-style (
        name: Text Style
        type: staticContent
        source {
            htmlCode: <p>Use these classes as simple modifiers to control the text style of a given component. For example, you may want to use the <span class="class tag">u-bold</span> to make the text of a button have a stronger weight.</p>
        }
        layout {
            sequence: 60
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region text-transform (
        name: Text Transform
        type: staticContent
        source {
            htmlCode: <p>These classes are useful when you want to control the text case for a given component. For example, an input field where you want characters to display in upper case. </p>
        }
        layout {
            sequence: 50
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region text-wrap (
        name: Text Wrap
        type: staticContent
        source {
            htmlCode: <p>Use this class to force text not to wrap inside its container.</p>
        }
        layout {
            sequence: 70
            slot: body
            columnSpan: 8
            columnCssClasses: col-sm-12
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h1
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

)

