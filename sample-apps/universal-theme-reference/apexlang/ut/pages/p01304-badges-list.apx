page 1304 (
    name: List - Badges
    alias: BADGES-LIST
    title: Badges List - &APP_TITLE.
    pageGroup: @components
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @universal-theme-breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region column-names (
        name: Column Names
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select '#A01#'       , 'The text of the link inside of the Badge List item.'
                  from dual union all
                select '#A02#'       , 'Classes for the Badge List Item'
                  from dual union all
                select '#A03#'       , 'HTML Attributes for the link inside of the Badge List item.'
                  from dual
                ```
        }
        layout {
            sequence: 70
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--lightBG
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
        }

        column '#A01#' (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: &#x27;#a01#&#x27;
                alignment: center
            }
            layout {
                sequence: 10
            }
        )

        column 'THETEXTOFTHELINKINSIDEOFTHEBADGELISTITEM.' (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: &#x27;thetextofthelinkinsideofthebadgelistitem.&#x27;
                alignment: center
            }
            layout {
                sequence: 20
            }
        )

    )

    region demo (
        name: Demo
        type: list
        source {
            list: @badge-list-sample
        }
        layout {
            sequence: 40
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--lightBG
                js-headingLevel-2
            ]
        }
        advanced {
            htmlDomId: BadgeDemo
            regionDisplaySelector: true
        }
        componentAppearance {
            listTemplate: @/badge-list
            templateOptions: [
                #DEFAULT#
                u-colors
                t-BadgeList--circular
                t-BadgeList--cols t-BadgeList--3cols
                t-BadgeList--large
            ]
            cssClasses: dm-TemplateOption-previewTarget
        }
    )

    region instructions (
        name: Instructions
        type: plugin/componentInstructions
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--shadowBG
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            staticId: BadgeDemo
        }
    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode: <p>This list template is useful for displaying badges or counters.</p>
        }
        layout {
            sequence: 20
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region template-options (
        name: Template Options
        type: plugin/previewTemplateOptions
        layout {
            sequence: 50
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--shadowBG
                js-headingLevel-3
            ]
        }
        settings {
            staticId: BadgeDemo
        }
    )

)

