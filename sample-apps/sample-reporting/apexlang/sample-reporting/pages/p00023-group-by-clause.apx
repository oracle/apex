                heading: Project
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column TASKS (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Tasks
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column TOTAL_BUDGET (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Total Budget
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column TOTAL_COST (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Total Cost
            }
