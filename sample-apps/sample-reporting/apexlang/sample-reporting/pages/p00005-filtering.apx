page 5 (
    name: Filtering
    alias: FILTERING
    title: Filtering
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <style>
            ul.sSearchResultsReport span.title span.highlight {
              background-color: #FFEA87;
              text-decoration: underline
              }
            ul.sSearchResultsReport span.highlight {
              background-color: #FFEA87;
              }
            </style>
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This classic report is a standard report region created using the create page wizard.  The SQL used to create the report is displayed in the show/hide region at the bottom of the page.  A <strong>Filter Side Bar</strong> region was also created on this page with a number of page items that can be used to control report results.  The value of the page items is referenced in the SQL query using standard bind variable syntax.</p>
                
                <p>Rather than including a "Go" button, the Search and Assigned To page items have their "Submit when Enter pressed" attribute set to yes.  There is also a dynamic action that will submit the page when the Status is changed.  For the Rows selector, "Page Action when Value Changed" is set to "Redirect and Set Value".  That action is available because the item is a select list.</p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region filter (
        name: Filter
        type: staticContent
        layout {
            sequence: 50
            slot: leftColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
                t-Form--stretchInputs
            ]
        }
    )

    region filtered-data (
        name: Filtered Data
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select rowid,
                       ID,
                       PROJECT,
                       TASK_NAME,
                       START_DATE,
                       END_DATE,
                       STATUS,
                       ASSIGNED_TO,
                       COST,
                       BUDGET
                from EBA_DEMO_IR_PROJECTS
                where (nvl(:P5_STATUS,'0') = '0' or instr(:P5_STATUS||':',status||':') > 0) and
                     --
                     (:P5_SEARCH is null or 
                     instr(upper(project) || '//'||
                     upper(TASK_NAME) || '//'||
                     upper(ASSIGNED_TO) || '//'||
                     upper(STATUS),upper(:P5_SEARCH) ) > 0) and
                     --
                     (:P5_ASSIGNEE is null or instr(upper(assigned_to),upper(:P5_ASSIGNEE))>0)
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
                t-Region--noBorder
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        advanced {
            htmlDomId: filter_side_bar
            excludeTitleFromTranslation: true
        }
        reportLayout {
            numberOfRowsType: itemValue
            item: P5_ROWS
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No data found.
        }
        componentAdvanced {
            stripHtml: true
        }

        column ASSIGNED_TO (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Assigned To
            }
            layout {
                sequence: 7
            }
        )

        column BUDGET (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Budget
                alignment: end
            }
            layout {
                sequence: 9
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
        )

        column COST (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Cost
                alignment: end
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
        )

        column END_DATE (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: End Date
            }
            layout {
                sequence: 5
            }
        )

        column ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column PROJECT (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Project
            }
            layout {
                sequence: 2
            }
            sorting {
                defaultSequence: 1
            }
        )

        column ROWID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column START_DATE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Start Date
            }
            layout {
                sequence: 4
            }
        )

        column STATUS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 6
            }
        )

        column TASK_NAME (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Task Name
            }
            layout {
                sequence: 3
            }
            sorting {
                defaultSequence: 2
            }
        )

    )

    region filtering (
        name: Filtering
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region sql-source (
        name: SQL Source
        type: plugin/sourceDisplay
        layout {
            sequence: 10
            parentRegion: @filtered-data
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        settings {
            regionStaticId: filter_side_bar
        }
    )

    pageItem P5_ASSIGNEE (
        type: textField
        label {
            label: Assigned To
            alignment: left
        }
        settings {
            trimSpaces: none
            submitWhenEnterPressed: true
        }
        layout {
            sequence: 20
            region: @filter
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        validation {
            maxLength: 4000
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P5_ROWS (
        type: selectList
        label {
            label: Rows
            alignment: left
        }
        settings {
            pageActionOnSelection: redirectSetValue
        }
        lov {
            type: sharedComponent
            lov: @number-of-rows-per-page
        }
        layout {
            sequence: 40
            region: @filter
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: staticValue
            staticValue: 15
        }
        default {
            type: static
            staticValue: 15
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P5_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            trimSpaces: none
            submitWhenEnterPressed: true
        }
        layout {
            sequence: 10
            region: @filter
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        validation {
            maxLength: 4000
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P5_STATUS (
        type: checkboxGroup
        label {
            label: Status
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @distinct-status-values
        }
        layout {
            sequence: 30
            region: @filter
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare r varchar2(500) := null;
                begin
                for c1 in (select distinct status from EBA_DEMO_IR_PROJECTS) loop
                   r := r||c1.status||':';
                end loop;
                return rtrim(r,':');
                end;
                ```
        }
        security {
            restrictedChars: webSafe
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @filtering
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 5
                clearCache: 5
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction submit-report-on-status-filter-change (
        name: submit report on status filter change
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P5_STATUS
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 5
                successMessage: false
            }
        }
        comments {
            comments: Created 14-DEC-2011 09:16 by SHAKEEB
        }
    )

)

