page 1 (
    name: Interactive Report
    alias: INTERACTIVE-REPORT
    title: Interactive Report
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>This interactive report was created using the Create Page Wizard. The SQL used to create this report displays in the show/hide region at the bottom of the page. Interactive reports feature built-in search capability in that your search term is used to search across the row.  In addition to the default interactive report functionality, this report has a <strong>Detail</strong> view which you can toggle to by clicking the <strong>Detail View</strong> icon.  You can sort and filter columns by clicking on column headings, click the <strong>Actions</strong> drop down menu to control the columns to display on the report and the order in which they are displayed.  You can also save custom reports, chart data, and perform many other actions.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
    )

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region projects (
        name: Projects
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select	ROWID,
                       ID,
                       PROJECT,
                       TASK_NAME,
                       START_DATE,
                       END_DATE,
                       STATUS,
                       ASSIGNED_TO,
                       COST,
                       BUDGET,
                       budget - cost available_budget
                from EBA_DEMO_IR_PROJECTS
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: projects_report
        }
        link {
            linkColumn: customTarget
            target: {
                page: 2
                items: {
                    P2_ROWID: #ROWID#
                }
                clearCache: 2
            }
            linkIcon: <img src="#IMAGE_PREFIX#app_ui/img/icons/apex-edit-pencil.png" class="apex-edit-pencil" alt="Edit">
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        detailView {
            show: true
            beforeRows:
                ```html
                <style>
                table.apexir_WORKSHEET_CUSTOM { border: none !important; -moz-box-shadow: none; box-shadow: none; -webkit-box-shadow: none; }
                .apexir_WORKSHEET_DATA td {border-bottom: none !important;}
                table.reportDetail td {
                	border: none !important;
                	font: 11px/16px Arial, sans-serif;
                	}
                	table.reportDetail td.separator {
                		background: #CCC;
                		height: 2px !important;
                padding: 0;
                		line-height: 2px !important;
                overflow: hidden;
                		}
                table.reportDetail td h1 {margin: 8px 0 !important}
                table.reportDetail td img {margin-top: 8px; border: 4px solid #CCC; -moz-border-radius: 4px; -webkit-border-radius: 4px;}
                </style>
                <table class="reportDetail">
                ```
            forEachRow:
                ```html
                <tr><td colspan="4" class="separator"></td></tr>
                <tr>
                <td><strong><u>#PROJECT#</u></strong></td><td><i>#TASK_NAME#</i></td>
                </tr>
                <tr><td align="left"><strong>#STATUS_LABEL#:</strong></td><td>#STATUS#</td>
                </tr>
                <tr><td align="left"><strong>#ASSIGNED_TO_LABEL#:</strong></td><td>#ASSIGNED_TO#</td>
                </tr>
                <tr>
                <td style="padding-bottom: 0px;"><strong>#START_DATE_LABEL#</strong></td>
                <td style="padding-bottom: 0px;"><strong>#END_DATE_LABEL#</strong></td>
                <td style="padding-bottom: 0px;"><strong>#BUDGET_LABEL#</strong></td>
                <td style="padding-bottom: 0px;"><strong>#COST_LABEL#</strong></td>
                </tr>
                <tr>
                <td style="padding-top: 0px;">#START_DATE#</td>
                <td style="padding-top: 0px;">#END_DATE#</td>
                <td style="padding-top: 0px;">#BUDGET#</td>
                <td style="padding-top: 0px;">#COST#</td>
                </tr>
                ```
            afterRows:
                ```html
                <tr><td colspan="4" class="separator"></td></tr>
                </table>
                ```
        }
        advanced {
            savedReportMappingIdentifier: 1908983501483820764
        }

        column ASSIGNED_TO (
            type: plainText
            heading {
                heading: Assigned To
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column AVAILABLE_BUDGET (
            type: plainText
            heading {
                heading: Available Budget
                alignment: end
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column BUDGET (
            type: plainText
            heading {
                heading: Budget
                alignment: end
            }
            layout {
                sequence: 9
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column COST (
            type: plainText
            heading {
                heading: Cost
                alignment: end
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column END_DATE (
            type: plainText
            heading {
                heading: End Date
            }
            layout {
                sequence: 5
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column PROJECT (
            type: plainText
            heading {
                heading: Project
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column ROWID (
            type: hidden
            heading {
                heading: Rowid
            }
            layout {
                sequence: 10
            }
            source {
                dataType: OTHER
            }
            advanced {
                endUserAlias: J
            }
            security {
                escapeSpecialChars: false
            }
        )

        column START_DATE (
            type: plainText
            heading {
                heading: Start Date
            }
            layout {
                sequence: 4
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: D
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column TASK_NAME (
            type: plainText
            heading {
                heading: Task Name
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        savedReport 19091460 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn ASSIGNED_TO (
                sequence: 7
            )

            displayColumn AVAILABLE_BUDGET (
                sequence: 11
            )

            displayColumn BUDGET (
                sequence: 9
            )

            displayColumn COST (
                sequence: 8
            )

            displayColumn END_DATE (
                sequence: 5
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn PROJECT (
                sequence: 2
            )

            displayColumn ROWID (
                sequence: 10
            )

            displayColumn START_DATE (
                sequence: 4
            )

            displayColumn STATUS (
                sequence: 6
            )

            displayColumn TASK_NAME (
                sequence: 3
            )

            sort (
                column: START_DATE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: END_DATE
                sort {
                    sequence: 2
                }
            )

            sort (
                column: PROJECT
                sort {
                    sequence: 3
                }
            )

            aggregate (
                column: COST
            )

            aggregate (
                column: BUDGET
            )

        )

        savedReport 19092255 (
            visibility: alternativeDefault
            name: Budget Review
            view {
                chart: true
                groupBy: true
                default: chart
                rowsPerPage: 15
            }

            displayColumn APXWS_CC_001 (
                sequence: 6
            )

            displayColumn BUDGET (
                sequence: 5
            )

            displayColumn COST (
                sequence: 4
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn STATUS (
                sequence: 3
            )

            displayColumn TASK_NAME (
                sequence: 2
            )

            computation APXWS_CC_001 (
                identifier: C01
                source {
                    expression: I - H
                    dataType: number
                }
                label {
                    column: Budget v Cost
                }
                appearance {
                    formatMask: FML999G999G999G999G990D00
                }
            )

            aggregate (
                column: APXWS_CC_001
            )

            aggregate (
                column: COST
            )

            aggregate (
                column: BUDGET
            )

            controlBreak (
                column: PROJECT
                layout {
                    sequence: 1
                }
            )

            chart {
                label: PROJECT
                value: APXWS_CC_001
                valueAggregation: sum
            }
            axisTitle {
                label: Project
                value: Budget v Cost
            }
            sort {
                by: labelAsc
            }
            chartAppearance {
                orientation: horizontal
            }

            groupByColumn (
                column: STATUS
                layout {
                    sequence: 1
                }
            )

            groupByAggregate (
                aggregate {
                    column: COST
                    displaySum: true
                }
                appearance {
                    formatMask: FML999G999G999G999G990D00
                }
                layout {
                    sequence: 1
                }
            )

            groupByAggregate (
                aggregate {
                    column: BUDGET
                    displaySum: true
                }
                appearance {
                    formatMask: FML999G999G999G999G990D00
                }
                layout {
                    sequence: 2
                }
            )

            groupByAggregate (
                aggregate {
                    column: APXWS_CC_001
                    displaySum: true
                }
                appearance {
                    formatMask: FML999G999G999G999G990D00
                }
                layout {
                    sequence: 3
                }
            )

            groupBySort (
                column: STATUS
                sort {
                    sequence: 1
                }
            )

        )

        savedReport 20240823 (
            visibility: alternativeDefault
            name: Highlighted Over Budget
            view {
                rowsPerPage: 15
            }

            displayColumn ASSIGNED_TO (
                sequence: 6
            )

            displayColumn AVAILABLE_BUDGET (
                sequence: 9
            )

            displayColumn BUDGET (
                sequence: 8
            )

            displayColumn COST (
                sequence: 7
            )

            displayColumn END_DATE (
                sequence: 4
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn START_DATE (
                sequence: 3
            )

            displayColumn STATUS (
                sequence: 5
            )

            displayColumn TASK_NAME (
                sequence: 2
            )

            sort (
                column: START_DATE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: END_DATE
                sort {
                    sequence: 2
                }
            )

            sort (
                column: PROJECT
                sort {
                    sequence: 3
                }
            )

            aggregate (
                column: COST
            )

            aggregate (
                column: BUDGET
            )

            highlight ir-condition (
                name: Over Budget
                condition {
                    column: AVAILABLE_BUDGET
                    operator: <
                    value: 0
                }
                colors {
                    background: #FFFF99
                }
                execution {
                    sequence: 10
                }
            )

        )

        savedReport 21844430 (
            visibility: alternativeDefault
            name: Pivot Example
            view {
                pivot: true
                default: pivot
                rowsPerPage: 15
            }

            displayColumn ASSIGNED_TO (
                sequence: 7
            )

            displayColumn AVAILABLE_BUDGET (
                sequence: 11
            )

            displayColumn BUDGET (
                sequence: 9
            )

            displayColumn COST (
                sequence: 8
            )

            displayColumn END_DATE (
                sequence: 5
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn PROJECT (
                sequence: 2
            )

            displayColumn ROWID (
                sequence: 10
            )

            displayColumn START_DATE (
                sequence: 4
            )

            displayColumn STATUS (
                sequence: 6
            )

            displayColumn TASK_NAME (
                sequence: 3
            )

            sort (
                column: START_DATE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: END_DATE
                sort {
                    sequence: 2
                }
            )

            sort (
                column: PROJECT
                sort {
                    sequence: 3
                }
            )

            aggregate (
                column: COST
            )

            aggregate (
                column: BUDGET
            )

            pivotColumn (
                column: ASSIGNED_TO
                layout {
                    sequence: 1
                }
            )

            pivotRowColumn (
                column: PROJECT
                layout {
                    sequence: 1
                }
            )

            pivotAggregate ir-pivot-agg (
                heading: Total Cost
                aggregate {
                    function: sum
                    column: COST
                }
                appearance {
                    formatMask: 999G999G999G999G990
                }
                layout {
                    sequence: 1
                }
            )

            pivotAggregate ir-pivot-agg-2 (
                heading: Total Budget
                aggregate {
                    function: sum
                    column: BUDGET
                }
                appearance {
                    formatMask: 999G999G999G999G990
                }
                layout {
                    sequence: 2
                }
            )

        )

    )

    region sql-source (
        name: SQL Source
        type: plugin/sourceDisplay
        layout {
            sequence: 10
            parentRegion: @projects
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        settings {
            regionStaticId: projects_report
        }
    )

    button reset-data (
        buttonName: RESET_DATA
        label: Reset
        layout {
            sequence: 10
            region: @projects
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                clearCache: [
                    1
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-edit (
        name: Refresh on Edit
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @projects
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @projects
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

