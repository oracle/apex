    region replace-query (
        name: Replace Query
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    empno,
                    ename,
                    replace(job,'SALESMAN','SALESPERSON') as job,
                    mgr,
                    hiredate,
                    sal,
                    comm,
                    deptno
                from
                    eba_demo_ir_emp
                where
                    job = 'SALESMAN'
                order by
                    3
                ```
        }
        layout {
            sequence: 130
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
