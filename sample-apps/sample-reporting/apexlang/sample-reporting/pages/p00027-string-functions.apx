    region substr-query (
        name: Substr Query
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    empno,
                    ename,
                    job,
                    mgr,
                    hiredate,
                    sal,
                    comm,
                    deptno
                from
                    eba_demo_ir_emp
                where
                    substr(ename,1,1) = 'M'
                order by
                    2
                ```
