    region instr-query (
        name: Instr Query
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    empno,
                    ename,
                    job,
                    mgr,
                    hiredate,
                    sal,
                    comm,
                    deptno
                from
                    eba_demo_ir_emp
                where
                    instr(job,'SALES') > 0
                order by
                    2
                ```
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
