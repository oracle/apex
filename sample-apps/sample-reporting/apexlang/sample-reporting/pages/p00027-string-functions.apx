    region nvl2-query (
        name: Nvl2 Query
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    empno,
                    ename,
                    job,
                    mgr,
                    hiredate,
                    sal,
                    nvl2(comm, 'Commissioned', 'Non-Commissioned') as comm,
                    deptno
                from
                    eba_demo_ir_emp
                order by
                    7
                ```
        }
