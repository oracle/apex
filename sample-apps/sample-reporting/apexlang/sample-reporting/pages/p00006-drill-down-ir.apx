                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            link {
                target: {
                    page: 1
                    items: {
                        IR_PROJECT: #PROJECT#
                        IR_STATUS: Pending
                    }
                    clearCache: [
                        RR
                        CR
                    ]
                    action: resetPagination
                }
                linkText: #PENDING#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column PROJECT (
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 1
                    items: {
                        IR_PROJECT: #PROJECT#
                    }
                    clearCache: [
                        RR
                        CR
                    ]
                    action: resetPagination
                }
                linkText: #PROJECT#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: A
            }
        )

        column TASKS (
            type: link
            heading {
                heading: Tasks
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            link {
                target: {
                    page: 1
                    items: {
                        IR_PROJECT: #PROJECT#
                    }
                    clearCache: [
