        savedReport 20240239 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn CLOSED (
                sequence: 4
            )

            displayColumn COST_VS_BUDGET (
                sequence: 9
            )

            displayColumn ON_HOLD (
                sequence: 6
            )

            displayColumn OPEN (
                sequence: 3
            )

            displayColumn PENDING (
                sequence: 5
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn TASKS (
                sequence: 2
            )

            displayColumn TOTAL_BUDGET (
                sequence: 8
            )

            displayColumn TOTAL_COST (
                sequence: 7
            )

            aggregate (
                column: TOTAL_COST
            )

            aggregate (
                column: TOTAL_BUDGET
            )

            aggregate (
                column: COST_VS_BUDGET
            )

            highlight ir-condition (
                name: Over Budget
                condition {
                    column: COST_VS_BUDGET
                    operator: <
                    value: 0
                }
                colors {
                    background: #FF7755
                }
                execution {
                    sequence: 10
                }
            )

            highlight ir-condition-2 (
                name: Expensive Projects
                condition {
                    column: TOTAL_COST
                    operator: >
                    value: 5000
                }
                highlight {
                    type: cell
                }
                colors {
                    background: #FFFF99
                }
                execution {
                    sequence: 10
                }
            )

        )

