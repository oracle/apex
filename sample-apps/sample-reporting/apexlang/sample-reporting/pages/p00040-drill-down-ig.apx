                }
                linkText: &PENDING.
            }
            source {
                databaseColumn: PENDING
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column PROJECT (
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 10
            }
            link {
                target: {
                    page: 17
                    items: {
                        IG_PROJECT: &PROJECT.
                    }
                    action: clearRegions
                    request: "IG[projects_report]_Costings"
                }
                linkText: &PROJECT.
            }
            source {
                databaseColumn: PROJECT
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
