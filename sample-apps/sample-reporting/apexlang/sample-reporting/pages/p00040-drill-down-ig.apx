page 40 (
    name: Drill Down IG
    alias: DRILL-DOWN-IG
    title: Drill Down IG
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>This interactive grid was created using the create page wizard.  The SQL used to create the report is displayed in the show/hide region at the bottom of the page. Many columns of this report provide drill down capabilities.  To make a report column "hot" you edit the Column <strong>Link</strong> attributes which are on the <strong>Columns</strong> tab of the interactive grid region.  You can link report columns to other pages in the Oracle APEX application and control the session state to be passed.  You can also link to custom URLs.  Your column link can access any of the values of a given report row using the <strong>&amp;MY_COLUMN.</strong> syntax.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region container (
        name: Container
        type: staticContent
        layout {
            sequence: 20
            slot: body
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region projects (
        name: Projects
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                       PROJECT,
                       count(*) tasks,
                       min(START_DATE) first_start_date,
                       max(END_DATE) last_end_date,
                       sum(decode(STATUS,'Open',1,0)) open,
                       sum(decode(STATUS,'Closed',1,0)) closed,
                       sum(decode(STATUS,'Pending',1,0)) pending,
                       sum(decode(STATUS,'On-Hold',1,0)) on_hold,   
                       count(distinct ASSIGNED_TO) assignees,
                       sum(COST) total_cost,
                       sum(BUDGET) total_budget,
                       sum(BUDGET) - sum(COST) cost_vs_budget
                from EBA_DEMO_IR_PROJECTS
                group by project
                ```
        }
        layout {
            sequence: 10
            parentRegion: @container
            slot: subRegions
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        advanced {
            htmlDomId: projects_report
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 1029855602099718145
        }

        savedReport 14149 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @PROJECT
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @TASKS
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @FIRST_START_DATE
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @LAST_END_DATE
                layout {
                    sequence: 4
                }
            )

            displayColumn (
                column: @OPEN
                layout {
                    sequence: 5
                }
            )

            displayColumn (
                column: @CLOSED
                layout {
                    sequence: 6
                }
            )

            displayColumn (
                column: @PENDING
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @ON_HOLD
                layout {
                    sequence: 8
                }
            )

            displayColumn (
                column: @ASSIGNEES
                layout {
                    sequence: 9
                }
            )

            displayColumn (
                column: @TOTAL_COST
                layout {
                    sequence: 10
                }
            )

            displayColumn (
                column: @TOTAL_BUDGET
                layout {
                    sequence: 11
                }
            )

            displayColumn (
                column: @COST_VS_BUDGET
                layout {
                    sequence: 12
                }
            )

        )

        column ASSIGNEES (
            type: link
            heading {
                heading: Assignees
                alignment: end
            }
            layout {
                sequence: 90
                columnAlignment: end
            }
            link {
                target: {
                    page: 17
                    items: {
                        IG_PROJECT: &PROJECT.
                    }
                    action: clearRegions
                    request: "IG[projects_report]_Costings"
                }
                linkText: &ASSIGNEES.
            }
            source {
                databaseColumn: ASSIGNEES
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column CLOSED (
            type: link
            heading {
                heading: Closed
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            link {
                target: {
                    page: 17
                    items: {
                        IG_PROJECT: &PROJECT.
                    }
                    action: clearRegions
                    request: "IG[projects_report]_Costings"
                }
                linkText: &CLOSED.
            }
            source {
                databaseColumn: CLOSED
                dataType: number
            }
            columnFilter {
