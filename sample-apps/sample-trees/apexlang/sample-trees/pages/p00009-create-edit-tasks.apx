    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 20
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_TASK_ID
        }
    )

    validation completion-date-required (
        name: Completion Date Required
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P9_TASK_COMP
        }
        error {
            errorMessage: #LABEL# must be specified when status is set to 100%.
            displayLocation: inlineInNotification
            associatedItem: @P9_TASK_COMP
        }
        serverSideCondition {
            whenButtonPressed: @create
            type: item=value
            item: P9_TASK_STATUS
            value: 100
        }
    )

    computation p10-rowid (
        itemName: P10_ROWID
        execution {
            sequence: 1
            point: afterSubmit
        }
        computation {
            type: staticValue
        }
        serverSideCondition {
            type: request=Value
            value: CREATE
        }
    )

    process fetch-row-from-eba-demo-tree-task (
        name: Fetch Row from EBA_DEMO_TREE_TASK
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_TREE_TASK
            pkColumn: TASK_ID
            pkItem: P9_TASK_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 3170835600432658361
        }
    )

    process get-next-or-previous-primary-key-value (
        name: Get Next or Previous Primary Key Value
        type: formPagination
        target {
            tableName: EBA_DEMO_TREE_TASK
            pkColumn: TASK_ID
            pkItem: P9_TASK_ID
            nextPkItem: P9_TASK_ID_NEXT
            prevPkItem: P9_TASK_ID_PREV
            currentRowCountItem: P9_TASK_ID_COUNT
        }
        execution {
            sequence: 20
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 3170839182023658379
        }
    )

    process process-row-of-eba-demo-tree-task (
        name: Process Row of EBA_DEMO_TREE_TASK
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_TREE_TASK
            pkColumn: TASK_ID
            pkItem: P9_TASK_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 3170835786773658362
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 3170835995119658362
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process set-page-navigation (
        name: Set Page Navigation
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'T' then 
                    :LAST_VIEW := 3;
                else
                    :LAST_VIEW := 8;
                end if;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 3174608499834011171
        }
    )

    branch (
        execution {
            sequence: 30
        }
        behavior {
            target: {
                page: &LAST_VIEW.
            }
        }
    )

    branch (
        execution {
            sequence: 10
            point: afterSubmit
        }
        behavior {
            target: {
                page: 9
                items: {
                    P9_TASK_ID: &P9_TASK_ID_NEXT.
                }
                successMessage: false
            }
        }
        serverSideCondition {
            whenButtonPressed: @get-next-task-id
        }
        comments {
            comments: This button is needed for Get Next or Previous Primary Key Value process.
        }
    )

    branch (
        execution {
            sequence: 20
            point: afterSubmit
        }
        behavior {
            target: {
                page: 9
                items: {
                    P9_TASK_ID: &P9_TASK_ID_PREV.
                }
                successMessage: false
            }
        }
        serverSideCondition {
            whenButtonPressed: @get-previous-task-id
