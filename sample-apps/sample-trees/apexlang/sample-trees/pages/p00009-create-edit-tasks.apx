page 9 (
    name: Create/Edit Tasks
    alias: CREATE-EDIT-TASKS
    title: Create/Edit Tasks
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            var htmldb_ch_message='"OK_TO_GET_NEXT_PREV_PK_VALUE"';
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 1
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region create-edit-tasks (
        name: Create/Edit Tasks
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
    )

    region subtask-information (
        name: Subtask Information
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select rowid, a.* from eba_demo_tree_subtask a
                where a.task_id = :P9_TASK_ID
                and a.proj_id = :P9_PROJ_ID
                ```
            pageItemsToSubmit: [
                P9_TASK_ID
                P9_PROJ_ID
            ]
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_TASK_ID
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No subtasks found.
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 11
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 16
            derivedColumn: N
            type: hidden
            layout {
                sequence: 16
            }
        )

        column PROJ_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
            sorting {
                defaultSequence: 1
            }
        )

        column ROWID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 10
                    items: {
                        P10_ROWID: #ROWID#
                        P10_PROJ_ID: #PROJ_ID#
                    }
                }
                linkText: <img src="#IMAGE_PREFIX#menu/pencil2_16x16.gif" alt="Edit">
            }
            sorting {
                sortable: false
            }
        )

        column ROW_VERSION_NUMBER (
            reportColumnQueryId: 15
            derivedColumn: N
            type: hidden
            layout {
                sequence: 15
            }
        )

        column SUB_ASSIGN (
            reportColumnQueryId: 13
            derivedColumn: N
            type: hidden
            layout {
                sequence: 13
            }
        )

        column SUB_COMP (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Completed
            }
            layout {
                sequence: 8
            }
            sorting {
                sortable: false
            }
        )

        column SUB_DESC (
            reportColumnQueryId: 14
            derivedColumn: N
            type: hidden
            layout {
                sequence: 14
            }
        )

        column SUB_EST_COMP (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Estimated Completion
            }
            layout {
                sequence: 7
            }
            sorting {
                sortable: false
            }
        )

        column SUB_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column SUB_NAME (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column SUB_PRIORITY (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Priority
            }
            layout {
                sequence: 9
            }
            sorting {
                sortable: false
            }
        )

        column SUB_START (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Start
            }
            layout {
                sequence: 6
            }
            sorting {
                sortable: false
            }
        )

        column SUB_STATUS (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column TASK_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column UPDATED (
            reportColumnQueryId: 12
            derivedColumn: N
            type: hidden
            layout {
                sequence: 12
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 17
            derivedColumn: N
            type: hidden
            layout {
                sequence: 17
            }
        )

    )

