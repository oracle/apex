page 7 (
    name: Create/Edit Project
    alias: CREATE-EDIT-PROJECT
    title: Create/Edit Project
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/wizard-modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: wizardButtons
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region create-edit-project (
        name: Create/Edit Project
        type: staticContent
        layout {
            sequence: 10
            slot: wizardBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
                t-Region--noBorder
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
    )

    pageItem P7_COMPLETION_DATE (
        type: datePicker
        label {
            label: Completion Date
            alignment: left
        }
        layout {
            sequence: 50
            region: @create-edit-project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: COMPLETION_DATE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_ESTIMATED_COMPLETION (
        type: datePicker
        label {
            label: Estimated Completion
            alignment: left
        }
        layout {
            sequence: 40
            region: @create-edit-project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: ESTIMATED_COMPLETION
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_PROJECT_NAME (
        type: textField
        label {
            label: Project Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @create-edit-project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: PROJECT_NAME
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_PROJ_ID (
        type: hidden
        layout {
            sequence: 10
            region: @create-edit-project
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: PROJ_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_START_DATE (
        type: datePicker
        label {
            label: Start Date
            alignment: left
        }
        layout {
            sequence: 30
            region: @create-edit-project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: START_DATE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_STATUS (
        type: selectList
        label {
            label: Status
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @status
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 70
            region: @create-edit-project
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: STATUS
            used: always
        }
        default {
            type: static
            staticValue: 0
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_UPDATED (
        type: hidden
        layout {
            sequence: 80
            region: @create-edit-project
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 20
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P7_PROJ_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 10
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P7_PROJ_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P7_PROJ_ID
        }
    )

    dynamicAction cancel-modal (
        name: Cancel Modal
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation completion-date-required (
        name: Completion Date Required
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P7_COMPLETION_DATE
        }
        error {
            errorMessage: #LABEL# must be specified when status is set to 100%.
            displayLocation: inlineInNotification
            associatedItem: @P7_COMPLETION_DATE
        }
        serverSideCondition {
            whenButtonPressed: @save
            type: item=value
            item: P7_STATUS
            value: 100
        }
    )

    process fetch-row-from-eba-demo-tree-projects (
        name: Fetch Row from EBA_DEMO_TREE_PROJECTS
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_TREE_PROJECTS
            pkColumn: PROJ_ID
            pkItem: P7_PROJ_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 3170807508229922573
        }
    )

    process process-row-of-eba-demo-tree-projects (
        name: Process Row of EBA_DEMO_TREE_PROJECTS
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_TREE_PROJECTS
            pkColumn: PROJ_ID
            pkItem: P7_PROJ_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 3170807699234922575
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 3170807893460922576
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process set-page-navigation (
        name: Set Page Navigation
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'T' then 
                    :LAST_VIEW := 3;
                else
                    :LAST_VIEW := 6;
                end if;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 3171040685813531809
        }
    )

    branch (
        execution {
            sequence: 1
        }
        behavior {
            target: {
                page: &LAST_VIEW.
            }
        }
    )

)

