searchConfig product_search_configuration_oracle_text (
    name: Product Search Configuration Oracle Text
    type: text
    source {
        sqlQuery:
            ```sql
            select p.product_id, 
                   p.product_name, 
                   '$' || p.unit_price unit_price,
                   p.text_index_column,
                   j.description,
                   j.gender, 
                   j.colour,
                   j.brand
              from eba_demo_search_products p,
                   json_table (
                       p.product_details, 
                       '$' 
                       columns ( 
                           description varchar2(4000) path '$.description',
                           colour      varchar2(4000) path '$.colour',
                           gender      varchar2(4000) path '$.gender',
                           brand       varchar2(4000) path '$.brand')) j
            ```
        oracleTextIndexColumn: TEXT_INDEX_COLUMN
        type: sqlQuery
    }
    columnMapping {
        primaryKey1Column: PRODUCT_ID
        titleColumn: PRODUCT_NAME
        subtitleColumn: BRAND
        descriptionColumn: DESCRIPTION
        badgeColumn: UNIT_PRICE
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-package u-color-1-text
    }
)

searchConfig product_text_index_function (
    name: Product Search Configuration Oracle Text  Function
    type: text
    source {
        sqlQuery:
            ```sql
            select p.product_id, 
                   p.product_name, 
                   '$' || p.unit_price unit_price,
                   p.text_index_column,
                   j.description,
                   j.gender, 
                   j.colour,
                   j.brand
              from eba_demo_search_products p,
                   json_table (
                       p.product_details, 
                       '$' 
                       columns ( 
                           description varchar2(4000) path '$.description',
                           colour      varchar2(4000) path '$.colour',
                           gender      varchar2(4000) path '$.gender',
                           brand       varchar2(4000) path '$.brand')) j
            ```
        oracleTextIndexColumn: TEXT_INDEX_COLUMN
        type: sqlQuery
    }
    rowSearch {
        textQueryFunction: custom
        customFunctionName: eba_demo_search_text_pkg.convert_text_query
    }
    columnMapping {
        primaryKey1Column: PRODUCT_ID
        titleColumn: PRODUCT_NAME
        subtitleColumn: BRAND
        descriptionColumn: DESCRIPTION
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-package u-color-1-text
    }
)

searchConfig store (
    name: Store Search Configuration
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select store_id,
                   store_name,
                   web_address,
                   physical_address
              from eba_demo_search_stores
            ```
        searchableColumns: [
            STORE_NAME
            PHYSICAL_ADDRESS
        ]
    }
    columnMapping {
        primaryKey1Column: STORE_ID
        titleColumn: STORE_NAME
        subtitleColumn: WEB_ADDRESS
        descriptionColumn: PHYSICAL_ADDRESS
    }
    link {
        type: redirectThisApp
        target: {
            page: 106
            items: {
                P106_STORE_ID: &STORE_ID.
            }
            action: resetRegions
        }
    }
    iconAndBadge {
        iconSource: iconClass
        iconCssClasses: fa-shopping-bag u-color-4-text
    }
    performance {
        maxRowsToReturn: 5
    }
)

