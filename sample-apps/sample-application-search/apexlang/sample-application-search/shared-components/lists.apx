list administration (
    name: Administration

    entry manage-sample-data (
        label: Manage Sample Data
        icon {
            imageIconCssClasses: fa-database
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 501
            }
        }
        userDefinedAttributes {
            translatable: true
            1: This application ships with sample data. You can reset the sample data using this administrative page.
        }
    )

    entry manage-web-credentials (
        label: Manage Web Credentials
        icon {
            imageIconCssClasses: fa-key
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 503
            }
        }
        userDefinedAttributes {
            translatable: true
            1: The REST Data Source page in the Basics section rely on REST Data Sources. Use this page to provide your own TMDb API key.
        }
    )

    entry theme-style (
        label: Theme Style
        icon {
            imageIconCssClasses: fa-design
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 502
            }
        }
        userDefinedAttributes {
            translatable: true
            1: Set application user interface theme style for all users.
        }
    )

)

