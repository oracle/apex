list home (
    name: Home

    entry advanced (
        label: Advanced
        icon {
            imageIconCssClasses: fa-rocket
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 300
            }
        }
        userDefinedAttributes {
            translatable: true
            1: Explore advanced Application Search variations: Highlight search results, Integrate your Search Configurations with APEX regions like Maps, Cards ...
        }
    )

    entry basics (
        label: Basics
        icon {
            imageIconCssClasses: fa-layers
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 100
            }
        }
        userDefinedAttributes {
            translatable: true
            1: Create Search Configurations based on Local data source, REST Enabled SQL Service, REST Data Source ... And integrate it with Search regions.
        }
    )

    entry oracle-text (
        label: Oracle Text
        icon {
            imageIconCssClasses: fa-server-search
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 400
            }
        }
        userDefinedAttributes {
            translatable: true
            1: Leverage to Oracle Text advanced searching capabilities: Keyword searching, Fuzzy search and much more.
        }
    )

    entry use-cases (
        label: Use Cases
        icon {
            imageIconCssClasses: fa-puzzle-piece
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 200
            }
        }
        userDefinedAttributes {
            translatable: true
            1: Explore different use case of the Search Configuration: prefix searching, link search result to from ...
        }
    )

)

list navigation-bar (
    name: Navigation Bar

    entry administration (
        label: " Administration"
        icon {
            imageIconCssClasses: fa-gear
        }
        layout {
            sequence: 5
        }
        link {
            target: {
                page: 500
            }
        }
    )

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 15
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry help (
        label: Help
        icon {
            imageIconCssClasses: fa-question-circle-o
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 600
            }
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 20
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 30
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
    )

)

