lov login-remember-username (
    name: LOGIN_REMEMBER_USERNAME
    source {
        location: staticValues
    }

    entry remember-username (
        sequence: 10
        display: Remember username
        return: Y
    )

)

lov product-colors (
    name: PRODUCT COLORS
    source {
        type: sqlQuery
        sqlQuery: select distinct json_value(product_details,'$.colour') product_color from eba_demo_search_products
    }
    columnMapping {
        return: PRODUCT_COLOR
        display: PRODUCT_COLOR
    }
)

