page 104 (
    name: Movie Details
    alias: MOVIE-DETAILS
    title: Movie Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            /* Customize Movie Header Card */
            .movie-header-card.a-CardView {
                /* Increase the font sizes for movie name and tag line */
                --a-cv-title-font-size: 24px;
                --a-cv-subtitle-font-size: 16px;
            
                /* Add additional spacing around the header content */
                --ut-cv-subtitle-margin: 16px 0 0 0;
                display: flex;
                padding: 24px 0;
            }
            
            .movie-header-card .a-CardView-header {
                /* Center Title and Badge */
                display: flex;
                flex-direction: column;
                text-align: center;
            }
            
            .a-CardView-media{
                background: black;
            }
            .a-CardView-media img{
                opacity: .7;
            }
            .movie-header-card .a-CardView-body {
                /* Remove unnecessary padding */
                padding-top: 0;
            }
            .movie-details {
                /* Center align Card Body text */
                text-align: center;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region header (
        name: Header
        type: cards
        source {
            location: restSource
            restSource: @Movie_Details
        }
        localPostProcessing {
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       title,
                       'https://image.tmdb.org/t/p/w500' || poster_path                                                    as poster_url,
                       'https://image.tmdb.org/t/p/w500' || backdrop_path                                                  as backdrop_url,
                       release_date,
                       runtime,
                       trunc(runtime/60) || 'hr ' || extract (minute from numtodsinterval((runtime/60), 'HOUR' )) || 'min' as runtime_friendly,
                       vote_average,
                       tagline
                  from #APEX$SOURCE_DATA#
                ```
        }
        layout {
            sequence: 220
            parentRegion: @movie-details
            slot: regionBody
        }
        appearance {
            template: @/cards-container
            templateOptions: #DEFAULT#
        }

        parameter (
            name: @movie-id
            value {
                type: item
                item: P104_ID
            }
        )

        componentAppearance {
            layout: horizontal
            cssClasses: movie-header-card
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: TITLE
        }
        subtitle {
            column: TAGLINE
        }
        body {
            advancedFormatting: true
            htmlExpression:
                ```html
                <div class="movie-details">
                    <span title="Release Date">Released &RELEASE_DATE.</span> &middot; 
                    <span title="Runtime">&RUNTIME_FRIENDLY.</span> &middot;
                    <span title="&VOTE_AVERAGE. out of 10"><span class="fa fa-star" style="color:gold;" aria-hidden="true"></span> &VOTE_AVERAGE.</span>
                </div>
                ```
        }
        iconAndBadge {
            iconSource: imageUrl
            imageUrl: &POSTER_URL.
            iconCssClasses: w100 h100
        }
        media {
            source: imageUrl
            url: &BACKDROP_URL.
            position: background
            sizing: cover
        }
    )

    region movie-details (
        name: Movie Details
        type: form
        source {
            location: restSource
            restSource: @Movie_Details
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }

        parameter (
            name: @movie-id
            value {
                type: item
                item: P104_ID
            }
        )

    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode: &P104_OVERVIEW.
        }
        layout {
            sequence: 230
            parentRegion: @movie-details
            slot: regionBody
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
            ]
        }
    )

    pageItem P104_ADULT (
        type: hidden
        layout {
            sequence: 20
            region: @movie-details
            slot: regionBody
        }
        source {
            formRegion: @movie-details
            column: ADULT
            dataType: varchar2
        }
        security {
            sessionStateProtection: restricted
        }
    )

