page 304 (
    name: Card Region Details
    alias: CARD-REGION-DETAILS
    title: Card Region Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region card-region-details-customer (
        name: Card Region Details Customer
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_SEARCH_CUSTOMERS
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Customer Search Configuration
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region card-region-details-product (
        name: Card Region Details Product
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_SEARCH_PRODUCTS
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Product Search Configuration
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region card-region-details-store (
        name: Card Region Details Store
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_SEARCH_STORES
        }
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Store Search Configuration
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P304_CONFIG (
        type: hidden
        layout {
            sequence: 10
            slot: contentBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_CUSTOMER_ID (
        type: hidden
        layout {
            sequence: 10
            region: @card-region-details-customer
            slot: regionBody
        }
        source {
            formRegion: @card-region-details-customer
            column: CUSTOMER_ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_EMAIL_ADDRESS (
        type: textField
        label {
            label: Email Address
            alignment: left
        }
        layout {
            sequence: 30
            region: @card-region-details-customer
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @card-region-details-customer
            column: EMAIL_ADDRESS
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_FULL_NAME (
        type: textField
        label {
            label: Full Name
            alignment: left
        }
        layout {
            sequence: 20
            region: @card-region-details-customer
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @card-region-details-customer
            column: FULL_NAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_PHYSICAL_ADDRESS (
        type: textarea
        label {
            label: Address
            alignment: left
        }
        layout {
            sequence: 40
            region: @card-region-details-store
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 5
        }
        validation {
            maxLength: 512
        }
        source {
            formRegion: @card-region-details-store
            column: PHYSICAL_ADDRESS
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_PRODUCT_ID (
        type: hidden
        layout {
            sequence: 20
            region: @card-region-details-product
            slot: regionBody
        }
        source {
            formRegion: @card-region-details-product
            column: PRODUCT_ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_PRODUCT_NAME (
        type: textarea
        label {
            label: Product Name
            alignment: left
        }
        layout {
            sequence: 40
            region: @card-region-details-product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @card-region-details-product
            column: PRODUCT_NAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_STORE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @card-region-details-store
            slot: regionBody
        }
        source {
            formRegion: @card-region-details-store
            column: STORE_ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_STORE_NAME (
        type: textField
        label {
            label: Store Name
            alignment: left
        }
        layout {
            sequence: 20
            region: @card-region-details-store
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @card-region-details-store
            column: STORE_NAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_UNIT_PRICE (
        type: numberField
        label {
            label: Unit Price
            alignment: left
        }
        layout {
            sequence: 50
            region: @card-region-details-product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @card-region-details-product
            column: UNIT_PRICE
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P304_WEB_ADDRESS (
        type: textField
        label {
            label: Web Address
            alignment: left
        }
        layout {
            sequence: 30
            region: @card-region-details-store
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 100
        }
        source {
            formRegion: @card-region-details-store
            column: WEB_ADDRESS
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P304_PRODUCT_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P304_PRODUCT_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P304_PRODUCT_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 4098804709775017642
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-customer-details (
        name: Initialize form Customer Details
        type: formInitialization
        formRegion: @card-region-details-customer
        execution {
            sequence: 30
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 4098813491824084060
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Customer Search Configuration
        }
    )

    process initialize-form-product-details (
        name: Initialize form Product Details
        type: formInitialization
        formRegion: @card-region-details-product
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 4098803833539017642
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Product Search Configuration
        }
    )

    process initialize-form-store-details (
        name: Initialize form Store Details
        type: formInitialization
        formRegion: @card-region-details-store
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 4098813363587084059
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Store Search Configuration
        }
    )

    process process-form-customer-details (
        name: Process form Customer Details
        type: formAutoRowProcessing
        formRegion: @card-region-details-customer
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 4098813261485084058
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Customer Search Configuration
        }
    )

    process process-form-product-details (
        name: Process form Product Details
        type: formAutoRowProcessing
        formRegion: @card-region-details-product
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 4098804221673017642
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Product Search Configuration
        }
    )

    process process-form-store-details (
        name: "Process form Store Details "
        type: formAutoRowProcessing
        formRegion: @card-region-details-store
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 4098813155690084057
        }
        serverSideCondition {
            type: item=value
            item: P304_CONFIG
            value: Store Search Configuration
        }
    )

)

