page 6 (
    name: Row Header
    alias: ROW-HEADER
    title: Row Header
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .a-GV-rowHeader {
              font-weight: bold;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview-row-header (
        name: Overview: Row Header
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>An editable Interactive Grid will have a selection row header by default but you can add one to any grid. Create a new column and select Row Selector for the type. The name doesn't matter because it is not seen. The order also doesn't matter because the selection row header is always the first column. In fact it isn't really a column at all. It is treated special. It has no data source and is always frozen at the start of the grid. It allows you to configure settings related to single or multiple selection, select all, and showing a checkbox or radio button control. 
                </p>
                <p>This example shows the default settings. Play around with the Enable Multi Select, Show Select All, and Hide Control settings. Multiple selection and select all are independent of having a row header. These settings and more can be controlled with advanced configuration as the next two examples show.
                </p>
                <p>The Row Selector as a selection row header should not be confused with the Use As Row Header column attribute which is used for accessiblity. It is a best practice to select at least one column that best represents the contents of the row. This example has set the ENAME column to Use As Row Header. In addition to making the column value the accessible row header for assistive technology it also adds the "a-GV-rowHeader" class to the cell. In this example a custom CSS rule is added to the page to make the text bold.</p>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region row-header (
        name: Row Header
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select EMPNO,
                       ENAME,
                       JOB,
                       MGR,
                       HIREDATE,
                       SAL,
                       COMM,
                       DEPTNO,
                       ONLEAVE,
                       NOTES
                  from EBA_DEMO_IG_EMP
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: emp
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            showTotalCount: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 1948334986570898107
        }

        savedReport 14443 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @EMPNO
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @DEPTNO
                layout {
                    width: 162
                    sequence: 4
                }
            )

            displayColumn (
                column: @ENAME
                layout {
                    width: 106
                    sequence: 2
                }
            )

            displayColumn (
                column: @JOB
                layout {
                    width: 86
                    sequence: 3
                }
            )

            displayColumn (
                column: @MGR
                layout {
                    width: 95
                    sequence: 5
                }
            )

            displayColumn (
                column: @HIREDATE
                layout {
                    width: 125
                    sequence: 6
                }
            )

            displayColumn (
                column: @SAL
                layout {
                    width: 95
                    sequence: 7
                }
            )

            displayColumn (
                column: @COMM
                layout {
                    width: 104
                    sequence: 8
                }
            )

            displayColumn (
                column: @ONLEAVE
                layout {
                    width: 85
                    sequence: 9
                }
            )

            displayColumn (
                column: @NOTES
                layout {
                    sequence: 10
                }
            )

            sort (
                column: @ENAME
                sort {
                    direction: desc
                    nulls: last
                    sequence: 2
                }
            )

            sort (
                column: @JOB
                sort {
                    nulls: last
                    sequence: 1
                }
            )

        )

        column COMM (
            type: numberField
            heading {
                heading: Comm
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            source {
                databaseColumn: COMM
                dataType: number
            }
        )

        column DEPTNO (
            type: selectList
            heading {
                heading: Department
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select dname, deptno 
                    from eba_demo_ig_dept
                    ```
            }
            layout {
                sequence: 90
            }
            source {
                databaseColumn: DEPTNO
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column EMPNO (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: EMPNO
                dataType: number
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ENAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            accessibility {
                valueIdentifiesRow: true
            }
            validation {
                maxLength: 60
            }
            source {
                databaseColumn: ENAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column HIREDATE (
            type: datePickerJquery
            heading {
                heading: Hire Date
            }
            layout {
                sequence: 60
            }
            source {
                databaseColumn: HIREDATE
                dataType: date
            }
        )

        column JOB (
            type: textField
            heading {
                heading: Job
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 9
            }
            source {
                databaseColumn: JOB
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column MGR (
            type: selectList
            heading {
                heading: Manager
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ename, empno 
                    from eba_demo_ig_emp
                    ```
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: MGR
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column NOTES (
            type: textField
            heading {
                heading: Notes
            }
            layout {
                sequence: 110
            }
            validation {
                maxLength: 1000
            }
            source {
                databaseColumn: NOTES
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column ONLEAVE (
            type: checkbox
            heading {
                heading: On Leave
                alignment: center
            }
            layout {
                sequence: 100
                columnAlignment: center
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: ONLEAVE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column "Row Header" (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column SAL (
            type: numberField
            heading {
                heading: Salary
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            source {
                databaseColumn: SAL
                dataType: number
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 7
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 5
                action: resetPagination
            }
        }
    )

)

