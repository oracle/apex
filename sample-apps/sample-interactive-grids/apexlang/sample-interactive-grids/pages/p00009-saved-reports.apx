page 9 (
    name: Saved Reports
    alias: SAVED-REPORTS
    title: Saved Reports
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview-saved-reports (
        name: Overview: Saved Reports
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Like Interactive Reports, Interactive Grids allow the developer and optionally the end user to save customized reports. 
                Reports can be public or private. See attribute Enable Users To: Save Public Reports. It has been set to yes for this example.
                This example has a report called Salary by Department. It has a control break set for department and an Average aggregation 
                on the Salary column.
                </p>
                <p>This report has variable height rows by setting the Fixed Row Height propety to Off.</p>
                <p>By default the width of columns stretch to fill the availble window width. Both of
                these reports are saved with the user setting Actions > Format > Stretch Column Widths unchecked.
                </p>
                <p>Interactive Grid has some new features related to saving reports<br>
                <ul>
                <li>The UI for saving report settings has been improved. See the Actions > Report sub menu.</li>
                <li>The primary report can be given a name other than Primary. Here it is named Main.</li>
                <li>The alternative report can have an authorization to control who has access to it.</li>
                <li>The collapsed/expanded state of report setting is saved along with the report.</li>
                </ul>
                </p>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region saved-reports (
        name: Saved Reports
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select EMPNO,
                       ENAME,
                       JOB,
                       MGR,
                       HIREDATE,
                       SAL,
                       COMM,
                       DEPTNO,
                       ONLEAVE,
                       NOTES
                  from EBA_DEMO_IG_EMP
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: emp
        }
        componentAppearance {
            showNullValuesAs: -
            fixedRowHeight: false
        }
        pagination {
            showTotalCount: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        enableUsersTo {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2604997835277365660
        }

        savedReport Main (
            visibility: primary
            name: Main
            view {
                default: grid
                stretchColumns: false
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @EMPNO
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @DEPTNO
                layout {
                    width: 119
                    sequence: 4
                }
            )

            displayColumn (
                column: @ENAME
                layout {
                    width: 82
                    sequence: 2
                }
            )

            displayColumn (
                column: @JOB
                layout {
                    width: 83
                    sequence: 3
                }
            )

            displayColumn (
                column: @MGR
                layout {
                    width: 85
                    sequence: 5
                }
            )

            displayColumn (
                column: @HIREDATE
                layout {
                    width: 86
                    sequence: 6
                }
            )

            displayColumn (
                column: @SAL
                layout {
                    width: 79
                    sequence: 8
                }
            )

            displayColumn (
                column: @COMM
                layout {
                    width: 77
                    sequence: 7
                }
            )

            displayColumn (
                column: @ONLEAVE
                layout {
                    width: 72
                    sequence: 9
                }
            )

            displayColumn (
                column: @NOTES
                layout {
                    width: 377
                    sequence: 10
                }
            )

            sort (
                column: @DEPTNO
                sort {
                    nulls: last
                    sequence: 1
                }
            )

            sort (
                column: @ENAME
                sort {
                    nulls: last
                    sequence: 2
                }
            )

        )

        savedReport salary (
            visibility: alternative
            name: Salary by Department
            view {
                default: grid
                stretchColumns: false
                settingsAreaExpanded: false
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @EMPNO
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @DEPTNO
                layout {
                    show: false
                    width: 115
                    sequence: 4
                }
            )

            displayColumn (
                column: @ENAME
                layout {
                    width: 83
                    sequence: 2
                }
            )

            displayColumn (
                column: @JOB
                layout {
                    width: 83
                    sequence: 3
                }
            )

            displayColumn (
                column: @MGR
                layout {
                    width: 102
                    sequence: 5
                }
            )

            displayColumn (
                column: @HIREDATE
                layout {
                    width: 93
                    sequence: 6
                }
            )

            displayColumn (
                column: @SAL
                layout {
                    width: 85
                    sequence: 8
                }
            )

            displayColumn (
                column: @COMM
                layout {
                    width: 78
                    sequence: 7
                }
            )

            displayColumn (
                column: @ONLEAVE
                layout {
                    width: 79
                    sequence: 9
                }
            )

            displayColumn (
                column: @NOTES
                layout {
                    width: 221
                    sequence: 10
                }
            )

            sort (
                column: @ENAME
                sort {
                    nulls: last
                    sequence: 1
                }
            )

            aggregate avg (
                column: @SAL
                function: average
                showGrandTotal: true
                tooltip: Average
            )

            controlBreak (
                column: @DEPTNO
                sort {
                    nulls: last
                }
                layout {
                    sequence: 1
                }
            )

        )

        column COMM (
            type: numberField
            heading {
                heading: Comm
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
            source {
                databaseColumn: COMM
                dataType: number
            }
        )

        column DEPTNO (
            type: selectList
            heading {
                heading: Department
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select dname, deptno 
                    from eba_demo_ig_dept
                    ```
            }
            layout {
                sequence: 90
            }
            source {
                databaseColumn: DEPTNO
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column EMPNO (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: EMPNO
                dataType: number
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ENAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            validation {
                maxLength: 60
            }
            source {
                databaseColumn: ENAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column HIREDATE (
            type: datePickerJquery
            heading {
                heading: Hire Date
            }
            layout {
                sequence: 60
            }
            source {
                databaseColumn: HIREDATE
                dataType: date
            }
        )

        column JOB (
            type: textField
            heading {
                heading: Job
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 9
            }
            source {
                databaseColumn: JOB
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column MGR (
            type: selectList
            heading {
                heading: Manager
            }
            lov {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select ename, empno 
                    from eba_demo_ig_emp
                    ```
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: MGR
                dataType: number
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column NOTES (
            type: textField
            heading {
                heading: Notes
            }
            layout {
                sequence: 110
            }
            validation {
                maxLength: 1000
            }
            source {
                databaseColumn: NOTES
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column ONLEAVE (
            type: checkbox
            heading {
                heading: On Leave
                alignment: center
            }
            layout {
                sequence: 100
                columnAlignment: center
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: ONLEAVE
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column SAL (
            type: numberField
            heading {
                heading: Salary
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
            source {
                databaseColumn: SAL
                dataType: number
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 8
                action: resetPagination
            }
        }
    )

)

