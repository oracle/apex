            )

        )

        column AGE (
            type: textField
            heading {
                heading: Age
                alignment: end
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            source {
                databaseColumn: AGE
                dataType: number
            }
        )

        column CATEGORY (
            type: displayOnly
            heading {
                heading: Category
            }
            settings {
                basedOn: lov
            }
            lov {
                type: sharedComponent
                lov: @people-categories
            }
            layout {
                sequence: 100
            }
            source {
                databaseColumn: CATEGORY
                dataType: varchar2
            }
            columnFilter {
