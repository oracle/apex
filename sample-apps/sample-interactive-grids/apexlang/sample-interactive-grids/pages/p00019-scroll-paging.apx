page 19 (
    name: Scroll Paging
    alias: SCROLL-PAGING
    title: Scroll Paging
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        fileUrls: #APP_FILES#sample-interactive-grid#MIN#.css
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview-scroll-paging (
        name: Overview: Scroll Paging
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>An exciting new feature of Interactive Grids is scroll paging (also known as infinite scrolling or virtual paging). To use scroll paging set the Pagination: Type to Scroll and Show Total Row Count to Yes. Note that scroll paging applies to Icon and Details views as well.
                </p>
                <p>The region appears to contain the entire result set but rows are rendered on demand as the user scrolls. In turn the model fetches data from the server as it is needed by the view. You can even drag the scroll bar handle all the way to the bottom (or press the Ctrl+End key) and then scroll up. The Interactive Grid does not need to fetch or render all the data from the start to finish of the result set. Only the data that needs to be displayed is rendered or fetched into the model. This means there can be holes in what is rendered or in the model. These holes are filled in as the user scrolls. Notice that the Rows Per Page menu option is not available because it is not needed.
                </p>
                <p>Note that the Category column wraps because Fixed Row Height option is off. Try making some columns wider to see how the frozen columns work with scroll paging.</p>
                <p>With large data sets and scroll paging a lot of data can accumulate on the client. Most of the time this is not a problem because the user will tire of scrolling and resort to searching or filtering.
                </p>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        comments {
            comments:
                ```
                Add this text once the features are implemented: 
                The Performance: Maximum Row Count and Requires Filter attributes can be used to limit the size of the results.
                ```
        }
    )

    region scroll-paging (
        name: Scroll Paging
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID, RATING, NAME, COUNTRY, FROM_YR,
                        TO_YR,
                        LINK, CATEGORY,
                        coalesce( to_yr, extract(year from sysdate) ) - FROM_YR as AGE,
                        case CATEGORY
                            when 'S_T' then 'fa fa-rocket'
                            when 'P' then 'fa fa-university'
                            when 'A' then 'fa fa-paint-brush'
                            when 'S' then 'fa fa-bicycle'
                            when 'B_L' then 'fa fa-money'
                            else 'fa fa-question'
                        end as ICON,
                        case CATEGORY
                            when 'S_T' then 'Science & Technology'
                            when 'P' then 'Politics'
                            when 'A' then 'Art'
                            when 'S' then 'Sports'
                            when 'B_L' then 'Business & Law'
                            else 'Undefined'
                        end as DISPLAY_CATEGORY,
                        GENDER
                    from EBA_DEMO_IG_PEOPLE
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: people
        }
        componentAppearance {
            showNullValuesAs: -
            fixedRowHeight: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        heading {
            fixedTo: region
            fixedReportHeight: 518
        }
        iconView {
            show: true
            custom: true
            customIcon:
                ```html
                <li class="t-Cards-item" data-id='&APEX$ROW_ID.'>
                    <div class="t-Card">
                        <div class="t-Card-wrap">
                            <div class="t-Card-icon u-color"><span class="t-Icon &ICON."></span></div>
                            <div class="t-Card-titleWrap"><h3 class="t-Card-title">&NAME.</h3></div>
                            <div class="t-Card-body">
                                <div class="t-Card-desc">Country: &COUNTRY.<br>Age: &AGE.</div>
                                <div class="t-Card-info">&DISPLAY_CATEGORY.</div>
                            </div>
                        </div>
                    </div>
                </li>
                ```
        }
        detailView {
            show: true
            beforeRows: <ul class="t-MediaList t-MediaList--showDesc t-MediaList--showIcons t-MediaList--showBadges">
            forEachRow:
                ```html
                <li class="t-MediaList-item  ">
                    <div class="t-MediaList-itemWrap">
                        <div class="t-MediaList-iconWrap">
                            <span class="t-MediaList-icon"><span class="t-Icon fa &ICON."></span></span>
                        </div>
                        <div class="t-MediaList-body">
                            <h3 class="t-MediaList-title">&NAME.</h3>
                            <p class="t-MediaList-desc">
                                Country: &COUNTRY.<br>
                                Born: &FROM_YR.<br>
                                Age: &AGE.
                            </p>
                        </div>
                        <div class="t-MediaList-badgeWrap">
                            <span class="t-MediaList-badge">&DISPLAY_CATEGORY.</span>
                        </div>
                    </div>
                </li>
                ```
            afterRows: </ul>
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    config.defaultGridViewOptions = {
                        rowHeader: "sequence"
                    };
                    config.defaultIconViewOptions = {
                        collectionClasses: "t-Cards t-Cards--5cols t-Cards--animColorFill t-Cards--basic t-Cards--displayIcons u-colors"
                    };
                    return config; // don't forget to return this!
                }
                
                ```
        }
        advanced {
            savedReportMappingIdentifier: 4684364841614685161
        }

        savedReport 14463 (
