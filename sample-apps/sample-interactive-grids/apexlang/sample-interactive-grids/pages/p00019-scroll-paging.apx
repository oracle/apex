            displayColumn (
                column: @RATING
                layout {
                    width: 115
                    sequence: 3
                }
            )

            displayColumn (
                column: @NAME
                layout {
                    frozen: true
                    width: 703
                    sequence: 2
                }
            )

            displayColumn (
                column: @COUNTRY
                layout {
                    width: 155
                    sequence: 4
                }
            )

            displayColumn (
                column: @FROM_YR
                layout {
                    width: 112
                    sequence: 5
                }
            )

            displayColumn (
