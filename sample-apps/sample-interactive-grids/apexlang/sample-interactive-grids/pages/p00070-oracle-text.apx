page 70 (
    name: Oracle Text
    alias: ORACLE-TEXT
    title: Oracle Text
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region oracle-text (
        name: Oracle Text
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region oracle-text-index-does-not-exist (
        name: Oracle Text Index does not exist
        type: staticContent
        source {
            htmlCode: <p>Oracle Text is available in your workspace, but the Full Text index does not exist yet.</p>
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1 from user_indexes
                where index_name='EBA_DEMO_IG_TEXT_FTX'
                ```
        }
        security {
            authorizationScheme: @oracle-text-is-available
        }
    )

    region oracle-text-is-not-available (
        name: Oracle Text is not available
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Oracle Text is not available in your workspace. Contact your database administrator to get the <strong>CTXAPP</strong> role granted using the following SQL statement.</p>
                <pre>grant CTXAPP to #OWNER#;</pre>
                <p>Then log out and back into the application and revisit this page. </p>
                ```
        }
        layout {
            sequence: 30
            slot: body
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        security {
            authorizationScheme: !@oracle-text-is-available
        }
    )

    region overview-oracle-text (
        name: Overview: Oracle Text
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This page shows how Oracle Text can be used within an Interactive Grid to perform full-text search using linguistic features. An Oracle Text index has been created on your table. Consult the <i>Oracle Text Application Developers Guide</i> for details. For performance reasons, only one Oracle Text index may be used within an Interactive Grid. In Page Designer, navigate to the Attribute Section, then to <strong>Oracle Text Index Column</strong> and select the table column, for which the Oracle Text index has been created.</p>
                <p>In this example, Oracle Text features are available to search the <b>Name</b> and <b>Country</b> columns with the Interactive Grid <i>Row Filter</i>. Type your query (or one of the below examples) into the <b>Search: Full text</b> field. Your query is automatically translated to Oracle Text query syntax by the <b>EBA_DEMO_IG_TEXT_PKG.CONVERT_TEXT_QUERY</b> function. It will find exact as well as fuzzy matches.</p>
                </p>
                <p>Query Examples (fuzzy logic will find results)</p>
                <ul>
                <li>Julius Caesar</li>
                <li>gustav eifel</li>
                <li>armstong states</li>
                </ul>
                <p>You can also type in Oracle Text query syntax directly; simply prefix your query with <b>ORATEXT:</b>. For details about the query syntax, consult the <i>Oracle Text Application Developers' Guide</i>.</p>
                <ul>
                <li>ORATEXT: Julius and ?Itali</li>
                <li>ORATEXT: Einstein and Germany</li>
                </ul>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                i-h240
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from user_indexes
                where index_name='EBA_DEMO_IG_TEXT_FTX'
                ```
        }
        security {
            authorizationScheme: @oracle-text-is-available
        }
    )

    region people (
        name: People
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       RATING,
                       NAME,
                       COUNTRY,
                       TO_CHAR(FROM_YR) as FROM_YR,
                       case when TO_YR = 0 then '' else TO_CHAR(TO_YR) end as TO_YR, 
                       gender
                  from EBA_DEMO_IG_PEOPLE
                
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from user_indexes
                where index_name='EBA_DEMO_IG_TEXT_FTX'
                ```
        }
        security {
            authorizationScheme: @oracle-text-is-available
        }
        componentAppearance {
            showNullValuesAs: -
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        componentAdvanced {
            oracleTextIndexColumn: NAME
        }
        advanced {
            savedReportMappingIdentifier: 1155231413590489502
        }

        savedReport 14512 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @ID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @RATING
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @NAME
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @COUNTRY
                layout {
                    sequence: 4
                }
            )

            displayColumn (
                column: @FROM_YR
                layout {
                    sequence: 5
                }
            )

            displayColumn (
                column: @TO_YR
                layout {
                    sequence: 6
                }
            )

            displayColumn (
                column: @GENDER
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @ROWID
                layout {
                    sequence: 8
                }
            )

        )

        column COUNTRY (
            type: textField
            heading {
                heading: Country
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: COUNTRY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column FROM_YR (
            type: numberField
            heading {
                heading: Born
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 50
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: FROM_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
        )

        column GENDER (
            type: selectList
            heading {
                heading: Gender
            }
            lov {
                type: sharedComponent
                lov: @people-gender
                displayExtraValues: false
                displayNullValue: false
            }
            layout {
                sequence: 100
            }
            source {
                databaseColumn: GENDER
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ID
                dataType: number
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column NAME (
            type: textarea
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            validation {
                maxLength: 255
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
            enableUsersTo {
                sort: false
            }
        )

        column RATING (
            type: numberField
            heading {
                heading: Rating
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 20
                columnAlignment: end
            }
            source {
                databaseColumn: RATING
                dataType: number
            }
            columnFilter {
                lovType: none
            }
        )

        column ROWID (
            type: hidden
            layout {
                sequence: 110
            }
            source {
                databaseColumn: ROWID
                dataType: rowid
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column TO_YR (
            type: numberField
            heading {
                heading: Died
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: TO_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: none
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        columnHeadings {
            fontWeight: normal
            backgroundColor: #9bafde
        }
        columns {
            backgroundColor: #efefef
        }
    )

    button create-text-index (
        buttonName: CREATE_TEXT_INDEX
        label: Create Oracle Text index
        layout {
            sequence: 10
            region: @oracle-text-index-does-not-exist
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @oracle-text-is-available
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 20
            region: @oracle-text
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 38
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @oracle-text
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 14
                action: resetPagination
            }
        }
    )

    process create-oracle-text-index (
        name: Create Oracle Text Index
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    eba_demo_ig_text_pkg.drop_text_preferences;
                    eba_demo_ig_text_pkg.create_text_preferences;
                    eba_demo_ig_text_pkg.create_text_index;
                end;
                
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 1157744413283168864
        }
        security {
            authorizationScheme: @oracle-text-is-available
        }
    )

)

