    process maintain-log (
        name: Maintain log
        type: executeCode
        editableRegion: @basic-editing
        source {
            plsqlCode:
                ```plsql
                begin
                  if not apex_collection.collection_exists( p_collection_name => 'IG_OPERATIONS' ) then
                     apex_collection.create_collection( p_collection_name => 'IG_OPERATIONS' );
                  end if;
                
                  apex_collection.add_member(
                      p_collection_name => 'IG_OPERATIONS', 
                      p_d001 => sysdate,
                      p_c001 => :EMPNO,
                      p_c002 => :ENAME,
                      p_c003 => :JOB,
                      p_c004 => :HIREDATE,
                      p_c005 => :SAL,
                      p_c006 => :COMM,
                      p_c007 => :MGR,
                      p_c008 => :DEPTNO,
                      p_c009 => :ONLEAVE, 
                      p_c010 => :NOTES,
                      p_c011 => :RATING, 
                      p_c012 => :APEX$ROW_STATUS
                  );
                 end;
                
                
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 1863235105700192079
        }
    )

    process save-interactive-grid-data (
        name: " - Save Interactive Grid Data"
