    dynamicAction validate-comm (
        name: Validate COMM
        execution {
            sequence: 20
        }
        when {
            selectionType: columns
            interactiveGrid: @client-validation
            columns: COMM
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var comm = apex.item("cComm"),
                        num = comm.getValue();
                    if ( num !== "" && (parseFloat(num) != num || num < 0 || num > 10000)) {
                        comm.node.setCustomValidity("invalid number"); // this message is only shown if there is no data-valid-message attribute on the column item
                    } else {
                        comm.node.setCustomValidity(""); // clear the error
                    }
                    
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction validate-comm-limit (
        name: Validate comm limit
        execution {
            sequence: 30
        }
        when {
            event: custom
            customEvent: apexendrecordedit
            selectionType: region
            region: @client-validation
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var validity, message,
                        ui = this.data,
                        sal = $v("cSal"),
                        comm = $v("cComm");
                    
                    if ( comm == "" || comm < 1.5 * sal ) {
                        validity = "valid";
                    } else {
                        validity = "error";
                        // use apex.lang api if you want to localize this message
                        message = "Commission must be less than 1.5 times the Salary";
                    }
                    // passing null for the field set the error on the whole row/record
                    ui.model.setValidity(validity, ui.recordId, null, message);
                    
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction validate-sal (
        name: Validate SAL
        execution {
            sequence: 10
        }
        when {
            selectionType: columns
            interactiveGrid: @client-validation
            columns: SAL
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var sal = apex.item("cSal"),
                        num = sal.getValue();
                    if ( num !== "" && (parseFloat(num) != num || num < 0 || num > 10000)) {
                        sal.node.setCustomValidity("invalid number"); // this message is only shown if there is no data-valid-message attribute on the column item
                    } else {
                        sal.node.setCustomValidity(""); // clear the error
                    }
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    validation comm-in-range (
        name: comm in range
        execution {
            sequence: 70
        }
        validation {
            editableRegion: @client-validation
            plsqlExpression: :COMM is null or (to_number(:COMM) > 0 and to_number(:COMM) < 10000)
        }
        error {
            errorMessage: #COLUMN_HEADER# must be between 0 and 10,000.
            associatedColumn: COMM
        }
    )

    validation comm-limit (
        name: Comm limit
        execution {
            sequence: 80
        }
        validation {
            editableRegion: @client-validation
            plsqlExpression: :COMM is null or to_number(:COMM) < 1.5 * to_number(:SAL)
        }
        error {
            errorMessage: Commission must be less than 1.5 times the Salary
        }
    )

    validation hire-date-in-past (
        name: hire date in past
        execution {
            sequence: 20
        }
        validation {
            editableRegion: @client-validation
            plsqlExpression: to_date(:HIREDATE) < SYSDATE
        }
        error {
            errorMessage: #COLUMN_HEADER# must be in the past.
            associatedColumn: HIREDATE
        }
    )

    validation no-special-characters (
        name: No special characters
        execution {
            sequence: 90
        }
        validation {
            editableRegion: @client-validation
            plsqlExpression: "REGEXP_INSTR(:ENAME, '^[-A-Z'' a-z]*$') = 1"
        }
        error {
            errorMessage: #COLUMN_HEADER# must not contain special characters or numbers.
            associatedColumn: ENAME
        }
    )

    validation sal-in-range (
        name: sal in range
        execution {
            sequence: 60
        }
        validation {
            editableRegion: @client-validation
            plsqlExpression: :SAL is null or ( to_number(:SAL) > 0 and to_number(:SAL) < 10000 )
        }
        error {
            errorMessage: #COLUMN_HEADER# must be between 0 and 10,000.
            associatedColumn: SAL
        }
    )

    process save-interactive-grid-data (
        name: " - Save Interactive Grid Data"
        type: interactiveGridAutoRowProcessing
        editableRegion: @client-validation
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 723455454843136978
        }
    )

)

