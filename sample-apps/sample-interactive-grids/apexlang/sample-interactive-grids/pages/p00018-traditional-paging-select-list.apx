page 18 (
    name: Traditional Paging (Select List)
    alias: TRADITIONAL-PAGING-SELECT-LIST
    title: Traditional Paging (Select List)
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        fileUrls: #APP_FILES#sample-interactive-grid#MIN#.css
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview-traditional-paging-select-list (
        name: Overview: Traditional Paging (Select List)
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This example uses advanced configuration (see Advanced: Initialization JavaScript Function attribute)
                to display a drop down select list of all the pages rather than a list of links.
                </p>
                <p>A minor difference to icon view is that the width of the icons uses a percentage
                so that there will be 3 items per row. This could be combined with media queries for responsive design.
                </p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region traditional-paging-select-list (
        name: Traditional Paging (Select List)
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID, RATING, NAME, COUNTRY, TO_CHAR(FROM_YR) as FROM_YR,
                        to_char(TO_YR) as TO_YR,
                        LINK, CATEGORY,
                        coalesce( to_yr, extract(year from sysdate) ) - FROM_YR as AGE,
                        case CATEGORY
                            when 'S_T' then 'fa fa-rocket'
                            when 'P' then 'fa fa-university'
                            when 'A' then 'fa fa-paint-brush'
                            when 'S' then 'fa fa-bicycle'
                            when 'B_L' then 'fa fa-money'
                            else 'fa fa-question'
                        end as ICON,
                        case CATEGORY
                            when 'S_T' then 'Science & Technology'
                            when 'P' then 'Politics'
                            when 'A' then 'Art'
                            when 'S' then 'Sports'
                            when 'B_L' then 'Business & Law'
                            else 'Undefined'
                        end as DISPLAY_CATEGORY,
                        GENDER
                    from EBA_DEMO_IG_PEOPLE
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: people
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: page
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        heading {
            fixedTo: region
            fixedReportHeight: 518
        }
        iconView {
            show: true
            custom: true
            customIcon:
                ```html
                <li class="t-Cards-item" data-id='&APEX$ROW_ID.'>
                    <div class="t-Card">
                        <div class="t-Card-wrap">
                            <div class="t-Card-icon u-color"><span class="t-Icon &ICON."></span></div>
                            <div class="t-Card-titleWrap"><h3 class="t-Card-title">&NAME.</h3></div>
                            <div class="t-Card-body">
                                <div class="t-Card-desc">Country: &COUNTRY.<br>Age: &AGE.</div>
                                <div class="t-Card-info">&DISPLAY_CATEGORY.</div>
                            </div>
                        </div>
                    </div>
                </li>
                ```
        }
        detailView {
            show: true
            beforeRows:
                ```html
                <ul class="t-MediaList t-MediaList--showDesc t-MediaList--showIcons t-MediaList--showBadges">
                
                ```
            forEachRow:
                ```html
                <li class="t-MediaList-item  ">
                    <div class="t-MediaList-itemWrap">
                        <div class="t-MediaList-iconWrap">
                            <span class="t-MediaList-icon"><span class="t-Icon fa &ICON."></span></span>
                        </div>
                        <div class="t-MediaList-body">
                            <h3 class="t-MediaList-title">&NAME.</h3>
                            <p class="t-MediaList-desc">
                                Country: &COUNTRY.<br>
                                Born: &FROM_YR.<br>
                                Age: &AGE.
                            </p>
                        </div>
                        <div class="t-MediaList-badgeWrap">
                            <span class="t-MediaList-badge">&DISPLAY_CATEGORY.</span>
                        </div>
                    </div>
                </li>
                
                ```
            afterRows: </ul>
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    var paginationSettings = {
                            showRange: true,
                            showPageSelector: true,
                            showPageLinks: false,
                // uncomment to hide the first and last buttons
                //            firstAndLastButtons: false
                        };
                
                    config.defaultGridViewOptions = {
                        rowHeader: "sequence",
                        pagination: paginationSettings
                    };
                    config.defaultIconViewOptions = {
                        collectionClasses: "t-Cards t-Cards--5cols t-Cards--animColorFill t-Cards--basic t-Cards--displayIcons u-colors",
                        pagination: paginationSettings
                    };
                    config.defaultDetailViewOptions = {
                        pagination: paginationSettings
                    }
                    return config; // don't forget to return this!
                }
                ```
        }
        advanced {
            savedReportMappingIdentifier: 6077277603966851608
        }

        savedReport 14461 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @ID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @RATING
                layout {
                    width: 93
                    sequence: 2
                }
            )

            displayColumn (
                column: @NAME
                layout {
                    width: 218
                    sequence: 3
                }
            )

            displayColumn (
                column: @COUNTRY
                layout {
                    width: 214
                    sequence: 4
                }
            )

            displayColumn (
                column: @FROM_YR
                layout {
                    width: 85
                    sequence: 5
                }
            )

            displayColumn (
                column: @TO_YR
                layout {
                    width: 91
                    sequence: 6
                }
            )

            displayColumn (
                column: @AGE
                layout {
                    width: 73
                    sequence: 7
                }
            )

            displayColumn (
                column: @LINK
                layout {
                    sequence: 8
                }
            )

            displayColumn (
                column: @CATEGORY
                layout {
                    width: 212
                    sequence: 9
                }
            )

            displayColumn (
                column: @ICON
                layout {
                    sequence: 10
                }
            )

            displayColumn (
                column: @GENDER
                layout {
                    width: 84
                    sequence: 11
                }
            )

            displayColumn (
                column: @DISPLAY_CATEGORY
                layout {
                    sequence: 12
                }
            )

            sort (
                column: @RATING
                sort {
                    direction: desc
                    nulls: last
                    sequence: 1
                }
            )

        )

        column AGE (
            type: textField
            heading {
                heading: Age
                alignment: end
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            source {
                databaseColumn: AGE
                dataType: number
            }
        )

        column CATEGORY (
            type: displayOnly
            heading {
                heading: Category
            }
            settings {
                basedOn: lov
            }
            lov {
                type: sharedComponent
                lov: @people-categories
            }
            layout {
                sequence: 100
            }
            source {
                databaseColumn: CATEGORY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column COUNTRY (
            type: textField
            heading {
                heading: Country
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: COUNTRY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column DISPLAY_CATEGORY (
            type: hidden
            layout {
                sequence: 130
            }
            source {
                databaseColumn: DISPLAY_CATEGORY
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column FROM_YR (
            type: textField
            heading {
                heading: Born
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: FROM_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column GENDER (
            type: displayOnly
            heading {
                heading: Gender
            }
            settings {
                basedOn: lov
            }
            lov {
                type: sharedComponent
                lov: @people-gender
            }
            layout {
                sequence: 120
            }
            source {
                databaseColumn: GENDER
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column ICON (
            type: hidden
            layout {
                sequence: 110
            }
            source {
                databaseColumn: ICON
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column LINK (
            type: hidden
            layout {
                sequence: 90
            }
            source {
                databaseColumn: LINK
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 255
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column RATING (
            type: textField
            heading {
                heading: Popularity
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            source {
                databaseColumn: RATING
                dataType: number
            }
        )

        column "Row Header" (
            type: rowSelector
            settings {
                enableMultiSelect: false
                hideControl: true
            }
            layout {
                sequence: 10
            }
        )

        column TO_YR (
            type: textField
            heading {
                heading: Died
                alignment: end
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: TO_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 19
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 17
                action: resetPagination
            }
        }
    )

)

