page 11 (
    name: Traditional Paging
    alias: TRADITIONAL-PAGING
    title: Traditional Paging
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        fileUrls: #APP_FILES#sample-interactive-grid#MIN#.css
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview-traditional-paging (
        name: Overview: Traditional Paging
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>All the previous examples have used the default Pagination settings; Type: Scroll and Show Total Row Count: No. These next few examples will explore the pagination options. For illustrative purposes these examples use a <a href='f?p=&APP_ID.:7:&SESSION.::'>sequence number</a> in the row header. They also include icon and detail views to show how they work with the same pagination settings.
                </p>
                <p>This page uses Pagination Type: Page and Show Total Row Count: No. It also has a fixed size region with the headers fixed to the region. When type is Page it results in pagination controls in the footer of the Interactive Grid. Show Total Row Count really determines if the database counts the total number of rows in the query result set. When the total number of rows is not known then only the range of rows (For example 1 - 50) and Next and Previous buttons can be shown. The Auto setting for Actions menu Rows Per Page lets the grid choose the number of rows based on the height of the grid. The general idea is that the user should either be paging or scrolling but not both.
                </p>
                <p>You may notice that as you click Next page sometimes the progress spinner is shown indicating that data is being fetched from the server and sometimes it isn't. An important difference between Interactive Report and Interactive Grid is that the latter has distinct data (model) and view layers. This is known as model view separation. The view shows just a portion of the rows in the model and the model is responsible for getting more data from the server when needed. This is critical for editable grids and for scroll paging but always in effect even for traditional paging.
                </p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region traditional-paging (
        name: Traditional Paging
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID, RATING, NAME, COUNTRY, TO_CHAR(FROM_YR) as FROM_YR,
                        to_char( TO_YR ) as to_yr,
                        LINK, CATEGORY,
                        coalesce( to_yr, extract(year from sysdate) ) - FROM_YR as age,
                        case CATEGORY
                            when 'S_T' then 'fa fa-rocket'
                            when 'P' then 'fa fa-university'
                            when 'A' then 'fa fa-paint-brush'
                            when 'S' then 'fa fa-bicycle'
                            when 'B_L' then 'fa fa-money'
                            else 'fa fa-question'
                        end as ICON,
                        case CATEGORY
                            when 'S_T' then 'Science & Technology'
                            when 'P' then 'Politics'
                            when 'A' then 'Art'
                            when 'S' then 'Sports'
                            when 'B_L' then 'Business & Law'
                            else 'Undefined'
                        end as DISPLAY_CATEGORY,
                        GENDER
                    from EBA_DEMO_IG_PEOPLE
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: people
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: page
            showTotalCount: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        heading {
            fixedTo: region
            fixedReportHeight: 518
        }
        iconView {
            show: true
            custom: true
            customIcon:
                ```html
                <li class="t-Cards-item" data-id='&APEX$ROW_ID.'>
                    <div class="t-Card">
                        <div class="t-Card-wrap">
                            <div class="t-Card-icon u-color"><span class="t-Icon &ICON."></span></div>
                            <div class="t-Card-titleWrap"><h3 class="t-Card-title">&NAME.</h3></div>
                            <div class="t-Card-body">
                                <div class="t-Card-desc">Country: &COUNTRY.<br>Age: &AGE.</div>
                                <div class="t-Card-info">&DISPLAY_CATEGORY.</div>
                            </div>
                        </div>
                    </div>
                </li>
                ```
        }
        detailView {
            show: true
            beforeRows: <ul class="t-MediaList t-MediaList--showDesc t-MediaList--showIcons t-MediaList--showBadges">
            forEachRow:
                ```html
                <li class="t-MediaList-item  ">
                    <div class="t-MediaList-itemWrap">
                        <div class="t-MediaList-iconWrap">
                            <span class="t-MediaList-icon"><span class="t-Icon fa &ICON."></span></span>
                        </div>
                        <div class="t-MediaList-body">
                            <h3 class="t-MediaList-title">&NAME.</h3>
                            <p class="t-MediaList-desc">
                                Country: &COUNTRY.<br>
                                Born: &FROM_YR.<br>
                                Age: &AGE.
                            </p>
                        </div>
                        <div class="t-MediaList-badgeWrap">
                            <span class="t-MediaList-badge">&DISPLAY_CATEGORY.</span>
                        </div>
                    </div>
                </li>
                ```
            afterRows: </ul>
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    config.defaultGridViewOptions = {
                        rowHeader: "sequence"
                    };
                    config.defaultIconViewOptions = {
                        collectionClasses: "t-Cards t-Cards--5cols t-Cards--animColorFill t-Cards--basic t-Cards--displayIcons u-colors"
                    };
                    return config;
                }
                ```
        }
        advanced {
            savedReportMappingIdentifier: 3987876765427745048
        }

        savedReport 14450 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @ID
                layout {
                    sequence: 1
                }
            )

            displayColumn (
                column: @RATING
                layout {
                    width: 89
                    sequence: 2
                }
            )

            displayColumn (
                column: @NAME
                layout {
                    width: 185
                    sequence: 3
                }
            )

            displayColumn (
                column: @COUNTRY
                layout {
                    width: 133
                    sequence: 4
                }
            )

            displayColumn (
                column: @FROM_YR
                layout {
                    width: 82
                    sequence: 5
                }
            )

            displayColumn (
                column: @TO_YR
                layout {
                    width: 88
                    sequence: 6
                }
            )

            displayColumn (
                column: @AGE
                layout {
                    width: 76
                    sequence: 7
                }
            )

            displayColumn (
                column: @LINK
                layout {
                    sequence: 8
                }
            )

            displayColumn (
                column: @CATEGORY
                layout {
                    width: 152
                    sequence: 9
                }
            )

            displayColumn (
                column: @GENDER
                layout {
                    width: 67
                    sequence: 10
                }
            )

            displayColumn (
                column: @ICON
                layout {
                    sequence: 11
                }
            )

            displayColumn (
                column: @DISPLAY_CATEGORY
                layout {
                    sequence: 12
                }
            )

            sort (
                column: @RATING
                sort {
                    direction: desc
                    nulls: last
                    sequence: 1
                }
            )

        )

        column AGE (
            type: textField
            heading {
                heading: Age
                alignment: end
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            source {
                databaseColumn: AGE
                dataType: number
            }
        )

        column CATEGORY (
            type: displayOnly
            heading {
                heading: Category
            }
            settings {
                basedOn: lov
            }
            lov {
                type: sharedComponent
                lov: @people-categories
            }
            layout {
                sequence: 100
            }
            source {
                databaseColumn: CATEGORY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column COUNTRY (
            type: textField
            heading {
                heading: Country
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 50
            }
            source {
                databaseColumn: COUNTRY
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column DISPLAY_CATEGORY (
            type: hidden
            layout {
                sequence: 130
            }
            source {
                databaseColumn: DISPLAY_CATEGORY
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column FROM_YR (
            type: textField
            heading {
                heading: Born
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: FROM_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column GENDER (
            type: displayOnly
            heading {
                heading: Gender
            }
            settings {
                basedOn: lov
            }
            lov {
                type: sharedComponent
                lov: @people-gender
            }
            layout {
                sequence: 110
            }
            source {
                databaseColumn: GENDER
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
                lovType: useLov
            }
        )

        column ICON (
            type: hidden
            layout {
                sequence: 120
            }
            source {
                databaseColumn: ICON
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column ID (
            type: hidden
            layout {
                sequence: 20
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column LINK (
            type: hidden
            layout {
                sequence: 90
            }
            source {
                databaseColumn: LINK
                dataType: varchar2
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column NAME (
            type: textField
            heading {
                heading: Name
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 255
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column RATING (
            type: textField
            heading {
                heading: Popularity
                alignment: end
            }
            layout {
                sequence: 30
                columnAlignment: end
            }
            source {
                databaseColumn: RATING
                dataType: number
            }
        )

        column "Row Header" (
            type: rowSelector
            settings {
                enableMultiSelect: false
                hideControl: true
            }
            layout {
                sequence: 10
            }
        )

        column TO_YR (
            type: textField
            heading {
                heading: Died
                alignment: end
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: TO_YR
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 12
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 38
                action: resetPagination
            }
        }
    )

)

