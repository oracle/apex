page 35 (
    name: Master Detail
    alias: MASTER-DETAIL
    title: Master Detail
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 50
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region departments (
        name: Departments
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select  DEPTNO,
                        DNAME,
                        LOC,
                        NOTES
                    from EBA_DEMO_IG_DEPT
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: dept
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        messages {
            whenNoDataFound: No Departments found.
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        heading {
            fixedTo: region
            fixedReportHeight: 280
        }
        iconView {
            show: true
            custom: true
            customIcon:
                ```html
                <li data-id='&APEX$ROW_ID.'>
                <div class="t-Card">
                    <div class="t-Card-wrap">
                      <div class="t-Card-icon u-color"><span class="t-Icon fa fa-building-o"></span></div>
                      <div class="t-Card-titleWrap"><h3 class="t-Card-title">&DNAME.</h3></div>
                      <div class="t-Card-body">
                        <div class="t-Card-desc">&LOC.</div>
                        <div class="t-Card-info"></div>
                      </div>
                    </div>
                </div>
                </li>
                ```
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    // for icon view style
                    config.defaultIconViewOptions = {
                        collectionClasses: "t-Cards t-Cards--compact t-Cards--displayIcons u-colors t-Cards--desc-2ln"
                    };
                    return config; // don't forget to return this!
                }
                ```
        }
        advanced {
            savedReportMappingIdentifier: 696647637560602326
        }

        savedReport 14484 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @DEPTNO
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @DNAME
                layout {
                    width: 311
                    sequence: 3
                }
            )

            displayColumn (
                column: @LOC
                layout {
                    width: 190
                    sequence: 4
                }
            )

            displayColumn (
                column: @NOTES
                layout {
                    sequence: 6
                }
            )

        )

        column APEX$ROW_ACTION (
            type: actionsMenu
            layout {
                sequence: 20
            }
        )

        column APEX$ROW_SELECTOR (
            type: rowSelector
            layout {
                sequence: 10
            }
        )

        column DEPTNO (
            type: hidden
            layout {
                sequence: 30
            }
            source {
                databaseColumn: DEPTNO
                dataType: number
                primaryKey: true
            }
            default {
                duplicateCopiesExistingValue: false
            }
            exportPrinting {
                includeInExportPrint: false
            }
        )

        column DNAME (
            type: textField
            heading {
                heading: Department Name
            }
            layout {
                sequence: 40
            }
            validation {
                maxLength: 60
            }
            source {
                databaseColumn: DNAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column LOC (
            type: textField
            heading {
                heading: Location
            }
            layout {
                sequence: 50
            }
            validation {
                maxLength: 40
            }
            source {
                databaseColumn: LOC
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column NOTES (
            type: textField
            heading {
                heading: Notes
            }
            layout {
                sequence: 60
            }
            validation {
                maxLength: 1000
            }
            source {
                databaseColumn: NOTES
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        columnHeadings {
            fontWeight: normal
            backgroundColor: #9bafde
        }
        columns {
            backgroundColor: #efefef
        }
    )

    region employees (
        name: Employees
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select EMPNO,
                       ENAME,
                       JOB,
                       MGR,
                       HIREDATE,
                       SAL,
                       COMM,
                       ONLEAVE,
                       NOTES,
                       DEPTNO
                  from EBA_DEMO_IG_EMP
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        masterDetail {
            masterRegion: @departments
        }
        advanced {
            htmlDomId: emp
            regionDisplaySelector: true
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        messages {
            whenNoDataFound: No Employees found.
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
            ]
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        heading {
            fixedTo: region
            fixedReportHeight: 280
        }
        iconView {
            show: true
            custom: true
            customIcon:
                ```html
                <li data-id='&APEX$ROW_ID.'>
                <div class="t-Card">
                    <div class="t-Card-wrap">
                      <div class="t-Card-icon u-color"><span class="t-Icon fa fa-user"></span></div>
                      <div class="t-Card-titleWrap"><h3 class="t-Card-title">&ENAME.</h3></div>
                      <div class="t-Card-body">
                        <div class="t-Card-desc">Manager: &MGR.</div>
                        <div class="t-Card-info">$&SAL.</div>
                      </div>
                    </div>
                </div>
                </li>
                ```
        }
        detailView {
            show: true
            beforeRows:
                ```html
                <ul class="t-MediaList t-MediaList--showDesc t-MediaList--showIcons t-MediaList--showBadges">
                
                ```
            forEachRow:
                ```html
                <li class="t-MediaList-item  ">
                    <div class="t-MediaList-itemWrap">
                        <div class="t-MediaList-iconWrap">
                            <span class="t-MediaList-icon"><span class="t-Icon fa fa-user"></span></span>
                        </div>
                        <div class="t-MediaList-body">
                            <h3 class="t-MediaList-title">&ENAME.</h3>
                            <p class="t-MediaList-desc">
                                Manager: &MGR.<br>
                                Job: &JOB.
                            </p>
                        </div>
                        <div class="t-MediaList-badgeWrap">
                            <span class="t-MediaList-badge">$&SAL.</span>
                        </div>
                    </div>
                </li>
                
                
                ```
            afterRows: </ul>
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function(config) {
                    // for icon view style
                    config.defaultIconViewOptions = {
                        collectionClasses: "t-Cards t-Cards--compact t-Cards--displayIcons u-colors t-Cards--desc-2ln"
                    };
                    return config; // don't forget to return this!
                }
                ```
        }
        advanced {
            savedReportMappingIdentifier: 696648280119602332
        }

        savedReport 14485 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @APEX$ROW_ACTION
                layout {
                    sequence: 2
                }
            )

            displayColumn (
                column: @EMPNO
                layout {
                    sequence: 3
                }
            )

            displayColumn (
                column: @ENAME
                layout {
                    sequence: 4
                }
            )

            displayColumn (
                column: @JOB
                layout {
                    sequence: 5
                }
            )

            displayColumn (
                column: @MGR
                layout {
                    sequence: 6
                }
            )

            displayColumn (
                column: @HIREDATE
                layout {
                    sequence: 7
                }
            )

            displayColumn (
                column: @SAL
                layout {
                    sequence: 8
                }
            )

            displayColumn (
                column: @COMM
                layout {
                    sequence: 9
                }
            )

            displayColumn (
                column: @ONLEAVE
                layout {
                    sequence: 10
                }
            )

            displayColumn (
                column: @NOTES
                layout {
                    sequence: 11
                }
            )

            displayColumn (
                column: @DEPTNO
