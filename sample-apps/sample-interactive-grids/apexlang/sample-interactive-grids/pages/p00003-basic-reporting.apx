page 3 (
    name: Basic Reporting
    alias: BASIC-REPORTING
    title: Basic Reporting
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region basic-read-only (
        name: Basic Read Only
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region basic-reporting (
        name: Basic Reporting
        type: interactiveGrid
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select EMPNO,
                       ENAME,
                       JOB,
                       MGR,
                       HIREDATE,
                       SAL,
                       COMM,
                       DEPTNO
                  from EBA_DEMO_IG_EMP
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            showTotalCount: false
        }
        toolbar {
            controls: [
                searchCol
                searchField
                actionsMenu
                resetButton
                saveButton
            ]
        }
        enableUsersTo {
            defineChartView: false
        }
        download {
            formats: [
                csv
                html
                excel
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 645872463517057873
        }

        savedReport 14437 (
            visibility: primary
            view {
                default: grid
            }
            singleRowView {
                displayedColumns: true
            }

            displayColumn (
                column: @EMPNO
                layout {
                    frozen: true
                    width: 90
                    sequence: 1
                }
            )

            displayColumn (
                column: @ENAME
                layout {
                    frozen: true
                    width: 140
                    sequence: 2
                }
            )

            displayColumn (
                column: @JOB
                layout {
                    width: 133
                    sequence: 3
                }
            )

            displayColumn (
                column: @MGR
                layout {
                    width: 95
                    sequence: 5
                }
            )

            displayColumn (
                column: @HIREDATE
                layout {
                    width: 125
                    sequence: 4
                }
            )

            displayColumn (
                column: @SAL
                layout {
                    width: 95
                    sequence: 6
                }
            )

            displayColumn (
                column: @COMM
                layout {
                    width: 70
                    sequence: 7
                }
            )

            displayColumn (
                column: @DEPTNO
                layout {
                    width: 96
                    sequence: 8
                }
            )

            sort (
                column: @JOB
                sort {
                    nulls: last
                    sequence: 1
                }
            )

            sort (
                column: @HIREDATE
                sort {
                    direction: desc
                    nulls: first
                    sequence: 2
                }
            )

        )

        column COMM (
            type: numberField
            heading {
                heading: Comm
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            source {
                databaseColumn: COMM
                dataType: number
            }
        )

        column DEPTNO (
            type: numberField
            heading {
                heading: Deptno
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            source {
                databaseColumn: DEPTNO
                dataType: number
            }
        )

        column EMPNO (
            type: numberField
            heading {
                heading: Empno
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            validation {
                valueRequired: true
            }
            source {
                databaseColumn: EMPNO
                dataType: number
            }
        )

        column ENAME (
            type: textField
            heading {
                heading: Ename
            }
            layout {
                sequence: 20
            }
            validation {
                maxLength: 60
            }
            source {
                databaseColumn: ENAME
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column HIREDATE (
            type: datePickerJquery
            heading {
                heading: Hiredate
            }
            layout {
                sequence: 50
            }
            source {
                databaseColumn: HIREDATE
                dataType: date
            }
        )

        column JOB (
            type: textField
            heading {
                heading: Job
            }
            layout {
                sequence: 30
            }
            validation {
                maxLength: 9
            }
            source {
                databaseColumn: JOB
                dataType: varchar2
            }
            columnFilter {
                performanceImpactingOperators: [
                    contains
                    startsWith
                    caseInsensitive
                    regexp
                ]
            }
        )

        column MGR (
            type: numberField
            heading {
                heading: Mgr
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 40
                columnAlignment: end
            }
            source {
                databaseColumn: MGR
                dataType: number
            }
        )

        column SAL (
            type: numberField
            heading {
                heading: Sal
                alignment: end
            }
            settings {
                numberAlignment: end
                virtualKeyboard: text
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            source {
                databaseColumn: SAL
                dataType: number
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
    )

    region overview-basic-reporting (
        name: Overview: Basic Reporting
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This page shows the result of going through the create page wizard and choosing Report for page type, then Interactive Grid, and selecting EBA_DEMO_IG_EMP for the table (leave Editing Enabled set to the default: No). These are all the defaults; no additional customization has been done. This Overview region and navigation buttons were added later. For an editable grid see <a href='f?p=&APP_ID.:30:&SESSION.:'>Basic Editing</a>.
                </p>
                <p>In many ways it looks and acts like an Interactive Report. Here are some new features and differences:
                </p>
                <ul>
                <li>Rows are fixed height by default and columns have a specific width that can be adjusted by dragging the border between column headers or with Ctrl+Left/Right keys when the column header has keyboard focus.</li>
                <li>Columns can be reordered with drag and drop (dragging the handle at the start of a column heading) or with Shift+Left/Right keys when the column header has keyboard focus.</li>
                <li>Columns can be sorted using the buttons in the column heading (or Alt+Up/Down key). Use the Shift key to add additional sort columns.</li>
                <li>Columns can be frozen using the column heading popup menu Freeze button.</li>
                <li>By default rows are selected. You can use Actions -> Selection sub menu to change to cell selection. Use the Shift key to select a range of cells. The selection can be copied to the clipboard.</li>
                <li>By default the toolbar and column headings stick to the top of the page and the footer sticks to the bottom when scrolling</li>
                <li>By default pagination uses progressive scrolling. The sample data has so few records that all are seen at once. See <a href='f?p=&APP_ID.:2:&SESSION.:'>Progressive Scroll</a> for a better example.</li>
                <li>The grid is keyboard navigable with a focused cell and current selected row (single selection by default).</li>
                <li>The toolbar includes a Reset button by default that restores all the report settings to their defaults</li>
                <li>The Actions menu has been slightly reorganized relative to Interactive Reports.</li>
                </ul>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @basic-read-only
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillEnd
            ]
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 4
                action: resetPagination
            }
        }
    )

    button prev (
        buttonName: PREV
        label: Previous
        layout {
            sequence: 10
            region: @basic-read-only
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--pillStart
            ]
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 37
                action: resetPagination
            }
        }
    )

)

