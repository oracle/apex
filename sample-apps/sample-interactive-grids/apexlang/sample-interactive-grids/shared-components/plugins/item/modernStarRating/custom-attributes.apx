customAttribute attribute_06 (
    apexlangName: tooltipTemplate
    attribute: 6
    name: Tooltip Template
    validation {
        maxLength: 50
    }
    appearance {
        sequence: 60
    }
    builder {
        common: false
        showInWizard: false
        translatable: true
        displayWidth: 30
    }
    default {
        value: Rating: #VALUE#
    }
    supports {
        components: [
            pageItems
            interactiveGridColumns
        ]
    }
    help {
        helpText: Specify the template for the tooltip. The #VALUE# substitution is being replaces by the current rating value.
    }
    examples {
        examples: Rating: #VALUE# stars.
    }
)

