    }
    help {
        helpText: Choose the default color for inactive stars.
    }
)

customAttribute attribute_03 (
    apexlangName: useComponentDefaults
    attribute: 3
    name: Use Component Defaults
    type: yesNo
    appearance {
        sequence: 20
    }
    builder {
        showInWizard: false
    }
    default {
        value: true
    }
    supports {
        components: [
            pageItems
            interactiveGridColumns
        ]
    }
    help {
        helpText: Choose whether to use component defaults or not.
    }
)

