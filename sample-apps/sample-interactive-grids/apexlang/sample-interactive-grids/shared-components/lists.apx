list ig-report-linking-examples (
    name: IG Report Linking Examples

    entry clearing-report-settings (
        label: Clearing report settings
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 15
                action: clearRegions
            }
        }
        userDefinedAttributes {
            2: reportIcon
        }
    )

    entry filtering-report-for-salaries-greater-than (
        label: Filtering Report for salaries greater than 3000
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 15
                items: {
                    IG_SAL: 3000
                }
                action: clearRegions
            }
        }
        userDefinedAttributes {
            2: reportIcon
        }
    )

    entry invoking-a-saved-report (
        label: Invoking a Saved Report
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 15
                action: resetRegions
                request: IG_Roles
            }
        }
        userDefinedAttributes {
            2: reportIcon
        }
    )

    entry linking-to-a-saved-report (
        label: Linking to a Saved Report
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 9
                items: {
                    IGGT_SAL: 3000
                }
                action: clearRegions
                request: "IG[emp]_Main"
            }
        }
        userDefinedAttributes {
            2: reportIcon
        }
    )

    entry resetting-to-developer-defaults (
        label: Resetting to Developer Defaults
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 15
                action: resetRegions
            }
        }
        userDefinedAttributes {
            2: reportIcon
        }
    )

)

