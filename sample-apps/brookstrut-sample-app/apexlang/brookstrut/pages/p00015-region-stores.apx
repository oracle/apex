    )

    computation p15-region-name (
        itemName: P15_REGION_NAME
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery: select region_name from OOW_DEMO_REGIONS where id = :P15_REGION_ID
        }
    )

    process start-timer (
        name: start timer
        type: executeCode
        source {
            plsqlCode: oow_demo_timing.start_timer;
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 12014533130090491905
        }
    )

