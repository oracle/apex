                heading: Store Type
                alignment: center
            }
            layout {
                sequence: 60
            }
        )

    )

    region timing (
        name: Timing
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   x clob;
                begin
                    x := to_char(oow_demo_timing.get_elap,'99G9990D000')||' seconds';
                    return x;
                end;
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    pageItem P15_REGION_ID (
        type: hidden
        layout {
            sequence: 10
            region: @stores
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P15_REGION_NAME (
        type: hidden
        layout {
            sequence: 20
            region: @stores
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button edit (
        buttonName: Edit
        label: Edit
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-edit
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9
                items: {
                    P9_ID: &P15_REGION_ID.
                }
                clearCache: 9
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Refresh
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 15
                items: {
                    P15_REGION_ID: &P15_REGION_ID.
                }
                clearCache: [
                    8
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: up
