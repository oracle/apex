page 33 (
    name: Transaction Log
    title: Transaction Log
    pageGroup: @reporting
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region transaction-generation-log (
        name: Transaction Generation Log
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id, owner, num_days, max_orders, end_time, end_time_since, elapsed_seconds, row_count,
                       to_number(decode (elapsed_seconds,null,null,row_count/elapsed_seconds)) rows_per_second
                from (
                select
                    ID,
                    OWNER,
                    NUM_DAYS,
                    MAX_ORDERS,
                    START_TIME,
                    END_TIME,
                    END_TIME end_time_since,
                    (extract(SECOND FROM end_time-start_time)) +
                    (extract(MINUTE FROM end_time-start_time) * 60) +
                    (extract(HOUR FROM end_time-start_time) *3600 ) elapsed_seconds,
                    row_count
                from OOW_DEMO_HIST_GEN_LOG) base_query
                ```
        }
        layout {
            sequence: 10
            slot: body-3
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2727520115186399180
        }

        column ELAPSED_SECONDS (
            type: plainText
            heading {
                heading: Elapsed Seconds
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column END_TIME (
            type: plainText
            heading {
                heading: End Time
            }
            layout {
                sequence: 6
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: F
            }
        )

        column END_TIME_SINCE (
            type: plainText
            heading {
                heading: Last Action
            }
            layout {
                sequence: 28
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: K
            }
        )

        column ID (
            type: plainText
            heading {
                heading: Id
            }
            layout {
                sequence: 1
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column MAX_ORDERS (
            type: plainText
            heading {
                heading: Max Orders
                alignment: end
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: D
            }
        )

        column NUM_DAYS (
            type: plainText
            heading {
                heading: Num Days
                alignment: end
            }
            layout {
                sequence: 3
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: C
            }
        )

        column OWNER (
            type: plainText
            heading {
                heading: Owner
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column ROWS_PER_SECOND (
            type: plainText
            heading {
                heading: Rows Per Second
                alignment: end
            }
            layout {
                sequence: 18
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column ROW_COUNT (
            type: plainText
            heading {
                heading: New Rows
                alignment: end
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        savedReport 27275210 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn ELAPSED_SECONDS (
                sequence: 5
            )

            displayColumn END_TIME (
                sequence: 4
            )

            displayColumn END_TIME_SINCE (
                sequence: 8
            )

            displayColumn MAX_ORDERS (
                sequence: 3
            )

            displayColumn NUM_DAYS (
                sequence: 2
            )

            displayColumn OWNER (
                sequence: 1
            )

            displayColumn ROWS_PER_SECOND (
                sequence: 7
            )

            displayColumn ROW_COUNT (
                sequence: 6
            )

            sort (
                column: END_TIME_SINCE
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            sort (
                column: START_TIME
                sort {
                    direction: desc
                    sequence: 2
                }
            )

            aggregate (
                column: ROW_COUNT
            )

            aggregate (
                column: ELAPSED_SECONDS
            )

        )

    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @transaction-generation-log
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 33
                clearCache: [
                    33
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 19
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

