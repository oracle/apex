page 45 (
    name: Sales History Smart Search w Menu Actions
    alias: SALES-HISTORY-SMART-SEARCH-W-MENU-ACTIONS
    title: Sales History Smart Search w Menu Actions
    pageGroup: @reporting
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region facets (
        name: Facets
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
        advanced {
            htmlDomId: active_facets
            regionDisplaySelector: true
        }
    )

    region facets-2 (
        name: Facets
        type: smartFilters
        source {
            filteredRegion: @sales-history
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
        }

        filter P45_PRODUCT (
            type: checkboxGroup
            label {
                label: Product
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: PRODUCT
            }
        )

        filter P45_REGION (
            type: checkboxGroup
            label {
                label: Region
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: REGION
            }
        )

        filter P45_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        filter P45_STORE (
            type: checkboxGroup
            label {
                label: Store
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: STORE
            }
        )

        filter P45_THE_MONTH (
            type: checkboxGroup
            label {
                label: Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: THE_MONTH
            }
        )

    )

    region sales-history (
        name: Sales History
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    h.ID            id,
                    r.REGION_NAME   region,
                    s.store_name    store,
                    i.item_Name     product,
                    h.DATE_OF_SALE,
                    to_char(h.DATE_OF_SALE,'YYYY.MM') the_month,
                    h.QUANTITY,
                    h.TRANSACTION_ID,
                    h.ITEM_PRICE,
                    h.QUANTITY * h.ITEM_PRICE sale,
                    i.id product_id,
                    s.id store_id
                from #OWNER#.OOW_DEMO_SALES_HISTORY h,
                     #OWNER#.OOW_DEMO_REGIONS r,
                     #OWNER#.OOW_DEMO_STORES s,
                     #OWNER#.OOW_DEMO_STORE_PRODUCTS p,
                     #OWNER#.OOW_DEMO_ITEMS i
                where s.region_id = r.id and
                      h.store_id = s.id and
                      p.ITEM_ID = h.PRODUCT_ID and
                      p.item_id = i.id
                
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &PRODUCT.
            description:
                ```html
                Location: &REGION.: &STORE.<br>
                Date: &DATE_OF_SALE. <br>
                Transaction: &TRANSACTION_ID.
                ```
            miscellaneous:
                ```html
                Price: &ITEM_PRICE. <br>
                Quantity: &QUANTITY. 
                ```
            displayAvatar: true
            displayBadge: true
        }
        plugin-avatar {
            icon: fa-tag
        }
        plugin-badge {
            label: Sale
            value: SALE
        }
        pagination {
            entitiesPerPage: 100
        }

        column DATE_OF_SALE (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: DATE_OF_SALE
                dataType: timestampWithLocalTimeZone
            }
            appearance {
                formatMask: DD-MON-YYYY HH24:MI:SS
            }
        )

        column ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ID
                dataType: number
            }
        )

        column ITEM_PRICE (
            layout {
                sequence: 90
            }
            source {
                databaseColumn: ITEM_PRICE
                dataType: number
            }
        )

        column PRODUCT (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: PRODUCT
                dataType: varchar2
            }
        )

        column PRODUCT_ID (
            layout {
                sequence: 110
            }
            source {
                databaseColumn: PRODUCT_ID
                dataType: number
            }
        )

        column QUANTITY (
            layout {
                sequence: 70
            }
            source {
                databaseColumn: QUANTITY
                dataType: number
            }
        )

        column REGION (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: REGION
                dataType: varchar2
            }
        )

        column SALE (
            layout {
                sequence: 100
            }
            source {
                databaseColumn: SALE
                dataType: number
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
        )

        column STORE (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: STORE
                dataType: varchar2
            }
        )

        column STORE_ID (
            layout {
                sequence: 120
            }
            source {
                databaseColumn: STORE_ID
                dataType: number
            }
        )

        column THE_MONTH (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: THE_MONTH
                dataType: varchar2
            }
        )

        column TRANSACTION_ID (
            layout {
                sequence: 80
            }
            source {
                databaseColumn: TRANSACTION_ID
                dataType: varchar2
            }
        )

        action action (
            position: fullRowLink
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 36
                    items: {
                        P36_TRANSACTION_ENTRY_ID: &ID.
                    }
                    clearCache: 36
                    action: resetPagination
                }
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
                cssClasses: t-Button--noUI
            }

            menu product-details (
                label: Product Details
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 18
                        items: {
                            P18_ID: &PRODUCT_ID.
                        }
                        clearCache: 18
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu store-details (
                label: Store Details
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 3
                        items: {
                            P3_ID: &STORE_ID.
                        }
                        clearCache: 3
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-shopping-bag
                }
            )

            menu transaction-details (
                label: Transaction Details
                layout {
                    sequence: 20
                }
                behavior {
                    target: {
                        page: 36
                        items: {
                            P36_TRANSACTION_ENTRY_ID: &ID.
                        }
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-tag
                }
            )

        )

    )

    region timer (
        name: Timer
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   x clob;
                begin
                    x := to_char(oow_demo_timing.get_elap,'99G9990D000')||' seconds';
                    return x;
                end;
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    pageItem P45_NAVIGATION (
        type: selectList
        label {
            label: Navigation
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @sales-history-navigation
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            height: 1
        }
        default {
            type: static
            staticValue: &APP_PAGE_ID.
        }
    )

    button reset (
        buttonName: reset
        label: Reset
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 45
                clearCache: 45
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction on-navigation-click (
        name: on navigation click
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P45_NAVIGATION
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process start-timer (
        name: Start Timer
        type: executeCode
        source {
            plsqlCode: oow_demo_timing.start_timer;
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 12016846343175618090
        }
    )

    branch (
        name: branch to requested page
        execution {
            sequence: 40
        }
        behavior {
            target: {
                page: &P45_NAVIGATION.
                clearCache: &P45_NAVIGATION.
                action: resetPagination
            }
        }
    )

)

