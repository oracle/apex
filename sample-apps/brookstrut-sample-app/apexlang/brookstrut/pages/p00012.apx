page 12 (
    name: Product
    title: Product
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region button-bar (
        name: button bar
        type: staticContent
        layout {
            sequence: 1
            slot: dialogFooter
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
    )

    region product (
        name: Product
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P12_ID (
        type: hidden
        layout {
            sequence: 10
            region: @product
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P12_ITEM_DESC (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 90
            region: @product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
            height: 5
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: ITEM_DESC
            used: always
        }
    )

    pageItem P12_ITEM_NAME (
        type: textField
        label {
            label: Item Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 60
            region: @product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 48
        }
        validation {
            maxLength: 60
        }
        source {
            type: databaseColumn
            databaseColumn: ITEM_NAME
            used: always
        }
    )

    pageItem P12_ITEM_TYPE (
        type: selectList
        label {
            label: Type
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @food-types
            displayNullValue: false
        }
        layout {
            sequence: 30
            region: @product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        advanced {
            cssClasses: mnw180
        }
        source {
            type: databaseColumn
            databaseColumn: ITEM_TYPE
            used: always
        }
    )

    pageItem P12_MSRP (
        type: numberField
        label {
            label: MSRP
            alignment: left
        }
        settings {
            minValue: 0
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @product
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            formatMask: 999G999G999G999G990D00
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: MSRP
            used: always
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @button-bar
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button create (
        buttonName: CREATE
        label: Add Store Item
        layout {
            sequence: 40
            region: @button-bar
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P12_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @button-bar
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P12_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @button-bar
            slot: change
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P12_ID
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation p12-item-name-not-null (
        name: P12_ITEM_NAME Not Null
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody: return trim(:P12_ITEM_NAME) is not null
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P12_ITEM_NAME
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process fetch-row-from-oow-demo-items (
        name: Fetch Row from OOW_DEMO_ITEMS
        type: autoRowFetch
        source {
            tableName: OOW_DEMO_ITEMS
            pkColumn: ID
            pkItem: P12_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 16574535388351414176
        }
    )

    process process-row-of-oow-demo-items (
        name: Process Row of OOW_DEMO_ITEMS
        type: autoRowProcessing
        target {
            tableName: OOW_DEMO_ITEMS
            pkColumn: ID
            pkItem: P12_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 16574535588104414179
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 16574535780149414179
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    branch (
        execution {
            sequence: 1
        }
        behavior {
            target: {
                page: 11
            }
        }
    )

)

