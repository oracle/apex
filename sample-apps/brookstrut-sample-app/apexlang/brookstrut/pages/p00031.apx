page 31 (
    name: 100 Transactions Generated
    title: 100 Transactions Generated
    pageGroup: @data-generation
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 1
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region generate-100-transactions-on-page-load (
        name: Generate 100 Transactions on Page Load
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region show-last-generation (
        name: show last generation
        type: plSqlDynamicContent
        source {
            plsqlCode: oow_demo_gen_data_pkg.exec_100_transactions;
        }
        layout {
            sequence: 20
            parentRegion: @generate-100-transactions-on-page-load
            slot: subRegions
        }
    )

    region timing (
        name: Timing
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   x clob;
                begin
                    x := to_char(oow_demo_timing.get_elap,'99G9990D000')||' seconds';
                    return x;
                end;
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    pageItem P31_TRANSACTION_ID (
        type: hidden
        layout {
            sequence: 10
            region: @generate-100-transactions-on-page-load
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button refresh-page (
        buttonName: refresh_page
        label: Generate 100 Transactions
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-gear
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 31
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 28
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process start-timer (
        name: start timer
        type: executeCode
        source {
            plsqlCode: oow_demo_timing.start_timer;
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 12014853657244092289
        }
    )

    branch (
        name: Go to Calling Page
        execution {
            sequence: 20
        }
        behavior {
            target: {
                page: &LAST_VIEW.
                action: resetPagination
            }
        }
    )

)

