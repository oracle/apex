            heading {
                heading: Distinct Stores
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
        )

        column LOAD_TIME_MILLISECONDS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Load Time Milliseconds
                alignment: center
            }
            layout {
                sequence: 80
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
        )

        column LOAD_TIME_SECONDS (
