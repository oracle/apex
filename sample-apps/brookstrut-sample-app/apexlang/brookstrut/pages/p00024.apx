page 24 (
    name: Sales History Generation Log
    title: Sales History Generation Log
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region sales-history-generation-log (
        name: Sales History Generation Log
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                    owner,
                    num_days,
                    max_orders,
                    start_time,
                    end_time,
                    (extract(DAY FROM end_time-start_time)*24*60*60)+ 
                        (extract(HOUR FROM end_time-start_time)*60*60)+
                        (extract(MINUTE FROM end_time-start_time)*60)+
                        extract(SECOND FROM end_time-start_time) duration
                from oow_demo_hist_gen_log
                ```
        }
        layout {
            sequence: 10
            slot: body-3
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2713031204256408091
        }

        column DURATION (
            type: plainText
            heading {
                heading: Duration (sec)
                alignment: center
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column END_TIME (
            type: plainText
            heading {
                heading: End Time
                alignment: center
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: F
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column MAX_ORDERS (
            type: plainText
            heading {
                heading: Max Orders
                alignment: center
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: D
            }
        )

        column NUM_DAYS (
            type: plainText
            heading {
                heading: Num Days
                alignment: center
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: C
            }
        )

        column OWNER (
            type: plainText
            heading {
                heading: Owner
                alignment: center
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column START_TIME (
            type: plainText
            heading {
                heading: Start Time
                alignment: center
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: E
            }
        )

        savedReport 27130322 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn DURATION (
                sequence: 6
            )

            displayColumn END_TIME (
                sequence: 5
            )

            displayColumn MAX_ORDERS (
                sequence: 3
            )

            displayColumn NUM_DAYS (
                sequence: 2
            )

            displayColumn OWNER (
                sequence: 1
            )

            displayColumn START_TIME (
                sequence: 4
            )

            sort (
                column: START_TIME
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

)

