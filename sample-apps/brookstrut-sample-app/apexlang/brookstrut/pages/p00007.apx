        name: Process Row of OOW_DEMO_STORES
        type: autoRowProcessing
        target {
            tableName: OOW_DEMO_STORES
            pkColumn: ID
            pkItem: P7_ID
            returnKeyIntoItem: P7_ID
        }
        execution {
            sequence: 20
