    dynamicAction checkcreate (
        name: CheckCreate
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @create
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: validateAddressAndSubmit("CREATE");
            }
            affectedElements {
                selectionType: items
                items: [
                    P7_STORE_LAT
                    P7_STORE_LNG
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

