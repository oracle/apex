        source {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_vc_arr2   apex_application_global.vc_arr2;
                begin
                    select item_id
                    bulk collect into l_vc_arr2 
                    from OOW_DEMO_STORE_PRODUCTS
                    where store_id = :P7_ID;
                 
                    return apex_util.table_to_string ( l_vc_arr2 ); 
                end;
                ```
            used: always
