    process populate-google-maps-api-key (
        name: Populate Google Maps API Key
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    select preference_value
                      into :P7_MAPS_API_KEY
                      from oow_demo_preferences
                     where preference_name = 'GOOGLE_MAPS_API_KEY';
                exception
                    when no_data_found then
                        :P7_MAPS_API_KEY := null;
                end;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 14736669393840007738
        }
    )

