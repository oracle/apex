page 18 (
    name: Sales by Product
    alias: SALES-BY-PRODUCT
    title: Sales by Product
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region sales-by-product (
        name: Sales by Product
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                      h.ID            id,
                      r.REGION_NAME   region,
                      s.store_name    store,
                      i.item_Name     product,
                      h.DATE_OF_SALE,
                      to_char(h.DATE_OF_SALE,'YYYY.MM') the_month,
                      h.QUANTITY,
                      h.TRANSACTION_ID,
                      h.ITEM_PRICE,
                      h.QUANTITY * h.ITEM_PRICE sale,
                      h.ID transaction_entry_id
                from  #OWNER#.OOW_DEMO_SALES_HISTORY h,
                      #OWNER#.OOW_DEMO_REGIONS r,
                      #OWNER#.OOW_DEMO_STORES s,
                      #OWNER#.OOW_DEMO_STORE_PRODUCTS p,
                      #OWNER#.OOW_DEMO_ITEMS i
                where s.region_id = r.id and
                      h.store_id = s.id and
                      p.ITEM_ID = h.PRODUCT_ID and
                      p.item_id = i.id and
                      i.id = :P18_ID
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column DATE_OF_SALE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Date of Sale
            }
            layout {
                sequence: 50
            }
            appearance {
                formatMask: FMDay Month DD, YYYY HH24:MI
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column ITEM_PRICE (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Item Price
                alignment: end
            }
            layout {
                sequence: 100
                columnAlignment: end
            }
        )

        column PRODUCT (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Product
            }
            layout {
                sequence: 40
            }
        )

        column QUANTITY (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Quantity
                alignment: end
            }
            layout {
                sequence: 90
                columnAlignment: end
            }
            advanced {
                computeSum: true
            }
        )

        column REGION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Region
            }
            layout {
                sequence: 20
            }
        )

        column SALE (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Total Sales Amount
                alignment: end
            }
            layout {
                sequence: 110
                columnAlignment: end
            }
            advanced {
                computeSum: true
            }
        )

        column STORE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Store
            }
            layout {
                sequence: 30
            }
        )

        column THE_MONTH (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Month
            }
            layout {
                sequence: 60
            }
        )

        column TRANSACTION_ENTRY_ID (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 120
            }
        )

        column TRANSACTION_ID (
            reportColumnQueryId: 8
            derivedColumn: N
            type: link
            heading {
                heading: Transaction ID
            }
            layout {
                sequence: 80
            }
            link {
                target: {
                    page: 36
                    items: {
                        P36_TRANSACTION_ENTRY_ID: #TRANSACTION_ENTRY_ID#
                    }
                    clearCache: 36
                    action: resetPagination
                }
                linkText: #TRANSACTION_ID#
            }
        )

    )

    region search (
        name: Search
        type: smartFilters
        source {
            filteredRegion: @sales-by-product
        }
        layout {
            sequence: 2
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        settings {
            compactNosThreshold: 10000
        }

        filter P18_REGION (
            type: checkboxGroup
            label {
                label: Region
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: REGION
            }
        )

        filter P18_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        filter P18_STORE (
            type: checkboxGroup
            label {
                label: Store
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: STORE
            }
        )

        filter P18_THE_MONTH (
            type: checkboxGroup
            label {
                label: Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            suggestions {
                type: dynamic
            }
            source {
                databaseColumn: THE_MONTH
            }
        )

    )

    pageItem P18_ID (
        type: selectList
        label {
            label: Product
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery: select item_name, id from OOW_DEMO_ITEMS order by 1
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
    )

    pageItem P18_PROCUCT_NAME (
        type: hidden
        layout {
            sequence: 20
            slot: body
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button up (
        buttonName: up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 11
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report-on-change (
        name: refresh report on change
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P18_ID
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p18-procuct-name (
        itemName: P18_PROCUCT_NAME
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select ITEM_NAME 
                from OOW_DEMO_ITEMS 
                where id = :P18_ID
                ```
        }
    )

)

