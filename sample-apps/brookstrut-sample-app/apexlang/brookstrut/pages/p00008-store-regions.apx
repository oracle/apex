            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column SALES_PRIOR_30_DAYS (
            type: plainText
            heading {
                heading: Sales Prior 30 Days
                alignment: center
            }
            layout {
                sequence: 46
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column SALES_TRAILING_30_DAYS (
            type: plainText
            heading {
                heading: Sales Trailing 30 Days
                alignment: end
            }
            layout {
                sequence: 26
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column SALES_TREND (
            type: plainText
            heading {
                heading: Sales Trend
                alignment: center
            }
            layout {
                sequence: 56
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990D00
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column SALES_TREND_PERCENTAGE (
            type: plainText
            heading {
                heading: Sales Trend Percentage
                alignment: end
            }
            layout {
                sequence: 66
                columnAlignment: end
            }
            appearance {
                formatMask: S999G999G999G999G990D00
            }
            columnFormatting {
                htmlExpression: #SALES_TREND_PERCENTAGE#%
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column STORES (
            type: plainText
            heading {
                heading: Stores
                alignment: end
            }
            layout {
                sequence: 16
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        savedReport 27083913 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn AVG_STORE_SALES (
                sequence: 6
            )

            displayColumn REGION_NAME (
                sequence: 1
            )

            displayColumn SALES_PRIOR_30_DAYS (
                sequence: 4
            )

            displayColumn SALES_TRAILING_30_DAYS (
                sequence: 3
            )

            displayColumn SALES_TREND (
                sequence: 5
            )

            displayColumn STORES (
                sequence: 2
            )

            sort (
                column: AVG_STORE_SALES
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            aggregate (
                column: SALES_TRAILING_30_DAYS
            )

            aggregate (
                column: STORES
            )

            aggregate (
                column: SALES_PRIOR_30_DAYS
            )

            aggregate (
                column: SALES_TREND
            )

        )

    )

    button create (
