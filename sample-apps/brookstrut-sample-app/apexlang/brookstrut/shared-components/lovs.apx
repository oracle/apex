lov auto-refresh (
    name: AUTO REFRESH
    source {
        location: staticValues
    }

    entry every-1-minute (
        sequence: 40
        display: Every 1 minute
        return: 40
    )

    entry every-10-seconds (
        sequence: 20
        display: Every 10 seconds
        return: 10
    )

    entry every-30-seconds (
        sequence: 30
        display: Every 30 seconds
        return: 30
    )

    entry every-5-seconds (
        sequence: 10
        display: Every 5 seconds
        return: 5
    )

    entry every-second (
        sequence: 1
        display: Every Second
        return: 1
    )

)

lov desktop-theme-styles (
    name: DESKTOP THEME STYLES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select s.name d,
                   s.theme_style_id r
              from apex_application_theme_styles s,
                   apex_application_themes t
             where s.application_id = :app_id
               and t.application_id = s.application_id
               and t.theme_number   = s.theme_number
               and t.is_current     = 'Yes'
             order by 1
            ```
    }
    columnMapping {
        return: R
        display: D
    }
)

