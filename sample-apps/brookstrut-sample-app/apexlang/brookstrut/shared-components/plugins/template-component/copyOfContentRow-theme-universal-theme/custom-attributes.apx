customAttribute BADGE_STATE (
    apexlangName: state
    attribute: 15
    name: State
    type: sessionStateValue
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 150
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the source column for the state of the badge. Substitute column value with "danger", "warning", "success" or "info" for default styling.
    }
)

customAttribute BADGE_STYLE (
    apexlangName: style
    attribute: 18
    name: Style
    type: selectList
    componentLov {
        nullText: Default
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 180
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the badge style. Default inherits the style set by the containing template.
    }

    entry outline (
        sequence: 20
        display: Outline
        return: t-Badge--outline
    )

    entry subtle (
        sequence: 10
        display: Subtle
        return: t-Badge--subtle
    )

)

customAttribute BADGE_VALUE (
    apexlangName: value
    attribute: 14
    name: Value
    type: sessionStateValue
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 140
    }
    supports {
        dataTypes: [
            varchar2
            number
            date
            intervalYearToMonth
            intervalDayToSecond
        ]
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select a source column for the badge value.
    }
)

customAttribute DESCRIPTION (
    apexlangName: description
    attribute: 3
    name: Description
    security {
        escapeMode: raw
    }
    appearance {
        sequence: 30
    }
    builder {
        translatable: true
    }
    default {
        sampleDataValue: Nunc sit amet nunc quis magna ornare suscipit. Etiam aliquet maximus sapien, at sagittis sem gravida nec.
    }
    help {
        helpText: Enter some text and/or column substitution strings to be used as the description in each row.
    }
)

customAttribute DISPLAY_AVATAR (
    apexlangName: displayAvatar
    attribute: 5
    name: Display Avatar
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        sequence: 50
    }
    help {
        helpText: Specify whether to display or hide the avatar for each row. When set to Yes, an avatar will be displayed with the assigned image, icon, or initials. When set to No, no avatar will be displayed.
    }
)

customAttribute DISPLAY_BADGE (
    apexlangName: displayBadge
    attribute: 6
    name: Display Badge
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        sequence: 60
    }
    help {
        helpText: Specify whether to display or hide the badge for each row. When set to Yes, a badge will be displayed in each row. When set to No, no badge will be displayed.
    }
)

customAttribute MISC (
    apexlangName: miscellaneous
    attribute: 4
    name: Miscellaneous
    security {
        escapeMode: raw
    }
    appearance {
        sequence: 40
    }
    builder {
        translatable: true
    }
    help {
        helpText: Enter miscellaneous content such as additional text and/or column substitution strings to display in each row.
    }
)

customAttribute OVERLINE (
    apexlangName: overline
    attribute: 1
    name: Overline
    security {
        escapeMode: raw
    }
    appearance {
        sequence: 10
    }
    builder {
        translatable: true
    }
    default {
        sampleDataValue: Category
    }
    help {
        helpText: Enter some text and/or column substitution strings to display at the top of each row above the title and description.
    }
)

customAttribute TITLE (
    apexlangName: title
    attribute: 2
    name: Title
    security {
        escapeMode: raw
    }
    appearance {
        sequence: 20
    }
    builder {
        translatable: true
    }
    default {
        sampleDataValue: Lorem ipsum dolor sit amet
    }
    help {
        helpText: Enter some text and/or column substitution strings to be used as the title in each row.
    }
)

