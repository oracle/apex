customAttribute APPLY_THEME_COLORS (
    apexlangName: applyThemeColors
    attribute: 23
    name: Apply Theme Colors
    scope: report
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        sequence: 230
    }
    default {
        value: true
    }
    help {
        helpText: Specify whether to use the Universal Theme colors for avatar and badge row items. When set to Yes, the u-colors class will be applied to each row. When set to No, a default color will be used instead.
    }
)

customAttribute AVATAR_ICON (
    apexlangName: icon
    attribute: 11
    name: Icon
    type: icon
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 110
    }
    default {
        value: fa-user
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: icon
    }
    help {
        helpText: Enter an icon class or use the Pick Icon dialog to select the icon you want to add to display in the avatar.
    }
)

customAttribute AVATAR_IMAGE (
    apexlangName: image
    attribute: 8
    name: Image
    type: media
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 80
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: image
    }
    help {
        helpText:
            ```
            <p>Use the Media popup dialog to select a source for the avatar image.</p>
            
            <p>Available options include:
            <ul>
            <li>URL</li>
            <li>BLOB Column</li>
            <li>URL Column</li>
            </ul>
            </p>
            ```
    }
)

customAttribute AVATAR_IMAGE_ALT (
    apexlangName: imageDescription
    attribute: 9
    name: Image Description
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 90
    }
    builder {
        translatable: true
    }
    dependingOn {
        attribute: @AVATAR_IMAGE/component
        conditionType: isNotNull
    }
    help {
        helpText: Enter a short description of the image or select a source column from the quick pick options. This will be used as alt text for the avatar image.
    }
)

customAttribute AVATAR_INITIALS (
    apexlangName: initials
    attribute: 10
    name: Initials
    type: sessionStateValue
    validation {
        required: true
    }
    security {
        escapeMode: stripHtml
    }
    appearance {
        attributeGroup: @avatar
        sequence: 100
    }
    dependingOn {
        attribute: @AVATAR_TYPE/component
        conditionType: =
        value: initials
    }
    help {
        helpText: Select the source column to be displayed within each avatar. Only varchar2 data types are supported.
    }
)

customAttribute AVATAR_SHAPE (
    apexlangName: shape
    attribute: 12
    name: Shape
    type: selectList
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 120
    }
    default {
        value: t-Avatar--rounded
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the shape of the avatar. Default inherits the shape set by the containing template.
    }

    entry circular (
        sequence: 20
        display: Circular
        return: t-Avatar--circle
        help {
            helpText: Displayed within a circular shape.
        }
    )

    entry noShape (
        sequence: 40
        display: No Shape
        return: t-Avatar--noShape
        help {
            helpText: Displayed inline without a containing shape.
        }
    )

    entry rounded (
        sequence: 10
        display: Rounded
        return: t-Avatar--rounded
        help {
            helpText: Displayed within a square with rounded corners.
        }
    )

    entry square (
        sequence: 30
        display: Square
        return: t-Avatar--square
        help {
            helpText: Displayed within a square shape.
        }
    )

)

customAttribute AVATAR_SIZE (
    apexlangName: size
    attribute: 20
    name: Size
    type: selectList
    componentLov {
        nullText: Default
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @avatar
        sequence: 200
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Set the size of the avatar. The default inherits the sizing set by the containing template.
    }

    entry extraExtraLarge (
        sequence: 70
        display: Extra Extra Large
        return: t-Avatar--xxl
    )

    entry extraExtraSmall (
        sequence: 10
        display: Extra Extra Small
        return: t-Avatar--xxs
    )

    entry extraLarge (
        sequence: 60
        display: Extra Large
        return: t-Avatar--xl
    )

    entry extraSmall (
        sequence: 20
        display: Extra Small
        return: t-Avatar--xs
    )

    entry large (
        sequence: 50
        display: Large
        return: t-Avatar--lg
    )

    entry medium (
        sequence: 40
        display: Medium
        return: t-Avatar--md
    )

    entry small (
        sequence: 30
        display: Small
        return: t-Avatar--sm
    )

)

customAttribute AVATAR_TYPE (
    apexlangName: type
    attribute: 7
    name: Type
    type: selectList
    validation {
        required: true
    }
    appearance {
        attributeGroup: @avatar
        sequence: 70
    }
    default {
        value: icon
        sampleDataValue: icon
    }
    dependingOn {
        attribute: @DISPLAY_AVATAR/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Select the type of content that will be displayed in the avatar.
    }

    entry icon (
        sequence: 30
        display: Icon
        return: icon
    )

    entry image (
        sequence: 10
        display: Image
        return: image
    )

    entry initials (
        sequence: 20
        display: Initials
        return: initials
    )

)

customAttribute BADGE_COL_WIDTH (
    apexlangName: columnWidth
    attribute: 22
    name: Column Width
    type: selectList
    validation {
        required: true
    }
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 220
    }
    default {
        value: t-ContentRow-badge--md
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Set the width of the content row columns. Default width is medium.
    }

    entry auto (
        sequence: 40
        display: Auto
        return: t-ContentRow-badge--auto
    )

    entry large (
        sequence: 30
        display: Large
        return: t-ContentRow-badge--lg
    )

    entry medium (
        sequence: 20
        display: Medium
        return: t-ContentRow-badge--md
    )

    entry small (
        sequence: 10
        display: Small
        return: t-ContentRow-badge--sm
    )

)

customAttribute BADGE_ICON (
    apexlangName: icon
    attribute: 16
    name: Icon
    type: icon
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 160
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Enter an icon class or use the Pick Icon dialog to select the icon you want to add to display in the badge.
    }
)

customAttribute BADGE_LABEL (
    apexlangName: label
    attribute: 13
    name: Label
    validation {
        required: true
    }
    appearance {
        attributeGroup: @badge
        sequence: 130
    }
    builder {
        translatable: true
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Enter a value for the badge label or select a source column from the quick pick options.
    }
)

customAttribute BADGE_LABEL_DISPLAY (
    apexlangName: displayLabel
    attribute: 17
    name: Display Label
    type: yesNo
    security {
        escapeMode: htmlAttribute
    }
    appearance {
        attributeGroup: @badge
        sequence: 170
    }
    dependingOn {
        attribute: @DISPLAY_BADGE/component
        conditionType: =
        value: Y
    }
    help {
        helpText: Specify whether to display or hide the badge label. When set to Yes, the badge label will be displayed in addition to the badge value. When set to No, only the badge value will be displayed.
    }
)

customAttribute BADGE_SHAPE (
    apexlangName: shape
