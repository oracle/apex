        }
    )

    entry table-row-counts (
        label: Table Row Counts
        icon {
            imageIconCssClasses: fa-table
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 32
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: View a list of the database tables used by this demonstration system and the current row counts.
            2: reportIcon
        }
    )

)

list reset-sample-data-list (
    name: reset sample data LIST

    entry reset-data-to-2xl (
        label: Reset Data to 2XL
        icon {
            imageIconCssClasses: fa-cog
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                type: url
                url: javascript:$s('P40_SIZE','XXL');apex.submit({showWait:true});
            }
        }
        userDefinedAttributes {
            1: Truncate existing sales history data and generate 50,000 rows of sales history
        }
    )

    entry reset-data-to-3xl (
        label: Reset Data to 3XL
        icon {
            imageIconCssClasses: fa-cog
        }
