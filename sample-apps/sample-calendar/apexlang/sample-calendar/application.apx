app SAMPLE-CALENDAR (
    name: Sample Calendar
    version: 26.1.0
    group: @sample-apps
    logo {
        type: text
        text: Sample Calendar
    }
    navigation {
        homeUrl: {
            page: 1
        }
    }
    navigationMenu {
        listTemplate: @/side-navigation-menu
        templateOptions: [
            #DEFAULT#
            js-defaultCollapsed
            js-navCollapsed--hidden
            t-TreeNav--styleA
        ]
        list: @navigation-menu
    }
    navigationBar {
        list: @navigation-bar-top
        listTemplate: @/navigation-bar
    }
    userInterface {
        currentTheme: @universal-theme
        usersCanChooseThemeStyle: true
    }
    appFormatMasks {
        date: YYYY/MM/DD
        dateTime: YYYY/MM/DD HH24:MI
    }
    css {
        fileUrls: #IMAGE_PREFIX#pkgapp_ui/css/5.0#MIN#.css
    }
    authentication {
        scheme: @apex-auth
        publicUser: APEX_PUBLIC_USER
    }
    authorization {
        runOnPublicPages: true
    }
    security {
        deepLinking: true
        embedInFrames: allowSameOrigin
        runtimeApiUsage: modifyThisApp
    }
    sessionStateProtection {
        allowUrlsCreatedAfter: 1999-08-04T00:00:00
        checksumSalt: 0D453848360D386985C4B2C8DC5F4FD47285B41C90A9749316FD215E7F0A4AB5
    }
    sessionManagement {
        rejoinSessions: publicSessions
    }
    globalization {
        primaryLanguage: en-us
        documentDirection: leftToRight
    }
    progressiveWebApp {
        enable: false
    }
    rowSearch {
        tokenize: false
    }
    reportPrinting {
        type: useInstanceSettings
    }
    advanced {
        passEcid: false
        modernizeApp: true
        copyrightBanner:
            ```
            Name: #APP_NAME#
            Copyright (c) 2012, #YEAR# Oracle and/or its affiliates.
            Licensed under the Universal Permissive License v 1.0 as shown
            at https://oss.oracle.com/licenses/upl/
            
            This script makes use of the FullCalendar product. Refer to
            THIRD_PARTY_LICENSES.txt in the top directory of this project
            or at https://github.com/oracle/apex for license information.
            ```
    }
    comments {
        comments:
            ```
            1.0.7 -> 1.0.8: Added "SQL Source" show/hide region to "Monthly Calendar" and "Date Reporting" pages.
            1.0.8 -> 1.0.9: Changed Authentication scheme to use new "ORA_WWV_PACKAGED_APPLICATIONS" cookie
            ```
    }

    substitution APP_NAME (
        value {
            staticValue: Sample Calendar
        }
    )

    substitution GETTING_STARTED_URL (
        value {
            staticValue: http://www.oracle.com/technetwork/developer-tools/apex/index.html
        }
    )

)

