page 14 (
    name: &P14_PROJECT.
    alias: P14-PROJECT
    title: &P14_PROJECT.
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region end-date (
        name: End Date
        type: plugin/miniCalendar
        source {
            sqlQuery: select END_DATE, 'End Date' lbl from EBA_DEMO_CAL_PROJECTS where id = :P14_ID
        }
        layout {
            sequence: 70
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
                t-Region--noBorder
            ]
        }
        settings {
            dateColumn: END_DATE
            labelColumn: LBL
        }
    )

    region hidden-items (
        name: Hidden Items
        type: staticContent
        layout {
            sequence: 50
            slot: banner
        }
    )

    region project-details (
        name: Project Details
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: style="margin: 8px;"
        }
    )

    region start-date (
        name: Start Date
        type: plugin/miniCalendar
        source {
            sqlQuery: select start_date, 'Start Date' lbl from EBA_DEMO_CAL_PROJECTS where id = :P14_ID
