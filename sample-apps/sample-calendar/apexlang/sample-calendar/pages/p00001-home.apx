page 1 (
    name: Sample Calendar
    alias: HOME
    title: &APP_NAME.
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-application (
        name: About this application
        type: staticContent
        source {
            htmlCode: <p>Oracle APEX has an integrated calendaring component.  This application demonstrates how this component can be used and also shows APEX plugins which can display calendars useful in some applications.  Calendars in APEX are based on data obtained from SQL queries.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
    )

    region app-name (
        name: &APP_NAME.
        type: staticContent
        source {
            htmlCode: <p>Demonstrations of calendars in Oracle APEX</p>
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/hero
            templateOptions: #DEFAULT#
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region calendar-examples (
        name: Calendar Examples
        type: list
        source {
            list: @home-page-list
        }
        layout {
            sequence: 20
            slot: body
        }
        componentAppearance {
            listTemplate: @/cards
            templateOptions: [
                #DEFAULT#
                t-Cards--basic
                t-Cards--displayIcons
                t-Cards--3cols
                t-Cards--desc-4ln
                u-colors
                t-Cards--animColorFill
            ]
        }
    )

    region footer (
        name: Footer
        type: plugin/sampleAppsFooter
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

)

