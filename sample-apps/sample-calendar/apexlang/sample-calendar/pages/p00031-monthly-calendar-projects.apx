page 31 (
    name: Monthly Calendar: Projects
    alias: MONTHLY-CALENDAR-PROJECTS
    title: Monthly Calendar: Projects
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode: <p>This is a standard Oracle APEX calendar region component built using the create calendar region wizard. A <strong>Button Bar</strong> region was also created and a <strong>P31_PROJECTS</strong> page item to allow for filtering by project. Click on a calendar event to open a dialog where you can edit the event's details.</p>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
    )

    region tasks (
        name: Tasks
        type: calendar
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                   id,
                   project,
                   task_name,
                   status,
                   assigned_to,
                   cost,
                   start_date,
                   end_date,
                   case
                      when status = 'Pending' then 'apex-cal-blue'
                      when status = 'Open' then 'apex-cal-green'
                      when status = 'Closed' then 'apex-cal-gray'
                      when status = 'On-Hold' then 'apex-cal-orange'
                   end as css_class
                from eba_demo_cal_projects
                where (nvl(:P31_PROJECTS,'0') = '0' or project = :P31_PROJECTS)
                order by end_date
                ```
            pageItemsToSubmit: P31_PROJECTS
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            htmlDomId: task_due_dates
        }
        settings {
            displayColumn: TASK_NAME
            startDateColumn: START_DATE
            endDateColumn: END_DATE
            pkColumn: ID
            showTime: true
            multipleLineEvents: false
            calendarViewsAndNavigation: [
                month
                week
                day
                list
                navigation
            ]
            viewEditLink: {
                page: 3
                items: {
                    P3_ID: &ID.
                    P3_LASTVIEW: &APP_PAGE_ID.
                }
                action: resetPagination
            }
            maxEventsDay: 3
            cssClass: CSS_CLASS
        }
        performance {
            lazyLoading: true
        }
        componentAdvanced {
            initJavaScriptFunction:
                ```javascript-browser
                function (p) {
                 p.endDateExclusive = false;
                }
                ```
        }
    )

    pageItem P31_PROJECTS (
        type: selectList
        label {
            label: Project
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @distinct-projects
            nullDisplayValue: - All Projects -
            nullReturnValue: 0
        }
        layout {
            sequence: 10
            region: @button-bar
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                margin-bottom-md
            ]
            height: 1
        }
        source {
            type: staticValue
            staticValue: 0
        }
        default {
            type: static
            staticValue: 0
        }
    )

    dynamicAction change-project-refresh-calendar (
        name: Change Project - Refresh Calendar
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P31_PROJECTS
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @tasks
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction dialog-closed (
        name: Dialog closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @tasks
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @tasks
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

