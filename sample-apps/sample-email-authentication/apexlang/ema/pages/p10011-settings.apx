page 10011 (
    name: Settings
    alias: SETTINGS
    title: Settings
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administrator
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region settings (
        name: Settings
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       NAME || apex_item.hidden(1,id) name,
                       DESCRIPTION,
                       apex_item.text(2,value) VALUE,
                       UPDATED_ON,
                       UPDATED_BY
                  from EBA_EMA_SETTINGS
                  order by display_order, name
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column DESCRIPTION (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 0
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Last Updated By
            }
            layout {
                sequence: 11
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED_ON (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Last Updated
            }
            layout {
                sequence: 10
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column VALUE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Value
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cancel (
        name: cancel
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process update-settings (
        name: Update settings
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_name  eba_ema_settings.name%type;
                begin
                
                for i in 1..apex_application.g_f01.count loop
                    select name
                      into l_name
                      from eba_ema_settings
                     where id = apex_application.g_f01(i);
                
                    if l_name is not null then
                        eba_ema_util.set_setting (
                            p_name => l_name,
                            p_value => apex_application.g_f02(i) );
                    end if;
                    
                    l_name := null;
                end loop;
                
                end;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Settings saved.
        }
        error {
            errorMessage: Settings failed to be saved.
        }
        advanced {
            executionMappingIdentifier: 9036718052272608712
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

)

