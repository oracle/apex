    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @data-load-wizard-progress
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 21
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next (
        buttonName: NEXT
        label: Load Data
        layout {
            sequence: 30
            region: @data-load-wizard-progress
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 10
            region: @data-load-wizard-progress
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 22
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process prepare-uploaded-data (
        name: Prepare Uploaded Data
        type: loadUploadedData
        dataLoading {
            dataLoadDefinition: @load-employees
        }
        processingResult {
            insertCountItem: P24_INSERT_COUNT
            updateCountItem: P24_UPDATE_COUNT
            errorCountItem: P24_ERROR_COUNT
            reviewCountItem: P24_REVIEW_COUNT
        }
        execution {
            sequence: 10
        }
        error {
            errorMessage: Data Loading Failed
        }
        advanced {
            executionMappingIdentifier: 2670900985537359777
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 24
            }
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

)

