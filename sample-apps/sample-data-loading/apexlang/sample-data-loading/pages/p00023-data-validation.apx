page 23 (
    name: Data Validation
    alias: DATA-VALIDATION
    title: Data Validation
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        executeWhenPageLoads:
            ```javascript-browser
            /* apply u-Report--dataLoad CSS class to Data Load Report and hide empty columns */
            $("table.standardLook").addClass("u-Report");
            $("table.standardLook").addClass("u-Report--standardLook");
            $("table.u-Report--standardLook tr:nth-child(1) td:empty").css("display", "none");
            $("table.u-Report--standardLook tr th:empty").css("display", "none");
            $("table.u-Report--standardLook tr th:empty").each( function (idx, elem) { $("table.u-Report--standardLook tr td[headers=\""+$(elem).attr('id')+"\"]").css("display", "none");});
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region data-load-wizard-progress (
        name: Data Load Wizard Progress
        type: list
        source {
            list: @data-load-wizard-progress-load-employees
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/wizard-container
            templateOptions: [
                #DEFAULT#
                t-Wizard--hideStepsXSmall
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            listTemplate: @/wizard-progress
            templateOptions: [
                #DEFAULT#
                t-WizardSteps--displayLabels
            ]
        }
    )

    region data-validation (
        name: Data Validation
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select n001 as row_num,
                       c049 as action,
                       c001, c002, c003,
                       c004, c005, c006,
                       c007, c008, c009,
                       c010, c011, c012,
                       c013, c014, c015,
                       c016, c017, c018,
                       c019, c020, c021,
                       c022, c023, c024,
                       c025, c026, c027,
                       c028, c029, c030,
                       c031, c032, c033,
                       c034, c035, c036,
                       c037, c038, c040,
                       c041, c042, c043,
                       c044, c045
                  from apex_collections
                 where collection_name = 'LOAD_CONTENT'
                   and c049 in ('INSERT','UPDATE', 'FAILED')
                 order by seq_id
                ```
        }
        layout {
            sequence: 20
            parentRegion: @data-load-wizard-progress
            slot: wizardSubRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noBorder
                t-Region--scrollBody
            ]
            cssClasses: data-upload-validation
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
        }
        componentAppearance {
            templateType: predefined
        }
        pagination {
            type: setPaginationSelectList
            partialPageRefresh: false
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }
        heading {
            type: plsqlFunctionBody
            plsqlFunctionBody:
                ```plsql
                declare  
                    l_string varchar(32767);
                begin
                    l_string := wwv_flow_lang.system_message('DATA_LOAD.SEQUENCE_ACTION');
                    for l_heading in ( select c005 as label
                                         from apex_collections
                                        where collection_name = 'LOAD_COL_HEAD'
                                        order by seq_id )
                    loop
                        l_string := l_string || ':' || apex_escape.html(l_heading.label);
                    end loop;
                    return l_string;
                end;
                ```
        }

