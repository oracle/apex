    region upload-a-file (
        name: Upload a File
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @data-source
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNull
            item: P17_FILE
        }
        settings {
            outputAs: text
        }
    )

    pageItem P17_ERROR_ROWS (
        type: hidden
        layout {
            sequence: 30
            region: @about-this-page
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_FILE (
        type: fileUpload
        label {
            label: Upload a File
            alignment: left
        }
        display {
            displayAs: blockDropzone
            dropzoneTitle: Drag and Drop Sales Data
            dropzoneDesc: Supported formats CSV, TXT, ZIP
        }
        storage {
            type: appTempFiles
            maxFileSize: 10000
        }
        layout {
            sequence: 10
            region: @upload-a-file
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
        }
    )

    pageItem P17_FILE_NAME (
        type: displayOnly
        label {
            label: Loaded File
            alignment: left
        }
        layout {
            sequence: 20
            region: @loaded-file
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Pasted Data
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_LOAD_EXEC_ID (
        type: hidden
        layout {
            sequence: 10
            region: @about-this-page
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_PROCESSED_ROWS (
        type: hidden
        layout {
            sequence: 20
            region: @about-this-page
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button clear (
        buttonName: CLEAR
        label: Clear
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button load (
        buttonName: LOAD
        label: Load Data
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P17_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P17_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation is-valid-file-type (
        name: Is valid file type
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                if apex_data_parser.assert_file_type(
                       p_file_name => :P17_FILE_NAME,
                       p_file_type => apex_data_parser.c_file_type_csv ) or
                   lower( :P17_FILE_NAME ) like '%.zip'
                then
                    return true;
                else
                    :P17_FILE := null;
                    return false;
                end if;
                ```
        }
        error {
            errorMessage: Invalid file type. Supported file types CSV, TXT, ZIP.
            associatedItem: @P17_FILE
        }
    )

    computation p17-file-name (
        itemName: P17_FILE_NAME
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P17_FILE
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P17_FILE
        }
    )

    process clear-cache (
        name: Clear Cache
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 1661952210155930294
        }
        serverSideCondition {
            whenButtonPressed: @clear
        }
    )

    process load-data (
        name: Load Data
        type: dataLoading
        executionChain: @load-data-background
        dataLoading {
            dataLoadDefinition: @Sales_Data_Load
        }
        sourceData {
            sourceDataType: sqlQuery
            sqlQuery: select eba_demo_data_load.get_file_blob from sys.dual
        }
        processingResult {
            processedRowCountItem: P17_PROCESSED_ROWS
            errorRowCountItem: P17_ERROR_ROWS
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: "{\"rows_processed\": &P17_PROCESSED_ROWS., \"rows_with_error\": &P17_ERROR_ROWS. }  "
        }
        advanced {
            executionMappingIdentifier: 156157145293832925
        }
    )

    process load-data-background (
        name: Load Data Background
        type: executionChain
        backgroundExecution {
            runInBackground: true
            returnIdIntoItem: P17_LOAD_EXEC_ID
            tempFileHandling: move
            tempFileItems: P17_FILE
            executionsLimit: 1
            submitImmediately: true
        }
        serialization {
            serialize: true
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Data Loading task kicked off for execution.
        }
        error {
            errorMessage: Only one file can be loaded at a time.
        }
        advanced {
            executionMappingIdentifier: 156156947944832923
        }
        serverSideCondition {
            whenButtonPressed: @load
            type: itemIsNotNull
            item: P17_FILE
        }
    )

    process report-loading-results (
        name: Report Loading Results
        type: executeCode
        executionChain: @load-data-background
        source {
            plsqlCode: apex_background_process.set_status( '{"rows_processed":' || :P17_PROCESSED_ROWS || ',"rows_with_error":' || :P17_ERROR_ROWS || '}' );
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 156157224800832926
        }
    )

    process unpack-zip-archive (
        name: Unpack ZIP Archive
        type: executeCode
        executionChain: @load-data-background
        source {
            plsqlCode:
                ```plsql
                declare
                    l_file      blob;
                    l_mime_type apex_application_temp_files.mime_type%type;
                begin
                    select mime_type,
                           blob_content
                      into l_mime_type,
                           l_file
                      from apex_application_temp_files
                     where name = :P17_FILE;
                
                    if l_mime_type = 'application/zip' then
                        l_file := eba_demo_data_load.zip_to_csv( p_blob_content => l_file, p_mime_type => l_mime_type );
                    end if;
                
                    eba_demo_data_load.set_file_blob( l_file );
                end;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 156157015679832924
        }
    )

    branch (
        name: View Load Status
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 18
                items: {
                    P18_LOAD_EXEC_ID: &P17_LOAD_EXEC_ID.
                }
                clearCache: [
                    17
                    18
                    SALES_DATA_LOAD_ERR
                ]
            }
        }
        serverSideCondition {
            whenButtonPressed: @load
        }
    )

)

