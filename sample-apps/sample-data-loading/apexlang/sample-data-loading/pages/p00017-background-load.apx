page 17 (
    name: Background Load
    alias: BACKGROUND-LOAD
    title: Background Load
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>If you are loading large datasets, the loading can run into a long running page process.  
                   If the instance is set up with a resource limit, you will see the maximum limit has been reached for this type of load. To load large data efficiently, 
                   you can run the loading process in the background.</p>
                <p>This page illustrates how to use a process of the <strong>Execution Chain</strong> type to send the
                   Data Loading execution to the background. The status of the background loading operation can be 
                   monitored in the <strong>APEX_APPL_PAGE_BG_PROC_STATUS</strong> APEX view. You can also review
                   currently running background executions by clicking <strong>Session</strong> in the 
                   <strong>Developer Toolbar</strong> and then viewing <strong>Background Executions</strong>.
                   </p>
                
                <p>Download sample <a href="#APP_IMAGES#SalesData.zip">SalesData.zip</a> file.</a> This page uses <em>APEX_ZIP</em> package to unzip the zip file.  You can upload either the ZIP or CSV file.</p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 60
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P17_FILE
        }
        settings {
            outputAs: text
        }
    )

    region create-job-privilege-is-missing (
        name: Create Job Privilege is Missing
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>To use this page, your application parsing schema must have <em>CREATE JOB</em> privilege. Contact your database administrator to get the <strong>CREATE JOB</strong> privilege granted using the following SQL statement.</p>
                <pre>grant CREATE JOB to #OWNER#;</pre>
                <p>Then log out and back into the application and revisit this page. </p>
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        security {
            authorizationScheme: !@create-job-priv-available
        }
    )

    region data-source (
        name: Data Source
        type: staticContent
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        security {
            authorizationScheme: @create-job-priv-available
        }
        settings {
            outputAs: text
        }
    )

    region loaded-file (
        name: Loaded File
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @data-source
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--large
                t-Form--stretchInputs
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P17_FILE
        }
        settings {
            outputAs: text
        }
    )

    region preview (
        name: Preview
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.line_number,
                       p.col001, p.col002, p.col003, p.col004, p.col005, p.col006, p.col007, p.col008, p.col009, p.col010
                       -- add more columns (col011 to col300) here.
                  from apex_application_temp_files f, 
                       table( apex_data_parser.parse(
                                  p_content          => eba_demo_data_load.zip_to_csv(
                                                            p_blob_content => f.blob_content,
                                                            p_mime_type    => f.mime_type ),
                                  p_file_name        => f.filename,
                                  p_file_type        => 2,  -- csv file type
                                  p_add_headers_row  => 'Y',
                                  p_csv_enclosed     => '"',
                                  p_file_charset     => 'WE8ISO8859P1',
                                  p_max_rows         => 10 ) ) p
                 where f.name = :P17_FILE
                 and p.line_number > 1;
                ```
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P17_FILE
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--horizontalBorders
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        heading {
            type: plsqlFunctionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_col_headers varchar2(32767);
                begin
                    select p.line_number || ':' || 
                       p.col001 || ':' || p.col002 || ':' || p.col003 || ':' || p.col004 || ':' || p.col005 || ':' || 
                       p.col006 || ':' || p.col007 || ':' || p.col008 || ':' || p.col009 || ':' || p.col010
                    into l_col_headers
                       -- add more columns (col011 to col300) here.
                     from apex_application_temp_files f, 
                          table( apex_data_parser.parse(
                                     p_content          => eba_demo_data_load.zip_to_csv(
                                                               p_blob_content => f.blob_content,
                                                               p_mime_type    => f.mime_type ),
                                     p_file_name        => f.filename,
                                     p_file_type        => 2,  -- csv file type
                                     p_add_headers_row  => 'Y',
                                     p_csv_enclosed     => '"',
                                     p_file_charset     => 'WE8ISO8859P1',
                                     p_max_rows         => 10 ) ) p
                    where f.name = :P17_FILE
                    and p.line_number = 1;
                
                    return l_col_headers;
                end;
                ```
        }

        column COL001 (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Col001
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
