page 16 (
    name: Multiple File Types Load
    alias: MULTI-FILETYPES-LOAD
    title: Multiple File Types Load
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This page allows uploading employees data in CSV, XLSX, XML or JSON file types.  It uses <a href="https://docs.oracle.com/en/database/oracle/application-express/21.1/aeapi/APEX_DATA_LOADING.html" target="_new">APEX_DATA_LOADING</a> package to call different application data loading definition based on file types. Download sample files to try the load.</p>
                
                <ul>
                <li><a href="#APP_IMAGES#Employees.csv">Employees.csv</a></li>
                <li><a href="#APP_IMAGES#Employees.xlsx">Employees.xlsx</a></li>
                <li><a href="#APP_IMAGES#Employees.xml">Employees.xml</a></li>
                <li><a href="#APP_IMAGES#Employees.json">Employees.json</a></li>
                </ul>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

