        label: Load Data
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction submit-worksheet-on-change (
        name: Submit worksheet on change
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P16_XLSX_WORKSHEET
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P16_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P16_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation is-valid-file-type (
        name: Is valid file type
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                if :P16_FILE_TYPE in (
                    apex_data_parser.c_file_type_csv,
                    apex_data_parser.c_file_type_xlsx,
                    apex_data_parser.c_file_type_xml,
                    apex_data_parser.c_file_type_json )
                then
                    return true;
                else
                    :P16_FILE := null;
                    return false;
                end if;
                ```
        }
        error {
            errorMessage: Invalid file type. Supported file types are CSV, TXT, XLSX, XML, JSON.
            associatedItem: @P16_FILE
        }
    )

    computation p16-file-name (
        itemName: P16_FILE_NAME
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P16_FILE
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P16_FILE
        }
    )

    computation p16-file-type (
        itemName: P16_FILE_TYPE
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            type: expression
            plsqlExpression: apex_data_parser.get_file_type( p_file_name => :P16_FILE )
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P16_FILE
        }
    )

    process clear-cache (
        name: Clear Cache
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 1659730169146728107
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR' or :P16_ERROR_ROW_COUNT = 0
        }
    )

    process load-data (
        name: Load Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                DECLARE
                    l_file blob;
                    l_load_result apex_data_loading.t_data_load_result;
                BEGIN
                    SELECT blob_content
                      INTO l_file
                      FROM apex_application_temp_files
                     WHERE name = :P16_FILE;
                    
                    if :P16_FILE_TYPE = apex_data_parser.c_file_type_csv then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'CSV_Load',
                                             p_data_to_load => l_file );
                    elsif :P16_FILE_TYPE = apex_data_parser.c_file_type_xlsx then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id       => 'XLSX_Load',
                                             p_data_to_load    => l_file,
                                             p_xlsx_sheet_name => :P16_XLSX_WORKSHEET );
                    elsif :P16_FILE_TYPE = apex_data_parser.c_file_type_xml then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'XML_Load',
                                             p_data_to_load => l_file );
                    elsif :P16_FILE_TYPE = apex_data_parser.c_file_type_json then
                        l_load_result := apex_data_loading.load_data (
                                             p_static_id    => 'JSON_Load',
                                             p_data_to_load => l_file );
                    end if;
                
                    :P16_ERROR_ROW_COUNT := l_load_result.error_rows;
                    :P16_PROCESSED_ROW_COUNT := l_load_result.processed_rows;
                END;
                ```
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Loaded &P16_PROCESSED_ROW_COUNT!HTML. rows.
        }
        error {
            errorMessage: Failed to load &P16_ERROR_ROW_COUNT!HTML. rows.
        }
        advanced {
            executionMappingIdentifier: 1659744766058768993
        }
        serverSideCondition {
            whenButtonPressed: @load
        }
    )

)

