    pageItem P16_PROCESSED_ROW_COUNT (
        type: hidden
        layout {
            sequence: 30
            region: @upload-a-file
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P16_XLSX_WORKSHEET (
        type: selectList
        label {
            label: XLSX Worksheet
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.sheet_display_name,
                       p.sheet_file_name
                  from apex_application_temp_files f,
                       table( apex_data_parser.get_xlsx_worksheets( p_content => f.blob_content ) ) p
                 where f.name = :P16_FILE
                ```
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 30
            region: @loaded-file
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_sheet_count number;
                begin
                    if :P16_FILE_TYPE != apex_data_parser.c_file_type_xlsx then
                        return false;
                    end if;
                
                    select count(*)
                      into l_sheet_count
                      from apex_application_temp_files f,
                           table( apex_data_parser.get_xlsx_worksheets( p_content => f.blob_content ) ) p
                     where f.name = :P16_FILE;
                    
                     -- display if the XSLX file contains multiple worksheets
                    return ( l_sheet_count > 1 );
                exception
                    when others then 
                        return false;
                end;
                ```
        }
    )

