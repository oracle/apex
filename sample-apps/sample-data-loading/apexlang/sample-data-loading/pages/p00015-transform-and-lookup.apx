    region loaded-file (
        name: Loaded File
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @data-source
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_FILE
        }
        settings {
            outputAs: text
        }
    )

    region preview (
        name: Preview
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.line_number,
                       p.col001, p.col002, p.col003, p.col004, p.col005, p.col006, p.col007, p.col008, p.col009, p.col010
                       -- add more columns (col011 to col300) here.
                  from apex_application_temp_files f, 
                       table( apex_data_parser.parse(
                                  p_content          => f.blob_content,
                                  p_file_name        => f.filename,
                                  p_add_headers_row   => 'Y',
                                  p_csv_enclosed      => '"',
                                  p_file_charset      => 'WE8ISO8859P1',
                                  p_max_rows         => 10 ) ) p
                 where f.name = :P15_FILE
                 and p.line_number > 1;
                ```
            pageItemsToSubmit: P15_FILE
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_FILE
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--horizontalBorders
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        heading {
            type: plsqlFunctionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_col_headers varchar2(32767);
                begin
                    select p.line_number || ':' || 
                       p.col001 || ':' || p.col002 || ':' || p.col003 || ':' || p.col004 || ':' || p.col005 || ':' || 
                       p.col006 || ':' || p.col007 || ':' || p.col008 || ':' || p.col009 || ':' || p.col010
                    into l_col_headers
                       -- add more columns (col011 to col300) here.
                      from apex_application_temp_files f, 
                           table( apex_data_parser.parse(
                                      p_content          => f.blob_content,
                                      p_file_name        => f.filename,
                                      p_add_headers_row   => 'Y',
                                      p_csv_enclosed      => '"',
                                      p_file_charset      => 'WE8ISO8859P1',
                                      p_max_rows         => 10 ) ) p
                     where f.name = :P15_FILE
                     and p.line_number = 1;
                
                    return l_col_headers;
                end;
                ```
        }

        column COL001 (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Col001
            }
            layout {
                sequence: 2
            }
            sorting {
