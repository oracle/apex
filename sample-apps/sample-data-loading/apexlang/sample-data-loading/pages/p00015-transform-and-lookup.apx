    region upload-a-file (
        name: Upload a File
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @data-source
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNull
            item: P15_FILE
        }
        settings {
            outputAs: text
        }
    )

    pageItem P15_ERROR_ROW_COUNT (
        type: hidden
        layout {
            sequence: 20
            region: @upload-a-file
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P15_FILE (
        type: fileUpload
        label {
            label: Upload a File
            alignment: left
        }
        display {
            displayAs: blockDropzone
            dropzoneDesc: Supported formats CSV, TXT
        }
        storage {
            type: appTempFiles
            maxFileSize: 5000
        }
        layout {
            sequence: 10
            region: @upload-a-file
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
        }
    )

    pageItem P15_FILE_NAME (
        type: displayOnly
        label {
            label: Loaded File
            alignment: left
        }
        layout {
            sequence: 20
            region: @loaded-file
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Pasted Data
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button clear (
        buttonName: CLEAR
        label: Clear
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button load (
        buttonName: LOAD
        label: Load Data
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P15_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P15_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation is-valid-file-type (
        name: Is valid file type
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                if apex_data_parser.assert_file_type(
                       p_file_name => :P15_FILE_NAME,
                       p_file_type => apex_data_parser.c_file_type_csv )
                then
                    return true;
                else
                    :P15_FILE := null;
                    return false;
                end if;
                ```
        }
        error {
            errorMessage: Invalid file type. Supported file types CSV, TXT.
            associatedItem: @P15_FILE
        }
    )

    computation p15-file-name (
        itemName: P15_FILE_NAME
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P15_FILE
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_FILE
        }
    )

    process clear-cache (
        name: Clear Cache
        type: clearSessionState
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 1658704713304802477
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR' or :P15_ERROR_ROW_COUNT = 0
        }
    )

    process load-data (
        name: Load Data
        type: dataLoading
        dataLoading {
            dataLoadDefinition: @Transform_and_Lookup
        }
        sourceData {
            fileBrowseItem: P15_FILE
        }
        processingResult {
            errorRowCountItem: P15_ERROR_ROW_COUNT
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 1658704292856802477
        }
        serverSideCondition {
            whenButtonPressed: @load
        }
    )

)

