                       JOB              F_JOB,
                       MGR              F_MGR,
                       HIREDATE         F_HIREDATE,
                       SAL              F_SAL,
                       COMM             F_COMM,
                       DEPTNO           F_DEPTNO,
                       CREATED          F_CREATED,
                       LAST_UPDATED     F_LAST_UPDATED
                  from EBA_DEMO_LOAD_EMP_ERR$
                
