    button load-file (
        buttonName: LOAD_FILE
        label: Load Data
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 20
            region: @button-bar-2
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-angle-right
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNull
            item: P11_DATA
        }
    )

    dynamicAction upload-a-file (
        name: Upload a File
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P11_FILE
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P11_FILE
        }

        action native-submit-page (
            action: submitPage
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation is-valid-file-type (
        name: Is valid file type
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                if apex_data_parser.assert_file_type(
                       p_file_name => :P11_FILE_NAME,
                       p_file_type => apex_data_parser.c_file_type_csv )
                then
                    return true;
                else
                    :P11_FILE := null;
                    return false;
                end if;
                ```
        }
        error {
            errorMessage: Invalid file type. Supported file types CSV, TXT.
            associatedItem: @P11_FILE
        }
        serverSideCondition {
            whenButtonPressed: @load-file
        }
    )

    computation p11-file-name (
        itemName: P11_FILE_NAME
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            sqlQuery:
                ```sql
                select filename
                  from apex_application_temp_files 
                 where name = :P11_FILE
                ```
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P11_FILE is not null and :REQUEST = 'LOAD_FILE'
        }
    )

    process clear-file-cache (
        name: Clear File Cache
        type: clearSessionState
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 1658647463670735400
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR_FILE' or :P11_FILE_ERROR_ROW_COUNT = 0
        }
    )

    process clear-pasted-data-cache (
        name: Clear Pasted Data Cache
        type: clearSessionState
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 884681840390477436
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :REQUEST = 'CLEAR_DATA' or :P11_COPY_PASTE_ERROR_ROW_COUNT = 0
        }
    )

    process load-file-data (
        name: Load File Data
        type: dataLoading
        dataLoading {
            dataLoadDefinition: @CSV_Load
        }
        sourceData {
            fileBrowseItem: P11_FILE
        }
        processingResult {
            errorRowCountItem: P11_FILE_ERROR_ROW_COUNT
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 1658647059508735399
        }
        serverSideCondition {
            whenButtonPressed: @load-file
            type: itemIsNotNull
            item: P11_FILE
        }
    )

    process load-pasted-data (
        name: Load Pasted Data
        type: dataLoading
        dataLoading {
            dataLoadDefinition: @CSV_Load
        }
        sourceData {
            sourceDataType: textareaItem
            textareaItem: P11_DATA
        }
        processingResult {
            errorRowCountItem: P11_COPY_PASTE_ERROR_ROW_COUNT
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 1659167643657872007
        }
        serverSideCondition {
            whenButtonPressed: @load-data
            type: itemIsNotNull
            item: P11_DATA
        }
    )

)

