            alignment: left
        }
        layout {
            sequence: 20
            region: @pasted-data
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-clipboard-arrow-up fa-2x
        }
        default {
            type: static
            staticValue: Pasted Data
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button clear-data (
