    pageItem P11_COPY_PASTE_ERROR_ROW_COUNT (
        type: hidden
        layout {
            sequence: 20
            region: @copy-and-paste-delimited-data-2
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P11_DATA (
        type: textarea
        label {
            label: Copy and Paste Delimited Data
            alignment: left
        }
        layout {
            sequence: 10
            region: @copy-and-paste-delimited-data-2
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            width: 60
            height: 10
        }
    )

    pageItem P11_FILE (
        type: fileUpload
        label {
            label: Upload a File
            alignment: left
        }
        display {
            displayAs: blockDropzone
            dropzoneDesc: Supported formats CSV, TXT
        }
        storage {
            type: appTempFiles
            maxFileSize: 5000
        }
        layout {
            sequence: 10
            region: @upload-a-file
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
        }
    )

    pageItem P11_FILE_ERROR_ROW_COUNT (
        type: hidden
        layout {
            sequence: 20
            region: @upload-a-file
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P11_FILE_NAME (
        type: displayOnly
        label {
            label: Loaded File
            alignment: left
        }
        layout {
            sequence: 20
            region: @loaded-file
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Pasted Data
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P11_PASTED_DATA (
        type: displayOnly
        label {
