            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: timer-container
            regionDisplaySelector: true
        }
    )

    pageItem P18_LOADING_STATUS (
        type: hidden
        layout {
            sequence: 20
            region: @load-status
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P18_LOAD_EXEC_ID (
        type: hidden
        layout {
            sequence: 30
            region: @load-status
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    dynamicAction refresh-load-status-on-timer (
        name: Refresh Load Status on Timer
        execution {
            sequence: 20
        }
        when {
            event: custom
            customEvent: job_timer
            selectionType: jQuerySelector
            jquerySelector: #timer-container
        }

        action get-loading-job-status (
            name: Get Loading Job Status
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    begin
                        select status_code
                          into :P18_LOADING_STATUS
                          from apex_appl_page_bg_proc_status
                         where execution_id = :P18_LOAD_EXEC_ID;
                    exception when others then
                        :P18_LOADING_STATUS := 'SUCCESS';
                    end;
                    ```
                itemsToReturn: P18_LOADING_STATUS
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-load-status-timer (
        name: Refresh Load Status Timer
        execution {
            sequence: 30
        }
        when {
            event: ready
        }

        action initialize-timer-for-load-status-refresh (
            name: Initialize Timer for Load Status Refresh
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var lSpinner$ = apex.util.showSpinner( $( "#loadStatus" ) );
                    
                    var triggerRefresh = function(){ 
                        var lstatus = apex.item("P18_LOADING_STATUS").getValue() ?? "ENQUEUED";
                    
                        apex.event.trigger( apex.jQuery("#timer-container"), "job_timer" );
                    
                        console.log( "current satus " + lstatus );
                    
                        if (  lstatus === 'SUCCESS'  || 
                              lstatus === 'ABORTED'  || 
                              lstatus === 'FAILED' ) {
                          apex.region( "loadStatus" ).refresh();
                          apex.region( "sales" ).refresh();
                          
                          if ( lstatus === 'FAILED' ||  
                               lstatus === 'ABORTED' ) {
                              apex.region( "loadError" ).element.show();
                              apex.region( "loadError" ).refresh();
                          }
                    
                          clearInterval( refreshInterval );
                          lSpinner$.remove();
                        } else {
                          apex.region( "loadStatus" ).refresh();
                          apex.region( "sales" ).refresh(); 
                        }
                    };
                    
                    var refreshInterval = setInterval( triggerRefresh, 1000);
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

)

