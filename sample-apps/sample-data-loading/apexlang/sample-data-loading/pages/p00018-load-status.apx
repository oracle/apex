    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 50
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region load-status (
        name: Load Status
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select initcap(status_code)                                               as status,
                       sofar                                                              as rows_processed,
                       json_value( status_message, '$.rows_processed'  returning number ) as rows_successful,
                       json_value( status_message, '$.rows_with_error' returning number ) as rows_with_error
                  from apex_appl_page_bg_proc_status
                 where execution_id = :P18_LOAD_EXEC_ID
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: loadStatus
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/badge-list
            templateOptions: [
                #DEFAULT#
                t-BadgeList--xlarge
                t-BadgeList--dash
                t-BadgeList--fixed
                t-Report--hideNoPagination
            ]
            showNullValuesAs: -
        }

        column ROWS_PROCESSED (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Rows Processed
                alignment: center
            }
            layout {
                sequence: 20
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            serverSideCondition {
                type: itemIsNotInColonDelimitedList
                item: P18_LOADING_STATUS
                list: [
