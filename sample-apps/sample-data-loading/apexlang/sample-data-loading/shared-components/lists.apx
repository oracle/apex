            sequence: 80
            parentEntry: @manual-data-loading
        }
        link {
            target: {
                page: 31
            }
        }
    )

    entry reset-data (
        label: Reset Data
        layout {
            sequence: 60
            parentEntry: @administration
        }
        link {
            target: {
                page: 8
            }
        }
    )

    entry theme-style (
        label: Theme Style
        layout {
            sequence: 70
            parentEntry: @administration
        }
        isCurrent {
            type: pages
            pages: 7
        }
        link {
            target: {
                page: 7
            }
        }
    )

    entry transformation-and-lookup (
        label: Transformation and Lookup
        icon {
            imageIconCssClasses: fa-dynamic-content
        }
        layout {
            sequence: 110
            parentEntry: @data-loading
        }
        link {
            target: {
