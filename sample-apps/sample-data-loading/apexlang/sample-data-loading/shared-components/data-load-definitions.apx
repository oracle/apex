dataLoadDefinition CSV_Load (
    name: CSV Load
    target {
        tableName: EBA_DEMO_LOAD_EMP
        loadingMethod: merge
    }
    dataProfile {
        name: CSV Load
        format: csv
    }
    advanced {
        encoding: iso-8859-1
        csvEnclosedBy: "
    }

    dataProfileColumn comm (
        columnName: COMM
        source {
            sequence: 7
            dataType: number
        }
        parsing {
            selector: COMM
        }
    )

    dataProfileColumn deptno (
        columnName: DEPTNO
        source {
            sequence: 8
            dataType: number
        }
        parsing {
            selector: DEPTNO
        }
    )

    dataProfileColumn empno (
        columnName: EMPNO
        source {
            sequence: 1
            dataType: number
            primaryKey: true
        }
        parsing {
            selector: EMPNO
        }
    )

    dataProfileColumn ename (
        columnName: ENAME
        source {
            sequence: 2
            dataType: varchar2
            maxLength: 10
        }
        parsing {
            selector: ENAME
        }
    )

    dataProfileColumn hiredate (
        columnName: HIREDATE
        source {
            sequence: 5
            dataType: date
        }
        parsing {
            selector: HIREDATE
            formatMask: MM/DD/YYYY
            hasTimeZone: false
        }
    )

    dataProfileColumn job (
        columnName: JOB
        source {
            sequence: 3
            dataType: varchar2
            maxLength: 10
        }
        parsing {
            selector: JOB
        }
    )

    dataProfileColumn mgr (
        columnName: MGR
        source {
            sequence: 4
            dataType: number
        }
        parsing {
            selector: MGR
        }
    )

    dataProfileColumn sal (
        columnName: SAL
        source {
            sequence: 6
            dataType: number
        }
        parsing {
            selector: SAL
        }
    )

)

dataLoadDefinition JSON_Load (
    name: JSON Load
