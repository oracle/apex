            pathExpression: sal
            decimalChar: .
        }
    )

)

dataLoadDefinition Sales_Data_Load (
    name: Sales Data Load
    target {
        tableName: EBA_DEMO_LOAD_SALES
        loadingMethod: replace
    }
    errorHandling {
        whenOnError: logErrorIntoCollection
        name: SALES_DATA_LOAD_ERR
    }
    dataProfile {
        name: Sales Data Load
        format: csv
    }
    advanced {
        encoding: iso-8859-1
        csvEnclosedBy: "
    }

    dataProfileColumn country (
        columnName: COUNTRY
