dataLoadDefinition Transform_and_Lookup (
    name: Transform and Lookup
    target {
        tableName: EBA_DEMO_LOAD_EMP
        loadingMethod: replace
    }
    dataProfile {
        name: Transform and Lookup
        format: csv
    }
    advanced {
        encoding: iso-8859-1
        csvEnclosedBy: "
    }

    dataProfileColumn comm (
        columnName: COMM
        source {
            sequence: 7
            dataType: number
        }
        parsing {
            selectorType: regexp
            selector: COMM|Commission
        }
    )

    dataProfileColumn deptno (
        columnName: DEPTNO
        source {
            sequence: 18
            type: lookup
            dataType: number
        }
        lookup {
            tableName: EBA_DEMO_LOAD_DEPT
            returnColumn: DEPTNO
            tableColumn1: DNAME
            dataColumn1: DEPTNO_LOADED
        }
    )

    dataProfileColumn deptno-loaded (
        columnName: DEPTNO_LOADED
        source {
            sequence: 8
            dataType: varchar2
        }
        parsing {
            selectorType: regexp
            selector: DEPTNO|Department
        }
    )

    dataProfileColumn empno (
        columnName: EMPNO
        source {
            sequence: 1
            dataType: number
            primaryKey: true
        }
        parsing {
            selector: EMPNO
        }
    )

    dataProfileColumn ename (
        columnName: ENAME
        source {
            sequence: 2
            dataType: varchar2
            maxLength: 10
        }
        parsing {
            selectorType: regexp
            selector: .*Name$
        }
    )

    dataProfileColumn hiredate (
        columnName: HIREDATE
        source {
            sequence: 5
            dataType: date
        }
        parsing {
            selector: HIREDATE
            formatMask: MM/DD/YYYY
            hasTimeZone: false
        }
    )

    dataProfileColumn job (
        columnName: JOB
        source {
            sequence: 3
            dataType: varchar2
            maxLength: 9
        }
        parsing {
            selector: JOB
        }
        transformation {
            type: upper
        }
    )

    dataProfileColumn mgr (
        columnName: MGR
        source {
            sequence: 28
            type: lookup
            dataType: number
        }
        lookup {
            tableName: EBA_DEMO_LOAD_EMP
            returnColumn: EMPNO
            tableColumn1: ENAME
            dataColumn1: MGR_LOADED
        }
    )

    dataProfileColumn mgr-loaded (
        columnName: MGR_LOADED
        source {
            sequence: 4
            dataType: varchar2
        }
        parsing {
            selectorType: regexp
            selector: MGR|Manager
        }
    )

    dataProfileColumn sal (
        columnName: SAL
        source {
            sequence: 6
            dataType: number
        }
        parsing {
            selectorType: regexp
            selector: SAL|Salary
        }
    )

)

