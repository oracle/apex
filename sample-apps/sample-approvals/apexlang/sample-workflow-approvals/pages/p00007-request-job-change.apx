page 7 (
    name: Request Job Change
    alias: REQUEST-JOB-CHANGE
    title: Request Job Change
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        width: 300
        resizable: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region request-job-change (
        name: Request Job Change
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_APPR_EMP
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P7_EMPNO (
        type: hidden
        layout {
            sequence: 10
            region: @request-job-change
            slot: regionBody
        }
        source {
            formRegion: @request-job-change
            column: EMPNO
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_ENAME (
        type: displayOnly
        label {
            label: Ename
            alignment: left
        }
        layout {
            sequence: 20
            region: @request-job-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-job-change
            column: ENAME
            dataType: varchar2
            queryOnly: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_JOB (
        type: displayOnly
        label {
            label: Current Job
            alignment: left
        }
        layout {
            sequence: 30
            region: @request-job-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-job-change
            column: JOB
            dataType: varchar2
            queryOnly: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P7_PROPOSED_JOB (
        type: selectList
        label {
            label: Proposed Job
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select distinct job dv, job rv from eba_demo_appr_emp
                where job != :P7_JOB
                order by 1
                ```
        }
        layout {
            sequence: 90
            region: @request-job-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        sessionState {
            storage: request
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button submit-for-approval (
        buttonName: SUBMIT_FOR_APPROVAL
        label: Submit
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P7_EMPNO
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 614290017259748429
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SUBMIT_FOR_APPROVAL,DELETE
        }
    )

    process initialize-form-request-salary-change (
        name: Initialize form Request Salary Change
        type: formInitialization
        formRegion: @request-job-change
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 614287759566748374
        }
    )

    process process-form-request-salary-change (
        name: Process form Request Salary Change
        type: formAutoRowProcessing
        formRegion: @request-job-change
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 614288198700748381
        }
    )

    process submit-task (
        name: Submit Task
        type: humanTaskCreate
        humanTask {
            definition: @JOB_CHANGE
            detailsPkItem: P7_EMPNO
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 614289612654748427
        }
        serverSideCondition {
            whenButtonPressed: @submit-for-approval
        }

        parameter (
            name: @P_NEW_JOB
            value {
                type: item
                item: P7_PROPOSED_JOB
            }
        )

    )

)

