page 4 (
    name: Request Salary Change
    alias: REQUEST-SALARY-CHANGE
    title: Request Salary Change
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        width: 300
        resizable: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region request-salary-change (
        name: Request Salary Change
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_APPR_EMP
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P4_EMPNO (
        type: hidden
        layout {
            sequence: 10
            region: @request-salary-change
            slot: regionBody
        }
        source {
            formRegion: @request-salary-change
            column: EMPNO
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4_ENAME (
        type: displayOnly
        label {
            label: Ename
            alignment: left
        }
        layout {
            sequence: 20
            region: @request-salary-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-salary-change
            column: ENAME
            dataType: varchar2
            queryOnly: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4_JOB (
        type: hidden
        layout {
            sequence: 100
            region: @request-salary-change
            slot: regionBody
        }
        source {
            formRegion: @request-salary-change
            column: JOB
            dataType: varchar2
            queryOnly: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4_PROPOSED_SALARY (
        type: numberField
        label {
            label: Proposed Salary
            alignment: left
        }
        settings {
            virtualKeyboard: text
        }
        layout {
            sequence: 90
            region: @request-salary-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
        sessionState {
            storage: request
        }
    )

    pageItem P4_SAL (
        type: displayOnly
        label {
            label: Current Salary
            alignment: left
        }
        layout {
            sequence: 30
            region: @request-salary-change
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @request-salary-change
            column: SAL
            dataType: number
            queryOnly: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button submit-for-approval (
        buttonName: SUBMIT_FOR_APPROVAL
        label: Submit
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4_EMPNO
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation ensure-at-least-one-admin (
        name: Ensure at Least One Admin
        execution {
            sequence: 10
        }
        validation {
            plsqlExpression:
                ```plsql
                eba_demo_appr.get_admin_for('SALARY_CHANGE',
                                            :P4_EMPNO,
                                            :P4_JOB,
                                            :P4_PROPOSED_SALARY) is not null
                ```
        }
        error {
            errorMessage: No salary change admin was available to assign. Check Admin participant entries on Salary Change Approvers page.
        }
    )

    validation ensure-at-least-one-approver (
        name: Ensure at Least One Approver
        execution {
            sequence: 20
        }
        validation {
            plsqlExpression:
                ```plsql
                eba_demo_appr.get_approver_for('SALARY_CHANGE',
                                               :P4_EMPNO,
                                               :P4_JOB,
                                               :P4_PROPOSED_SALARY) is not null
                ```
        }
        error {
            errorMessage: No salary change approver was available to assign (after excluding your username). Check Approver participant entries on Salary Change Approvers page.
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 613541917431122791
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SUBMIT_FOR_APPROVAL,DELETE
        }
    )

    process initialize-form-request-salary-change (
        name: Initialize form Request Salary Change
        type: formInitialization
        formRegion: @request-salary-change
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 613541222405122786
        }
    )

    process process-form-request-salary-change (
        name: Process form Request Salary Change
        type: formAutoRowProcessing
        formRegion: @request-salary-change
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 613541489297122790
        }
    )

    process submit-task (
        name: Submit Task
        type: humanTaskCreate
        humanTask {
            definition: @SALARY_CHANGE
            detailsPkItem: P4_EMPNO
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 584379284205672775
        }
        serverSideCondition {
            whenButtonPressed: @submit-for-approval
        }

        parameter (
            name: @P_NEW_SALARY
            value {
                type: item
                item: P4_PROPOSED_SALARY
            }
        )

    )

)

