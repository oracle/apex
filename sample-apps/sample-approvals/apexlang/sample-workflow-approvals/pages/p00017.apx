        }
    )

    pageItem P17_STATUS (
        type: hidden
        layout {
            sequence: 120
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: STATUS
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_SUCCESS_MESSAGE (
        type: hidden
        layout {
            sequence: 20
            slot: contentBody
        }
        sessionState {
            storage: request
        }
        security {
            sessionStateProtection: restricted
            encryptSessionState: false
        }
    )

    pageItem P17_TASK_ID (
        type: hidden
        layout {
            sequence: 10
            slot: contentBody
        }
        sessionState {
            storage: request
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            encryptSessionState: false
        }
    )

    pageItem P17_VP_REVIEW_DATE (
        type: hidden
        layout {
            sequence: 160
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: VP_REVIEW_DATE
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
        serverSideCondition {
            type: item=value
            item: P17_APPRAISAL_ID_PROVIDED
            value: N
        }
    )

    button close (
        buttonName: CLOSE
        label: Close
        layout {
            sequence: 20
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
        serverSideCondition {
            type: item=value
            item: P17_APPRAISAL_ID_PROVIDED
            value: Y
        }
    )

    button complete (
        buttonName: COMPLETE
        label: Complete
        layout {
            sequence: 40
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--success
                t-Button--iconLeft
            ]
            icon: fa-box-arrow-out-east
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P17_APPRAISAL_ID_PROVIDED = 'N' and
                apex_approval.is_allowed (
                    p_task_id   => :P17_TASK_ID,
                    p_operation => apex_approval.c_task_op_complete )
                ```
        }
    )

    button save (
        buttonName: SAVE
        label: Save
        layout {
            sequence: 30
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--link
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P17_APPRAISAL_ID_PROVIDED = 'N' and
                apex_approval.is_allowed (
                    p_task_id   => :P17_TASK_ID,
                    p_operation => apex_approval.c_task_op_complete )
                ```
        }
    )

    dynamicAction cancel (
        name: Cancel
        execution {
            sequence: 220
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction on-click-ok (
        name: On Click Ok
        execution {
            sequence: 230
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-close (
            action: closeDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-comments (
        name: Refresh - Comments
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P17_ALL_COMMENTS
        }
    )

    dynamicAction refresh-history (
        name: Refresh - History
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P17_ALL_HISTORY
        }
    )

    computation p17-appraisal-id-provided (
        itemName: P17_APPRAISAL_ID_PROVIDED
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: expression
            plsqlExpression: CASE WHEN :P17_ID IS NOT NULL THEN 'Y' ELSE 'N' END
        }
    )

    computation p17-ename (
        itemName: P17_ENAME
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            sqlQuery:
                ```sql
                select ename
                from eba_demo_appr_emp
                where empno = :P17_EMPNO
                ```
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P17_APPRAISAL_ID_PROVIDED = 'Y' or :P17_EMPNO != :CURRENT_USER_EMPNO
        }
    )

    computation p17-expecting-input-from (
        itemName: P17_EXPECTING_INPUT_FROM
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select actual_owner
                from apex_tasks
                where task_id = :P17_TASK_ID
                ```
        }
    )

    computation p17-id (
        itemName: P17_ID
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select detail_pk
                from apex_tasks
                where task_id = :P17_TASK_ID
                ```
        }
        serverSideCondition {
            type: itemIsNull
            item: P17_ID
        }
    )

    process appraisal-region-automatic-dml (
        name: Appraisal Region Automatic DML
        type: formAutoRowProcessing
        formRegion: @employee-self-review
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Evaluation Saved
        }
        advanced {
            executionMappingIdentifier: 577228043266818443
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: COMPLETE,SAVE
        }
    )

    process claim (
        name: Claim
        type: humanTaskManage
        action {
            type: claim
        }
        humanTask {
            taskIdItem: P17_TASK_ID
        }
        execution {
            sequence: 10
        }
        error {
            errorMessage: #SQLERRM_TEXT#
        }
        advanced {
            executionMappingIdentifier: 581442455966425842
        }
        config {
            buildOption: @commented-out
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 160
        }
        successMessage {
            successMessage: &P17_SUCCESS_MESSAGE.
        }
        advanced {
            executionMappingIdentifier: 581447911597425846
        }
        serverSideCondition {
            type: requestIsNotContainedInValue
            value: CLAIM,SET_PRIORITY,SET_DUE,INVITE_PARTICIPANT,REMOVE_PARTICIPANT,RENEW,UPDATE_PARAMETER,SAVE
        }
    )

    process complete (
        name: Complete
        type: humanTaskManage
        action {
            type: completeWithoutOutcome
        }
        humanTask {
            taskIdItem: P17_TASK_ID
        }
        execution {
            sequence: 30
        }
        error {
            errorMessage: #SQLERRM_TEXT#
        }
        advanced {
            executionMappingIdentifier: 581442871574425842
        }
        serverSideCondition {
            whenButtonPressed: @complete
        }
    )

    process compute-appraisal-period (
        name: Compute Appraisal Period
        type: invokeApi
        invoke {
            package: EBA_DEMO_APPR
            procedureOrFunction: APPRAISAL_PERIOD
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 849663032812009438
        }

        parameter (
            type: functionResult
            value {
                item: P17_APPRAISAL_PERIOD
            }
            advanced {
                displaySequence: 10
            }
        )

        parameter p_end_date (
            parameter {
                dataType: date
            }
            value {
                type: item
                item: P17_PERIOD_END
            }
            advanced {
                displaySequence: 30
            }
        )

        parameter p_start_date (
            parameter {
                dataType: date
            }
            value {
                type: item
                item: P17_PERIOD_START
            }
            advanced {
                displaySequence: 20
            }
        )

    )

    process initialize-form-employee-self-review-details (
        name: Initialize form Employee Self Review Details
        type: formInitialization
        formRegion: @employee-self-review
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 577226397710818426
        }
    )

    process set-success-message (
        name: Set Success Message
        type: executeCode
        source {
            plsqlCode: :P17_SUCCESS_MESSAGE := apex_application.g_print_success_message;
        }
        execution {
            sequence: 150
        }
        error {
            errorMessage: #SQLERRM_TEXT#
        }
        advanced {
            executionMappingIdentifier: 581447525311425846
        }
    )

    branch (
        name: Reload Dialog
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: &APP_PAGE_ID.
                items: {
                    P17_TASK_ID: &P17_TASK_ID.
                }
            }
        }
    )

)

