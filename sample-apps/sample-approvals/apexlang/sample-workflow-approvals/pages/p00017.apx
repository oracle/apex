page 17 (
    name: Employee Self Review Details
    title: Employee Self Review Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    readOnly {
        type: expression
        plsqlExpression: :P17_APPRAISAL_ID_PROVIDED = 'Y' or :P17_EXPECTING_INPUT_FROM != :APP_USER
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 210
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--stickToBottom
                t-ButtonRegion--slimPadding
                margin-bottom-none
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region employee-self-review (
        name: Employee Self Review
        type: form
        source {
            location: localDatabase
            tableName: EBA_DEMO_APPR_APPRAISALS
        }
        layout {
            sequence: 110
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        readOnly {
            type: expression
            plsqlExpression:
                ```plsql
                apex_approval.is_allowed (
                    p_task_id   => :P17_TASK_ID,
                    p_operation => apex_approval.c_task_op_claim )
                ```
        }
    )

    region subject (
        name: Subject
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                    l_result clob;
                begin
                    select to_clob(replace(replace(replace('
                            <div class="a-CardView has-title has-badge">
                              <div class="a-CardView-header">
                                <div class="a-CardView-headerBody">
                                  <h3 class="a-CardView-title">#SUBJECT#</h3>
                                </div>
                                <div class="a-CardView-badge #BADGE_CSS_CLASSES#" title="#BADGE_TEXT#">
                                  <span class="a-CardView-badgeValue">#BADGE_TEXT#</span>
                                </div>
                              </div>
                            </div>',
                           '#SUBJECT#'          , subject          ),
                           '#BADGE_TEXT#'       , badge_text       ),
                           '#BADGE_CSS_CLASSES#', badge_css_classes) )
                      into l_result
                      from table ( apex_approval.get_tasks (
                                       p_context => 'SINGLE_TASK',
                                       p_task_id => :P17_TASK_ID ) );
                
                    return l_result;
                exception
                    when no_data_found then
                        return l_result;
                end;
                ```
            pageItemsToSubmit: P17_TASK_ID
        }
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: item=value
            item: P17_EMPNO
            value: &CURRENT_USER_EMPNO.
        }
    )

    pageItem P17_APPRAISAL_DATE (
        type: displayOnly
        label {
            label: Appraisal Date
            alignment: left
        }
        layout {
            sequence: 60
            region: @employee-self-review
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @employee-self-review
            column: APPRAISAL_DATE
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_APPRAISAL_ID_PROVIDED (
        type: hidden
        layout {
            sequence: 120
            slot: contentBody
        }
        default {
            type: static
            staticValue: N
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_APPRAISAL_PERIOD (
        type: displayOnly
        label {
            label: Appraisal Period
            alignment: left
        }
        layout {
            sequence: 30
            region: @employee-self-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_DATE_ORIGINATED (
        type: hidden
        layout {
            sequence: 140
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: DATE_ORIGINATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_EMPNO (
        type: hidden
        layout {
            sequence: 20
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: EMPNO
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_EMP_ACHIEVEMENTS (
        type: markdownEditor
        label {
            label: Self Review - My Achievements
            alignment: left
        }
        layout {
            sequence: 100
            region: @employee-self-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @employee-self-review
            column: EMP_ACHIEVEMENTS
            dataType: varchar2
        }
        readOnly {
            type: item!=value
            item: P17_STATUS
            value: ORIGINATED
        }
    )

    pageItem P17_EMP_DEVELOPMENT_GOALS (
        type: markdownEditor
        label {
            label: Self Review -  Development Goals
            alignment: left
        }
        layout {
            sequence: 110
            region: @employee-self-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @employee-self-review
            column: EMP_DEVELOPMENT_GOALS
            dataType: varchar2
        }
        readOnly {
            type: item!=value
            item: P17_STATUS
            value: ORIGINATED
        }
    )

    pageItem P17_ENAME (
        type: displayOnly
        label {
            label: Employee
            alignment: left
        }
        layout {
            sequence: 70
            region: @employee-self-review
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: expression
            plsqlExpression: :P17_APPRAISAL_ID_PROVIDED = 'Y' or :P17_EMPNO != :CURRENT_USER_EMPNO
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_EXPECTING_INPUT_FROM (
        type: hidden
        layout {
            sequence: 130
            slot: contentBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_ID (
        type: hidden
        layout {
            sequence: 10
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_INPUT_COMPLETED (
        type: hidden
        layout {
            sequence: 150
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: INPUT_COMPLETED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_MANAGER_COMPLETED (
        type: hidden
        layout {
            sequence: 170
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: MANAGER_COMPLETED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_MGR_APPRAISAL (
        type: markdownEditor
        label {
            label: Manager Appraisal Comments
            alignment: left
        }
        layout {
            sequence: 80
            region: @employee-self-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @employee-self-review
            column: MGR_APPRAISAL
            dataType: varchar2
        }
        serverSideCondition {
            type: itemIsInColonDelimitedList
            item: P17_STATUS
            list: [
                SUBMITTED
                MGR_SUBMITTED
                VP_REVIEWED
                COMPLETED
            ]
        }
        readOnly {
            type: itemIsNotInColonDelimitedList
            item: P17_STATUS
            list: SUBMITTED
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_MGR_OBJECTIVES (
        type: markdownEditor
        label {
            label: Manager's Objectives Comments
            alignment: left
        }
        layout {
            sequence: 90
            region: @employee-self-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @employee-self-review
            column: MGR_OBJECTIVES
            dataType: varchar2
        }
        serverSideCondition {
            type: itemIsInColonDelimitedList
            item: P17_STATUS
            list: [
                SUBMITTED
                MGR_SUBMITTED
                VP_REVIEWED
                COMPLETED
            ]
        }
        readOnly {
            type: itemIsNotInColonDelimitedList
            item: P17_STATUS
            list: SUBMITTED
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_ORIGINATOR (
        type: hidden
        layout {
            sequence: 130
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: ORIGINATOR
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_PERIOD_END (
        type: hidden
        layout {
            sequence: 50
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: PERIOD_END
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P17_PERIOD_START (
        type: hidden
        layout {
            sequence: 40
            region: @employee-self-review
            slot: regionBody
        }
        source {
            formRegion: @employee-self-review
            column: PERIOD_START
            dataType: date
        }
        security {
