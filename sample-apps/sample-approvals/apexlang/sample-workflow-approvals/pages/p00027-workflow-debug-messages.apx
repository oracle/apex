                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column SESSION_ID (
            type: plainText
            heading {
                heading: Session Id
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column WORKFLOW_INSTANCE_ID (
            type: plainText
            heading {
                heading: Instance Id
                alignment: end
            }
            layout {
