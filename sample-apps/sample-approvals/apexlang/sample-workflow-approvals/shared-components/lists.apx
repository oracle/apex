list user-interface (
    name: User Interface
    config {
        buildOption: @feature-theme-style-selection
    }

    entry email-settings (
        label: Email Settings
        icon {
            imageIconCssClasses: fa-envelope-wrench
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 11
            }
        }
        userDefinedAttributes {
            1: Configure an email address to notify for job changes as well as laptop approval and delivery.
        }
    )

    entry manage-laptop-stock (
        label: Manage Laptop Stock
        icon {
            imageIconCssClasses: fa-laptop
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 32
            }
        }
        userDefinedAttributes {
            1: Manage laptop stock amounts
        }
    )

    entry manage-sample-data (
        label: Manage Sample Data
        icon {
            imageIconCssClasses: fa-pencil-square-o
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 18
            }
        }
        userDefinedAttributes {
            1: Reset the data for the sample
        }
    )

    entry salary-change-approvers (
        label: Salary Change Approvers
        icon {
            imageIconCssClasses: fa-badge-check
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 9
            }
        }
        userDefinedAttributes {
            1: Manage and test salary change approver assignments
        }
    )

    entry theme-style-selection (
        label: Theme Style Selection
        icon {
            imageIconCssClasses: fa-paint-brush
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 10010
                clearCache: 10010
            }
        }
        userDefinedAttributes {
            1: Set the default application look and feel
        }
    )

)

