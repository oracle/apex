    }
)

lov emp-ename (
    name: EMP.ENAME
    source {
        tableName: EMP
    }
    columnMapping {
        return: EMPNO
        display: ENAME
        defaultSort: ENAME
    }
)

lov unified-task-list-lov-due (
    name: UNIFIED_TASK_LIST.LOV.DUE
    source {
        location: staticValues
    }

    entry more-than-30-days (
        sequence: 6
        display: More than 30 days
        return: 720|
    )

    entry next-24-hours (
        sequence: 3
        display: Next 24 hours
        return: 1|24
    )

    entry next-30-days (
        sequence: 5
        display: Next 30 days
        return: 168|720
    )

    entry next-7-days (
        sequence: 4
        display: Next 7 days
        return: 24|168
    )

    entry next-hour (
        sequence: 2
        display: Next hour
        return: 0|1
    )

    entry overdue (
        sequence: 1
        display: Overdue
        return: |0
    )

)

lov unified-task-list-lov-initiated (
    name: UNIFIED_TASK_LIST.LOV.INITIATED
    source {
        location: staticValues
    }

    entry last-24-hours (
        sequence: 2
        display: Last 24 hours
        return: 1|24
    )

    entry last-30-days (
        sequence: 4
        display: Last 30 days
        return: 168|720
    )

    entry last-7-days (
        sequence: 3
        display: Last 7 days
        return: 24|168
    )

    entry last-hour (
        sequence: 1
        display: Last hour
        return: |1
    )

    entry older-than-30-days (
        sequence: 5
        display: Older than 30 days
        return: 720|
    )

)

lov unified-task-list-lov-priority (
    name: UNIFIED_TASK_LIST.LOV.PRIORITY
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            
            select disp, 
                   val 
              from table ( apex_approval.get_lov_priority )
             order by insert_order
            ```
    }
    columnMapping {
        return: VAL
        display: DISP
    }
)

