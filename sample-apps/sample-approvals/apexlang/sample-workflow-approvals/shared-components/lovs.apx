lov all-enames-lov (
    name: ALL_ENAMES_LOV
    source {
        tableName: EBA_DEMO_APPR_EMP
    }
    columnMapping {
        return: ENAME
        display: ENAME
        defaultSort: ENAME
    }
)

lov approval-task-lov (
    name: APPROVAL_TASK_LOV
    source {
        type: sqlQuery
        sqlQuery: select name,static_id from apex_appl_taskdefs where application_id = :APP_ID
    }
    columnMapping {
        return: STATIC_ID
        display: NAME
        defaultSort: NAME
    }
)

lov available-laptop-types (
    name: AVAILABLE_LAPTOP_TYPES
    source {
        location: staticValues
    }

    entry lenovo-t (
        sequence: 2
        display: Lenovo T490
        return: WIN
    )

    entry macbook-pro (
        sequence: 1
        display: MacBook Pro 14"
        return: MAC
    )

)

lov dept-dname (
    name: DEPT.DNAME
    source {
        tableName: DEPT
    }
    columnMapping {
        return: DEPTNO
        display: DNAME
        defaultSort: DNAME
    }
)

lov desktop-theme-styles (
    name: DESKTOP THEME STYLES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select s.name d,
                   s.theme_style_id r
              from apex_application_theme_styles s,
                   apex_application_themes t
             where s.application_id = :app_id
               and t.application_id = s.application_id
               and t.theme_number   = s.theme_number
               and t.ui_type_name   = 'DESKTOP'
               and t.is_current     = 'Yes'
             order by 1
            ```
    }
    columnMapping {
        return: R
        display: D
    }
)

lov distinct-job-codes-lov (
    name: DISTINCT_JOB_CODES_LOV
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select job dv, job rv
            from (
                select distinct job from eba_demo_appr_emp
            )
            order by job
            ```
    }
    columnMapping {
        return: RV
        display: DV
        defaultSort: DV
    }
)

lov eba-demo-conf-emp-lov (
    name: EBA_DEMO_CONF_EMP_LOV
    source {
        tableName: EBA_DEMO_APPR_EMP
    }
    columnMapping {
        return: EMPNO
        display: ENAME
