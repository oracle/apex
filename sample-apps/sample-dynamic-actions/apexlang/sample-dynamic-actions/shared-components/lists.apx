list administration-options (
    name: Administration Options

    entry reset-data (
        label: Reset Data
        icon {
            imageIconCssClasses: fa-database
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 23
            }
        }
        userDefinedAttributes {
            1: Reset the sample data provided in this application to the default.
        }
    )

    entry theme-style (
        label: Theme Style
        icon {
            imageIconCssClasses: fa-laptop
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 24
            }
        }
        userDefinedAttributes {
            1: Change user interface theme style for all users.
        }
    )

)

list dynamic-actions (
    name: Dynamic Actions

    entry add-remove-class-error (
        label: Add/Remove Class (Error)
        icon {
            imageIconCssClasses: fa-exclamation-triangle-o
        }
        layout {
            sequence: 30
        }
        isCurrent {
            type: pages
            pages: [
                6
                7
            ]
        }
        link {
            target: {
                page: 6
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Using the Add and Remove Class actions to highlight errors
        }
    )

    entry add-remove-class-focus (
        label: Add/Remove Class (Focus)
        icon {
            imageIconCssClasses: fa-info-circle-o
        }
        layout {
            sequence: 40
        }
        isCurrent {
            type: pages
            pages: [
                8
                9
            ]
        }
        link {
            target: {
                page: 8
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Using the Add and Remove Class actions to show focus
        }
    )

    entry debounce-and-throttle (
        label: Debounce and Throttle
        icon {
            imageIconCssClasses: fa-clock-o
        }
        layout {
            sequence: 145
        }
        link {
            target: {
                page: 21
            }
        }
        userDefinedAttributes {
            1: Execute dynamic actions immediately or after a delay
        }
    )

    entry delete-and-refresh (
        label: Delete and Refresh
        icon {
            imageIconCssClasses: fa-table-x
        }
        layout {
            sequence: 135
        }
        link {
            target: {
                page: 18
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Use a multi-part dynamic action to confirm deletions and refresh a report
        }
    )

    entry disable-enable (
        label: Disable/Enable
        icon {
            imageIconCssClasses: fa-table-ban
        }
        layout {
            sequence: 10
        }
        isCurrent {
            type: pages
            pages: [
                2
                3
            ]
        }
        link {
            target: {
                page: 2
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Disable and enable items automatically
        }
    )

    entry execute-pl-sql-code (
        label: Execute PL/SQL Code
        icon {
            imageIconCssClasses: fa-code
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 11
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Executing PL/SQL as part of a dynamic action
        }
    )

    entry filter-and-refresh (
        label: Filter and Refresh
        icon {
            imageIconCssClasses: fa-table-arrow-down
        }
        layout {
            sequence: 120
        }
        link {
            target: {
                page: 19
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Use a dynamic action to filter a report
        }
    )

    entry hide-show (
        label: Hide/Show
        icon {
            imageIconCssClasses: fa-eye-slash
        }
        layout {
            sequence: 20
        }
        isCurrent {
            type: pages
            pages: [
                4
                5
            ]
        }
        link {
            target: {
                page: 4
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Declaratively hide and show items based on user input
        }
    )

    entry refresh (
        label: Refresh
        icon {
            imageIconCssClasses: fa-refresh
        }
        layout {
            sequence: 100
        }
        link {
            target: {
                page: 17
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Refresh a report based on user interactions with an interactive report
        }
    )

    entry set-values-pl-sql (
        label: Set Values (PL/SQL)
        icon {
            imageIconCssClasses: fa-table-user
        }
        layout {
            sequence: 80
        }
        isCurrent {
            type: pages
            pages: [
                14
                15
            ]
        }
        link {
            target: {
                page: 14
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Automatically calculate values via PL/SQL based on user input
        }
    )

    entry set-values-sql (
        label: Set Values (SQL)
        icon {
            imageIconCssClasses: fa-table-edit
        }
        layout {
            sequence: 70
        }
        isCurrent {
            type: pages
            pages: [
                12
                13
            ]
        }
        link {
            target: {
                page: 12
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Using a dynamic action to execute SQL
        }
    )

    entry shuttle-refresh (
        label: Shuttle Refresh
        icon {
            imageIconCssClasses: fa-table-pointer
        }
        layout {
            sequence: 130
        }
        link {
            target: {
                page: 20
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Use a dynamic action with a shuttle page item to control a report
        }
    )

    entry stripe-report (
        label: Stripe Report
        icon {
            imageIconCssClasses: fa-table
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 10
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Using a dynamic action plug-in to enhance a report
        }
    )

    entry timer (
        label: Timer
        icon {
            imageIconCssClasses: fa-table-clock
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 16
                clearCache: RIR
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Utilize a timer for repeating dynamic actions
        }
    )

)

list navigation-bar-top (
    name: Navigation Bar (Top)

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry help (
        label: Help
        icon {
            imageIconCssClasses: fa-question-circle-o
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: HELP
            }
        }
    )

    entry sign-out (
        label: Sign Out
        layout {
            sequence: 50
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
    )

)

