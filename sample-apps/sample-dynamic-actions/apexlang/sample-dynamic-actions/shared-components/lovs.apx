lov department (
    name: DEPARTMENT
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select dname d, deptno r
            from eba_demo_da_dept
            order by 1
            ```
    }
)

lov job (
    name: JOB
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select distinct job d, job r
            from eba_demo_da_emp
            order by 1
            ```
    }
)

lov manager (
    name: MANAGER
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select ename d, empno r
            from eba_demo_da_emp
            order by 1
            ```
    }
)

