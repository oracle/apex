    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 14
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P15_ROWID
        }
    )

    dynamicAction calc-commission (
        name: CALC COMMISSION
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: [
                P15_JOB
                P15_SAL
            ]
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlFunctionBody
                plsqlFunctionBody:
                    ```plsql
                    declare
                        l_multiplier number := 0;
                    begin
                        -- determine multiplier based on job
                        case :P15_JOB
                            when 'ANALYST'      then l_multiplier := .1;
                            when 'CLERK'        then l_multiplier := .2;
                            when 'MANAGER'      then l_multiplier := .3;
                            when 'PRESIDENT'    then l_multiplier := .4;
                            when 'SALESMAN'     then l_multiplier := .3;
                            else                     l_multiplier := .1;
                        end case;
                        -- return commission, which is calculated by multiplying salary by multiplier
                        return :P15_SAL * l_multiplier;
                    end;
                    ```
                itemsToSubmit: [
                    P15_SAL
                    P15_JOB
                ]
            }
            affectedElements {
                selectionType: items
                items: P15_COMM
            }
            execution {
                sequence: 10
            }
        )

        action plugin-com-oracle-apex-highlight (
            action: plugin/highlight
            settings {
                color: #E5FFCC
                speed: normal
            }
            affectedElements {
                selectionType: items
                items: P15_COMM
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    process fetch-row-from-eba-demo-da-emp (
        name: Fetch Row from EBA_DEMO_DA_EMP
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P15_ROWID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2656134342550987092
        }
    )

    process process-row-of-eba-demo-da-emp (
        name: Process Row of EBA_DEMO_DA_EMP
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P15_ROWID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2656134533381987093
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 2656134733094987093
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 14
            }
        }
    )

)

