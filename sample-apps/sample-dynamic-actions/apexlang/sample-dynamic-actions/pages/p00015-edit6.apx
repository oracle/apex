        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: COMM
            used: always
        }
        security {
            restrictedChars: webSafe
        }
