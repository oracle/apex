    dynamicAction update-p21-debounce-delay (
        name: Update P21_DEBOUNCE_DELAY
        execution {
            sequence: 20
            type: debounce
            time: 2000
        }
        when {
            event: keyup
            selectionType: items
            items: P21_TEXT_AREA
        }

        action set-item-value (
            name: Set item value
            action: setValue
            settings {
                type: jsExpression
                jsExpression: this.triggeringElement.value
            }
            affectedElements {
                selectionType: items
                items: P21_DEBOUNCE_DELAY
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

