page 21 (
    name: Debounce and Throttle
    alias: DEBOUNCE-AND-THROTTLE
    title: Debounce and Throttle
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region debounce-delay (
        name: Debounce Delay
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @examples
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
            ]
        }
    )

    region debounce-delay-help-text (
        name: Debounce Delay Help Text
        type: staticContent
        source {
            htmlCode: <p><strong>Debounce Delay:</strong> the Dynamic Action will execute 2000ms after the key release event was triggered. If the event is triggered multiple times before the delay is over, the timer resets each time and the action will execute after the last event.</p>
        }
        layout {
            sequence: 10
            parentRegion: @debounce-delay
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region debounce-immediate (
        name: Debounce Immediate
        type: staticContent
        layout {
            sequence: 50
            parentRegion: @examples
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
            ]
        }
    )

    region debounce-immediate-help-text (
        name: Debounce Immediate Help Text
        type: staticContent
        source {
            htmlCode: <p><strong>Debounce Immediate:</strong> the Dynamic Action will execute immediately after the first key release event before starting the timer for 2000ms. If the event is triggered before the delay is over, the timer resets each time and all events are ignored until the delay is over.</p>
        }
        layout {
            sequence: 10
            parentRegion: @debounce-immediate
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region enter-text-here (
        name: Enter Text Here
        type: staticContent
