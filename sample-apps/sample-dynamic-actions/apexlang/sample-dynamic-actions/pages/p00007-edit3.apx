            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @p7-eba-demo-da-emp-job
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: JOB
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_MGR (
        type: popupLov
        label {
            label: Manager
            alignment: left
        }
        settings {
            displayAs: modalDialog
