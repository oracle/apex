page 7 (
    name: Edit
    alias: EDIT3
    title: Edit
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    css {
        inline:
            ```css
            .validation_error {
              border-color: #ff0000 !important;
            }
            
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        headerAndFooter {
            headerText:
                ```html
                <p>This page contains one dynamic action called 'NAME IS NULL'. This fires whenever the user leaves the 'Name' page item and checks if it is empty. If the 'Name' page item is empty a red border is applied to indicate there is a problem. The border is subsequently removed if and when the user leaves the 'Name' page item having entered some text.</p>
                <p>It uses two native actions ('Add Class' and 'Remove Class').</p>
                ```
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region maintain-employee (
        name: Maintain Employee
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    pageItem P7_COMM (
        type: numberField
        label {
            label: Commission
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 80
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: COMM
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_DEPTNO (
        type: selectList
        label {
            label: Department
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @p7-eba-demo-da-emp-deptno
            displayNullValue: false
        }
        layout {
            sequence: 90
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: DEPTNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_EMPNO (
        type: textField
        label {
            label: Employee Number
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 4
        }
        validation {
            valueRequired: true
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: EMPNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_ENAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 30
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 10
        }
        validation {
            valueRequired: true
            maxLength: 10
        }
        source {
            type: databaseColumn
            databaseColumn: ENAME
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_HIREDATE (
        type: datePicker
        label {
            label: Hire date
            alignment: left
        }
        layout {
            sequence: 60
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 30
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: HIREDATE
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_JOB (
        type: selectList
