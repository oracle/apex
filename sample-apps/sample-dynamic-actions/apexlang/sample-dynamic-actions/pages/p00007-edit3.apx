            type: databaseColumn
            databaseColumn: SAL
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 6
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P7_ROWID
        }
    )

    dynamicAction name-is-null (
        name: NAME IS NULL
        execution {
            sequence: 10
        }
        when {
            event: focusout
            selectionType: items
            items: P7_ENAME
        }
        clientSideCondition {
            type: itemIsNull
            item: P7_ENAME
        }

        action native-add-class (
            action: addClass
            settings {
                class: validation_error
            }
            affectedElements {
                selectionType: items
                items: P7_ENAME
            }
            execution {
                sequence: 10
            }
        )

        action native-remove-class (
            action: removeClass
            settings {
                class: validation_error
            }
            affectedElements {
                selectionType: items
                items: P7_ENAME
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

    )

    process fetch-row-from-eba-demo-da-emp (
        name: Fetch Row from EBA_DEMO_DA_EMP
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P7_ROWID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2650644750062138401
        }
    )

    process process-row-of-eba-demo-da-emp (
        name: Process Row of EBA_DEMO_DA_EMP
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P7_ROWID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2650644938583138403
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 2650645132475138405
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 6
            }
        }
    )

)

