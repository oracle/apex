        lov {
            type: sharedComponent
            lov: @p7-eba-demo-da-emp-mgr
            displayNullValue: false
        }
        layout {
            sequence: 50
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: MGR
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P7_ROWID (
        type: hidden
        layout {
            sequence: 10
            region: @maintain-employee
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ROWID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P7_SAL (
        type: numberField
        label {
            label: Salary
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
