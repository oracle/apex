            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 21
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P22_ROWID
        }
    )

    dynamicAction calc-commission (
        name: CALC COMMISSION
        execution {
            sequence: 20
        }
        when {
            event: item/plugin-slider/slidechange
            selectionType: items
            items: P22_SAL
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlFunctionBody
                plsqlFunctionBody:
                    ```plsql
                    declare
                        l_multiplier number := 0;
                    begin
                        -- determine multiplier based on job
                        case :P22_JOB
                            when 'ANALYST'      then l_multiplier := .1;
                            when 'CLERK'        then l_multiplier := .2;
                            when 'MANAGER'      then l_multiplier := .3;
                            when 'PRESIDENT'    then l_multiplier := .4;
                            when 'SALESMAN'     then l_multiplier := .3;
                            else                     l_multiplier := .1;
                        end case;
                        -- return commission, which is calculated by multiplying salary my multiplier
                        return :P22_SAL * l_multiplier;
                    end;
                    ```
                itemsToSubmit: [
                    P22_JOB
                    P22_SAL
                ]
            }
            affectedElements {
                selectionType: items
                items: P22_COMM
            }
            execution {
                sequence: 10
            }
        )

        action plugin-com-oracle-apex-highlight (
            action: plugin/highlight
            settings {
                color: #E5FFCC
                speed: slow
            }
            affectedElements {
                selectionType: items
                items: P22_COMM
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction salary-high (
        name: SALARY HIGH
        execution {
            sequence: 10
        }
        when {
            event: item/plugin-slider/slidechange
            selectionType: items
            items: P22_SAL
        }
        clientSideCondition {
            type: item>value
            item: P22_SAL
            value: 5000
        }

        action native-set-css (
            action: setStyle
            settings {
                styleName: color
                value: red
            }
            affectedElements {
                selectionType: domObject
                domObject: P22_SAL_display
            }
            execution {
                sequence: 10
            }
        )

        action native-set-css-2 (
            action: setStyle
            settings {
                styleName: color
                value: green
            }
            affectedElements {
                selectionType: domObject
                domObject: P22_SAL_display
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

    )

    process fetch-row-from-eba-demo-da-emp (
        name: Fetch Row from EBA_DEMO_DA_EMP
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P22_ROWID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2668715744985111427
        }
    )

    process process-row-of-eba-demo-da-emp (
        name: Process Row of EBA_DEMO_DA_EMP
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P22_ROWID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2668715953187111431
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
