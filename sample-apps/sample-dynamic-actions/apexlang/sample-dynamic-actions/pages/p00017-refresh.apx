page 17 (
    name: Refresh
    alias: REFRESH
    title: Refresh
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region employees (
        name: Employees
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT e.ROWID
                ,      e.EMPNO
                ,      e.ENAME
                ,      e.JOB
                ,      m.ename MGR
                ,      e.HIREDATE
                ,      e.SAL
                ,      e.COMM
                ,      d.dname DEPTNO
                FROM EBA_DEMO_DA_EMP e
                ,    EBA_DEMO_DA_EMP m
                ,    EBA_DEMO_DA_DEPT d
                WHERE e.mgr = m.empno (+)
                AND   e.deptno = d.deptno (+)
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        heading {
            fixedTo: none
        }
        componentAdvanced {
            reportIdItem: P17_REPORT_ID
        }
        advanced {
            savedReportMappingIdentifier: 2020151519198772745
        }

        column COMM (
            type: plainText
            heading {
                heading: Commission
                alignment: end
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column DEPTNO (
            type: plainText
