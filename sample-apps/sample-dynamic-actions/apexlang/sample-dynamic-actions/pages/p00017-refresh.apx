            displayColumn CURRENT_TIMESTAMP (
                sequence: 10
            )

            displayColumn DEPTNO (
                sequence: 9
            )

            displayColumn EMPNO (
                sequence: 2
            )

            displayColumn ENAME (
                sequence: 3
