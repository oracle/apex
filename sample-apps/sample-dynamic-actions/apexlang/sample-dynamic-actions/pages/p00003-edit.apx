page 3 (
    name: Edit
    alias: EDIT
    title: Edit
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>This page demonstrates how dynamic actions can be used to control multiple items and also that disabling items works for multiple item types.</p>
                <p>To achieve this, the page contains 1 dynamic action called 'JOB EQUALS SALESMAN'. This fires whenever a different 'Job' is selected from the 'Job' select list and checks if the value is equal to 'SALESMAN'. If it is equal to 'SALESMAN' the 'Commission' and 'Hiredate' page items are enabled, otherwise they are disabled.</p>
                <p>It uses 2 native actions ('Enable' and 'Disable').</p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region maintain-employee (
        name: Maintain Employee
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    pageItem P3_COMM (
        type: numberField
        label {
            label: Commission
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 80
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: COMM
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_DEPTNO (
        type: selectList
        label {
            label: Department
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select dname d, deptno r
                from eba_demo_da_dept
                order by 1
                ```
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 90
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: DEPTNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_EMPNO (
        type: numberField
        label {
            label: Employee Number
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 20
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 4
        }
        validation {
            valueRequired: true
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: EMPNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_ENAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 30
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 10
        }
        validation {
            maxLength: 10
        }
        source {
            type: databaseColumn
            databaseColumn: ENAME
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_HIREDATE (
        type: datePicker
        label {
            label: Hire date
            alignment: left
        }
        layout {
            sequence: 60
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 11
        }
        validation {
            maxLength: 11
        }
        source {
            type: databaseColumn
            databaseColumn: HIREDATE
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_JOB (
        type: selectList
        label {
            label: Job
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select distinct job d, job r
                from eba_demo_da_emp
                order by 1
                ```
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 40
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: JOB
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_MGR (
        type: popupLov
        label {
            label: Manager
            alignment: left
        }
        settings {
            displayAs: modalDialog
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select ename d, empno r
                from eba_demo_da_emp
                order by 1
                ```
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 50
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: MGR
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P3_ROWID (
        type: hidden
        layout {
            sequence: 10
            region: @maintain-employee
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ROWID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P3_SAL (
        type: numberField
        label {
            label: Salary
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: SAL
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P3_ROWID
        }
    )

    dynamicAction commission-for-salesman-only (
        name: Commission for Salesman Only
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P3_JOB
        }
        clientSideCondition {
            type: item=value
            item: P3_JOB
            value: SALESMAN
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: items
                items: P3_COMM
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-disable-2 (
            action: disable
            affectedElements {
                selectionType: items
                items: P3_HIREDATE
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: items
                items: P3_COMM
            }
            execution {
                sequence: 10
            }
        )

        action native-enable-2 (
            action: enable
            affectedElements {
                selectionType: items
                items: P3_HIREDATE
            }
            execution {
                sequence: 20
            }
        )

    )

    process fetch-row-from-eba-demo-da-emp (
        name: Fetch Row from EBA_DEMO_DA_EMP
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P3_ROWID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2647405134660838732
        }
    )

    process process-row-of-eba-demo-da-emp (
        name: Process Row of EBA_DEMO_DA_EMP
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P3_ROWID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2647405362373838733
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 2647405535343838734
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 2
            }
        }
    )

)

