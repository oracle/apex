page 9 (
    name: Edit
    alias: EDIT4
    title: Edit
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    css {
        inline:
            ```css
            .showfocus {
              background-color: gold !important;
            }
            .t-Form-inputContainer input.showfocus.popup_lov, .t-Form-inputContainer input[type=text].showfocus, .t-Form-inputContainer select.showfocus,  .t-Form-inputContainer select.showfocus.selectlist {
              background-color: gold !important;
            }
            ```
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region about-this-page (
        name: About this page
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        headerAndFooter {
            headerText:
                ```html
                <p>This page contains two dynamic actions called 'ITEM GETS FOCUS' and 'ITEM LOSES FOCUS'. These fire whenever the user enters and leaves any page item in the 'Maintain Employee' region, respectively. When an item gets focus, the dynamic action adds additional highlighting to show the current focus more clearly, which is subsequently removed when the user leaves the item. Notice that the selection type is specified as 'Event Source' so that operates on the item firing the dynamic action.</p>
                <p>It uses two native actions ('Add Class' and 'Remove Class').</p>
                ```
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region maintain-employee (
        name: Maintain Employee
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    pageItem P9_COMM (
        type: numberField
        label {
            label: Commission
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 80
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: COMM
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_DEPTNO (
        type: selectList
        label {
            label: Department
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @p9-eba-demo-da-emp-deptno
            displayNullValue: false
        }
        layout {
            sequence: 90
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: DEPTNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_EMPNO (
        type: textField
        label {
            label: Employee Number
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 4
        }
        validation {
            valueRequired: true
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: EMPNO
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_ENAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 30
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 10
        }
        validation {
            maxLength: 10
        }
        source {
            type: databaseColumn
            databaseColumn: ENAME
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_HIREDATE (
        type: datePicker
        label {
            label: Hire date
            alignment: left
        }
        layout {
            sequence: 60
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 30
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: HIREDATE
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_JOB (
        type: selectList
        label {
            label: Job
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @p9-eba-demo-da-emp-job
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: JOB
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_MGR (
        type: popupLov
        label {
            label: Manager
            alignment: left
        }
        settings {
            displayAs: modalDialog
        }
        lov {
            type: sharedComponent
            lov: @p9-eba-demo-da-emp-mgr
            displayNullValue: false
        }
        layout {
            sequence: 50
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4
        }
        source {
            type: databaseColumn
            databaseColumn: MGR
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P9_ROWID (
        type: hidden
        layout {
            sequence: 10
            region: @maintain-employee
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ROWID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P9_SAL (
        type: numberField
        label {
            label: Salary
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @maintain-employee
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 7
        }
        validation {
            maxLength: 7
        }
        source {
            type: databaseColumn
            databaseColumn: SAL
            used: always
        }
        security {
            restrictedChars: webSafe
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 8
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_ROWID
        }
    )

    dynamicAction item-gets-focus (
        name: ITEM GETS FOCUS
        execution {
            sequence: 10
        }
        when {
            event: focusin
            selectionType: region
            region: @maintain-employee
        }

        action native-add-class (
            action: addClass
            settings {
                class: showfocus
            }
            affectedElements {
                selectionType: eventSource
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction item-loses-focus (
        name: ITEM LOSES FOCUS
        execution {
            sequence: 20
        }
        when {
            event: focusout
            selectionType: region
            region: @maintain-employee
        }

        action native-remove-class (
            action: removeClass
            settings {
                class: showfocus
            }
            affectedElements {
                selectionType: eventSource
            }
            execution {
                sequence: 10
            }
        )

    )

    process fetch-row-from-eba-demo-da-emp (
        name: Fetch Row from EBA_DEMO_DA_EMP
        type: autoRowFetch
        source {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P9_ROWID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2652196845771452769
        }
    )

    process process-row-of-eba-demo-da-emp (
        name: Process Row of EBA_DEMO_DA_EMP
        type: autoRowProcessing
        target {
            tableName: EBA_DEMO_DA_EMP
            pkColumn: ROWID
            pkItem: P9_ROWID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2652197040698452771
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 2652197243441452772
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 8
            }
        }
    )

)

