)

classicNavigationBarEntry logout (
    label: Logout
    layout {
        sequence: 30
    }
    link {
        target: {
            type: url
            url: &LOGOUT_URL.
        }
    }
    serverSideCondition {
        type: currentPage!=page
        page: 101
    }
)

