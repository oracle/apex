    region apex-collection-update-member-attribute (
        name: apex_collection.update_member_attribute
        type: staticContent
        source {
            htmlCode:
                ```html
                <pre>
                for c1 in (select n001 empno, seq_id
                             from apex_collections
                            where collection_name = 'EMPCOLLECTION'
                           order by seq_id) loop
                    
                    l_rowxml := dbms_xmlgen.getxml( 'select * from eba_demo_cs_emp where empno = ' || c1.empno );
                    apex_collection.update_member_attribute( 
                        p_collection_name => 'EMPCollection',
                        p_seq             => c1.seq_id,
                        p_xmltype_number  => 1,
                        p_xmltype_value   => XMLType(l_rowxml));
                end loop;
                </pre>
                ```
        }
        layout {
            sequence: 90
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region apex-collections (
        name: apex_collections
        type: staticContent
        source {
            htmlCode:
                ```html
                <pre>select seq_id editlink,
                    seq_id, 
                    n001, 
                    n002, 
                    n003, 
                    n004, 
                    d001, 
                    c001, 
                    c002, 
                    c003, 
                    c004 status
                from apex_collections
                where collection_name = 'EMPCOLLECTION'
                </pre>
                ```
        }
        layout {
            sequence: 70
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
    )

    region breadcrumb (
