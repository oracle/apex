    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumbs
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region footer (
        name: Footer
        type: plugin/sampleAppsFooter
        layout {
            sequence: 40
            slot: body
        }
    )

    region tip (
        name: Tip
        type: staticContent
        source {
            htmlCode:
                ```html
                <ol style="margin: 8px 24px;">
                <li>Click the "Create Collection" button to create a new named collection
                <li>Add members to the collection by clicking the "Modify Collection" button
                <li>Modify the members of the collection by clicking the icon in the Action column in the report below
                </ol>
                ```
        }
        layout {
            sequence: 20
            slot: body
            columnAttributes: valign=top
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: infoTextRegion
        }
    )

    button create-collection (
        buttonName: Create_Collection
        label: Create Collection
        layout {
            sequence: 20
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
                clearCache: 2
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button modify-collection (
        buttonName: Modify_Collection
        label: Modify Collection
        layout {
            sequence: 10
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 3
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @apex-collections-view
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

