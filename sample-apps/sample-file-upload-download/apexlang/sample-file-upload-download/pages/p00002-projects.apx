page 2 (
    name: Projects
    alias: PROJECTS
    title: Projects
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline: .apexir_WORKSHEET_DATA td img { max-width: 320px; }
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }

    region application-features-demonstrated-on-this-page (
        name: Application features demonstrated on this page
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                This report includes the sum of the file sizes associated with each project.  It also includes the display of the icon associated with the project, if one has been uploaded.  To upload an icon, edit a project and upload any small icon you have available.  To learn how to include displays like this, click Files.  You can also view the SQL source at the bottom of the page and edit the page to view details of the report column formatting. 
                </p>
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: infoTextRegion
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region projects (
        name: Projects
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    ID,
                    ROW_VERSION_NUMBER,
                    PROJECT,
                    TASK_NAME,
                    START_DATE,
                    END_DATE,
                    STATUS,
                    ASSIGNED_TO,
                    COST,
                    BUDGET,
                    (select count(*) from EBA_DEMO_FILES where project_id = p.id) files,
                    nvl((select sum(dbms_lob.getlength(file_blob)) s from eba_demo_files where project_id = p.id),0) file_size,
                    decode(nvl(dbms_lob.getlength(icon_blob),0),0,'No','Yes') has_icon,
                    dbms_lob.getlength(icon_blob) project_icon
                from EBA_DEMO_FILE_PROJECTS p
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        advanced {
            htmlDomId: projects_report
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        heading {
            fixedTo: none
        }
        advanced {
            savedReportMappingIdentifier: 2598740502172417976
        }

        column ASSIGNED_TO (
            type: plainText
            heading {
                heading: Assigned To
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column BUDGET (
            type: plainText
            heading {
                heading: Budget
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column COST (
            type: plainText
            heading {
                heading: Cost
                alignment: end
            }
            layout {
                sequence: 9
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column END_DATE (
            type: plainText
            heading {
                heading: End Date
            }
            layout {
                sequence: 6
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: F
            }
        )

        column FILES (
            type: plainText
            heading {
                heading: Attachments
                alignment: end
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column FILE_SIZE (
            type: plainText
            heading {
                heading: Attachment Size
                alignment: end
            }
            layout {
                sequence: 12
                columnAlignment: end
            }
            appearance {
                formatMask: FILESIZE
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column HAS_ICON (
            type: plainText
            heading {
                heading: Has Icon
            }
            layout {
                sequence: 13
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column ID (
            type: plainText
            heading {
                heading: Id
                alignment: end
            }
            layout {
                sequence: 1
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column PROJECT (
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 3
            }
            link {
                target: {
                    page: 13
                    items: {
                        P13_ID: #ID#
                    }
                    clearCache: 13
                    action: resetPagination
                }
                linkText: #PROJECT#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column PROJECT_ICON (
            type: displayImage
            heading {
                heading: Project Icon
                alignment: end
            }
            layout {
                sequence: 14
                columnAlignment: end
            }
            blobAttributes {
                tableName: EBA_DEMO_FILE_PROJECTS
                blobColumn: ICON_BLOB
                primaryKeyColumn1: ID
                mimeTypeColumn: ICON_MIMETYPE
                filenameColumn: ICON_NAME
                lastUpdatedColumn: ICON_LAST_UPDATED
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
        )

        column ROW_VERSION_NUMBER (
            type: plainText
            heading {
                heading: Row Version Number
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column START_DATE (
            type: plainText
            heading {
                heading: Start Date
            }
            layout {
                sequence: 5
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column TASK_NAME (
            type: plainText
            heading {
                heading: Task Name
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        savedReport 25987418 (
            visibility: primaryDefault
            view {
                rowsPerPage: 10
            }

            displayColumn ASSIGNED_TO (
                sequence: 5
            )

            displayColumn COST (
                sequence: 6
            )

            displayColumn FILES (
                sequence: 7
            )

            displayColumn FILE_SIZE (
                sequence: 8
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn PROJECT_ICON (
                sequence: 9
            )

            displayColumn START_DATE (
                sequence: 3
            )

            displayColumn STATUS (
                sequence: 4
            )

            displayColumn TASK_NAME (
                sequence: 2
            )

            sort (
                column: PROJECT
                sort {
                    sequence: 1
                }
            )

            sort (
                column: TASK_NAME
                sort {
                    sequence: 2
                }
            )

        )

    )

    region sql-source (
        name: SQL Source
        type: plugin/sourceDisplay
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        settings {
            regionStaticId: projects_report
        }
    )

    button add-project (
        buttonName: ADD_PROJECT
        label: Add Project
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: t-Button--iconRight
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                clearCache: 13
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
                clearCache: [
                    2
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

