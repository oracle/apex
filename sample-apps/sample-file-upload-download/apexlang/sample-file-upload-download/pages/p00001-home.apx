                ```
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/tabs-container
            templateOptions: [
                #DEFAULT#
                t-TabsRegion-mod--simple
            ]
        }
        serverSideCondition {
            type: never
        }
    )

    region app-name (
        name: &APP_NAME.
        type: staticContent
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/hero
            templateOptions: #DEFAULT#
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
    )

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region footer (
        name: Footer
        type: plugin/sampleAppsFooter
        layout {
            sequence: 70
            slot: body
            startNewRow: false
            newColumn: false
        }
    )

    region project-summary (
        name: Project Summary
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    count(distinct PROJECT) projects,
                    count(distinct project||'.'||TASK_NAME) tasks,
                    count(distinct STATUS) status_codes,
                    count(distinct ASSIGNED_TO) assignees,
                    sum(COST) total_cost,
                    sum(BUDGET) total_budget,
                    max(file_count.c) files,
                    max(file_size.s) file_size
                from EBA_DEMO_FILE_PROJECTS p,
                    (select count(*) c from eba_demo_files) file_count,
                    (select nvl(sum(dbms_lob.getlength(file_blob)),0) s 
                     from eba_demo_files) file_size
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                i-h320
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: ONE
            customAttributes: " "
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column ASSIGNEES (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Assignees
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column FILES (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Files
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column FILE_SIZE (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: File Size
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: FILESIZE
            }
            sorting {
                sortable: false
            }
        )

        column PROJECTS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Projects
            }
            layout {
                sequence: 1
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                defaultSequence: 1
            }
        )

        column STATUS_CODES (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Status Codes
            }
            layout {
                sequence: 3
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column TASKS (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Tasks
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column TOTAL_BUDGET (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Total Budget
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column TOTAL_COST (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Total Cost
            }
            layout {
                sequence: 5
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    region project-summary-sql-source (
        name: Project Summary SQL Source
        type: plugin/sourceDisplay
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                i-h320
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        settings {
            regionStaticId: ONE
        }
    )

    region recent-files (
        name: Recent Files
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    ID,
                    ROW_VERSION_NUMBER,
                    PROJECT_ID,
                    FILENAME,
                    FILE_MIMETYPE,
                    FILE_CHARSET,
                    FILE_BLOB,
                    FILE_COMMENTS,
                    TAGS,
                    CREATED,
                    CREATED_BY,
                    UPDATED,
                    UPDATED_BY,
                    sys.dbms_lob.getlength(file_blob) as file_size,
                    sys.dbms_lob.getlength(file_blob) as download
                from EBA_DEMO_FILES
                order by created desc
                ```
        }
        layout {
            sequence: 30
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                i-h320
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: TWO
        }
        reportLayout {
            numberOfRows: 10
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        pagination {
            partialPageRefresh: false
        }
        performance {
            maxRowsToProcess: 10
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 11
            }
        )

        column DOWNLOAD (
            reportColumnQueryId: 15
            derivedColumn: N
            type: downloadBlob
            heading {
                heading: Download
            }
            layout {
                sequence: 15
            }
            appearance {
                downloadText: Download
            }
            blobAttributes {
                tableName: EBA_DEMO_FILES
                blobColumn: FILE_BLOB
                primaryKeyColumn1: ID
                mimeTypeColumn: FILE_MIMETYPE
                filenameColumn: FILENAME
                lastUpdatedColumn: UPDATED
                charSetColumn: FILE_CHARSET
            }
            sorting {
                sortable: false
            }
        )

        column FILENAME (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Filename
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column FILE_BLOB (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

        column FILE_CHARSET (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 6
            }
        )

        column FILE_COMMENTS (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column FILE_MIMETYPE (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

        column FILE_SIZE (
            reportColumnQueryId: 14
            derivedColumn: N
            type: hidden
            layout {
                sequence: 14
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column ROW_VERSION_NUMBER (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
        )

        column TAGS (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

        column UPDATED (
            reportColumnQueryId: 12
            derivedColumn: N
            type: hidden
            layout {
                sequence: 12
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 13
            derivedColumn: N
            type: hidden
            layout {
                sequence: 13
            }
        )

    )

    region recent-files-sql-source (
        name: Recent Files SQL Source
        type: plugin/sourceDisplay
        layout {
            sequence: 50
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                i-h320
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        settings {
            regionStaticId: TWO
        }
    )

    button add-file (
        buttonName: ADD_FILE
        label: Add File
        layout {
            sequence: 10
            region: @recent-files
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 12
                clearCache: 12
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button add-project (
        buttonName: ADD_PROJECT
        label: Add Project
        layout {
            sequence: 10
            region: @project-summary
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                clearCache: 13
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button view-files (
        buttonName: VIEW_FILES
        label: View Files
        layout {
            sequence: 20
            region: @recent-files
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 3
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button view-projects (
        buttonName: VIEW_PROJECTS
        label: View Projects
        layout {
            sequence: 20
            region: @project-summary
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

