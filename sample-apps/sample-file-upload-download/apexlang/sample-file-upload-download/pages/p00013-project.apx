    process upload-file (
        name: Upload File
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    for c1 in (select *
                               from apex_application_temp_files
                               where name = :P13_FILE)
                    loop
                        insert into eba_demo_files (
                            project_id,
                            filename,
                            file_blob,
                            file_comments,
                            file_mimetype)
                        values (
                            :P13_ID,
                            c1.filename,
                            c1.blob_content,
                            :P13_FILE_DESCRIPTION,
                            c1.mime_type);
                    end loop;
                
                    :P13_FILE_DESCRIPTION := null;
                    :P13_FILE  := null;
                end;
                ```
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: File uploaded.
        }
        error {
            errorMessage: There was a problem encountered while uploading the file: #SQLERRM_TEXT#
        }
        advanced {
            executionMappingIdentifier: 3241471509176857356
        }
        serverSideCondition {
            whenButtonPressed: @save
            type: itemIsNotNull
            item: P13_FILE
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 2
            }
        }
    )

)

