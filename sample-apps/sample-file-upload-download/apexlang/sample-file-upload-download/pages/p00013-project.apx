    region project-attachments (
        name: Project Attachments
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    ID,
                    FILENAME,
                    FILE_MIMETYPE,
                    FILE_CHARSET,
                    FILE_BLOB,
                    CREATED,
                    CREATED_BY,
                    UPDATED,
                    UPDATED_BY,
                    dbms_lob.getlength(file_blob) file_size,
                    dbms_lob.getlength(file_blob) download
                from EBA_DEMO_FILES
                where project_id = :P13_ID
                order by created desc
                ```
        }
        layout {
            sequence: 70
            parentRegion: @project
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P13_ID
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        pagination {
            partialPageRefresh: false
        }
        performance {
            maxRowsToProcess: 100
        }
        messages {
            whenNoDataFound: No files are attached to this project.
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column DOWNLOAD (
            reportColumnQueryId: 11
            derivedColumn: N
            type: downloadBlob
            heading {
                heading: Download
            }
            layout {
                sequence: 11
            }
            appearance {
                downloadText: Download
            }
            blobAttributes {
                tableName: EBA_DEMO_FILES
                blobColumn: FILE_BLOB
                primaryKeyColumn1: ID
                mimeTypeColumn: FILE_MIMETYPE
                filenameColumn: FILENAME
                lastUpdatedColumn: UPDATED
                charSetColumn: FILE_CHARSET
            }
            sorting {
                sortable: false
            }
        )

        column FILENAME (
            reportColumnQueryId: 2
            derivedColumn: N
            type: link
            heading {
                heading: Filename
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 12
                    items: {
                        P12_ID: #ID#
                    }
                    clearCache: 12
                }
                linkText: #FILENAME#
            }
            sorting {
                sortable: false
            }
        )

        column FILE_BLOB (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

        column FILE_CHARSET (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column FILE_MIMETYPE (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column FILE_SIZE (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: File Size
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            appearance {
                formatMask: FILESIZE
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column UPDATED (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

