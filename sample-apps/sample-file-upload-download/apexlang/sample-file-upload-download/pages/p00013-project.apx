page 13 (
    name: Project
    alias: PROJECT
    title: Project
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    htmlHeader {
        htmlHeader:
            ```html
            <style>
            table.uReport,
            table.uReportContainer {
              width: 100%;
            }
            table.uReportContainer {
              margin-bottom: 8px;
            }
            
            img.projectIcon {
            max-width: 100%;
            border-radius: 3px;
            display: block;
            margin-bottom: 16px;
            }
            </style>
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region application-features-demonstrated-on-this-page (
