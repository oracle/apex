supportingObject (
    prerequisites {
        freeSpace: 100
        systemPrivileges: [
            createProcedure
            createTable
            createTrigger
            createView
        ]
    }
    installation {
        objectNames: [
            EBA_DEMO_FILE_DATA
            EBA_DEMO_FILE_PROJECTS
            EBA_DEMO_FILES
        ]
    }
    deinstall {
        scriptFile: deinstall-script.sql
    }
    advanced {
        includeInAppExport: true
    }
)

