installScript "Data installation" (
    execution {
        sequence: 120
    }
    script {
        contentFile: data-installation.sql
    }

    databaseObject (
        owner: #OWNER#
        type: package
        name: EBA_DEMO_REST_DATA_PKG
    )

)

installScript ETLProcess (
    execution {
        sequence: 130
    }
    script {
        contentFile: etlprocess.sql
    }

    databaseObject (
        owner: #OWNER#
        type: package
        name: EBA_DEMO_REST_ETL_PKG
    )

)

installScript "ORDS Definition" (
    execution {
        sequence: 100
    }
    script {
        contentFile: ords-definition.sql
    }
)

installScript "Sequences Objects Definition" (
    execution {
        sequence: 49
    }
    script {
        contentFile: sequences-objects-definition.sql
    }

    databaseObject (
        owner: #OWNER#
        type: sequence
        name: DEPT_SEQ
    )

)

installScript "Table Definition" (
    execution {
        sequence: 50
    }
