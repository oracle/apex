        type: table
        name: EBA_DEMO_REST_EMPLOYEECUSTOM
    )

    databaseObject (
        owner: #OWNER#
        type: table
        name: EBA_DEMO_REST_ORDERITEMS
    )

    databaseObject (
        owner: #OWNER#
        type: table
        name: EBA_DEMO_REST_ORDERS
    )

    databaseObject (
