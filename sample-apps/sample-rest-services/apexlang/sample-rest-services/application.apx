app SAMPLE-REST-SERVICES (
    name: Sample REST Services
    version: 26.1.0
    logo {
        type: text
        text: Sample REST Services
    }
    navigation {
        homeUrl: {
            page: 1
        }
        loginUrl: {
            page: LOGIN
        }
    }
    navigationMenu {
        listTemplate: @/side-navigation-menu
        templateOptions: [
            #DEFAULT#
            js-defaultCollapsed
            js-navCollapsed--hidden
            t-TreeNav--styleA
        ]
        list: @navigation-menu
    }
    navigationBar {
        list: @navigation-bar
        listTemplate: @/navigation-bar
        templateOptions: #DEFAULT#
    }
    userInterface {
        currentTheme: @universal-theme
        globalPage: 0
    }
    appFormatMasks {
        date: DS
        timestamp: DS
        timestampTimeZone: DS
    }
    authentication {
        scheme: @oracle-apex-accounts
        publicUser: APEX_PUBLIC_USER
    }
    security {
        runtimeApiUsage: modifyThisApp
    }
    sessionStateProtection {
        checksumSalt: 05B9E120A271E945304560BECB549D85DEE17C5ED6456E0EC9639844218CDDEA
    }
    runtime {
        allowFeedback: true
    }
    advanced {
        modernizeApp: true
        copyrightBanner:
            ```
            Name: #APP_NAME#
            Copyright (c) 2012, #YEAR# Oracle and/or its affiliates.
            Licensed under the Universal Permissive License v 1.0
            as shown at https://oss.oracle.com/licenses/upl/
            ```
    }

    substitution APP_NAME (
        value {
            staticValue: Sample REST Services
        }
    )

    appSetting ODATA_URL (
        value {
            onUpgradeKeepValue: true
        }
    )

    appSetting REMOTE_SERVER_BASE_URL (
        value {
            onUpgradeKeepValue: true
        }
    )

    appSetting REMOTE_SERVER_INITIALIZED (
        value {
            staticValue: NO
        }
        validation {
            validValues: YES,NO
        }
    )

    appSetting REMOTE_SERVER_SCHEMA_ALIAS (
    )

    appSetting TMDB_APIKEY (
        value {
            staticValue: NO
        }
        validation {
            validValues: YES,NO
        }
    )

)

