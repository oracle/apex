page 305 (
    name: Oracle JET Charts
    alias: ORACLE-JET-CHARTS1
    title: Oracle JET Charts
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region order-status-distribution (
        name: Order Status Distribution
        type: chart
        layout {
            sequence: 40
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        chart {
            type: pie
        }
        chartLayout {
            height: 400
        }
        value {
            format: decimal
            decimalPlaces: 0
            formatScaling: none
        }

        series series (
            name: Series
            execution {
                sequence: 10
            }
            source {
                location: restSource
                restSource: @eba_rest_orders
            }
            localPostProcessing {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select order_status   as label, 
                           count(*)       as value
                      from #APEX$SOURCE_DATA#
                     group by order_status
                     order by value desc
                    
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
            label {
                show: true
            }
        )

    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <div>
                
                  <p>
                
                    This page demonstrates how REST data can be seamlessly integrated with Oracle APEX and visualized using Oracle JET charts. The underlying data is coming from our REST data source.
                  <ul>
                    <li>
                      <strong>Project Task Count (Bar Chart):</strong>  
                        Displays the number of tasks per project using data from <code>EBA_REST_TASKS</code> REST Data Source.
                    </li>
                
                    <li>
                      <strong>Order Status Distribution (Pie Chart):</strong>  
                      Uses data from <code>EBA_REST_ORDERS</code> REST Data Source to show the proportion of orders by status.
                    </li>
                
                   
                
                  </ul>
                 
                  <p>
                    This page leverages Oracle APEX's REST integration and Oracle JET's advanced visualization capabilities to deliver an interactive and responsive dashboard for data driven decision making.
                  </p>
                
                </div>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
    )

    region project-task-count (
        name: Project Task Count
        type: chart
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        chartLayout {
            height: 400
        }
        tooltip {
            showSeriesName: false
        }
        legend {
            show: false
        }

        series series (
            name: Series
            execution {
                sequence: 10
            }
            source {
                location: restSource
                restSource: @eba_rest_tasks
            }
            localPostProcessing {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    
                    select  project    as label,
                            count(*)   as value
                      from  #APEX$SOURCE_DATA#
                     group  by project
                     order  by value desc
                    ```
            }
            columnMapping {
                label: LABEL
                value: VALUE
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
                formatScaling: none
            }
            minorTicks {
                show: false
            }
        )

    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 306
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: previous
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 304
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

