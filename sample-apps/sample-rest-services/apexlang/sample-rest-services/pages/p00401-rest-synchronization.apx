            advanced {
                endUserAlias: I
            }
        )

        column RELEASE_DATE (
            type: plainText
            heading {
                heading: Release Date
            }
            layout {
                sequence: 100
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: J
            }
        )

        column TITLE (
            type: plainText
            heading {
                heading: Title
            }
            layout {
                sequence: 30
            }
            accessibility {
                valueIdentifiesRow: true
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column VIDEO (
            type: plainText
            heading {
