        )

    )

    region synchronization-table-doesnt-exists (
        name: Synchronization Table Doesnt Exists
        type: staticContent
        source {
            htmlCode: REST Synchronization requires a local table to exist, so please click the <strong>Create Table</strong> button to create it.
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
                t-Alert--accessibleHeading
            ]
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                apex_app_setting.get_value('TMDB_APIKEY') =  'YES'
                and not exists (
                  select 1
                    from sys.user_tables
                   where table_name = 'EBA_DEMO_REST_MOVIES_SYNC'
                )
                ```
        }
    )

    button create-table (
        buttonName: Create_Table
        label: Create Table
        layout {
            sequence: 10
            region: @synchronization-table-doesnt-exists
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-angle-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 402
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-angle-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 400
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button set-api-key (
        buttonName: Set_API_Key
        label: Set API Key
        layout {
            sequence: 10
            region: @api-key-not-provided
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 503
                items: {
                    P304_SOURCE: 401
                }
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button synchronize-data (
        buttonName: Synchronize_Data
        label: Synchronize Data
        layout {
            sequence: 10
            region: @synchronization-results
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-refresh
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process create-table-synchronization-definiton (
        name: Create Table Synchronization definiton
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                
                
                apex_rest_source_sync.synchronize_table_definition(
                        p_module_static_id     => 'eba_rest_movie_synchronization',
                        p_drop_unused_columns  => true 
                );
                  
                
                ```
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Table created successfully.
        }
        error {
            errorMessage: Sync table is not created.
        }
        advanced {
            executionMappingIdentifier: 8731459953172133
        }
        serverSideCondition {
            whenButtonPressed: @create-table
        }
    )

    process trigger-synchronization (
        name: Trigger Synchronization
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                begin
                    apex_rest_source_sync.synchronize_data(
                        p_module_static_id   => 'eba_rest_movie_synchronization',
                        p_run_in_background  => false,
                        p_application_id     => :APP_ID
                    );
                end;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Data synchronized successfully.
        }
        error {
            errorMessage: Error while triggering synchronization.
        }
        advanced {
            executionMappingIdentifier: 7669847588224627
        }
        serverSideCondition {
            whenButtonPressed: @synchronize-data
        }
    )

)

