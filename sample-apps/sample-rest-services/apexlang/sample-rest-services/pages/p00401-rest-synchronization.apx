            }
        )

        column ORIGINAL_LANGUAGE (
            type: plainText
            heading {
                heading: Original Language
            }
            layout {
                sequence: 140
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column ORIGINAL_TITLE (
            type: hidden
            heading {
                heading: Original Title
            }
            layout {
                sequence: 130
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column OVERVIEW (
            type: plainText
            heading {
                heading: Overview
            }
            layout {
                sequence: 50
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column POPULARITY (
            type: hidden
            heading {
                heading: Popularity
            }
            layout {
                sequence: 70
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
