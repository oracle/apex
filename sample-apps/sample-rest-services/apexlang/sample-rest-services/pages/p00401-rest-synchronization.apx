page 401 (
    name: REST Synchronization
    alias: REST-SYNCHRONIZATION
    title: REST Synchronization
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: mustNotBePublicUser
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region api-key-not-provided (
        name: API key Not  Provided
        type: staticContent
        source {
            htmlCode: This page relies on a REST Data Source. You need to provide your own API key for <strong>themoviedb.org</strong>. Go to administration and set your own api key in the Manage web credentials page
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
            ]
        }
        serverSideCondition {
            type: expression
            plsqlExpression: apex_app_setting.get_value('TMDB_APIKEY') = 'NO'
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <div >
                  <p>
                    This page demonstrates the integration of external RESTful data with local database tables, emphasizing the efficiency and flexibility of data synchronization.    The page utilizes a REST Data Source named <strong>EBA_REST_MOVIE_SYNCHRONIZATION</strong> to fetch data from an external movie database API.
                
                  </p>
                  <p>
                    This data is synchronized into a local table, <strong>EBA_DEMO_REST_MOVIES_SYNC</strong>, ensuring that the application benefits from faster data access and reduced latency.    By configuring the interactive report to use the synchronized table, the application achieves improved performance, especially when handling large datasets.
                
                  </p>
                
                  <p>
                    <strong>Note: </strong> The <strong>Synchronize Data</strong> button on the page invokes the <strong>APEX_REST_SOURCE_SYNC.SYNCHRONIZE_DATA</strong> API, allowing users to refresh the local data on-demand.
                    This approach ensures that the interactive report always displays the most up-to-date information without relying solely on scheduled synchronizations.
                  </p>
                </div>
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
    )

    region synchronization-results (
        name: Synchronization Results
        type: interactiveReport
        source {
            location: restSource
            restSource: @eba_rest_movie_synchronization
        }
        restSynchronization {
            useLocalTable: true
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        serverSideCondition {
            type: expression
            language: sql
            sqlExpression:
                ```sql
                apex_app_setting.get_value('TMDB_APIKEY') =  'YES'
                and exists (
                  select 1
                    from sys.user_tables
                   where table_name = 'EBA_DEMO_REST_MOVIES_SYNC'
                );
                ```
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: Table contains no data yet. Please click the Synchronize Data button.
        }
        advanced {
            savedReportMappingIdentifier: 7668113893224610
        }

        column ADULT (
            type: hidden
            heading {
                heading: Adult
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column BACKDROP_PATH (
            type: hidden
            heading {
                heading: Backdrop Path
            }
            layout {
                sequence: 120
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column GENRE_IDS (
            type: plainText
            heading {
                heading: Genre Ids
            }
            layout {
                sequence: 60
            }
            source {
                dataType: CLOB
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: F
            }
            enableUsersTo {
                sort: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
            advanced {
