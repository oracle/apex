page 501 (
    name: Application Appearance
    alias: APPLICATION-APPEARANCE1
    title: Application Appearance
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>Select the default color scheme used to display the application.</p>
            <p>If <strong>Allow End Users to choose Theme Style</strong> is checked, then each end user can select from the available theme styles by clicking the <em>Customize</em> link in the bottom left corner of the Home page.</p>
            ```
    }
    config {
        buildOption: @feature-theme-style-selection
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region configure-appearance (
        name: Configure Appearance
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--noIcon
                t-Alert--warning
            ]
        }
    )

    pageItem P501_DESKTOP_THEME_STYLE_ID (
        type: selectList
        label {
            label: Desktop Theme Style
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @desktop-theme-styles
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @configure-appearance
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select s.theme_style_id
                from apex_application_theme_styles s,
                    apex_application_themes t
                where s.application_id = t.application_id
                    and s.theme_number = t.theme_number
                    and s.application_id = :app_id
                    and s.is_current = 'Yes'
                ```
            used: always
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from apex_application_theme_styles s,
                       apex_application_themes t
                 where s.application_id = t.application_id
                   and s.theme_number   = t.theme_number
                   and s.application_id = :app_id
                ```
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
        help {
            inlineHelpText: The default Theme Style applies to all users.
        }
    )

    button save (
        buttonName: Save
        label: Save
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process save-theme-style (
        name: Save Theme Style
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :P501_DESKTOP_THEME_STYLE_ID is not null then
                    for l_theme in (select theme_number
                                      from apex_application_themes
                                     where application_id = :app_id
                                       and is_current     = 'Yes')
                    loop
                        apex_util.set_current_theme_style (
                            p_theme_number   => l_theme.theme_number,
                            p_theme_style_id => :P501_DESKTOP_THEME_STYLE_ID
                            );
                    end loop;
                end if;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Application appearance settings saved.
        }
        advanced {
            executionMappingIdentifier: 7454075016768815
        }
    )

    branch (
        name: Branch to Admin Page
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 500
                action: resetPagination
            }
        }
    )

)

