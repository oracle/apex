list advanced-features (
    name: Advanced Features

    entry invoke-api-process (
        label: Invoke API Process
        icon {
            imageIconCssClasses: fa-compass
        }
        layout {
            sequence: 19
        }
        link {
            target: {
                page: 402
            }
        }
        userDefinedAttributes {
            1: Shows how to declaratively invoke a REST API using the Invoke API Page Process type.
        }
    )

    entry nested-json-and-dynamic-actions (
        label: Nested JSON and Dynamic Actions
        icon {
            imageIconCssClasses: fa-ai-sparkle-generate-text
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 405
            }
        }
        userDefinedAttributes {
            1: Use Dynamic Actions to visualize nested JSON from a REST Data Source in two regions.
        }
    )

    entry rest-and-workflow (
        label: REST and Workflow
        icon {
            imageIconCssClasses: fa-workflow
        }
        layout {
            sequence: 51
        }
        link {
            target: {
                page: 407
            }
        }
        userDefinedAttributes {
            1: Explains how to orchestrate REST calls using Workflows.
        }
    )

    entry rest-data-and-pl-sql (
        label: REST Data and PL/SQL
        icon {
            imageIconCssClasses: fa-window-pointer
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 404
            }
        }
        userDefinedAttributes {
            1: Illustrates how to invoke REST endpoints with PL/SQL and the APEX_EXEC package.
        }
    )

    entry rest-data-source-plugins (
        label: REST Data Source Plugins
        icon {
            imageIconCssClasses: fa-plug
        }
        layout {
            sequence: 41
        }
        link {
            target: {
                page: 406
            }
        }
        userDefinedAttributes {
            1: Use a REST Data Source Plug-In to support special functionality of an external REST API.
        }
    )

    entry rest-synchronization (
        label: REST Synchronization
        icon {
            imageIconCssClasses: fa-refresh
        }
        layout {
            sequence: 1
        }
        link {
            target: {
                page: 401
            }
        }
        userDefinedAttributes {
            1: Leverage REST Synchronization for improved performance and availability.
        }
    )

)

list combine-with-relational-data (
    name: Combine with Relational Data

    entry derived-columns (
        label: Derived Columns
        icon {
            imageIconCssClasses: fa-circle-arrow-in-east
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 202
            }
        }
        userDefinedAttributes {
            1: Showcases how to use additional <em>derived columns</em> in the <strong>Data Profile</strong> to enrich results coming from the REST service.
        }
    )

    entry post-processing-sql (
        label: Post Processing SQL
        icon {
            imageIconCssClasses: fa-arrow-up
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 201
            }
        }
        userDefinedAttributes {
            1: Showcases how to combine external REST data with data from local tables using <strong>Post Processing SQL</strong>.
        }
    )

)

list data-display-options (
    name: Data Display Options

    entry calendar (
        label: Calendar
        icon {
            imageIconCssClasses: fa-calendar
        }
        layout {
            sequence: 90
        }
        link {
            target: {
                page: 308
            }
        }
        userDefinedAttributes {
            1: Presents REST data in the APEX Calendar component for date-based visualization.
        }
    )

    entry cards-layout (
        label: Cards Layout
        icon {
            imageIconCssClasses: fa-address-card
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 304
            }
        }
        userDefinedAttributes {
            1: Showcases how to use visual card regions to display REST data in a mobile-friendly format, offering an alternative presentation to traditional reports.
        }
    )

    entry faceted-search (
        label: Faceted Search
        icon {
            imageIconCssClasses: fa-table-search
        }
        layout {
            sequence: 70
        }
        link {
            target: {
                page: 306
            }
        }
        userDefinedAttributes {
            1: Demonstrates how to consume and display REST-sourced data using Faceted Search, with filtering by Job and Salary ranges.
        }
    )

    entry map (
        label: Map
        icon {
            imageIconCssClasses: fa-map-marker
        }
        layout {
            sequence: 80
        }
        link {
            target: {
                page: 307
            }
        }
        userDefinedAttributes {
            1:
                ```
                Displays REST data on a map using the built-in APEX Map component.
                
                
                ```
        }
    )

    entry oracle-jet-charts (
        label: Oracle JET Charts
        icon {
            imageIconCssClasses: fa-combo-chart
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 305
            }
        }
        userDefinedAttributes {
            1:
                ```
                Demonstrates how to build interactive, dynamic visualizations using Oracle JET.
                
                
                ```
        }
    )

    entry report-with-pagination (
        label: Report with Pagination
        icon {
            imageIconCssClasses: fa-table-clock
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 302
            }
        }
        userDefinedAttributes {
            1: Highlights how to dynamically fetch and display subsets of data from a REST service using offset/limit parameters, making it suitable for large datasets.
        }
    )

    entry report-with-query (
        label: Report with Query
        icon {
            imageIconCssClasses: fa-database-search
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 303
            }
        }
        userDefinedAttributes {
            1: Illustrates how to create a report that handles larger REST service responses and offers built-in query capabilities.
        }
    )

    entry simple-report (
        label: Simple Report
        icon {
            imageIconCssClasses: fa-table
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 301
            }
        }
        userDefinedAttributes {
            1: Shows how to consume a REST endpoint with automatic JSON conversion to present data without advanced features.
        }
    )

)

