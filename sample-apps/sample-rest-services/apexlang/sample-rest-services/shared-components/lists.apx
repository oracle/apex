list navigation-bar (
    name: Navigation Bar

    entry administration (
        label: Administration
        icon {
            imageIconCssClasses: fa-gear
        }
        layout {
            sequence: 5
        }
        link {
            target: {
                page: 500
            }
        }
    )

    entry app-user (
        label: &APP_USER.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry help (
        label: Help
        icon {
            imageIconCssClasses: fa-question-circle-o
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 600
            }
        }
        config {
            buildOption: @feature-about-page
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 60
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

    entry sign-out (
        label: Sign Out
        icon {
            imageIconCssClasses: fa-sign-out
        }
        layout {
            sequence: 70
            parentEntry: @app-user
        }
        link {
            target: {
                type: url
                url: &LOGOUT_URL.
            }
        }
        serverSideCondition {
            type: userIsAuthenticated
        }
    )

)

