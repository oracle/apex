list user-interface (
    name: User Interface
    config {
        buildOption: @feature-theme-style-selection
    }

    entry network-setup (
        label: Network Setup
        icon {
            imageIconCssClasses: fa-window-search
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 504
            }
        }
        userDefinedAttributes {
            1: This page helps you to setup connection with ORDS and ODATA.
        }
    )

    entry reset-data (
        label: Reset Data
        icon {
            imageIconCssClasses: fa-refresh
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 502
            }
        }
        userDefinedAttributes {
            1: This application ships with sample data. You can reset the sample data using this administrative page.
        }
    )

    entry theme-style-selection (
        label: Theme Style Selection
        icon {
            imageIconCssClasses: fa-paint-brush
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 501
                clearCache: 10010
            }
        }
        userDefinedAttributes {
            1: Set the default application look and feel.
        }
        config {
            buildOption: @feature-theme-style-selection
        }
    )

    entry web-credentials (
        label: Web Credentials
        icon {
            imageIconCssClasses: fa-lock-new
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 503
            }
        }
        userDefinedAttributes {
            1: The REST Data Source Plugins & Cards Layout pages rely on TMDb API. Use this page to provide your own TMDb API key.
        }
    )

)

