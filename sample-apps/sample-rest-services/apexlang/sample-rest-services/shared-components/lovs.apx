lov desktop-theme-styles (
    name: DESKTOP THEME STYLES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select s.name d,
                   s.theme_style_id r
              from apex_application_theme_styles s,
                   apex_application_themes t
             where s.application_id = :app_id
               and t.application_id = s.application_id
               and t.theme_number   = s.theme_number
               and t.is_current     = 'Yes'
             order by 1
            ```
    }
    columnMapping {
        return: R
        display: D
    }
)

lov employee-popup-lov (
    name: EMPLOYEE_POPUP_LOV
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select ename as employee,
                   empno as return_value,
                   sal   as old_salary
              from eba_demo_rest_employee
             order by ename
            
            ```
    }
    columnMapping {
        return: RETURN_VALUE
        display: EMPLOYEE
    }

    column EMPLOYEE (
        heading {
            heading: Employee
        }
        layout {
            sequence: 10
        }
        source {
            dataType: varchar2
        }
    )

    column OLD_SALARY (
        heading {
            heading: Old Salary
        }
        layout {
            sequence: 20
        }
        source {
            dataType: number
        }
    )

    column RETURN_VALUE (
        show: false
        layout {
            sequence: 30
        }
        source {
            dataType: number
        }
        advanced {
            searchable: false
        }
    )

)

lov user-theme-preference (
    name: USER_THEME_PREFERENCE
    source {
        location: staticValues
    }

    entry allow-end-users-to-choose-theme-style (
        sequence: 1
        display: Allow End Users to choose Theme Style
        return: Yes
    )

)

lov workflow-console-lov-initiated (
    name: WORKFLOW_CONSOLE.LOV.INITIATED
    source {
        location: staticValues
    }

    entry last-24-hours (
        sequence: 2
        display: Last 24 hours
        return: 1|24
    )

    entry last-30-days (
        sequence: 4
        display: Last 30 days
        return: 168|720
    )

    entry last-7-days (
        sequence: 3
        display: Last 7 days
        return: 24|168
    )

    entry last-hour (
        sequence: 1
        display: Last hour
        return: |1
    )

    entry older-than-30-days (
        sequence: 5
        display: Older than 30 days
        return: 720|
    )

)

lov workflow-console-lov-workflow-state (
    name: WORKFLOW_CONSOLE.LOV.WORKFLOW_STATE
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select disp,
                   val
              from table ( apex_workflow.get_lov_workflow_state )
             order by insert_order
            ```
    }
    columnMapping {
        return: VAL
        display: DISP
    }
)

