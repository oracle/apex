    region overview (
        name: Overview
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                    With appearance settings in APEX, you can easily customize the look
                    and feel of your PWA container to match the branding and design of
                    your application. This can help to create a more cohesive and professional
                    appearance for your app, making it more appealing to users.
                </p>
                ```
        }
        layout {
            sequence: 10
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region region-display-selector (
        name: Region Display Selector
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        accessibility {
            landmarkType: navigation
            landmarkLabel: Region Display Selector
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

    region theme-color (
        name: Theme Color
        type: staticContent
        source {
            htmlCode:
                ```html
                <p class="col-8">This attribute defines the theme color for the PWA. This affects how the operating system displays the frame of the PWA, for example the title bar on desktop or the status bar on mobile.</p>
                
                <p>This table shows the supported combinations of operating systems and browsers for the theme color attribute.</p>
                
                <table class="u-Report u-Report--staticBG u-Report--stretch dm-Report--doc dm-Report--grid col-8">
                    <thead>
                        <tr>
                            <td class="display-hidden"></td>
                            <th class="u-tL">Chrome</th>
                            <th class="u-tL">Edge</th>
                            <th class="u-tL">Firefox</th>
                            <th class="u-tL">Safari</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th class="u-tL" scope="row"><span>Android</span></th>
                            <td class="display-visible">Yes</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-hidden">N/A</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>iOS</span></th>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                            <td class="display-visible">Yes</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>macOS</span></th>
                            <td class="display-visible">Yes</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>Windows</span></th>
                            <td class="display-visible">Yes</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-hidden">N/A</td>
                        </tr>
                    </tbody>
                </table>
                
                <p class="margin-top-md"><em>Last updated: April 2023</em></p>
                ```
        }
        layout {
            sequence: 70
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
            renderComponents: belowContent
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region translucent (
        name: Translucent
        type: staticContent
        source {
            htmlCode: <p>Transparent Background. Useful for apps with no top navbar.</p>
        }
        layout {
            sequence: 30
            parentRegion: @ios-status-bar-style
            slot: subRegions
            startNewRow: false
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
            renderComponents: belowContent
        }
    )

)

