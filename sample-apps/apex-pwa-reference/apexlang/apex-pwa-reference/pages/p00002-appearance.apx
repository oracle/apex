page 2 (
    name: Appearance
    alias: APPEARANCE
    title: Appearance - &APP_NAME.
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }

    region background-color (
        name: Background Color
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>The background color is used when opening the PWA, as a splash screen while the app content is loading. For a smooth transition, it should match the APEX theme body background.</p>
                
                <p>This table shows the supported combinations of operating systems and browsers for the background color attribute.</p>
                
                <table class="u-Report u-Report--staticBG u-Report--stretch dm-Report--doc dm-Report--grid col-8">
                    <thead>
                        <tr>
                            <td class="display-hidden"></td>
                            <th class="u-tL">Chrome</th>
                            <th class="u-tL">Edge</th>
                            <th class="u-tL">Firefox</th>
                            <th class="u-tL">Safari</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <th class="u-tL" scope="row"><span>Android</span></th>
                            <td class="display-visible">Yes</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-hidden">N/A</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>iOS</span></th>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>macOS</span></th>
                            <td class="display-not">No</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-not">No</td>
                        </tr>
                        <tr>
                            <th class="u-tL" scope="row"><span>Windows</span></th>
                            <td class="display-not">No</td>
                            <td class="display-visible">Yes</td>
                            <td class="display-not">No</td>
                            <td class="display-hidden">N/A</td>
                        </tr>
                    </tbody>
                </table>
                
                <p class="margin-top-md"><em>Last updated: April 2023</em></p>
                ```
        }
        layout {
            sequence: 80
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region browser (
        name: Browser
        type: staticContent
        layout {
            sequence: 80
            parentRegion: @display
            slot: regionBody
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region custom-manifest (
        name: Custom Manifest
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>The <strong>Custom Manifest</strong> attribute is used to store additional JSON properties for the web app manifest.</p>
                <p>Custom manifest properties extend APEX PWA declarative options by overriding existing ones or appending new ones.</p>
                ```
        }
        layout {
            sequence: 100
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-2
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region custom-manifest-example (
        name: Custom Manifest Example
        type: staticContent
        source {
            htmlCode:
                ```html
                <code>{
                    "short_name": "APEX PWA",
                    "other": "value"
                }</code>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @custom-manifest
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
    )

    region custom-theme-color-example (
        name: Custom theme color example
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @theme-color
            slot: regionBody
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region default (
        name: Default
        type: staticContent
        source {
            htmlCode: <p>White Text and Black Background.</p>
        }
        layout {
            sequence: 10
            parentRegion: @ios-status-bar-style
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
            renderComponents: belowContent
        }
    )

    region default-theme-color-example (
        name: Default theme color example
        type: staticContent
        layout {
            sequence: 10
