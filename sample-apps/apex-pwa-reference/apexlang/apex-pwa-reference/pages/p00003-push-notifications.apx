page 3 (
    name: Push Notifications
    alias: PUSH-NOTIFICATIONS
    title: Push Notifications
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }

    region apex-appl-push-subscriptions (
        name: apex_appl_push_subscriptions
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                
                    The <code>apex_appl_push_subscriptions</code> view lists all users who have
                    opted in to receive your notifications, making it easy to target your messages
                    to all your subscribers and Send a notification using the API. You could find
                    an example in <code>Send using API</code> section above.
                
                </p>
                ```
        }
        layout {
            sequence: 20
            parentRegion: @apex-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--textContent
                t-Region--scrollBody
            ]
        }
    )

    region apex-push-notifications-queue (
        name: apex_push_notifications_queue
        type: staticContent
        source {
            htmlCode: <p>The <code>apex_push_notifications_queue</code> view, provides the notification records that are pending or have encountered errors during the sending process. This information useful for troubleshooting issues and ensuring the successful delivery of your push notifications.</p>
        }
        layout {
            sequence: 30
            parentRegion: @apex-views
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--textContent
                t-Region--scrollBody
            ]
        }
    )

    region apex-views (
        name: APEX Views
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                
                    Regardless of the method you choose to send a push notification, it's
                    important (for the APEX engine) to be able to identify the users who
                    have subscribed to the feature in order to use the page process or the
                    API meaningfully. APEX offers two views to help analyze this records of
                    who is subscribed to the push notifications of your application and the
                    notifications in the queue.
                
                </p>
                ```
        }
        layout {
            sequence: 70
            parentRegion: @sending-notifications
            slot: subRegions
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
            renderComponents: belowContent
        }
        accessibility {
            landmarkLabel: API
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region changing-the-application-alias-blocks-future-delivery-of-push-notifications (
        name: Changing the application alias blocks future delivery of push notifications
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>
                    Updating an application alias changes the structure of the URL and causes the service worker to invalidate.
                </p>
                <p>
                    We recommend not updating an application alias for production systems, or users will have to subscribe to push notifications again.
                </p>
                ```
        }
        layout {
            sequence: 40
            parentRegion: @common-issues
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region code (
        name: Code
        type: staticContent
        source {
            htmlCode:
                ```html
                <code>begin
                    apex_pwa.send_push_notification (
                        p_application_id => 100,
                        p_user_name      => 'SMITH',
                        p_title          => 'Notification Title',
                        p_body           => 'Notification Body' );
                end;</code>
                
                <br /><br />
                
                <code>begin
                    for l_subscription in ( 
                        select distinct user_name
                          from apex_appl_push_subscriptions
                         where application_id = :APP_ID )
                    loop
                        apex_pwa.send_push_notification (
                            p_application_id => :APP_ID,
                            p_user_name      => l_subscription.user_name,
                            p_title          => 'APEX 23.1 is here!',
                            p_body           => 'Try out the new features.' );
                    end loop;
                end;</code>
                ```
        }
        layout {
            sequence: 10
            parentRegion: @send-using-api
            slot: subRegions
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--padded
                t-ContentBlock--h3
                t-ContentBlock--shadowBG
                t-Region--removeHeader js-removeLandmark
            ]
        }
    )

