page 101 (
    name: Roadmap
    alias: ROADMAP
    title: Roadmap
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
    }

    region apex (
        name: APEX 23.2
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                  11 id,
                  'QR Code Generator' list_title,
                  'Let users easily share data using a QR code based on an APEX page URL or content' list_text,
                  null list_class,
                  null link, 
                  null link_attr,
                  null icon_color_class,
                  'fa fa-qrcode' icon_class
                from sys.dual
                
                union all
                
                select
                  13 id,
                  'Image Upload' list_title,
                  'Modern image upload experience so users can edit images before saving' list_text,
                  null list_class,
                  null link, 
                  null link_attr,
                  null icon_color_class,
                  'fa fa-image' icon_class
                from sys.dual
                
                order by id
                ```
        }
        layout {
            sequence: 30
            slot: body
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                t-ContentBlock--lightBG
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 9999
        }
        componentAppearance {
            template: @/media-list
            templateOptions: [
                #DEFAULT#
                t-MediaList--stack
                t-Report--hideNoPagination
            ]
        }

        column ICON_CLASS (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Icon Class
                alignment: center
            }
            layout {
                sequence: 80
            }
            sorting {
                sortable: false
            }
        )

        column ICON_COLOR_CLASS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Icon Color Class
                alignment: center
            }
            layout {
                sequence: 70
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Id
                alignment: center
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column LINK (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Link
                alignment: center
            }
            layout {
                sequence: 50
            }
            sorting {
                sortable: false
            }
        )

        column LINK_ATTR (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Link Attr
                alignment: center
            }
            layout {
                sequence: 60
            }
            sorting {
                sortable: false
            }
        )

        column LIST_CLASS (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: List Class
                alignment: center
            }
            layout {
                sequence: 40
            }
            sorting {
                sortable: false
            }
        )

        column LIST_TEXT (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: List Text
                alignment: center
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

        column LIST_TITLE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: List Title
                alignment: center
            }
            layout {
                sequence: 20
            }
            accessibility {
                valueIdentifiesRow: true
            }
            sorting {
                sortable: false
            }
        )

    )

