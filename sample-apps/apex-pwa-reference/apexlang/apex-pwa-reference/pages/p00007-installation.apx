            templateOptions: #DEFAULT#
        }
        accessibility {
            landmarkType: navigation
            landmarkLabel: Region Display Selector
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            mode: scrollWindow
            rememberSelection: false
        }
    )

)

