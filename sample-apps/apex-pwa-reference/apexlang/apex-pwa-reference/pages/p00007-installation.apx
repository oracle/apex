    )

    region edit-description (
        name: Edit Description
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @pwa-description-container
            slot: regionBody
            columnSpan: 8
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h3
                js-headingLevel-3
            ]
        }
    )

    region examples (
        name: Examples
        type: staticContent
        source {
            htmlCode:
                ```html
                <p class="col-8">
                    All devices, from desktop to mobile, offer a tailored web app installation experience. 
                    See examples below for a preview of the feature.
                </p>
                
                <p class="col-8">
                    Desktop users can find the <strong><span class="t-Icon fa fa-cloud-download" aria-hidden="true"></span> Install App</strong> button in the navigation bar to trigger the installation process. 
                    Mobile users can find the same button, except it will display as only an icon.
                </p>
                ```
        }
        layout {
            sequence: 1040
            slot: body
        }
        appearance {
            template: @/content-block
            templateOptions: [
                #DEFAULT#
                t-ContentBlock--h2
                js-headingLevel-2
            ]
            renderComponents: belowContent
        }
        accessibility {
            landmarkLabel: PWA Screenshots Example
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region image (
        name: Image
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @edit-description
            slot: regionBody
            columnCssClasses: padding-none
        }
        appearance {
            template: @/image
            templateOptions: [
                #DEFAULT#
                t-ImageRegion--auto
                t-ImageRegion--cover
                t-ImageRegion--rounded
                t-ImageRegion--noFilter
            ]
        }
        image {
            fileUrl: #APP_FILES#img/edit-description.jpeg
            customAttributes: loading="lazy"
        }
    )

