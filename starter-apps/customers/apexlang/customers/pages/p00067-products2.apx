        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 68
                items: {
                    P68_CUSTOMER_ID: &P67_ID.
                }
                clearCache: 68
            }
            warnOnUnsavedChanges: doNotCheck
        }
