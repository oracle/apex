page 22 (
    name: Updates
    alias: UPDATES
    title: Updates
    pageGroup: @reports
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: This calendar displays Changes to customers by day. Click the <strong><</strong> button to go to the previous month and the <strong>></strong> button to go forward a month. Switch between the calendar view to the list view by clicking the <strong>list</strong> button.
    }
    config {
        buildOption: @reports
    }

    region activities (
        name: Activities
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region updates (
        name: Updates
        type: calendar
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select distinct a.customer_id
                ,      a.updated
                ,      a.customer_name
                from (select n.customer_id
                      ,      trunc(n.created) updated
                      ,      c.CUSTOMER_NAME
                      from  eba_cust_notes n , eba_cust_customers c
                      where n.customer_id = c.id
                      union all
                      select c.id customer_id
                      ,      trunc(h.change_date) updated
                      ,      c.customer_name
                      from EBA_CUST_HISTORY h, eba_cust_customers c
                      where h.component_id = c.id
                     ) a
                
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        security {
            escapeSpecialChars: false
        }
        settings {
            displayColumn: CUSTOMER_NAME
            startDateColumn: UPDATED
            supplementalInfo: &DETAIL.
            showTooltip: false
            additionalCalendarViews: [
                list
                navigation
            ]
            viewEditLink: {
                page: 50
                items: {
                    P50_ID: &CUSTOMER_ID.
                }
                clearCache: 50
                action: resetPagination
            }
            maxEventsDay: 16
        }
        performance {
            lazyLoading: true
        }
    )

    pageItem P22_CALENDAR_DATE (
        type: hidden
        layout {
            sequence: 10
            region: @updates
            slot: regionBody
        }
        source {
            type: item
            item: P22_CALENDAR_DATE
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody: return to_char(sysdate,'YYYYMMDD');
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        comments {
            comments: Generated by Calendar wizard on 18-JUN-07
        }
    )

    pageItem P22_CALENDAR_TYPE (
        type: hidden
        layout {
            sequence: 20
            region: @updates
            slot: regionBody
        }
        source {
            type: item
            item: P22_CALENDAR_TYPE
            used: always
        }
        default {
            type: static
            staticValue: M
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        comments {
            comments: Generated by Calendar wizard on 18-JUN-07
        }
    )

    process adjust-calendar-date-daily (
        name: Adjust Calendar Date -Daily
        type: executeCode
        source {
            plsqlCode: " htmldb_util.daily_calendar('P22_CALENDAR_TYPE');"
        }
        execution {
            sequence: 40
        }
        error {
            errorMessage: Error changing calendar date.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17793462047370449051
        }
        comments {
            comments: Generated 18-JUN-07
        }
    )

