page 119 (
    name: Review Feedback
    alias: REVIEW-FEEDBACK
    title: Review Feedback
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>All user-provided feedback can be reviewed and managed here. If <a href="f?p=&APP_ID.:28:&APP_SESSION.">feedback recipients</a> have been defined then feedback submissions will also be emailed to the email addresses in the feedback recipients list. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.</p>
    }
    config {
        buildOption: @feedback
    }

    region feedback (
        name: Feedback
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       APPLICATION_ID,
                       PAGE_ID,
                       FEEDBACK,
                       RESPONSE,
                       TYPE_ID,
                       STATUS,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY
                  from EBA_CUST_FEEDBACK
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No feedback submissions found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        componentAdvanced {
            emailFromAddress: &P203_EMAIL_FROM_ADDRESS.
        }
        advanced {
            savedReportMappingIdentifier: 17674659788336175427
        }

        column APPLICATION_ID (
            type: plainText
            heading {
                heading: Application ID
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: H
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column FEEDBACK (
            type: plainText
            heading {
                heading: Feedback
            }
            layout {
                sequence: 51
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column ID (
            type: link
            heading {
                heading: <span class="u-VisuallyHidden">Edit</span>
                alignment: center
            }
            layout {
                sequence: 1
                columnAlignment: center
            }
            link {
                target: {
                    page: 120
                    items: {
                        P120_ID: #ID#
                    }
                    clearCache: 204
                    action: resetPagination
                }
                linkText: <img src="#IMAGE_PREFIX#app_ui/img/icons/apex-edit-pencil.png" class="apex-edit-pencil" alt="">
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            enableUsersTo {
                hide: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column PAGE_ID (
            type: plainText
            heading {
                heading: Page
                alignment: end
            }
            layout {
                sequence: 3
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: C
            }
        )

        column RESPONSE (
            type: plainText
            heading {
                heading: Response
            }
            layout {
                sequence: 41
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column STATUS (
            type: plainTextBasedOnLov
            heading {
                heading: Status
            }
            lov {
                lov: @feedback-statuses
            }
            layout {
                sequence: 21
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column TYPE_ID (
            type: plainTextBasedOnLov
            heading {
                heading: Type
            }
            lov {
                lov: @feedback-types
            }
            layout {
                sequence: 31
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: M
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 10
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: J
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 11
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 176746643 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn FEEDBACK (
                sequence: 4
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn PAGE_ID (
                sequence: 2
            )

            displayColumn RESPONSE (
                sequence: 6
            )

            displayColumn STATUS (
                sequence: 5
            )

            displayColumn TYPE_ID (
                sequence: 3
            )

            displayColumn UPDATED (
                sequence: 8
            )

            displayColumn UPDATED_BY (
                sequence: 7
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    pageItem P119_EMAIL_FROM_ADDRESS (
        type: hidden
        layout {
            sequence: 10
            region: @feedback
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @feedback
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-close-after-edit (
        name: Refresh on close after edit
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @feedback
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @feedback
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

