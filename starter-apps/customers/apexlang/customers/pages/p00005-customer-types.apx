page 5 (
    name: Customer Types
    alias: CUSTOMER-TYPES
    title: Customer Types
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: &CUSTOMER_TYPE_HELP.
    }

    region customer-types (
        name: Customer Types
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    t.id,
                    t.type as customer_type,
                    t.description,
                    decode(t.is_active,'Y',:ACTIVE_MSG,:INACTIVE_MSG) Status,
                    t.updated,
                    t.created,
                    t.updated_by,
                    t.created_by,
                    (select count(*) from eba_cust_customers c where c.type_id = t.id) customer_count
                from
                    eba_cust_type t
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No type codes found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 3741422720003038728
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 25
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: G
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created by
            }
            layout {
                sequence: 45
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column CUSTOMER_COUNT (
            type: link
            heading {
                heading: Customer Count
                alignment: end
            }
            layout {
                sequence: 55
                columnAlignment: end
            }
            link {
                target: {
                    page: 59
                    items: {
                        P59_STATUS: #ID#
                    }
                    clearCache: 59
                    action: resetPagination
                }
                linkText: #CUSTOMER_COUNT#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column CUSTOMER_TYPE (
            type: link
            heading {
                heading: Customer Type
            }
            layout {
                sequence: 65
            }
            link {
                target: {
                    page: 6
                    items: {
                        P6_ID: #ID#
                    }
                    clearCache: 6
                    action: resetPagination
                }
                linkText: #CUSTOMER_TYPE#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Type
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 15
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: F
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated by
            }
            layout {
                sequence: 35
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 9136235 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn CUSTOMER_COUNT (
                sequence: 4
            )

            displayColumn CUSTOMER_TYPE (
                sequence: 1
            )

            displayColumn DESCRIPTION (
                sequence: 2
            )

            displayColumn STATUS (
                sequence: 3
            )

            sort (
                column: CUSTOMER_TYPE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: CUSTOMER_STATUS
                sort {
                    sequence: 2
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Add Type Code
        layout {
            sequence: 20
            region: @customer-types
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 6
                clearCache: 6
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @customer-types
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 5
                clearCache: [
                    5
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Action Processed.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @customer-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

