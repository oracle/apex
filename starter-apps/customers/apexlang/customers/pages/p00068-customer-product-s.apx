        target {
            tableName: EBA_CUST_PRODUCT_USES
            pkColumn: ID
            pkItem: P68_ID
            secondaryKeyColumn: PRODUCT_ID
            secondaryKeyItem: P68_PRODUCT_ID
            supportedOperations: [
