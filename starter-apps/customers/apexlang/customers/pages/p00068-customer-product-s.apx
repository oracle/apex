                ```plsql
                insert into EBA_CUST_CONTACTS
                (name, customer_id) values (:P68_NEW_CONTACT, :P68_CUSTOMER_ID) returning id into :P68_CUSTOMER_CONTACT_ID;
                ```
        }
        execution {
