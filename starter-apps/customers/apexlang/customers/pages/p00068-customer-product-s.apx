    dynamicAction cancel-dialog (
        name: cancel dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction select-unselect-all-products (
        name: Select/Unselect All Products
        execution {
            sequence: 30
            eventScope: dynamic
            staticContainer: #productsIRR
        }
        when {
            selectionType: jQuerySelector
            jquerySelector: #selectUnselectAll
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    if ( $( '#selectUnselectAll' ).is(':checked') ) {
                      $('input[type=checkbox][name=f01]').attr('checked',true);
                    }
                    else {
                      $('input[type=checkbox][name=f01]').attr('checked',false);
                    }
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction show-hide-new-contact (
        name: Show/Hide New Contact
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P68_CUSTOMER_CONTACT_ID
        }
        clientSideCondition {
            type: item=value
            item: P68_CUSTOMER_CONTACT_ID
            value: -1
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: P68_NEW_CONTACT
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P68_NEW_CONTACT
            }
            execution {
                sequence: 10
            }
        )

    )

    validation new-contact-is-not-null (
        name: New Contact is not null
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNotNull
            item: P68_NEW_CONTACT
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P68_NEW_CONTACT
        }
        serverSideCondition {
            type: item=value
            item: P68_CUSTOMER_CONTACT_ID
            value: -1
        }
    )

    validation product-must-be-selected (
        name: Product Must Be Selected
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody:
                ```plsql
                declare
                    l_product_id number;
                begin
                    for i in 1..apex_application.g_f01.count
                    loop
                        l_product_id := to_number(APEX_APPLICATION.G_F01(i));
                        if l_product_id > 0 then
                            return true;
                        end if;
                    end loop;
                    return false;
                end;
                ```
        }
        error {
            errorMessage: At least one product must be selected.
            displayLocation: inlineInNotification
        }
        serverSideCondition {
            whenButtonPressed: @add-product
        }
    )

    process add-products (
        name: add products
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                  l_ref_types     eba_cust_product_uses.reference_type_ids%type;
                  l_ref_status_id eba_cust_product_uses.reference_status_id%type;
                begin
                    if APEX_UTIL.GET_BUILD_OPTION_STATUS(
                        P_APPLICATION_ID => :APP_ID,
                        P_BUILD_OPTION_NAME => 'Product Referencability') = 'INCLUDE' then
                        l_ref_types     := :P68_REFERENCE_TYPES;
                        l_ref_status_id := :P68_PRODUCT_STATUS_ID;
                    else
                        l_ref_types     := null;
                        l_ref_status_id := null;
                    end if;
                    
                    for i in 1..apex_application.g_f01.count
                    loop
                        insert into eba_cust_product_uses
                        (customer_id, product_id, reference_type_ids, reference_status_id, internal_contact,
                         customer_contact_id, valid_from, valid_to, comments)
                        values
                        (:P68_CUSTOMER_ID, to_number(APEX_APPLICATION.G_F01(i)), l_ref_types, l_ref_status_id, :P68_INTERNAL_CONTACT, 
                         :P68_CUSTOMER_CONTACT_ID, to_timestamp(:P68_VALID_FROM, 'DD-MON-YYYY HH:MI.SS AM'), to_timestamp(:P68_VALID_TO, 'DD-MON-YYYY HH:MI.SS AM'), :P68_COMMENTS);
                    end loop;
                end;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 16592507486631831657
        }
        serverSideCondition {
            whenButtonPressed: @add-product
        }
    )

