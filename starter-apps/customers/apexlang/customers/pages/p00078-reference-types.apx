page 78 (
    name: Reference Types
    alias: REFERENCE-TYPES
    title: Reference Types
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Reference Types are used for indicating how references are willing to be used. The Reference Type will be available when you Add, Modify or Search for a Contact. Reference Types can be made Active or Inactive but only active Reference Types will be shown when adding or modifying a Contact.
    }

    region reference-types (
        name: Reference Types
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                reference_TYPE,
                decode(is_active,'Y',:ACTIVE_MSG,:INACTIVE_MSG) Status,
                CREATED,
                CREATED_BY,
                UPDATED,
                UPDATED_BY
                from EBA_CUST_reference_TYPES
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2215987056873573291
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 25
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: G
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created by
            }
            layout {
                sequence: 35
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column REFERENCE_TYPE (
            type: link
            heading {
                heading: Reference type
            }
            layout {
                sequence: 15
            }
            link {
                target: {
                    page: 79
                    items: {
                        P79_ID: #ID#
                    }
                    action: resetPagination
                }
                linkText: #REFERENCE_TYPE#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
            security {
                authorizationScheme: @administration-rights
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 45
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: I
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated by
            }
            layout {
                sequence: 55
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 22159888 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn CREATED (
                sequence: 3
            )

            displayColumn CREATED_BY (
                sequence: 4
            )

            displayColumn REFERENCE_TYPE (
                sequence: 1
            )

            displayColumn STATUS (
                sequence: 2
            )

            displayColumn UPDATED (
                sequence: 5
            )

            displayColumn UPDATED_BY (
                sequence: 6
            )

            sort (
                column: STATUS
                sort {
                    sequence: 1
                }
            )

            sort (
                column: REFERENCE_TYPE
                sort {
                    sequence: 2
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Add Reference Type
        layout {
            sequence: 20
            region: @reference-types
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 79
                clearCache: 79
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Customer Referencability') = 'INCLUDE'
                or
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Product Referencability') = 'INCLUDE'
                ```
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @reference-types
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 78
                clearCache: [
                    5
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Action Processed.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @reference-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

