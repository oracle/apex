page 134 (
    name: Issues
    alias: ISSUES
    title: Issues
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region issues (
        name: Issues
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    customer_id as customer,
                    customer_id as customer_id,
                    name,
                    issue_type,
                    status_id,
                    product_id,
                    details,
                    resolution,
                    created,
                    created_by,
                    updated,
                    updated_by
                from
                    eba_cust_issues
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 2562576816419818606
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 71
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: G
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 81
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column CUSTOMER (
            type: plainTextBasedOnLov
            heading {
                heading: Customer
            }
            lov {
                lov: @customers
            }
            layout {
                sequence: 11
            }
            link {
                target: {
                    page: 50
                    items: {
                        P50_ID: #CUSTOMER_ID#
                    }
                    clearCache: 50
                    action: resetPagination
                    request: ISSUES
                }
                linkText: #CUSTOMER#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column CUSTOMER_ID (
            type: hidden
            heading {
                heading: Customer
            }
            layout {
                sequence: 21
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
            security {
                escapeSpecialChars: false
            }
        )

        column DETAILS (
            type: plainText
            heading {
                heading: Details
            }
            layout {
                sequence: 61
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ISSUE_TYPE (
            type: plainTextBasedOnLov
            heading {
                heading: Issue Type
            }
            lov {
                lov: @issue-types
            }
            layout {
                sequence: 41
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column NAME (
            type: plainText
            heading {
                heading: Issue
            }
            layout {
                sequence: 31
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column PRODUCT_ID (
            type: plainTextBasedOnLov
            heading {
                heading: Product
            }
            lov {
                lov: @products
            }
            layout {
                sequence: 111
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column RESOLUTION (
            type: plainText
            heading {
                heading: Resolution
                alignment: center
            }
            layout {
                sequence: 121
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column STATUS_ID (
            type: plainTextBasedOnLov
            heading {
                heading: Status
            }
            lov {
                lov: @issue-statuses
            }
            layout {
                sequence: 51
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: E
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 91
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: I
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 101
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 25625826 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CUSTOMER (
                sequence: 1
            )

            displayColumn DETAILS (
                sequence: 6
            )

            displayColumn ISSUE_TYPE (
                sequence: 3
            )

            displayColumn NAME (
                sequence: 2
            )

            displayColumn PRODUCT_ID (
                sequence: 5
            )

            displayColumn RESOLUTION (
                sequence: 7
            )

            displayColumn STATUS_ID (
                sequence: 4
            )

            displayColumn UPDATED (
                sequence: 9
            )

            displayColumn UPDATED_BY (
                sequence: 8
            )

            controlBreak (
                column: CUSTOMER
                layout {
                    sequence: 1
                }
            )

        )

    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @issues
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

