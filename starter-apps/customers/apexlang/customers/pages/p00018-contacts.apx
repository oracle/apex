page 18 (
    name: Contacts
    alias: CONTACTS
    title: Contacts
    pageGroup: @contacts
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>This page provides an interactive report of all customer contacts.  Each contact is associated with one customer.  Assuming you have contribution privileges you can add contacts from this page or by locating a customer and clicking the add contact button.  Click on column headings to sort and filter data, click on the <strong>Actions</strong> menu to customize column display and many additional advanced features.</p>
    }
    config {
        buildOption: @contacts
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--showBreadcrumb
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region contacts (
        name: Contacts
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.id,
                    a.name,
                    a.title,
                    a.phone,
                    a.email,
                    a.tags,
                    a.company,
                    (   select contact_type
                        from eba_cust_contact_types t
                        where t.id = a.contact_type_id ) contact_type,
                    a.city,
                    a.state,
                    a.country,
                    a.created,
                    a.created_by,
                    a.updated,
                    a.updated_by,
                    (   select customer_name
                        from eba_cust_customers c
                        where c.id = a.customer_id ) customer_name,
                    a.customer_id
                from eba_cust_contacts a
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: CONTACTS
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 3739529323348919187
        }

        column CITY (
            type: hidden
            heading {
                heading: City
            }
            layout {
                sequence: 11
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
            security {
                escapeSpecialChars: false
            }
        )

        column COMPANY (
            type: hidden
            heading {
                heading: Company
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CONTACT_TYPE (
            type: plainText
            heading {
                heading: Contact Type
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column COUNTRY (
            type: hidden
            heading {
                heading: Country
            }
            layout {
                sequence: 14
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 17
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: Q
            }
        )

        column CREATED_BY (
            type: hidden
            heading {
                heading: Created By
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CUSTOMER_ID (
            type: hidden
            heading {
                heading: Customer ID
            }
            layout {
                sequence: 40
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: AN
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CUSTOMER_NAME (
            type: link
            heading {
                heading: Customer
            }
            layout {
                sequence: 15
            }
            link {
                target: {
                    page: 50
                    items: {
                        P50_ID: #CUSTOMER_ID#
                    }
                    clearCache: 50
                    action: resetPagination
                }
                linkText: #CUSTOMER_NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column EMAIL (
            type: link
            heading {
                heading: Email
            }
            layout {
                sequence: 12
            }
            link {
                target: {
                    type: url
                    url: mailto:#EMAIL#
                }
                linkText: #EMAIL#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: " "
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                authorizationScheme: @contribution-rights
                escapeSpecialChars: false
            }
        )

        column NAME (
            type: link
            heading {
                heading: Name
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 20
                    items: {
                        P20_ID: #ID#
                    }
                    clearCache: 20
                }
                linkText: #NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

        column PHONE (
            type: plainText
            heading {
                heading: Phone
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column STATE (
            type: hidden
            heading {
                heading: State
            }
            layout {
                sequence: 13
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
            security {
                escapeSpecialChars: false
            }
        )

        column TAGS (
            type: plainText
            heading {
                heading: Tags
            }
            layout {
                sequence: 16
            }
            source {
                dataType: STRING
            }
            columnFilter {
                type: definedLovWordContains
                sqlQuery:
                    ```sql
                    select tag
                      from eba_cust_tags_type_sum
                     where content_type = 'CONTACT'
                       and tag_count > 0
                    ```
            }
            advanced {
                endUserAlias: P
            }
        )

        column TITLE (
            type: plainText
            heading {
                heading: Title
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 18
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: R
            }
        )

        column UPDATED_BY (
            type: hidden
            heading {
                heading: Updated By
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
            security {
                escapeSpecialChars: false
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 9117312 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn CONTACT_TYPE (
                sequence: 4
            )

            displayColumn CUSTOMER_ID (
                sequence: 7
            )

            displayColumn CUSTOMER_NAME (
                sequence: 2
            )

            displayColumn EMAIL (
                sequence: 6
            )

            displayColumn NAME (
                sequence: 1
            )

            displayColumn PHONE (
                sequence: 5
            )

            displayColumn TITLE (
                sequence: 3
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Add Contact
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 20
                clearCache: [
                    20
                    2
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @contacts
            slot: rightOfInteractiveReportSearchBar
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    RIR
                    &APP_PAGE_ID.
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button upload-contacts-data (
        buttonName: UPLOAD_CONTACTS_DATA
        label: Upload Contacts Data
        layout {
            sequence: 20
            region: @breadcrumb
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 60
                clearCache: [
                    60
                    61
                    62
                    63
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 18
        }
    )

    process reset-pagination (
        name: Reset Pagination
        type: resetPagination
        execution {
            sequence: 10
        }
        error {
            errorMessage: Unable to reset pagination.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17804253858680092607
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: Go,P18_REPORT_SEARCH
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 18
                successMessage: false
            }
            saveStateBeforeBranching: true
        }
    )

)

