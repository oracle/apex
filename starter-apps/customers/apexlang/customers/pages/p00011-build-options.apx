page 11 (
    name: Build Options
    alias: BUILD-OPTIONS
    title: Build Options
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>Build options allow for specific application functionality to be included and available, or excluded and not available.  Use build options to identify which features and functions you would like to run your application with.</p>
    }

    region build-options (
        name: Build Options
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                       build_option_id ID, 
                       build_option_name build_option, 
                       build_option_status,
                       apex_item.hidden(1, build_option_id) ||
                       apex_item.hidden(2, build_option_status) ||
                       apex_item.switch ( 
                            p_idx => 3,
                            p_value => build_option_status,
                            p_on_value => 'Include',
                            p_on_label => 'Yes',
                            p_off_value => 'Exclude',
                            p_off_label => 'No',
                            p_item_id => 'BO_OPT_' || rownum,
                            p_item_label => apex_escape.html(build_option_name) || ': Is Enabled',
                            p_attributes => 'style="white-space:pre;"') toggle_build_option,
                       component_comment,
                       last_updated_on updated,
                       lower(last_updated_by) updated_by
                  from apex_application_build_options bo
                 where application_id = :APP_ID
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 871299031774617967
        }

        column BUILD_OPTION (
            type: plainText
            heading {
                heading: Build Option
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column BUILD_OPTION_STATUS (
            type: plainText
            heading {
                heading: Current Status
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column COMPONENT_COMMENT (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column TOGGLE_BUILD_OPTION (
            type: plainText
            heading {
                heading: Status
                alignment: center
            }
            layout {
                sequence: 4
                columnAlignment: center
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
            enableUsersTo {
                hide: false
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: F
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        savedReport 8712999 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn BUILD_OPTION (
                sequence: 1
            )

            displayColumn BUILD_OPTION_STATUS (
                sequence: 2
            )

            displayColumn COMPONENT_COMMENT (
                sequence: 3
            )

            displayColumn TOGGLE_BUILD_OPTION (
                sequence: 4
            )

            displayColumn UPDATED (
                sequence: 5
            )

            displayColumn UPDATED_BY (
                sequence: 6
            )

            sort (
                column: BUILD_OPTION
                sort {
                    sequence: 1
                }
            )

            sort (
                column: UPDATED
                sort {
                    sequence: 2
                }
            )

        )

    )

    button apply-changes (
        buttonName: APPLY_CHANGES
        label: Apply Changes
        layout {
            sequence: 20
            region: @build-options
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @build-options
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 11
                clearCache: [
                    9
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process update (
        name: update
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for i in 1..apex_application.g_f01.count loop
                    for c1 in ( select application_id, build_option_name, build_option_status
                                from apex_application_build_options
                                where apex_application.g_f01(i) = build_option_id
                                   and application_Id = :APP_ID) loop
                        if c1.build_option_status != apex_application.g_f03(i) then
                            apex_util.set_build_option_status(  p_application_id => :APP_ID,
                                                                p_id => apex_application.g_f01(i),
                                                                p_build_status => upper(apex_application.g_f03(i)) );
                        end if;
                    end loop;
                end loop;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Build Status(es) updated.
        }
        error {
            errorMessage: Build Status(es) failed to be updated.
        }
        advanced {
            executionMappingIdentifier: 14935281876222410813
        }
        serverSideCondition {
            whenButtonPressed: @apply-changes
        }
    )

)

