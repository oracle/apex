    region timezone (
        name: timezone
        type: staticContent
        source {
            htmlCode:
                ```html
                "TIMEZONE" 
                 
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            expandShortcuts: true
        }
    )

    button create-customer (
        buttonName: CREATE_CUSTOMER
        label: Add Customer
        layout {
            sequence: 30
            region: @breadcrumbs
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
                clearCache: 2
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button reset-report (
        buttonName: Reset_Report
        label: Reset
        layout {
            sequence: 10
            region: @customers
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                    CIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button upload-customers (
        buttonName: UPLOAD_CUSTOMERS
        label: Upload Customers
        layout {
            sequence: 20
            region: @breadcrumbs
            slot: edit
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 53
                clearCache: [
                    53
                    54
                    55
                    56
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @customer-data-loading
        }
    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

    process load-data (
        name: Load Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'REPORTS' then 
                    :LAST_VIEW := 20;
                else
                    :LAST_VIEW := 30 ;
                end if;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 13541311042611233440
        }
        serverSideCondition {
            type: never
        }
    )

    process reset-pagination (
        name: Reset Pagination
        type: resetPagination
        execution {
            sequence: 10
        }
        error {
            errorMessage: Unable to reset pagination.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 13541310624699233439
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: Go,P93_REPORT_SEARCH,RESET
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 93
                successMessage: false
            }
            saveStateBeforeBranching: true
        }
    )

)

