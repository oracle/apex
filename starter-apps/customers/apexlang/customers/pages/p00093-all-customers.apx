                    }
                    clearCache: 50
                }
                linkText: <span>#ROW_KEY#</span>
                linkAttributes: class="uButton uButtonAlt" style="text-decoration: none;"
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: S
            }
        )

        column STATUS (
            type: plainText
