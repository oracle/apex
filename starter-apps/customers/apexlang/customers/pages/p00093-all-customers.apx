page 93 (
    name: All Customers
    alias: ALL-CUSTOMERS
    title: All Customers
    pageGroup: @customers
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>This page provides an interactive report of all customers.  Click the customer name to view details.  Click on column headings to sort and filter data, click on the <strong>Actions</strong> menu to customize column display and many additional advanced features.</p>
    }

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region customers (
        name: Customers
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.row_key,
                    a.id,
                    customer_name,
                    status,
                    category,
                    nvl(geography_name,'Not Defined') geography_name,
                    decode(referencable, null, 'No', referencable) referencable,
                    number_of_users,
                    decode(marquee_customer_yn, null, 'No', 'N', 'No', 'Y', 'Yes') marquee_customer,
                    decode(greatest(length(summary),50),50,summary,substr(summary,1,50)||'...') summary,
                    web_site,
                    (   select listagg(p.product_name, ', ') within group (order by p.product_name) product_uses
                        from eba_cust_customers c, eba_cust_product_uses u, eba_cust_products p
                        where c.id = u.customer_id
                            and u.product_id = p.id
                            and c.id = a.id
                        group by c.customer_name
                    ) product_uses,
                    tags,
                    nvl((select INDUSTRY_NAME from EBA_CUST_INDUSTRIES i where i.id = a.INDUSTRY_ID),'Not Defined') industry,
                    a.industry_id,
                    a.created,
                    a.created_by,
                    a.updated,
                    a.updated_by
                from eba_cust_customers a,
                    eba_cust_categories b,
                    eba_cust_status c,
                    eba_cust_geographies d
                where a.category_id = b.id(+)
                    and a.status_id = c.id(+)
                    and a.geography_id = d.id(+)
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: CUSTOMERS
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
        }
        advanced {
            savedReportMappingIdentifier: 12485757618114756691
        }

        column CATEGORY (
            type: plainText
            heading {
                heading: Category
            }
            layout {
                sequence: 16
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 20
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: T
            }
        )

        column CREATED_BY (
            type: hidden
            heading {
                heading: Created By
            }
            layout {
                sequence: 13
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CUSTOMER_NAME (
            type: link
            heading {
                heading: Customer
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 50
                    items: {
                        P50_ID: #ID#
                    }
                    clearCache: 50
                    action: resetPagination
                }
                linkText: #CUSTOMER_NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column GEOGRAPHY_NAME (
            type: plainText
            heading {
                heading: Geography
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: V
            }
            serverSideCondition {
                type: expression
                plsqlExpression: wwv_flow_utilities.is_build_option_enabled('Geography')
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Selected Customer
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column INDUSTRY (
            type: plainText
            heading {
                heading: Industry
            }
            layout {
                sequence: 25
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Y
            }
        )

        column INDUSTRY_ID (
            type: hidden
            heading {
                heading: Selected Industry
            }
            layout {
                sequence: 26
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: Z
            }
            security {
                escapeSpecialChars: false
            }
        )

        column MARQUEE_CUSTOMER (
            type: plainText
