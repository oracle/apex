            }
        )

        column REFERENCABLE (
            type: plainText
            heading {
                heading: Publicly Referenceable
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
            serverSideCondition {
                type: expression
                plsqlExpression:
                    ```plsql
                    APEX_UTIL.GET_BUILD_OPTION_STATUS(
                        P_APPLICATION_ID => :APP_ID,
                        P_BUILD_OPTION_NAME => 'Customer Referencability') = 'INCLUDE'
                    ```
            }
        )

        column ROW_KEY (
            type: link
