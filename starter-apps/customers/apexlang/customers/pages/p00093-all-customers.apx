            }
            advanced {
                endUserAlias: C
            }
        )

        column SUMMARY (
            type: plainText
            heading {
                heading: Summary
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column TAGS (
            type: plainText
            heading {
                heading: Tags
            }
            layout {
                sequence: 18
            }
            source {
                dataType: STRING
            }
            columnFilter {
                type: definedLovWordContains
                sqlQuery:
                    ```sql
                    select tag
                      from eba_cust_tags_type_sum
                     where content_type = 'CUSTOMER'
                       and tag_count > 0
                    ```
            }
            advanced {
                endUserAlias: R
