page 116 (
    name: Competitors
    alias: COMPETITORS2
    title: Competitors
    pageGroup: @products
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @view-competitors
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText:
            ```html
            
                Click the <strong>Reset</strong> button to reset the interactive Competitors report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive Competitors report.
            ```
    }
    config {
        buildOption: @competitors
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region competitors (
        name: Competitors
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id ,
                    c.name competitor,
                    c.website,
                    c.description,
                    (select count(*) from EBA_CUST_CUST_COMPETITOR_REF   r where r.competitor_ID = c.id) customers,
                (select listagg(customer_id,',') within group (order by customer_id desc) from EBA_CUST_CUST_COMPETITOR_REF r where r.competitor_ID = c.id) as cust_ids
                from 
                     EBA_CUST_COMPETITORS  c
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: COMP
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No competitors found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 16721079917243670991
        }

        column COMPETITOR (
            type: plainText
            heading {
                heading: Competitor
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column CUSTOMERS (
            type: link
            heading {
                heading: Customers
                alignment: end
            }
            layout {
                sequence: 50
                columnAlignment: end
            }
            link {
                target: {
                    page: 59
                    items: {
                        P59_COMPETITOR: #ID#
                        IRIN_ID: \#CUST_IDS#\
                    }
                    clearCache: [
                        RIR
                        CIR
                    ]
                    action: resetPagination
                }
                linkText: #CUSTOMERS#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: F
            }
        )

        column CUST_IDS (
            type: hidden
            heading {
                heading: Cust ids
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
            security {
                escapeSpecialChars: false
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column ID (
            type: link
            heading {
                heading: Edit
                alignment: center
            }
            layout {
                sequence: 10
                columnAlignment: center
            }
            link {
                target: {
                    page: 109
                    items: {
                        P109_ID: #ID#
                    }
                    clearCache: 109
                    action: resetPagination
                }
                linkText: <img src="#IMAGE_PREFIX#app_ui/img/icons/apex-edit-pencil.png" class="apex-edit-pencil" alt="Edit #COMPETITOR#">
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
            enableUsersTo {
                hide: false
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
            security {
                authorizationScheme: @edit-competitors
            }
        )

        column WEBSITE (
            type: plainText
            heading {
                heading: Website
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        savedReport 167210821 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn COMPETITOR (
                sequence: 2
            )

            displayColumn CUSTOMERS (
                sequence: 4
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn WEBSITE (
                sequence: 3
            )

            sort (
                column: CUSTOMERS
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    button create-competitor (
        buttonName: CREATE_COMPETITOR
        label: Create Competitor
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 109
                clearCache: 109
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @edit-competitors
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @competitors
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 116
                clearCache: RIR
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-ir-after-add (
        name: Refresh IR after add
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @create-competitor
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @competitors
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-ir-after-edit (
        name: Refresh IR after edit
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @competitors
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @competitors
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 44
        }
    )

)

