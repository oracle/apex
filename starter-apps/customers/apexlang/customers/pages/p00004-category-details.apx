page 4 (
    name: Category Details
    alias: CATEGORY-DETAILS
    title: Category Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            //-->
            </script>
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-information (
        name: Audit Information
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @category-details
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region category-details (
        name: Category Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P4_CATEGORY (
        type: textField
        label {
            label: Category
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @category-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 48
        }
        validation {
            valueRequired: true
            maxLength: 60
        }
        source {
            type: databaseColumn
            databaseColumn: CATEGORY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: Categories are used to categorize your Customers.  They can be regions, vertical markets, or whatever makes sense for your use.
        }
    )

    pageItem P4_CREATED (
        type: displayOnly
        label {
            label: <b>Created On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 40
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Category was created.
        }
    )

    pageItem P4_CREATED_BY (
        type: displayOnly
        label {
            label: <b>Created By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 50
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who created this Category.
        }
    )

    pageItem P4_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 40
            region: @category-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
            height: 4
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: DESCRIPTION
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: Enter short description.
        }
    )

    pageItem P4_ID (
        type: hidden
        layout {
            sequence: 1
            region: @category-details
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4_IS_ACTIVE (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Active;Y
            displayExtraValues: false
        }
        layout {
            sequence: 30
            region: @category-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: IS_ACTIVE
            used: always
        }
        default {
            type: expression
            plsqlExpression: case when :P4_ID is null then 'Y' end;
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4_UPDATED (
        type: displayOnly
        label {
            label: <b>Updated On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 60
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Category details was last Updated.
        }
    )

    pageItem P4_UPDATED_BY (
        type: displayOnly
        label {
            label: <b>Updated By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 70
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who last updated the Category Details.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Category
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P4_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation check-for-dependencies (
        name: Check for Dependencies
        execution {
            sequence: 30
        }
        validation {
            type: noRowsReturned
            sqlQuery: select 1 from eba_cust_customers where category_id = :P4_ID and rownum = 1
        }
        error {
            errorMessage: Cannot Delete this Category, Customers exists in this Category.
            associatedItem: @P4_CATEGORY
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    validation p4-category-unique (
        name: P4_CATEGORY unique
        execution {
            sequence: 5
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_cust_categories
                where upper(category) = upper(:P4_CATEGORY)
                    and (:P4_ID is null
                        or id <> :P4_ID )
                ```
        }
        error {
            errorMessage: #LABEL# already exists.
            associatedItem: @P4_CATEGORY
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 1611697323051273270
        }
    )

    process fetch-row-from-eba-cust-categories (
        name: Fetch Row from EBA_CUST_CATEGORIES
        type: autoRowFetch
        source {
            tableName: EBA_CUST_CATEGORIES
            pkColumn: ID
            pkItem: P4_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 17798851279705760927
        }
    )

    process load-data (
        name: Load data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'HOME' then
                   :LAST_VIEW := 100 ;
                else
                   :LAST_VIEW := 3 ;
                end if;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 17798275339105163631
        }
    )

    process process-row-of-eba-cust-categories (
        name: Process Row of EBA_CUST_CATEGORIES
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_CATEGORIES
            pkColumn: ID
            pkItem: P4_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_CUST_CATEGORIES.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17798851472626760933
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17798851653185760935
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

