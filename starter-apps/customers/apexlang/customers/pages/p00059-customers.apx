    button add-customer (
        buttonName: ADD_CUSTOMER
        label: Add Customer
        layout {
            sequence: 10
            region: @application-title
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 2
                clearCache: 2
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button config-acl (
        buttonName: CONFIG_ACL
        label: Configure ACL
        layout {
            sequence: 10
            region: @acl-warning
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 35
                clearCache: 35
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @customers-report
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: RIR
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 50
            region: @filters
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: definedByDynamicAction
        }
        advanced {
            htmlDomId: reset_button
        }
    )

    dynamicAction perform-search-on-enter (
        name: Perform Search on Enter
        execution {
            sequence: 60
        }
        when {
            event: keydown
            selectionType: items
            items: P59_SEARCH
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.browserEvent.which === 13
        }
        serverSideCondition {
            type: never
        }

        action native-cancel-event (
            action: cancelEvent
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @customer-cards
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @customer-logos
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    dynamicAction reset-search-filters (
        name: Reset Search Filters
        execution {
            sequence: 234
        }
        when {
            event: click
            selectionType: button
            button: @reset-report
        }

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: [
                    P59_SEARCH
                    P59_GEO
                    P59_INDUSTRY
                    P59_CATEGORY
                    P59_STATUS
                    P59_MAX_ROWS
                    P59_REFERENCE_TYPES
                    P59_LOGO_SIZE
                    P59_PRODUCT
                    P59_MARQUEE_CUST
                    P59_SCP_CUST
                    P59_TYPE
                    P59_USE_CASE
                    P59_REFERENCEABLE
                    P59_COUNTRY
                    P59_IMP_PARTNER
                    P59_COMPETITOR
                ]
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-logo-sizes (
        name: Set Logo Sizes
        execution {
            sequence: 254
        }
        when {
            selectionType: items
            items: P59_LOGO_SIZE
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var logo_cards$ = $("#logo_region_cards");
                    var logo_select_val = $v('P59_LOGO_SIZE');
                    
                    if (logo_select_val === 'S') {
                      logo_cards$.addClass("small-logos");
                      logo_cards$.removeClass("medium-logos large-logos"); 
                    } else if (logo_select_val === 'M') {
                      logo_cards$.addClass("medium-logos");
                      logo_cards$.removeClass("small-logos large-logos");
                    } else {
                      logo_cards$.addClass("large-logos");
                      logo_cards$.removeClass("small-logos medium-logos");
                    }
                    ```
            }
            affectedElements {
                selectionType: items
                items: P59_LOGO_SIZE
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction set-logo-sizes-on-region-refresh (
        name: Set Logo Sizes on Region Refresh
        execution {
            sequence: 264
        }
        when {
            event: apexafterrefresh
            selectionType: region
            region: @customer-logos
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var logo_cards$ = $("#logo_region_cards");
                    var logo_select_val = $v('P59_LOGO_SIZE');
                    
                    if (logo_select_val === 'S') {
                      logo_cards$.addClass("small-logos");
                      logo_cards$.removeClass("medium-logos large-logos"); 
                    } else if (logo_select_val === 'M') {
                      logo_cards$.addClass("medium-logos");
                      logo_cards$.removeClass("small-logos large-logos");
                    } else {
                      logo_cards$.addClass("large-logos");
                      logo_cards$.removeClass("small-logos medium-logos");
                    }
                    ```
            }
            affectedElements {
                selectionType: items
                items: P59_LOGO_SIZE
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction toggle-reference-type-checkboxes (
        name: Toggle Reference Type Checkboxes
        execution {
            sequence: 224
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: #reference_check_box
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: $(this.triggeringElement).text() === "Check All"
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $(".reference_types_checkbox input[type=checkbox]").prop('checked',true);
                    $(this.triggeringElement).text('Uncheck All');
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $(".reference_types_checkbox input[type=checkbox]").prop('checked',false);
                    $(this.triggeringElement).text('Check All');
                    ```
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #CARDS, #LOGOS, #CUSTOMERS
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #CARDS, #LOGOS, #CUSTOMERS
            }
            execution {
                sequence: 30
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

    branch (
        name: Go to Getting Started Page
        execution {
            sequence: 10
            point: beforeHeader
        }
        behavior {
            target: {
                page: 1000
                action: resetPagination
            }
        }
        serverSideCondition {
            type: expression
            plsqlExpression: eba_cust_fw.get_preference_value('FIRST_RUN') = 'YES'
        }
    )

)

