    region notifications (
        name: Notifications
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    decode(lower(NOTIFICATION_TYPE),'yellow','warning','red','danger',lower(NOTIFICATION_TYPE)) as ALERT_TYPE,
                    NOTIFICATION_NAME as ALERT_TITLE,
                    NOTIFICATION_DESCRIPTION as ALERT_DESC,
                    '' alert_action
                  from EBA_CUST_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                 order by nvl(DISPLAY_SEQUENCE,0),NOTIFICATION_NAME
                ```
        }
        layout {
            sequence: 1
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from EBA_CUST_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                ```
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/alerts
            templateOptions: #DEFAULT#
        }
        performance {
            maxRowsToProcess: 500
        }
        componentAdvanced {
            stripHtml: true
        }

