    pageItem P96_ID (
        type: hidden
        layout {
            sequence: 10
            region: @referenceability
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P96_REFERENCABLE (
        type: selectList
        label {
            label: Publicly Referenceable
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @referencable
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 20
            region: @referenceability
            slot: regionBody
            alignment: left
            labelColumnSpan: 4
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: REFERENCABLE
