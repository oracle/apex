page 13 (
    name: Customer Usage Metrics
    alias: CUSTOMER-USAGE-METRICS
    title: Customer Usage Metrics
    pageGroup: @customers
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region customer-usage-metrics (
        name: Customer Usage Metrics
        type: calendar
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    trunc(view_timestamp) view_timestamp,
                    trim(to_char(count(*),'999G999G999G990')) ||' Views / '||
                    trim(to_char(count(distinct app_username),'999G999G999G990')) ||' Users' Events
                from
                    eba_cust_clicks
                where
                    cust_id = :P13_ID 
                and
                    view_timestamp > sysdate - 90
                group by trunc(view_timestamp ) 
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        security {
            escapeSpecialChars: false
        }
        settings {
            displayColumn: EVENTS
            startDateColumn: VIEW_TIMESTAMP
            additionalCalendarViews: [
                list
                navigation
            ]
        }
        performance {
            lazyLoading: true
        }
    )

    region hidden-items (
        name: Hidden Items
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P13_CALENDAR_DATE (
        type: hidden
        layout {
            sequence: 20
            region: @customer-usage-metrics
            slot: regionBody
        }
        source {
            type: item
            item: P13_CALENDAR_DATE
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody: return sysdate;
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        comments {
            comments: Generated by Calendar wizard on 11/08/2013
        }
    )

    pageItem P13_CALENDAR_END_DATE (
        type: hidden
        layout {
            sequence: 30
            region: @customer-usage-metrics
            slot: regionBody
        }
        source {
            type: item
            item: P13_CALENDAR_END_DATE
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody: return sysdate+3;
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        comments {
            comments: Generated by Calendar wizard on 11/08/2013
        }
    )

    pageItem P13_CALENDAR_TYPE (
        type: hidden
        layout {
            sequence: 10
            region: @customer-usage-metrics
            slot: regionBody
        }
        source {
            type: item
            item: P13_CALENDAR_TYPE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        comments {
            comments: Generated by Calendar wizard on 11/08/2013
        }
    )

    pageItem P13_ID (
        type: hidden
        layout {
            sequence: 40
            region: @hidden-items
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button return-to-customer (
        buttonName: RETURN_TO_CUSTOMER
        label: Return to Customer
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 50
                items: {
                    P50_ID: &P13_ID.
                }
                clearCache: 50
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

