page 129 (
    name: Customer Issue
    alias: CUSTOMER-ISSUE
    title: Customer Issue
    pageGroup: @customers
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @issues
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region customer-issue (
        name: Customer Issue
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    pageItem P129_CLOSED_STATUS_IDS (
        type: hidden
        layout {
            sequence: 90
            region: @customer-issue
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P129_CUSTOMER_ID (
        type: hidden
        layout {
            sequence: 20
            region: @customer-issue
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: CUSTOMER_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P129_DETAILS (
        type: textarea
        label {
            label: Details
            alignment: left
        }
        layout {
            sequence: 70
            region: @customer-issue
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: DETAILS
            used: always
        }
    )

    pageItem P129_ID (
        type: hidden
        layout {
            sequence: 10
            region: @customer-issue
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P129_ISSUE_TYPE (
        type: selectList
        label {
            label: Issue Type
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @issue-types
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 40
            region: @customer-issue
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            type: databaseColumn
            databaseColumn: ISSUE_TYPE
            used: always
        }
    )

    pageItem P129_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        layout {
            sequence: 30
            region: @customer-issue
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            width: 72
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: NAME
            used: always
        }
    )

    pageItem P129_PRODUCT_ID (
        type: selectList
        label {
            label: Product
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @products
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 60
            region: @customer-issue
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: PRODUCT_ID
            used: always
        }
    )

    pageItem P129_RESOLUTION (
        type: textarea
        label {
            label: Resolution
            alignment: left
        }
        layout {
            sequence: 80
            region: @customer-issue
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: RESOLUTION
            used: always
        }
    )

    pageItem P129_STATUS_ID (
        type: selectList
        label {
            label: Status
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @issue-statuses
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 50
            region: @customer-issue
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            type: databaseColumn
            databaseColumn: STATUS_ID
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_retval number;
                begin
                    select id into l_retval from eba_cust_issue_statuses where open_yn = 'Y' and rownum = 1;
                    return l_retval;
                end;
                ```
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Issue
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P129_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P129_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P129_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction show-hide-resolution (
        name: Show/Hide Resolution
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P129_STATUS_ID
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: $v('P129_CLOSED_STATUS_IDS').indexOf($v('P129_STATUS_ID')) > 0
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: P129_RESOLUTION
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P129_RESOLUTION
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P129_RESOLUTION
            }
            execution {
                sequence: 10
            }
        )

    )

    computation p129-closed-status-ids (
        itemName: P129_CLOSED_STATUS_IDS
        execution {
            sequence: 10
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_retval varchar2(4000);
                begin
                    for c1 in
                    (
                        select
                            id
                        from
                            eba_cust_issue_statuses
                        where
                            open_yn = 'N'
                    )
                    loop
                        l_retval := l_retval || '"' || c1.id || '",';
                    end loop;
                    l_retval := rtrim(l_retval,', ');
                    return l_retval;
                end;
                ```
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 2564641525765374200
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process fetch-row-from-eba-cust-issues (
        name: Fetch Row from EBA_CUST_ISSUES
        type: autoRowFetch
        source {
            tableName: EBA_CUST_ISSUES
            pkColumn: ID
            pkItem: P129_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 2564640308365374199
        }
    )

    process process-row-of-eba-cust-issues (
        name: Process Row of EBA_CUST_ISSUES
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_ISSUES
            pkColumn: ID
            pkItem: P129_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        advanced {
            executionMappingIdentifier: 2564640670175374199
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 2564641072952374200
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

