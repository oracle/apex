page 105 (
    name: Use Case Details
    alias: USE-CASE-DETAILS
    title: Use Case Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            //-->
            </script>
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }
    config {
        buildOption: @customer-use-case
    }

    region audit-information (
        name: Audit Information
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P105_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 30
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region customer-use-case-code (
        name: Customer Use Case Code
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P105_CREATED (
        type: displayOnly
        label {
            label: <b>Created On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 50
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Customer Type was created.
        }
    )

    pageItem P105_CREATED_BY (
        type: displayOnly
        label {
            label: <b>Created By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 60
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who created this Customer Type.
        }
    )

    pageItem P105_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 40
            region: @customer-use-case-code
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
            height: 4
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: DESCRIPTION
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: Enter short description.
        }
    )

    pageItem P105_ID (
        type: hidden
        layout {
            sequence: 10
            region: @customer-use-case-code
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P105_IS_ACTIVE (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Active;Y
            displayExtraValues: false
        }
        layout {
            sequence: 30
            region: @customer-use-case-code
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: IS_ACTIVE
            used: always
        }
        default {
            type: expression
            plsqlExpression: case when :P105_ID is null then 'Y' end;
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P105_UPDATED (
        type: displayOnly
        label {
            label: <b>Updated On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 70
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Customer Type details was last Updated.
        }
    )

    pageItem P105_UPDATED_BY (
        type: displayOnly
        label {
            label: <b>Updated By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 80
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who last updated the Customer Type Details.
        }
    )

    pageItem P105_USE_CASE (
        type: textField
        label {
            label: Use Case
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @customer-use-case-code
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 48
        }
        validation {
            valueRequired: true
            maxLength: 60
        }
        source {
            type: databaseColumn
            databaseColumn: USE_CASE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: A Use Case can be associated with each customer.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &LAST_VIEW.
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Add Use Case Code
        layout {
            sequence: 40
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P105_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P105_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P105_ID
        }
    )

    validation check-dependencies (
        name: Check Dependencies
        execution {
            sequence: 20
        }
        validation {
            type: noRowsReturned
            sqlQuery: Select 1 from eba_cust_customers where type_id = :P105_ID and rownum = 1
        }
        error {
            errorMessage: Cannot Delete this Type, Customers exists with this Type.
            associatedItem: @P105_USE_CASE
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    validation p105-use-case-unique (
        name: P105_USE_CASE unique
        execution {
            sequence: 10
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_cust_use_case
                where upper(use_case) = upper(:P105_TYPE)
                    and (:P105_ID is null or id <> :P105_ID )
                ```
        }
        error {
            errorMessage: #LABEL# already exists.
            associatedItem: @P105_USE_CASE
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 336881150445043943
        }
    )

    process fetch-row-from-eba-cust-use-case (
        name: Fetch Row from EBA_CUST_USE_CASE
        type: autoRowFetch
        source {
            tableName: EBA_CUST_USE_CASE
            pkColumn: ID
            pkItem: P105_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 17125328983437825073
        }
    )

    process load-data (
        name: Load data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'HOME' then
                   :LAST_VIEW := 100 ;
                else
                   :LAST_VIEW := 104 ;
                end if;
                ```
        }
        execution {
            sequence: 40
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 17125330243100825075
        }
    )

    process process-row-of-eba-cust-use-case (
        name: Process Row of EBA_CUST_USE_CASE
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_USE_CASE
            pkColumn: ID
            pkItem: P105_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_CUST_TYPE.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17125329442133825074
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17125329774005825075
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

