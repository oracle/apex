    process count-clicks (
        name: Count Clicks
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_cust_clicks (cust_id) values (:P145_ID);
                delete from eba_cust_clicks where view_timestamp < (sysdate - 90);
                commit;
                ```
        }
        execution {
            sequence: 60
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 18166683398455540212
        }
    )

)

