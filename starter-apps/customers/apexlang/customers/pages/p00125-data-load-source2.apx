page 125 (
    name: Data Load Source
    alias: DATA-LOAD-SOURCE2
    title: Data Load Source
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            function set_item()
            {
            $x('P125_COPY_PASTE').value= $v('P125_SAMPLE_DATA');
            $x('P125_SEPARATOR').value= ',';
            $s('P125_FIRST_ROW', 'Y');
            }
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: "<p>This wizard allows the uploading of customer data into this application. Two options are provided to upload data, by uploading a comma separated file (.CSV), or to copy and paste data directly into the page.  The second step maps database column names with the uploaded data.  The third step, shows the data after lookups keys have been detected and validated.  Customer names that match are updated, new customers are added.  Statuses, types, and/or categories that do not match are not inserted or updated. They are ignored.</p> "
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region data-load-process-train (
        name: Data Load Process Train
        type: list
        source {
            list: @data-load-process-train-customers-3
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/wizard-container
            templateOptions: [
                #DEFAULT#
                t-Wizard--hideStepsXSmall
            ]
        }
        advanced {
            regionDisplaySelector: true
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            listTemplate: @/wizard-progress
            templateOptions: [
                #DEFAULT#
                t-WizardSteps--displayLabels
            ]
        }
    )

    region data-load-source (
        name: Data Load Source
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
        }
        settings {
            outputAs: text
        }
    )

    region globalization (
        name: Globalization
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
        }
        settings {
            outputAs: text
        }
    )

    region loading-data-from-spreadsheets (
        name: Loading Data From Spreadsheets
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>To load or update customer data from a spreadsheet follow the following instructions.</p> 
                
                
                <ol>
                <li>Organize data in a spreadsheet with column headings of "Customer Name", "Summary", "Category", "Status", "Type", and so forth. </li>
                
                <li>If you have additional attributes you want to load you can load these into custom attributes.  Simply add these columns as well and you can map them to custom attributes in the next step of the data loading wizard.</li>
                
                <li>Ensure the Categories and Status values match the categories defined in this application.  Administrators of this application can define categories and status values.  The current values are displayed on this page for reference.</li>
                
                <li>Once you have your data organized in your spreadsheet you can export the data to CSV format (recommended for larger data sets), or simply cut and paste the data (including column headings) into the text field on this page.</li>
                
                <li>Follow the wizard and load your data.</li>
                </ol>
                
                
                <p>Custom attribute data, data that this application does not natively track, can be loaded into custom attribute fields with character, number and date data types.  To have this data show about customers, Application administrators can define these custom attributes from the administration page.</p>
                ```
        }
        layout {
            sequence: 30
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--noBorder
                t-Region--scrollBody
            ]
            cssClasses: infoTextRegion
        }
    )

    region loading-sample-data (
        name: Loading Sample Data
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Click the <strong>Try Sample Data</strong> button to test data loading functionality.  The sample data has 5 columns, 4 of which match the customer data structures.  The location can be used to demonstrate extensibility via flexible attributes.</p> 
                </p>
                
                <table summary="sample data" class="uReport uReportStandard">
                <thead>
                <tr>
                <th>Customer Name</th>
                <th>Summary</th>
                <th>Category</th>
                <th>Location</th>
                <th>Status</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                <td>Altiris</td>
                <td>Software</td>
                <td>Corporate</td>
                <td>New York NY</td>
                <td>Partner</td>
                </tr>
                
                <tr>
                <td>Cephalon</td>
                <td>biotechnology</td>
                <td>Corporate</td>
                <td>San Francisco</td>
                <td>Unknown</td>
                </tr>
                
                <tr>
                <td>Euronet Worldwide</td>
                <td>banking software</td>
                <td>Corporate</td>
                <td>-</td>
                <td>Unknown</td>
                </tr>
                
                <tr>
                <td>Illumina</td>
                <td>biotechnology equipment</td>
                <td>Corporate</td>
                <td>-</td>
                <td>Customer</td>
                </tr>
                </tbody>
                </table>
                ```
        }
        layout {
            sequence: 50
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region valid-customer-categories (
        name: Valid Customer Categories
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select category,
                    description,
                    decode(is_active,'Y',:ACTIVE_MSG,:INACTIVE_MSG) Status
                from eba_cust_categories
                order by upper(category)
                ```
        }
        layout {
            sequence: 80
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        headerAndFooter {
            headerText: <p>Customer categories must be one of the valid values from the list below.  Application administrators can extend this list of values from the administrative console.</p>
        }
        reportLayout {
            numberOfRows: 1500
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CATEGORY (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Category
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column DESCRIPTION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column STATUS (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

    )

    region valid-customer-statuses (
        name: "Valid Customer Statuses "
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select status customer_status,
                    description,
                    decode(is_active,'Y',:ACTIVE_MSG,:INACTIVE_MSG) status
                from eba_cust_status
                order by upper(status)
