    dynamicAction toggle-reference-type-checkboxes (
        name: Toggle Reference Type Checkboxes
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: #reference_check_box
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: $(this.triggeringElement).text() === "Check All"
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $(".reference_types_checkbox input[type=checkbox]").prop('checked',true);
                    $(this.triggeringElement).text('Uncheck All');
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $(".reference_types_checkbox input[type=checkbox]").prop('checked',false);
                    $(this.triggeringElement).text('Check All');
                    ```
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #CARDS, #LOGOS, #CUSTOMERS
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: #CARDS, #LOGOS, #CUSTOMERS
            }
            execution {
                sequence: 30
                fireWhenEventResultIs: false
                fireOnInit: false
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

    process load-data (
        name: Load Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'REPORTS' then 
                    :LAST_VIEW := 20;
                else
                    :LAST_VIEW := 30 ;
                end if;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 17819283955657971321
        }
        serverSideCondition {
            type: never
        }
    )

    process reset-pagination (
        name: Reset Pagination
        type: resetPagination
        execution {
            sequence: 10
        }
        error {
            errorMessage: Unable to reset pagination.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17798794559773218133
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: Go,P1_REPORT_SEARCH,RESET
        }
    )

    process set-filters-for-redirect (
        name: Set Filters for Redirect
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                :P1_CATEGORY := :P1_CATEGORY;
                :P1_GEO := :P1_GEO;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 2013620086982979782
        }
    )

    branch (
        name: Go To Geographies
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 85
                items: {
                    P85_CATEGORY: &P1_CATEGORY.
                }
                action: resetPagination
            }
        }
        serverSideCondition {
            whenButtonPressed: @view-geo
        }
    )

    branch (
        name: Go to Categories
        execution {
            sequence: 20
        }
        behavior {
            target: {
                page: 32
                items: {
                    P32_CATEGORY: &P1_CATEGORY.
                    P32_GEO: &P1_GEO.
                }
                action: resetPagination
            }
        }
        serverSideCondition {
            whenButtonPressed: @view-cats
        }
    )

    branch (
        name: Go To Page 1
        execution {
            sequence: 30
        }
        behavior {
            target: {
                page: 1
                successMessage: false
            }
            saveStateBeforeBranching: true
        }
    )

)

