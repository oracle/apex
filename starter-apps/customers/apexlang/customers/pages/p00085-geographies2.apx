page 85 (
    name: Geographies
    alias: GEOGRAPHIES2
    title: Geographies
    pageGroup: @customers
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region customers-by-geography (
        name: Customers by Geography
        type: chart
        source {
            pageItemsToSubmit: P85_CATEGORY
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
            cssClasses: scrollable-region
        }
        config {
            buildOption: @geography
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            show: false
        }

        series geography (
            name: Geography
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select group_name, group_id, cnt, group_name || ' ('|| cnt || ')' tooltip
                    from (select  
                       nvl(geography_name,'Not Defined') group_name,
                       g.id group_id,
                       count(*) cnt
                    from   
                       eba_cust_customers a, 
                       eba_cust_geographies g
                    where a.geography_id = g.id (+)  and 
                          (NVL(:P85_CATEGORY,0) = 0 or a.CATEGORY_ID = :P85_CATEGORY)
                    group by nvl(geography_name,'Not Defined'), g.id
                    order by 3 desc)
                    ```
                pageItemsToSubmit: P85_CATEGORY
            }
            columnMapping {
                label: GROUP_NAME
                value: CNT
                customTooltip: TOOLTIP
            }
            link {
                type: redirectThisApp
                target: {
                    page: 59
                    items: {
                        P59_GEO: &GROUP_ID.
                        IR_GEOGRAPHY_NAME: &GROUP_NAME.
                        P59_CATEGORY: &P85_CATEGORY.
                    }
                    clearCache: RIR
                }
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

    pageItem P85_CATEGORY (
        type: selectList
        label {
            label: Category
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @cat
            nullDisplayValue: - All -
            nullReturnValue: 0
        }
        layout {
            sequence: 10
            region: @button-bar
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: staticValue
            staticValue: 0
        }
        default {
            type: static
            staticValue: 0
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction set-cat (
        name: set cat
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P85_CATEGORY
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @customers-by-geography
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

