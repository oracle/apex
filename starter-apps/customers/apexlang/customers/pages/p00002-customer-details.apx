    pageItem P2_REFERENCE_TYPES (
        type: checkboxGroup
        label {
            label: Reference Types
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @reference-types
            displayExtraValues: false
        }
        layout {
            sequence: 480
            region: @customer-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQueryMultipleValues
            sqlQuery:
                ```sql
                select listagg(rt.id,':') within group (order by rt.reference_type) types
                from eba_cust_reference_types rt,
                    eba_cust_customer_reftype_ref ref
                where rt.id = ref.reference_type_id
                    and ref.customer_id = :P2_ID
                ```
        }
        serverSideCondition {
            type: itemIsNull
            item: P2_ID
        }
        help {
            helpText: In what ways would this customer be willing to be a reference?
        }
        config {
            buildOption: @customer-referencability
        }
    )

