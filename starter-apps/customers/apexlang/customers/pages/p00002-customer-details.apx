        source {
            type: databaseColumn
            databaseColumn: STRATEGIC_CUSTOMER_PROGRAM_YN
            used: always
        }
        default {
            type: static
            staticValue: N
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        config {
            buildOption: @strategic-customer-program
        }
    )

    pageItem P2_SUMMARY (
        type: textarea
