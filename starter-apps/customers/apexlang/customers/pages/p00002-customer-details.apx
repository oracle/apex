page 2 (
    name: Customer Details
    alias: CUSTOMER-DETAILS
    title: Customer Details
    pageGroup: @customers
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            function open_url(url) {
                window.open(url);
                return ;
            }
            
            //-->
            </script>
            <style>
            .shuttle select {width: 350px}
            </style>
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumbs (
        name: Breadcrumbs
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb-2
        }
        layout {
            sequence: 60
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region classification (
        name: Classification
        type: staticContent
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region customer-details (
        name: Customer Details
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
                t-Form--stretchInputs
            ]
        }
        advanced {
            htmlDomId: CUSTOMERS
        }
    )

    region logo (
        name: Logo
        type: staticContent
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region project (
        name: Project
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: false
        }
    )

    pageItem P2_ANNUAL_RECURRING_REVENUE (
        type: numberField
        label {
            label: ARR
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 180
            region: @customer-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            type: databaseColumn
            databaseColumn: ANNUAL_RECURRING_REVENUE
            used: always
        }
        help {
            helpText: Annual Recurring Revenue (ARR) is a measure of revenue; it is typically used by companies that sell subscriptions or services.
        }
        config {
            buildOption: @annual-recurring-revenue-arr
        }
    )

    pageItem P2_CATEGORY_ID (
        type: selectList
        label {
            label: Category
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @active-categories-p
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        layout {
            sequence: 60
            region: @customer-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: CATEGORY_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P2_COUNTRY_ID (
        type: selectList
        label {
            label: Country
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @countries-p
            displayExtraValues: false
            nullDisplayValue: - Select -
        }
        cascadingLov {
            parentItems: P2_GEOGRAPHY_ID
        }
        layout {
            sequence: 90
            region: @customer-details
            slot: regionBody
            alignment: left
            startNewRow: false
            labelColumnSpan: 1
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: COUNTRY_ID
            used: always
        }
        config {
            buildOption: @countries
        }
    )

    pageItem P2_CURRENCY (
        type: textField
        label {
            label: Currency
            alignment: left
        }
        layout {
            sequence: 190
            region: @customer-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 20
        }
        source {
            type: databaseColumn
            databaseColumn: CURRENCY
            used: always
        }
        default {
            type: static
            staticValue: USD
        }
        help {
            helpText: Monitory values are to be in this currency.  Default is United States Dollars (USD).
        }
    )

    pageItem P2_CUSTOMER_ACCOUNT_NUMBER (
        type: textField
        label {
            label: Account Number
            alignment: left
        }
        layout {
            sequence: 180
            region: @classification
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: CUSTOMER_ACCOUNT_NUMBER
            used: always
        }
    )

    pageItem P2_CUSTOMER_NAME (
        type: textField
        label {
            label: Customer Name
            alignment: left
        }
        layout {
            sequence: 30
            region: @customer-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: CUSTOMER_NAME
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P2_CUSTOMER_PROFILE (
        type: textarea
        label {
            label: Customer Description
            alignment: left
        }
        layout {
            sequence: 210
            region: @customer-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 80
            height: 5
        }
        validation {
            maxLength: 99999999999
        }
        source {
            type: databaseColumn
            databaseColumn: CUSTOMER_PROFILE
            used: always
        }
    )

    pageItem P2_DISCOUNT_LEVEL (
        type: numberField
        label {
            label: Discount
            alignment: left
        }
        settings {
            minValue: 0
            maxValue: 100
