    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumbs
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &LAST_VIEW.
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Add Customer
        layout {
            sequence: 40
            region: @breadcrumbs
            slot: create
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P2_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @breadcrumbs
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @breadcrumbs
            slot: create
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    validation facebook-must-be-a-url-starting-with-http (
        name: Facebook Must Be a URL starting with http
        execution {
            sequence: 70
        }
        validation {
            plsqlExpression: substr(:P2_FACEBOOK, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P2_FACEBOOK
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_FACEBOOK
        }
    )

    validation linkedin-must-be-a-url-starting-with-http (
        name: LinkedIn Must Be a URL starting with http
        execution {
            sequence: 80
        }
        validation {
            plsqlExpression: substr(:P2_LINKEDIN, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P2_LINKEDIN
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_LINKEDIN
        }
    )

    validation no-customer-cycles (
        name: No Customer Cycles
        execution {
            sequence: 40
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from (  select c.id
                        from eba_cust_customers c
                        start with c.id = :P2_PARENT_CUSTOMER_ID
                        connect by prior parent_customer_id = id
                    ) x
                where x.id = :P2_ID
                ```
        }
        error {
            errorMessage: #LABEL# cannot be circular
            associatedItem: @P2_PARENT_CUSTOMER_ID
        }
    )

    validation p2-category-id-must-be-number (
        name: P2_CATEGORY_ID must be number
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNumeric
            item: P2_CATEGORY_ID
        }
        error {
            errorMessage: Category Id must be number.
            associatedItem: @P2_CATEGORY_ID
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

    validation p2-status-id-must-be-number (
        name: P2_STATUS_ID must be number
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNumeric
            item: P2_STATUS_ID
        }
        error {
            errorMessage: Status Id must be number.
            associatedItem: @P2_STATUS_ID
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

    validation twitter-must-be-a-url-starting-with-http (
        name: Twitter Must Be a URL starting with http
        execution {
            sequence: 90
        }
        validation {
            plsqlExpression: substr(:P2_TWITTER, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P2_TWITTER
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_TWITTER
        }
    )

    validation unique-account-number (
        name: Unique Account Number
        execution {
            sequence: 30
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_cust_customers
                where id <> :P2_ID
                    and customer_account_number = :P2_CUSTOMER_ACCOUNT_NUMBER
                ```
        }
        error {
            errorMessage: #LABEL# already associated with another customer.
            associatedItem: @P2_CUSTOMER_ACCOUNT_NUMBER
        }
    )

    validation valid-characters-in-tags (
        name: Valid Characters in Tags
        execution {
            sequence: 50
        }
        validation {
            plsqlExpression: "not regexp_like( :P2_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P2_TAGS
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    validation website-must-be-a-url-starting-with-http (
        name: Website Must Be a URL starting with http
        execution {
            sequence: 60
        }
        validation {
            plsqlExpression: substr(:P2_WEB_SITE, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P2_WEB_SITE
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P2_WEB_SITE
        }
    )

    process fetch-row-from-eba-cust-customers (
        name: Fetch Row from EBA_CUST_CUSTOMERS
        type: autoRowFetch
        source {
            tableName: EBA_CUST_CUSTOMERS
            pkColumn: ID
            pkItem: P2_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 17798800069712218306
        }
    )

    process process-row-of-eba-cust-customers (
        name: Process Row of EBA_CUST_CUSTOMERS
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_CUSTOMERS
            pkColumn: ID
            pkItem: P2_ID
            returnKeyIntoItem: P2_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_CUST_CUSTOMERS.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17798800170231218306
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    branch (
        name: Go To CUSTOMERS after delete
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: CUSTOMERS
                successMessage: false
            }
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    branch (
        name: goto edit customer on create
        execution {
            sequence: 20
        }
        behavior {
            target: {
                page: 50
                items: {
                    P50_ID: &P2_ID.
                }
                clearCache: 50
                action: resetPagination
                successMessage: false
            }
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    branch (
        execution {
            sequence: 30
        }
        behavior {
            target: {
                page: &LAST_VIEW.
                request: &P2_REQUEST.
            }
            saveStateBeforeBranching: true
        }
    )

)

