        source {
            type: expression
            plsqlExpression: '<a href="'||apex_util.prepare_url('f?p=&APP_ID.:50:&APP_SESSION.:::50:P50_ID:'||:P37_CUSTOMER_ID)||'">'||apex_escape.html(:P37_CUSTOMER_COMPANY)||'</a>'
