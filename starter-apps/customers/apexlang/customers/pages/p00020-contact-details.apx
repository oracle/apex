    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @contact-details-2
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 18
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Add Customer Contact
        layout {
            sequence: 40
            region: @contact-details-2
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P20_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @contact-details-2
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P20_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @contact-details-2
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P20_ID
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    validation fb-url-must-start-with-http (
        name: FB URL must start with http
        execution {
            sequence: 30
        }
        validation {
            plsqlExpression: substr(:P20_FACEBOOK, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P20_FACEBOOK
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P20_FACEBOOK
        }
    )

    validation linkedin-url-must-start-with-http (
        name: LINKEDIN URL must start with http
        execution {
            sequence: 40
        }
        validation {
            plsqlExpression: substr(:P20_LINKEDIN, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P20_LINKEDIN
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P20_LINKEDIN
        }
    )

    validation p20-name-not-null (
        name: P20_NAME Not Null
        execution {
            sequence: 10
        }
        validation {
            type: functionBodyReturningBoolean
            plsqlFunctionBody: return trim(:P20_NAME) is not null
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P20_NAME
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    validation twitter-url-must-start-with-http (
        name: Twitter URL must start with http
        execution {
            sequence: 50
        }
        validation {
            plsqlExpression: substr(:P20_TWITTER, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P20_TWITTER
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P20_TWITTER
        }
    )

    validation valid-characters-in-tags (
        name: Valid Characters in Tags
        execution {
            sequence: 20
        }
        validation {
            plsqlExpression: "not regexp_like( :P20_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P20_TAGS
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process fetch-row-from-eba-cust-contacts (
        name: Fetch Row from EBA_CUST_CONTACTS
        type: autoRowFetch
        source {
            tableName: EBA_CUST_CONTACTS
            pkColumn: ID
            pkItem: P20_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 17804317739846366580
        }
    )

    process load-data (
        name: Load Data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'CONTACTS' then
                   eba_cust.eba_cust_add_views_log('CON',:P20_ID);
                end if ;
                ```
        }
        execution {
            sequence: 40
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 17825911953681978723
        }
    )

    process process-row-of-eba-cust-contacts (
        name: Process Row of EBA_CUST_CONTACTS
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_CONTACTS
            pkColumn: ID
            pkItem: P20_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_CUST_CONTACTS.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17804317953685366580
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 17804318152872366580
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 18
            }
            saveStateBeforeBranching: true
        }
    )

)

