    pageItem P63_ERROR_COUNT (
        type: displayOnly
        label {
            label: Failed Row(s):
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 30
            region: @data-load-results
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: class="fielddata"
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select count(*) c from apex_collections where collection_name = 'LOAD_CONTENT' and c047 = 'FAILED'
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P63_INSERT_COUNT (
        type: displayOnly
        label {
            label: Inserted Row(s):
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 10
            region: @data-load-results
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: class="fielddata"
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P63_UPDATE_COUNT (
        type: displayOnly
        label {
            label: Updated Row(s):
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 20
            region: @data-load-results
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: class="fielddata"
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @breadcrumb
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 60
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button finish (
        buttonName: FINISH
        label: Finish
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 18
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 20
            region: @breadcrumb
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 62
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: never
        }
    )

)

