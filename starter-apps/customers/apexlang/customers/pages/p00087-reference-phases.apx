        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 23934369 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn DESCRIPTION (
                sequence: 2
            )

            displayColumn DISPLAY_SEQUENCE (
                sequence: 6
            )

            displayColumn IS_AN_ACTIVE_REFERENCE (
                sequence: 3
            )

            displayColumn STATUS (
                sequence: 1
            )

            displayColumn UPDATED (
                sequence: 4
            )

            displayColumn UPDATED_BY (
                sequence: 5
            )

            sort (
                column: STATUS
                sort {
