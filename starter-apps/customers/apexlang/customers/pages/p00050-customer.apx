                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
            cssClasses: t-Report--cleanBorders
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No products found
        }
        componentAdvanced {
            stripHtml: true
        }

