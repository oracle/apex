    dynamicAction reload-issues (
        name: Reload Issues
        execution {
            sequence: 140
        }
        when {
            event: apexafterclosedialog
            selectionType: jQuerySelector
            jquerySelector: #listPageActions, #rptIssues
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId == "129"
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select null from eba_cust_issues where customer_id = :P50_ID
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    location.reload();
                    $('li.apex-rds-item a')[3].click();
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation customer (
        itemName: CUSTOMER
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery: select apex_escape.html(customer_name) from eba_cust_customers where id = :P50_ID
        }
    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 50
        }
    )

    process count-clicks (
        name: Count Clicks
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_cust_clicks (cust_id) values (:P50_ID);
                delete from eba_cust_clicks where view_timestamp < (sysdate - 90);
                commit;
                ```
        }
        execution {
            sequence: 60
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 14932015987919223725
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 50
                items: {
                    P50_ID: &P50_ID.
                }
            }
        }
        comments {
            comments: Created 11-JAN-2012 16:02 by MIKE
        }
    )

)

