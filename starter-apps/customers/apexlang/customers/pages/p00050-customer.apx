    region usage-metrics-90-days (
        name: Usage Metrics - 90 days
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select
                    count(*) c,
                    'Views' l,
                    1 disp
                from
                    eba_cust_clicks
                where
                    cust_id = :P50_ID 
                and
                    view_timestamp > sysdate - 90
                UNION
                select
                    count(distinct app_username)  c,
                    'Users' l,
                    2 disp
                from
                    eba_cust_clicks
                where
                    cust_id = :P50_ID 
                and
                    view_timestamp > sysdate - 90
                order by disp    
                ```
        }
        layout {
            sequence: 160
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        settings {
            badgeStyle: circular
            value: C
            bottomLabel: L
            linkTarget: {
                page: 13
                items: {
                    P13_ID: &P50_ID.
                }
                clearCache: 13
            }
            layout: 2Columns
        }
    )

