    region tags (
        name: Tags
        type: plugin/tagCloud
        source {
            sqlQuery:
                ```sql
                select
                    t.tag, 
                    (select TAG_COUNT from eba_cust_tags_sum x where x.tag = t.tag) tag_count
                from
                    EBA_CUST_TAGS t,
                    eba_cust_tags_type_sum s
                where
                    t.content_id = :P50_ID
                and
                    s.tag = t.tag
                and
                    s.content_type = 'CUSTOMER'
                ```
        }
        layout {
            sequence: 130
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            linkTarget: {
                page: 59
                items: {
                    IRC_TAGS: #TAG#
                    P59_DISPLAY_AS: REPORT
                }
                clearCache: RIR
            }
        }
        messages {
            whenNoDataFound: No tags found.
        }
    )

    region updates (
        name: Updates
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                    '' class, --use grayComment for gray look
                    'Note' note_type,
                    null as attribute_1,
                    null as attribute_2,
                    null as attribute_3,
                    null as attribute_4,
                    replace(apex_escape.html(dbms_lob.substr(n.note,2000,1)),chr(10),'<br />') comment_text,
                    lower(n.created_by) user_name,
                    substr(n.created_by,0,2) user_icon,
                    'u-color-'|| (ora_hash(n.created_by,44) + 1) icon_modifier,
                    apex_util.get_since(NVL(n.note_date, nvl(n.updated, n.created))) ||' - '||to_char(NVL(n.note_date, nvl(n.updated, n.created)),'Day DD-MON-YYYY HH24:MI') comment_date,
                    'Edit' as link,
                    'Edit' as actions,
                    n.created,
                    n.id note_id
                from eba_cust_notes n,
                    eba_cust_contacts c
                where n.customer_id = :P50_ID 
                    and n.contact_id = c.id (+)
                order by 11 desc
                ```
            pageItemsToSubmit: P50_ID
        }
        layout {
            sequence: 120
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            htmlDomId: rptUpdates
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No updates found
        }
        componentAdvanced {
            stripHtml: true
        }
