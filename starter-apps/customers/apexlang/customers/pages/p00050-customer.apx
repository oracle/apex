    region customer-account (
        name: Customer Account
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select
                  'Discount Level' label,
                  to_char(nvl(DISCOUNT_LEVEL,0),'999G999G999G999G999G999G990') || '%' return_val
                from
                   eba_cust_customers
                where 
                   id = :P50_ID and nvl(DISCOUNT_LEVEL,0) != 0
                union all
                select
                  'Total Contract Value (TCV)' label,
                  '$' || to_char(nvl(TOTAL_CONTRACT_VALUE,0),'999G999G999G999G999G999G990') return_val
                from
                   eba_cust_customers
                where 
                   id = :P50_ID and nvl(TOTAL_CONTRACT_VALUE,0) != 0
                union all
                select
                  'Annual Recurring Revenue (ARR)' label,
                  '$' || to_char(nvl(annual_recurring_revenue,0),'999G999G999G999G999G999G990') return_val
                from
                   eba_cust_customers
                where 
                   id = :P50_ID and nvl(annual_recurring_revenue,0) != 0
                ```
        }
        layout {
            sequence: 30
            slot: masterDetail
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        settings {
            value: RETURN_VAL
            bottomLabel: LABEL
        }
    )

    region customer-added (
        name: Customer Added
        type: plugin/miniCalendar
        source {
            sqlQuery:
                ```sql
                select created, 'Customer Added' lbl
                from eba_cust_customers
                where id = :P50_ID
                ```
        }
        layout {
            sequence: 170
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hiddenOverflow
            ]
        }
        serverSideCondition {
            type: never
        }
        settings {
            dateColumn: CREATED
            labelColumn: LBL
        }
    )

    region customer-summary (
        name: Customer Summary
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                begin
                
                for c1 in (
                select
                   summary
                from
                   eba_cust_customers
                where
                   id = :P50_ID
                ) loop
                
                sys.htp.p('<p>'||apex_escape.html(c1.summary)||'</p>');
                
                end loop;
                
                end;
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            cssClasses: margin-md
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from eba_cust_customers
                 where id = :P50_ID
                   and summary is not null
                ```
        }
    )

    region customer-validations (
        name: Customer Validations
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                	lower(verified_by) as validated_by,
                        created last_validated,
                	created validation_date,
                	verification_comment
                from
                	eba_cust_verifications
                where
                	cust_id = :P50_ID
                order by
                	created desc
                ```
        }
        layout {
            sequence: 180
            slot: dialogsDrawersAndPopups
        }
        appearance {
            template: @/inline-dialog
            templateOptions: [
                #DEFAULT#
                js-dialog-size600x400
            ]
        }
        advanced {
            htmlDomId: view_validations
        }
        reportLayout {
            numberOfRows: 4
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No validations have been recorded
        }
        componentAdvanced {
            stripHtml: true
        }

