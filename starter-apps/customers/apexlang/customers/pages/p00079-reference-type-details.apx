page 79 (
    name: Reference Type Details
    alias: REFERENCE-TYPE-DETAILS
    title: Reference Type Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            //-->
            </script>
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-information (
        name: Audit Information
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P79_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region reference-type-details (
        name: Reference Type Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P79_CREATED (
        type: displayOnly
        label {
            label: <b>Created On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 30
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Contact Type was created.
        }
    )

    pageItem P79_CREATED_BY (
        type: displayOnly
        label {
            label: <b>Created By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 40
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who created this Contact Type.
        }
    )

    pageItem P79_ID (
        type: hidden
        layout {
            sequence: 1
            region: @reference-type-details
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P79_IS_ACTIVE (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Active;Y
            displayExtraValues: false
        }
        layout {
            sequence: 30
            region: @reference-type-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: IS_ACTIVE
            used: always
        }
        default {
            type: expression
            plsqlExpression: case when :P79_ID is null then 'Y' end;
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P79_REFERENCE_TYPE (
        type: textField
        label {
            label: Reference Type
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @reference-type-details
            slot: regionBody
            alignment: left
            columnSpan: 8
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 48
        }
        validation {
            valueRequired: true
            maxLength: 60
        }
        source {
            type: databaseColumn
            databaseColumn: REFERENCE_TYPE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: Contact Types are used to categorize Contacts.
        }
    )

    pageItem P79_UPDATED (
        type: displayOnly
        label {
            label: <b>Updated On:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 50
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the Contact Type details was last Updated.
        }
    )

    pageItem P79_UPDATED_BY (
        type: displayOnly
        label {
            label: <b>Updated By:</b>
            alignment: left
        }
        settings {
            showLineBreaks: false
            sendOnPageSubmit: false
        }
        layout {
            sequence: 60
            region: @audit-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: UPDATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The User who last updated the Contact Type Details.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create Reference Type
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P79_ID is null 
                and
                (
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Customer Referencability') = 'INCLUDE'
                or
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Product Referencability') = 'INCLUDE'
                )
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P79_ID is not null 
                and
                (
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Customer Referencability') = 'INCLUDE'
                or
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Product Referencability') = 'INCLUDE'
                )
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P79_ID is not null 
                and
                (
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Customer Referencability') = 'INCLUDE'
                or
                APEX_UTIL.GET_BUILD_OPTION_STATUS(
                    P_APPLICATION_ID => :APP_ID,
                    P_BUILD_OPTION_NAME => 'Product Referencability') = 'INCLUDE'
                )
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation p79-reference-type-unique (
        name: P79_REFERENCE_TYPE unique
        execution {
            sequence: 5
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_cust_reference_types
                where upper(reference_type) = upper(:P79_REFERENCE_TYPE)
                    and ( :P79_ID is null or id <> :P79_ID )
                ```
        }
        error {
            errorMessage: #LABEL# already exists.
            associatedItem: @P79_REFERENCE_TYPE
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 1611698333399273280
        }
    )

    process fetch-row-from-eba-cust-reference-types (
        name: Fetch Row from EBA_CUST_REFERENCE_TYPES
        type: autoRowFetch
        source {
            tableName: EBA_CUST_REFERENCE_TYPES
            pkColumn: ID
            pkItem: P79_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 15640312457071460317
        }
    )

    process load-data (
        name: Load data
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                if :REQUEST = 'HOME' then
                   :LAST_VIEW := 100 ;
                else
                   :LAST_VIEW := 78 ;
                end if;
                ```
        }
        execution {
            sequence: 50
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 15640313698435460319
        }
    )

    process process-row-of-eba-cust-reference-types (
        name: Process Row of EBA_CUST_REFERENCE_TYPES
        type: autoRowProcessing
        target {
            tableName: EBA_CUST_REFERENCE_TYPES
            pkColumn: ID
            pkItem: P79_ID
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_CUST_CONTACT_TYPES.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 15640312855247460318
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 40
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 15640313309503460318
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

)

