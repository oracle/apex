upgradeScript "populate eba_cust_acl_features" (
    execution {
        sequence: 450
    }
    script {
        contentFile: populate-eba-cust-acl-features.sql
    }
    serverSideCondition {
        type: functionBody
        plsqlFunctionBody:
            ```plsql
            declare
                l_cnt    pls_integer;
                l_retval boolean := true;
            begin
                select count(*)
                  into l_cnt
                  from eba_cust_acl_features
                 where authorization_name in ('EDIT_COMPETITORS', 'VIEW_COMPETITORS');
            
                if l_cnt > 0 then
                    l_retval := false;
                end if;
            
                return l_retval;
            end;
            ```
    }
)

