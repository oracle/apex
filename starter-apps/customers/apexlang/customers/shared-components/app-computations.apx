appComputation active-msg (
    itemName: ACTIVE_MSG
    execution {
        sequence: 10
    }
    computation {
        type: expression
        plsqlExpression: htmldb_lang.message('ACTIVE');
    }
)

appComputation application-title (
    itemName: APPLICATION_TITLE
    execution {
        sequence: 10
    }
    computation {
        type: functionBody
        plsqlFunctionBody:
            ```plsql
            declare
                l_app_name varchar2(255);
            begin
                select nvl(preference_value,:APP_NAME)
                  into l_app_name
                  from eba_cust_preferences
                 where preference_name = 'APPLICATION_TITLE';
                return l_app_name;
            exception
                when others then
                    return :APP_NAME;
            end;
            ```
    }
)

