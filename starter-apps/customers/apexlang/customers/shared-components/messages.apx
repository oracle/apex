textMessage BAU_EMAIL_INSTRUCTIONS (
    message {
        text: Enter or copy and paste email addresses separated by commas, semicolons, or new lines. Note that if you copy and paste email addresses from email messages, extraneous text will be filtered out. All email users provided will be added as the selected role. Existing or duplicate email addresses will be ignored.
        language: en
    }
)

