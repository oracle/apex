customAttribute attribute_01 (
    apexlangName: dateColumn
    attribute: 1
    name: Date Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
    appearance {
        sequence: 10
    }
    supports {
        dataTypes: [
            date
            timestamp
            timestampWithTimeZone
            timestampWithLocalTimeZone
        ]
    }
    help {
        helpText: Select the column from the region SQL Query which holds the single date value for the calendar.
    }
)

customAttribute attribute_02 (
    apexlangName: labelColumn
    attribute: 2
    name: Label Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
    appearance {
        sequence: 20
    }
    help {
        helpText: Select the column from the region SQL Query which holds the label for the calendar.
    }
)

