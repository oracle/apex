lov countries (
    name: COUNTRIES
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select country_name as d,
                   id as r
              from EBA_CUST_COUNTRIES
             where display_yn = 'Y'
             order by 1
            ```
    }
)

lov countries-p (
    name: COUNTRIES_P2
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select country_name as d,
                   id as r
              from EBA_CUST_COUNTRIES
             where display_yn = 'Y'
               and region_id = :P2_GEOGRAPHY_ID
             order by 1
            ```
    }
)

lov countries-p-2 (
    name: COUNTRIES_P59
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select country_name as d,
                   id as r
              from EBA_CUST_COUNTRIES
             where display_yn = 'Y'
               and (
                       (nvl(:P59_GEO,0) = 0 and id is not null)
                       or
                       (nvl(:P59_GEO,0)  > 0 and region_id = :P59_GEO)
                   )
             order by 1
            ```
    }
)

lov customers (
    name: CUSTOMERS
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select customer_name d, id r 
            from EBA_CUST_CUSTOMERS
            order by upper(customer_name)
            ```
    }
)

