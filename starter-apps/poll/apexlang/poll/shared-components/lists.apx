list access-control (
    name: Access Control
    config {
        buildOption: @feature-access-control
    }

    entry access-control (
        label: Access Control
        icon {
            imageIconCssClasses: fa-key
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 35
            }
        }
        userDefinedAttributes {
            1: Set level of access for authenticated users of this application
        }
    )

    entry self-service-access-requests (
        label: Self Service Access Requests
        icon {
            imageIconCssClasses: fa-comment-o
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 22
            }
        }
        userDefinedAttributes {
            1: Users without access can ask to be added. Review and approve or decline requests.
            2: &P4_SELF_SRVC_REQ_CNT.
        }
        config {
            buildOption: @self-service-requests
        }
    )

    entry users (
        label: Users
        icon {
            imageIconCssClasses: fa-users
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 10021
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Change access control settings and disable access control
        }
    )

)

