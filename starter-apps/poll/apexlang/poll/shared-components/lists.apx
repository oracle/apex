            imageIconCssClasses: fa-tag
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 30
            }
        }
        userDefinedAttributes {
            1: Manage notification messages displayed on the home page of this application.  Use notifications to alert application users of important information.
            2: &P4_NOTIFICATION_CNT.
        }
    )

    entry remove-extraneous-characters (
        label: Remove Extraneous Characters
        icon {
            imageIconCssClasses: fa-gear
        }
        layout {
            sequence: 80
        }
        link {
