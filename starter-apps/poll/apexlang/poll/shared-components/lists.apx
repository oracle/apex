list code-tables (
    name: Code Tables

    entry build-options (
        label: Build Options
        icon {
            imageIconCssClasses: fa-gear
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 2
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Manage the status of build options. Build options allow application functionality to be included or excluded from an application.  Use build options to factor your application.
            2: &P4_BUILD_OPTION_CNT.
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from apex_application_build_options
                 where application_id = :APP_ID
                ```
        }
    )

    entry manage-sample-data (
        label: Manage Sample Data
        icon {
            imageIconCssClasses: fa-database
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 32
            }
        }
        userDefinedAttributes {
