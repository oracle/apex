page 18 (
    name: Poll History
    alias: POLL-HISTORY
    title: Poll History
    pageGroup: @polls
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/wizard-modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region change-history (
        name: Change History
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select    
                    lower(created_by) || ' ('||apex_util.get_since(created)||')' CREATED,
                    lower(updated_by) || ' ('||apex_util.get_since(UPDATED)||')' updated
                from EBA_QPOLL_POLLS q
                where id = :POLL_ID
                order by 1
                ```
        }
        layout {
            sequence: 30
            slot: wizardBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
                t-Alert--accessibleHeading
            ]
            icon: fa-clock-o
        }
        advanced {
            htmlDomId: change_history
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

    )

    region history (
        name: History
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select '' comment_modifiers, 
                    'Question Update' note_type,
                    replace(initcap(replace(replace(f.column_name,'_ID',null),'_',' ')),chr(10),'<br>') comment_text,
                    ' changed from "'||f.old_value||'"' attribute_1,
                    ' to "'||f.new_value||'"' attribute_2,
                    ' ' attribute_3,
                    ' ' attribute_4,
                    lower(f.changed_by) user_name,
                    apex_util.get_since(f.change_date) comment_date,
                    ' ' link,
                    null update_id,
                    f.change_date,
                    '' actions,
                    upper(
                          decode(instr(replace(f.changed_by,'.',' '),' '),
                                 0, 
                                 substr(f.changed_by,1,2),
                                 substr(f.changed_by,1,1)||substr(f.changed_by,instr(replace(f.changed_by,'.',' '),' ')+1,1)
                           )) user_icon
                from eba_qpoll_history f,
                    eba_qpoll_questions q
                where f.table_name = 'QUESTIONS'
                    and f.component_id = q.id
                    and q.poll_id = :POLL_ID
                    and ( f.column_name != 'QUESTION'
                        or ( f.old_value is not null and f.new_value is not null ) )
                union all
                select  '' comment_modifiers, 
                    'Question Added' comment_type,
                    replace(initcap(replace(replace(f.column_name,'_ID',null),'_',' ')),chr(10),'<br>') comment_text,
                    ' ' attribute_1,
                    ' added "'||f.new_value||'"' attribute_2,
                    ' ' attribute_3,
                    ' ' attribute_4,
                    lower(f.changed_by) user_name,
                    apex_util.get_since(f.change_date) comment_date,
                    ' ' link,
                    null update_id,
                    f.change_date,
                    '' actions,
                    upper(
                          decode(instr(replace(f.changed_by,'.',' '),' '),
                                 0, 
                                 substr(f.changed_by,1,2),
                                 substr(f.changed_by,1,1)||substr(f.changed_by,instr(replace(f.changed_by,'.',' '),' ')+1,1)
                           )) user_icon
                from eba_qpoll_history f
                where f.table_name = 'QUESTIONS'
                    and f.poll_id = :POLL_ID
                    and f.column_name = 'QUESTION'
                    and f.old_value is null
                union all
                select '' comment_modifiers, 
                    'Question Removed' comment_type,
                    replace(initcap(replace(replace(f.column_name,'_ID',null),'_',' ')),chr(10),'<br>') comment_text,
                    ' removed "'||f.old_value||'"' attribute_1,
                    ' ' attribute_2,
                    ' ' attribute_3,
                    ' ' attribute_4,
                    lower(f.changed_by) user_name,
                    apex_util.get_since(f.change_date) comment_date,
                    ' ' link,
                    null update_id,
                    f.change_date,
                    '' actions,
                    upper(
                          decode(instr(replace(f.changed_by,'.',' '),' '),
                                 0, 
                                 substr(f.changed_by,1,2),
                                 substr(f.changed_by,1,1)||substr(f.changed_by,instr(replace(f.changed_by,'.',' '),' ')+1,1)
                           )) user_icon
                from eba_qpoll_history f
                where f.table_name = 'QUESTIONS'
                    and f.poll_id = :POLL_ID
                    and f.column_name = 'QUESTION'
                    and f.new_value is null
                order by 12 desc
                ```
        }
        layout {
            sequence: 20
            slot: wizardBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            htmlDomId: HISTORY
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                from eba_qpoll_history f
                where f.table_name = 'QUESTIONS'
                    and f.poll_id = :POLL_ID
                    and f.column_name = 'QUESTION'
                ```
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
            showNullValuesAs: " - "
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No history found.
        }
        componentAdvanced {
            stripHtml: true
        }

        column ACTIONS (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Actions
            }
            layout {
                sequence: 13
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_1 (
            reportColumnQueryId: 4
