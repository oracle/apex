page 6 (
    name: Purge Email History
    alias: PURGE-EMAIL-HISTORY
    title: Purge Email History
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>Only Access Requests that have been approved or declined will be purged. Those with the status of 'pending' will be retained.</p>
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region purge-email-history (
        name: Purge Email History
        type: staticContent
        source {
            htmlCode: All other logs are kept for 21 days.  Email History is manually maintained.  You can enter 0 to remove all history.
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P6_NBR_DAYS_TO_KEEP (
        type: numberField
        label {
            label: Number of Days to Keep
            alignment: left
        }
        settings {
            minValue: 0
            virtualKeyboard: text
        }
        layout {
            sequence: 10
            region: @purge-email-history
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 5
        }
        validation {
            valueRequired: true
            maxLength: 5
        }
        default {
            type: static
            staticValue: 30
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button purge (
        buttonName: PURGE
        label: Purge Email History
        layout {
            sequence: 20
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cnx (
        name: CNX
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 567790265714869940
        }
    )

    process purge (
        name: Purge
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                delete from eba_qpoll_emails
                 where sent_time < localtimestamp-:P6_NBR_DAYS_TO_KEEP;
                
                eba_qpoll_account.add_application_log (
                   p_activity => 'Purged Email History',
                   p_details  => 'keeping ' || :P6_NBR_DAYS_TO_KEEP || ' days');
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Purged Access Requests.
        }
        error {
            errorMessage: #SQLERRM#
        }
        advanced {
            executionMappingIdentifier: 567790671175869941
        }
        serverSideCondition {
            whenButtonPressed: @purge
        }
    )

)

