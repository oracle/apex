page 59 (
    name: Email History
    alias: EMAIL-HISTORY
    title: Email History
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: <p>If you cannot find an email that you were expecting to see here, check the <a href="f?p=&APP_ID.:34:&APP_SESSION.::NO:34,RIR::">Opt Out User List</a> to see if the user has opted out from receiving &APPLICATION_TITLE. emails.</p>
    }

    region email-history (
        name: Email History
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                	   subject,
                	   sent_time,
                	   lower(sent_by) sent_by,
                	   replace(sent_to,',',', ') sent_to,
                	   'View' view_email,
                       POLL_ID,
                       COMMUNITY_ID,
                       RESPONDENT_ID,
                       (select poll_name from eba_qpoll_polls x where x.id = h.poll_id) poll,
                       nvl((select name from EBA_QPOLL_RESP_COMMUNITIES x where x.id = h.community_id),'Other Invitee') community,
                       (select email from EBA_QPOLL_RESPONDENTS x where x.id = h.respondent_id) invitee,
                       initcap(replace(template_static_id,'_',' ')) template
                  from eba_qpoll_emails h
                ```
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            pivot: false
            subscription: false
        }
        download {
            formats: [
                csv
                html
            ]
        }
        heading {
            fixedTo: none
        }
        advanced {
            savedReportMappingIdentifier: 936618815108168113
        }

        column COMMUNITY (
            type: plainText
            heading {
                heading: Community
            }
            layout {
                sequence: 14
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
            enableUsersTo {
                pivot: false
            }
        )

        column COMMUNITY_ID (
            type: hidden
            heading {
                heading: Selected Community
            }
            layout {
                sequence: 11
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column INVITEE (
            type: plainText
            heading {
                heading: Invitee
            }
            layout {
                sequence: 15
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
            enableUsersTo {
                pivot: false
            }
        )

        column POLL (
            type: plainText
            heading {
                heading: Poll
            }
            layout {
                sequence: 13
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
            enableUsersTo {
                pivot: false
            }
        )

        column POLL_ID (
            type: hidden
            heading {
                heading: Selected Poll
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
            security {
                escapeSpecialChars: false
            }
        )

        column RESPONDENT_ID (
            type: hidden
            heading {
                heading: Selected Respondent
            }
            layout {
                sequence: 12
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
            security {
                escapeSpecialChars: false
            }
        )

        column SENT_BY (
            type: plainText
            heading {
                heading: Sent By
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
            enableUsersTo {
                pivot: false
            }
        )

        column SENT_TIME (
            type: plainText
            heading {
                heading: Sent
            }
            layout {
                sequence: 3
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: C
            }
            enableUsersTo {
                pivot: false
            }
        )

        column SENT_TO (
            type: plainText
            heading {
                heading: Sent To
            }
            layout {
                sequence: 16
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
            enableUsersTo {
                pivot: false
            }
        )

        column SUBJECT (
            type: plainText
            heading {
                heading: Subject
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
            enableUsersTo {
                pivot: false
            }
        )

        column TEMPLATE (
            type: plainText
            heading {
                heading: Template
                alignment: center
            }
            layout {
                sequence: 26
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Q
            }
        )

        column VIEW_EMAIL (
            type: link
            heading {
                heading: View Email
                alignment: center
            }
            layout {
                sequence: 9
                columnAlignment: center
            }
            link {
                target: {
                    page: 25
                    items: {
                        P25_EMAIL_ID: #ID#
                    }
                    clearCache: [
                        Y
                        25
                    ]
                }
                linkText: <img src="#APEX_FILES#app_ui/img/icons/apex-edit-view.png" class="apex-edit-view" alt="#VIEW_EMAIL#">
                linkAttributes: title="#VIEW_EMAIL#"
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
            enableUsersTo {
                hide: false
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        savedReport 9366202 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn POLL (
                sequence: 6
            )

            displayColumn SENT_BY (
                sequence: 3
            )

            displayColumn SENT_TIME (
                sequence: 1
            )

            displayColumn SENT_TO (
                sequence: 2
            )

            displayColumn SUBJECT (
                sequence: 5
            )

            displayColumn TEMPLATE (
                sequence: 4
            )

            displayColumn VIEW_EMAIL (
                sequence: 7
            )

            sort (
                column: SENT_TIME
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    pageItem P59_EMAIL_ID (
        type: hidden
        layout {
            sequence: 10
            region: @email-history
            slot: regionBody
        }
    )

    button purge (
        buttonName: PURGE
        label: Purge
        layout {
            sequence: 30
            region: @email-history
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 6
                clearCache: 6
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 20
            region: @email-history
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--link
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction load-email (
        name: Load Email
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P59_EMAIL_ID
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: null;
                itemsToSubmit: P59_EMAIL_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    openModal("view_email");
                    $("#view_email").parent().width("700px");
                    ```
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-after-purge (
        name: refresh after purge
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @purge
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @email-history
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

