                :P88_ENABLE_SCORE_YN = 'Y' and
                :P88_QUESTION_TYPE not in ('RADIO_GROUP', 'PICK_TWO', 'CHECKBOX','TEXTAREA', 'TEXT', 'STACK','ALLOCATION')
                ```
        }
    )

