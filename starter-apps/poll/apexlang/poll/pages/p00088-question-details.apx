    pageItem P88_DISPLAY_SEQUENCE (
        type: numberField
        label {
            label: Sequence
            alignment: left
        }
        settings {
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 70
            region: @add-question
            slot: regionBody
            alignment: left
            columnSpan: 4
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 8
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: DISPLAY_SEQUENCE
            used: always
        }
        default {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    l_next_seq number := 0;
                begin
                
                    select nvl(max(display_sequence), l_next_seq) + 10
                      into l_next_seq
                      from eba_qpoll_questions 
                     where poll_id = :POLL_ID;
                
                    return l_next_seq;
                
                exception
                    when others then
                        return l_next_seq + 10;
                end;
                ```
        }
    )

