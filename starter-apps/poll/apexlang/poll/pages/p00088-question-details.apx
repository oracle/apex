    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 60
        }
        advanced {
            executionMappingIdentifier: 8226102786031283831
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                if :REQUEST = 'ADD_ANOTHER' then
                   return FALSE;
                end if;
                
                for c1 in (
                   select count(*) cnt
                     from eba_qpoll_questions
                    where poll_id = :POLL_ID
                ) loop
                   if c1.cnt > 1 and :REQUEST != 'REMOVE_IMAGE' then
                      return TRUE;
                   end if;
                end loop;
                
                return FALSE;
                    
                ```
        }
    )

