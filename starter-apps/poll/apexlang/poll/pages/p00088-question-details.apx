            action: closeDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction handle-scoring (
        name: handle scoring
        execution {
            sequence: 80
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: item=value
            item: P88_SHOW_ENABLE_SCORING
            value: Y
        }

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P88_ENABLE_SCORE_YN
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction hide-canned-for-text-and-textarea (
        name: hide canned for text and textarea
        execution {
            sequence: 50
        }
        when {
            selectionType: items
            items: P88_QUESTION_TYPE
        }
        clientSideCondition {
            type: itemIsInList
            item: P88_QUESTION_TYPE
            list: [
                TEXT
                TEXTAREA
            ]
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @canned-answers
            }
            execution {
                sequence: 10
            }
        )

        action native-hide-2 (
            action: hide
            affectedElements {
                selectionType: items
                items: P88_ANSWERS
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: P88_ANSWERS
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

    )

