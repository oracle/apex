page 74 (
    name: Members
    alias: MEMBERS
    title: Members
    pageGroup: @communities
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region members (
        name: Members
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select i.id,
                    r.name,
                    r.email,
                    r.company,
                    r.title,
                    i.created_by,
                    i.created,
                    i.community_id,
                    c.name community_name
                from eba_qpoll_respondents r,
                    eba_qpoll_resp_comm_ref i,
                    eba_qpoll_resp_communities c
                where i.respondent_id = r.id
                    and i.community_id = c.id
                ```
        }
        layout {
            sequence: 10
            slot: body-3
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No members found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            pivot: false
            subscription: false
        }
        download {
            formats: [
                csv
                html
            ]
        }
        heading {
            fixedTo: none
        }
        advanced {
            savedReportMappingIdentifier: 929813319003114847
        }

        column COMMUNITY_ID (
            type: hidden
            heading {
                heading: Selected Community
            }
            layout {
                sequence: 13
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: M
            }
            security {
                escapeSpecialChars: false
            }
        )

        column COMMUNITY_NAME (
            type: plainText
            heading {
                heading: Community Name
            }
            layout {
                sequence: 14
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
            enableUsersTo {
                pivot: false
            }
        )

        column COMPANY (
            type: plainText
            heading {
                heading: Company
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
            enableUsersTo {
                pivot: false
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 10
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: J
            }
            enableUsersTo {
                pivot: false
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
            enableUsersTo {
                pivot: false
            }
        )

        column EMAIL (
            type: link
            heading {
                heading: Email
            }
            layout {
                sequence: 6
            }
            link {
                target: {
                    page: 75
                    items: {
                        P75_ID: #ID#
                    }
                    clearCache: 75
                    action: resetPagination
                }
                linkText: #EMAIL#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
            enableUsersTo {
                pivot: false
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column NAME (
            type: plainText
            heading {
                heading: Name
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
            enableUsersTo {
                pivot: false
            }
        )

        column TITLE (
            type: plainText
            heading {
                heading: Title
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
            enableUsersTo {
                pivot: false
            }
        )

        savedReport 9298147 (
            visibility: primaryDefault
            view {
                rowsPerPage: 100
            }

            displayColumn COMMUNITY_NAME (
                sequence: 2
            )

            displayColumn EMAIL (
                sequence: 3
            )

            displayColumn ID (
                sequence: 1
            )

            sort (
                column: EMAIL
                sort {
                    sequence: 1
                }
            )

            sort (
                column: COMMUNITY_NAME
                sort {
                    sequence: 2
                }
            )

            filter ir-condition (
                column: COMMUNITY_ID
                value: 9367320554626125849049864567291293984
            )

        )

    )

    button add-members (
        buttonName: ADD_MEMBERS
        label: Add Members
        layout {
            sequence: 20
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 70
                items: {
                    P70_COMMUNITY_ACTION: -4
                }
                clearCache: [
                    70
                    71
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @members
            slot: rightOfInteractiveReportSearchBar
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: &APP_PAGE_ID.
        }
    )

)

