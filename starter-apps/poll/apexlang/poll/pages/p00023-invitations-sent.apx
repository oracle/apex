page 23 (
    name: Invitations Sent
    alias: INVITATIONS-SENT
    title: Invitations Sent
    pageGroup: @polls
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            section.uSuccessRegion p.desc {
            font-size: 14px;
            line-height: 1.5;
            font-weight: normal;
            margin-bottom: 16px;
            color: #404040;
            text-align: left;
            }
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region community-invites (
        name: Community Invites
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select decode(email_sent,'YES','Emails Sent',
                                         'OPTED_OUT','Opted Out',
                                         'PREVIOUSLY_SENT','Previously Sent',
                                         'MANUAL_INVITE','Manual Invites',
                                         email_sent) email_sent, count(*) cnt
                  from eba_qpoll_invites
                 where comm_invite_id = :P72_COMM_INVITE_ID
                    or comm_invite_id = :P72_COMM_INVITE_ID2
                group by email_sent
                ```
        }
        layout {
            sequence: 20
            parentRegion: @invitations-sent
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
            renderComponents: belowContent
        }
        componentAppearance {
            template: @/value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        messages {
            whenNoDataFound: No community invites found.
        }
        componentAdvanced {
            stripHtml: true
        }
        heading {
            type: none
        }

        column CNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                alignment: end
            }
            layout {
                sequence: 1
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column EMAIL_SENT (
            reportColumnQueryId: 1
            derivedColumn: N
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

    )

    region invitations-sent (
        name: Invitations Sent!
        type: staticContent
        source {
            htmlCode: <p>Details of how many emails were sent, how many were not sent because the user had previously been invited and how many users have opted out of receiving emails are displayed below.</p>
        }
        layout {
            sequence: 10
            slot: body-3
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--wizard
                t-Alert--defaultIcons
                t-Alert--success
            ]
        }
    )

    pageItem P23_OTHER_INVITEES_MSG (
        type: displayOnly
        label {
            alignment: left
        }
        settings {
            format: html
            sendOnPageSubmit: false
        }
        layout {
            sequence: 10
            region: @community-invites
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        source {
            type: item
            item: P72_OTHER_INVITEES_MSG
            used: always
        }
        security {
            sessionStateProtection: restricted
        }
    )

    button invite-more (
        buttonName: INVITE_MORE
        label: Invite More
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 72
                items: {
                    P72_POLL_ID: &P72_POLL_ID.
                    P72_INVITE_METHOD: &P72_INVITE_METHOD.
                }
                clearCache: 72
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                from EBA_QPOLL_RESP_COMMUNITIES
                where id not in
                      (select community_id
                         from eba_qpoll_comm_invites
                        where poll_id = :P72_POLL_ID)
                ```
        }
    )

    button view-emails (
        buttonName: VIEW_EMAILS
        label: View Emails
        layout {
            sequence: 20
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 59
                items: {
                    IR_POLL_ID: &P72_POLL_ID.
                }
                clearCache: [
                    CIR
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button view-invites (
        buttonName: VIEW_INVITES
        label: View Invitations
        layout {
            sequence: 30
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 16
                items: {
                    IR_POLL_ID: &P72_POLL_ID.
                    IRC_COMM_INVITE_ID: &P72_COMM_INVITE_ID.
                }
                clearCache: [
                    CIR
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button view-poll (
        buttonName: VIEW_POLL
        label: Manage Poll
        layout {
            sequence: 40
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 100
                items: {
                    LPOLL_ID: &P72_POLL_ID.
                }
                clearCache: 100
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

