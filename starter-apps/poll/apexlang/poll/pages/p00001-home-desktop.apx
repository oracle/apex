    region email-address-not-set (
        name: Email Address Not Set
        type: staticContent
        source {
            htmlCode: <p>You have not defined the EMAIL FROM address (in Administration > Default Email Addresses).</p>
        }
        layout {
            sequence: 70
            parentRegion: @main-column
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--defaultIcons
                t-Alert--danger
                t-Alert--horizontal
            ]
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare x varchar2(4000) := null;
                begin
                  x := trim(replace(eba_qpoll_fw.get_preference_value('NOTIFICATION_EMAIL_FROM'),'N/A',null));
                  if x is null or instr(x,'@') = 0  or instr(x,'.') = 0 then 
                     return true; 
                  else 
                     return false; 
                  end if;
                end;
                ```
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    region filters (
        name: Filters
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @side-column
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
                t-Form--stretchInputs
            ]
        }
        advanced {
            htmlDomId: filters
        }
    )

    region getting-started (
        name: Getting Started
        type: staticContent
        source {
            htmlCode: <p>&APPLICATION_TITLE. makes it easy to create polls, distribute them, and analyze the results.</p>
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--wizard
                t-Alert--customIcons
                t-Alert--info
            ]
            icon: fa-mouse-pointer
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery: select 1 from EBA_QPOLL_POLLS
        }
    )

    region main-column (
        name: Main Column
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region notifications (
        name: Notifications
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select     id,
                    decode(lower(NOTIFICATION_TYPE),'yellow','warning','red','danger',lower(NOTIFICATION_TYPE)) as ALERT_TYPE,
                    NOTIFICATION_NAME as ALERT_TITLE,
                    NOTIFICATION_DESCRIPTION as ALERT_DESC,
                    '' alert_action
                  from EBA_QPOLL_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                 order by nvl(DISPLAY_SEQUENCE,0),NOTIFICATION_NAME
                ```
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-top-md
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from EBA_QPOLL_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                ```
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/alerts
            templateOptions: #DEFAULT#
            showNullValuesAs: " "
        }
        performance {
            maxRowsToProcess: 500
        }
        componentAdvanced {
            stripHtml: true
        }

