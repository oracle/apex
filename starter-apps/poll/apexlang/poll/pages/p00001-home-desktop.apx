                t-Button--stretch
            ]
            icon: fa-box-arrow-in-west
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                items: {
                    P1_VIEW_SELECTOR: &P1_VIEW_SELECTOR.
                }
                clearCache: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction perform-search-on-enter (
        name: Perform Search on Enter
        execution {
            sequence: 60
        }
        when {
            event: keypress
            selectionType: items
            items: [
                P1_SEARCH
                P1_SEARCH_READER
            ]
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.browserEvent.keyCode === 13
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: this.browserEvent.preventDefault();
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: .report_polls
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-reports-on-filter-change (
        name: Refresh Reports on Filter Change
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: [
                P1_STATUS_ID
                P1_SORT
                P1_CREATED_BY
                P1_SEARCH_READER
                P1_STATUS_READER
                P1_SORT_READER
            ]
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: jquerySelector
                jquerySelector: .report_polls
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction set-view-selector-for-readers (
        name: set view selector for Readers
        execution {
            sequence: 50
        }
        when {
            event: ready
        }
        security {
            authorizationScheme: !@contribution-rights
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @view-selector
            }
            execution {
                sequence: 10
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: R
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P1_VIEW_SELECTOR
            }
            execution {
                sequence: 20
            }
        )

    )

    computation last-view (
        itemName: LAST_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

    computation p1-view-selector (
        itemName: P1_VIEW_SELECTOR
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: C
        }
        serverSideCondition {
            type: itemIsNull
            item: P1_VIEW_SELECTOR
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    branch (
        name: Go to Getting Started Page
        execution {
            sequence: 10
            point: beforeHeader
        }
        behavior {
            target: {
                page: 1000
                action: resetPagination
            }
        }
        serverSideCondition {
            type: expression
            plsqlExpression: eba_qpoll_fw.get_preference_value('FIRST_RUN') = 'YES'
        }
    )

)

