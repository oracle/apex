            columnFormatting {
                htmlExpression:
                    ```html
                    <div class="qp-Stats">
                    <span class="qp-Stats-item">
                        <span class="qp-Stats-num">#RESPONSES#</span>
                        <span class="qp-Stats-label">responses</span>
                    </span>
                    <span class="qp-Stats-item">
                        <span class="qp-Stats-num">#INVITATIONS#</span>
