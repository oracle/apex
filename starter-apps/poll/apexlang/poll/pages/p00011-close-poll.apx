page 11 (
    name: Close Poll
    alias: CLOSE-POLL
    title: Close Poll
    pageGroup: @polls
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/wizard-modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        width: 480
        height: 240
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region buttons (
        name: buttons
        type: staticContent
        layout {
            sequence: 10
            slot: wizardButtons
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region close-poll (
        name: Close Poll
        type: staticContent
        source {
            htmlCode: <p>Please confirm you want to mark this poll as Closed.  Once Closed, no new responses will be allowed.</p>
        }
        layout {
            sequence: 10
            slot: wizardBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button close (
        buttonName: CLOSE
        label: Close Poll
        layout {
            sequence: 10
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-poll (
        name: close poll
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                update eba_qpoll_polls
                   set status_id = 4
                 where id = :POLL_ID
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Poll has been marked as Closed.
        }
        advanced {
            executionMappingIdentifier: 252353780077817346
        }
        serverSideCondition {
            whenButtonPressed: @close
        }
    )

    branch (
        name: close
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 100
                action: resetPagination
            }
        }
    )

)

