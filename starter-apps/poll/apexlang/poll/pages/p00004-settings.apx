    region email-address-not-set (
        name: Email Address Not Set
        type: staticContent
        source {
            htmlCode:
                ```html
                You have not defined the EMAIL FROM address.
                
                
                
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--defaultIcons
                t-Alert--danger
                t-Alert--horizontal
            ]
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare x varchar2(4000) := null;
                begin
                  x := trim(replace(eba_qpoll_fw.get_preference_value('NOTIFICATION_EMAIL_FROM'),'N/A',null));
                  if x is null or instr(x,'@') = 0  or instr(x,'.') = 0 then 
                     return true; 
                  else 
                     return false; 
                  end if;
                end;
                ```
        }
        settings {
            outputAs: text
        }
    )

