page 10021 (
    name: Manage User Access
    alias: MANAGE-USER-ACCESS
    title: Manage User Access
    pageGroup: @acl
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        executeWhenPageLoads:
            ```javascript-browser
            window.onunload = refreshParent;
            function refreshParent() {
                parent.location.reload();
            }
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>This page shows a report of the application users and the access level granted.</p>
            <p>Click on the column headings to sort and filter data, or click on the <strong>Actions</strong> button to customize column display and many additional advanced features.<br>
            Click the <strong>Reset</strong> button to reset the report back to the default settings.</p>
            <p>Click the username to edit the user details and access level, or to delete the user.</p>
            <p>Click <strong>Add User</strong>, at the top of the report, to add a new user and their access level.</p>
            ```
    }
    config {
        buildOption: @feature-access-control
    }

    region manage-user-access (
        name: Manage User Access
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                   user_name_lc USERNAME,
                   role_names ACCESS_ROLE
                from APEX_APPL_ACL_USERS
                where APPLICATION_ID = :APP_ID
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        heading {
            fixedTo: none
        }
        advanced {
            savedReportMappingIdentifier: 148870313461403957
        }

        column ACCESS_ROLE (
            type: plainText
            heading {
                heading: Role
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column USERNAME (
            type: link
            heading {
                heading: Username
            }
            layout {
                sequence: 20
            }
            link {
                target: {
                    page: 10022
                    items: {
                        P10022_ID: #ID#
                    }
                    clearCache: 10022
                    action: resetPagination
                }
                linkText: #USERNAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 1488720 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACCESS_ROLE (
                sequence: 2
            )

            displayColumn USERNAME (
                sequence: 1
            )

            sort (
                column: USERNAME
                sort {
                    sequence: 2
                }
            )

        )

    )

    button add-multiple-users (
        buttonName: ADD_MULTIPLE_USERS
        label: Add Multiple Users
        layout {
            sequence: 30
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10023
                clearCache: 10023
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 40
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10022
                clearCache: 10022
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                t-Button--link
                t-Button--iconLeft
                t-Button--gapRight
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-dialog-close (
        name: Refresh on Dialog Close
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @manage-user-access
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @manage-user-access
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

