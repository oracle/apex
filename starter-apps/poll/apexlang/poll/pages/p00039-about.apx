page 39 (
    name: About
    alias: ABOUT
    title: About
    pageGroup: @help
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            img.appIcon.live-poll {
                background-position: -448px -384px;
            }
            ```
    }
    htmlHeader {
        htmlHeader:
            ```html
            <style>
            div#uOneCol div.helpContainer div.helpSide h1.appNameHeader {margin-top: 8px; font-size: 16px; line-height: 24px;}
            div.helpContainer div.helpSide ul.vapList {
            padding-top: 8px;}
            </style>
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Use this page to learn more about this application.
    }

    region about-this-application (
        name: About this Application
        type: plugin/translatedMessage
        layout {
            sequence: 10
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_ABOUT
            addParagraphTags: false
        }
    )

    region application-title (
        name: &APPLICATION_TITLE.
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select aa.version app_version,
                       to_char(aa.pages,'999G999G990') pages,
                       'Oracle' vendor
                from apex_applications aa
                where aa.application_id = :APP_ID
                ```
        }
        layout {
            sequence: 20
            slot: body
            startNewRow: false
            columnSpan: 4
        }
        appearance {
            template: @/hero
            templateOptions: #DEFAULT#
            cssClasses: t-HeroRegion--featured
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-512.png
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
            showNullValuesAs: -
        }

        column APP_VERSION (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: App version
            }
            layout {
                sequence: 1
            }
        )

        column PAGES (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Pages
            }
            layout {
                sequence: 2
            }
        )

        column VENDOR (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Vendor
            }
            layout {
                sequence: 3
            }
        )

    )

    region features (
        name: Features
        type: plugin/translatedMessage
        layout {
            sequence: 100
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_FEATURES
            addParagraphTags: false
        }
    )

    region getting-started (
        name: Getting Started
        type: plugin/translatedMessage
        layout {
            sequence: 40
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_1.5
            addParagraphTags: false
        }
    )

    region getting-started-2 (
        name: Getting Started2
        type: plugin/translatedMessage
        layout {
            sequence: 50
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_2
            addParagraphTags: false
        }
    )

    region getting-started-3 (
        name: Getting Started3
        type: plugin/translatedMessage
        layout {
            sequence: 60
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_3
            addParagraphTags: false
        }
    )

    region getting-started-4 (
        name: Getting Started
        type: plugin/translatedMessage
        layout {
            sequence: 30
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED
            addParagraphTags: false
        }
    )

    region getting-started-acl (
        name: Getting Started ACL
        type: plugin/translatedMessage
        layout {
            sequence: 80
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_ACL
            addParagraphTags: false
        }
    )

    region getting-started-email (
        name: Getting Started EMAIL
        type: plugin/translatedMessage
        layout {
            sequence: 70
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_EMAIL
            addParagraphTags: false
        }
    )

    region getting-started-toc (
        name: Getting Started TOC
        type: plugin/translatedMessage
        layout {
            sequence: 20
            parentRegion: @help-container
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            textMessage: HELP_GETTING_STARTED_TOC
            addParagraphTags: false
        }
    )

    region help-container (
        name: Help Container
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
    )

)

