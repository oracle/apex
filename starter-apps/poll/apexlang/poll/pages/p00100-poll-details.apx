    dynamicAction refresh-after-actions-add-question (
        name: Refresh after actions - add question
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: jQuerySelector
            jquerySelector: #actions_menu
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data.dialogPageId === 88
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @questions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-after-actions-add-section (
        name: Refresh after actions - add section
