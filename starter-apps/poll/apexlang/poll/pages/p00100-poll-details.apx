page 100 (
    name: Poll Details
    alias: POLL-DETAILS
    title: Poll Details
    pageGroup: @polls
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .center-button {
                padding: 8px;
            }
            .center-button .uButton {
                display: block;
                margin: 0 8px;
            }
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Use this page to manage the selected poll. You can edit the attributes to change who can take the poll and if login will be required.  You can Invite users to take the poll, and view the results.
    }

    region average-score (
        name: Average Score
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                    round(avg(score),1) "Average Score"
                from
                    EBA_QPOLL_RESULTS r
                where
                    poll_id = :POLL_ID
                and nvl(r.is_valid_yn,'Y') = 'Y'
                and score is not null
                ```
        }
        layout {
            sequence: 130
            parentRegion: @summary
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: average_score
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from EBA_QPOLL_QUESTIONS q,
                       EBA_QPOLL_POLLS p,
                       EBA_QPOLL_RESULTS r
                  where q.poll_id = p.id and
                        p.id = :POLL_ID and
                        p.score_type in ('A','C') and 
                        p.enable_score_yn = 'Y' and
                        q.enable_score_yn = 'Y' and
                        r.poll_id = p.id and
                        nvl(r.is_valid_yn,'Y') = 'Y' and
                        r.score is not null
                ```
        }
        componentAppearance {
            template: @/badge-list
            templateOptions: [
                #DEFAULT#
                t-BadgeList--large
                t-BadgeList--fixed
                t-BadgeList--circular
            ]
            showNullValuesAs: -
        }

        column "Average Score" (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Average Score
                alignment: center
            }
            layout {
                sequence: 1
            }
        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        headerAndFooter {
            footerText: &P100_POLL_STATUS.
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region community-invitations (
        name: Community Invitations
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    v1.num_responses,
                    v1.num_requests,
                    v1.invite_date,
                    case when v1.num_requests = 0 then null
                         else to_char((v1.num_responses/v1.num_requests) * 100,'999G999G999G990')||'%'
                         end as pct_responded,
                    '<a href="'||apex_util.prepare_url('f?p='||:APP_ID||':16:'||:APP_SESSION||':::RIR,CIR:IR_POLL_ID,IR_COMM_INVITE_ID:'||:POLL_ID||','||comm_invite_id)||'">'
                        ||apex_escape.html(v1.community_name)||'</a>' community_name,
                    invite_method
                from
                (
                    select ID comm_invite_id,
                           community_name,
                           (select count(unique(r.respondent_id)) 
                              from eba_qpoll_results r,
                                   eba_qpoll_invites i
                             where r.poll_id = :POLL_ID
                               and r.IS_VALID_YN = 'Y'
                               and i.comm_invite_id = c.id
                               and r.respondent_id = i.respondent_id ) num_responses,
                           (select count(unique respondent_email)
                              from eba_qpoll_invites 
                             where comm_invite_id = c.id) num_requests,
                           created invite_date,
                           initcap(invite_method) invite_method
                      from eba_qpoll_comm_invites c
                     where poll_id = :POLL_ID
                       and community_name is not null
                ) v1
                order by v1.invite_date desc nulls last, upper(v1.community_name)
                ```
        }
        layout {
            sequence: 110
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_comm_invites 
                 where poll_id = :POLL_ID
                   and community_name is not null
                ```
        }
        reportLayout {
            numberOfRows: 10000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: no invitations found
        }
        componentAdvanced {
            stripHtml: true
        }

        column COMMUNITY_NAME (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Community
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column INVITE_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Sent
            }
            layout {
                sequence: 1
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column INVITE_METHOD (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Method
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column NUM_REQUESTS (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Invitations
                alignment: end
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column NUM_RESPONSES (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Responses
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column PCT_RESPONDED (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Response Rate
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

    )

    region hidden-items (
        name: Hidden Items
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region individual-invitations (
        name: Individual Invitations
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select '<a href="'||apex_util.prepare_url('f?p='||:APP_ID||':16:'||:APP_SESSION||':::RIR,CIR:IR_POLL_ID,IR_INVITE_ID:'||:POLL_ID||','||i.id)
                        ||'">'||apex_escape.html(i.respondent_email)||'</a>' invitee,
                    nvl((select 'Yes' 
                         from eba_qpoll_results r
                         where r.poll_id = :POLL_ID
                             and r.IS_VALID_YN = 'Y'
                             and r.respondent_id = i.respondent_id ),'No') responded,
                    c.created invite_date,
                    initcap(c.invite_method) invite_method
                from eba_qpoll_comm_invites c,
                    eba_qpoll_invites i
                where c.poll_id = :POLL_ID
                    and c.id = i.comm_invite_id
                    and c.community_name is null
                order by c.created desc, upper(i.respondent_email)
                ```
        }
        layout {
            sequence: 120
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_comm_invites 
                 where poll_id = :POLL_ID
                   and community_name is null
                ```
        }
        reportLayout {
            numberOfRows: 10000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--inline
                t-Report--rowHighlight
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: no invitations found
        }
        componentAdvanced {
            stripHtml: true
        }

        column INVITEE (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Invitee
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column INVITE_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Sent
            }
            layout {
                sequence: 1
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
