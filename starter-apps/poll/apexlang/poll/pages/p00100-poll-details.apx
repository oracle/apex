    region no-invitations (
        name: No Invitations
        type: staticContent
        source {
            htmlCode: <p>Your poll is Invite Only but you have not invited anyone to take it.  Use the Invite button on the right to send invitations.</p>
        }
        layout {
            sequence: 10
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from eba_qpoll_polls
                 where id = :POLL_ID
                   and invite_only_yn = 'Y'
                   and status_id = 3
                   and not exists (select 1
                                     from eba_qpoll_comm_invites
                                    where poll_id = :POLL_ID)
                   and nvl(:REQUEST,'OLD') != 'NEW'
                ```
        }
    )

    region no-questions-yet (
        name: no questions yet
        type: staticContent
        source {
            htmlCode: No questions defined yet.
        }
        layout {
            sequence: 80
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
                t-Alert--removeHeading js-removeLandmark
            ]
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                if :P100_USE_SECTIONS_YN = 'Y' then
                   for c1 in (
                      select count(*) c
                        from EBA_QPOLL_SECTIONS
                       where POLL_ID = :POLL_ID
                   ) loop
                      if c1.c = 0 then
                         return FALSE;
                      end if;
                   end loop;
                end if;
                
                for c1 in (
                   select count(*) c
                     from EBA_QPOLL_QUESTIONS
                    where POLL_ID = :POLL_ID
                ) loop
                   if c1.c = 0 then
                      return TRUE;
                   end if;
                end loop;
                
                return FALSE;
                ```
        }
    )

    region no-sections-yet (
        name: no sections yet
        type: staticContent
        source {
            htmlCode: No sections defined yet.
        }
        layout {
            sequence: 70
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--info
                t-Alert--removeHeading js-removeLandmark
            ]
        }
        serverSideCondition {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                if :P100_USE_SECTIONS_YN = 'Y' then
                   for c1 in (
                      select count(*) c
                        from EBA_QPOLL_SECTIONS
                       where POLL_ID = :POLL_ID
                   ) loop
                      if c1.c = 0 then
                         return TRUE;
                      end if;
                   end loop;
                end if;
                return FALSE;
                ```
        }
    )

    region not-invited (
        name: Not Invited
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select email,
                       created
                  from eba_qpoll_results
                 where poll_id = :POLL_ID
                   and IS_VALID_YN = 'Y'
                   and respondent_id not in (select i.respondent_id
                                               from eba_qpoll_comm_invites c,
                                                    eba_qpoll_invites i
                                              where c.poll_id = :POLL_ID
                                                and c.id = i.comm_invite_id)
                order by created desc, upper(email)
                ```
        }
        layout {
            sequence: 130
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_results
                 where poll_id = :POLL_ID
                   and IS_VALID_YN = 'Y'
                   and respondent_id not in (select i.respondent_id
                                               from eba_qpoll_comm_invites c,
                                                    eba_qpoll_invites i
                                              where c.poll_id = :POLL_ID
                                                and c.id = i.comm_invite_id)
                ```
        }
        reportLayout {
            numberOfRows: 10000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: no invitations found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Responded
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column EMAIL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Respondent
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region outstanding-invitations (
        name: Outstanding Invitations
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                if :OUTSTANDING_INVITES = 1 then
                   sys.htp.p('<p class="u-tC" style="font-size: 11px"><a href="'||apex_util.prepare_url('f?p='||:APP_ID||':16:'||:APP_SESSION||'::NO:RIR,CIR:IR_HAS_RESPONDED,IR_POLL_ID:No,'||:POLL_ID)||'">'||:OUTSTANDING_INVITES||' Oustanding Invitation</a></p>');
                else
                   sys.htp.p('<p class="u-tC" style="font-size: 11px"><a href="'||apex_util.prepare_url('f?p='||:APP_ID||':16:'||:APP_SESSION||'::NO:RIR,CIR:IR_HAS_RESPONDED,IR_POLL_ID:No,'||:POLL_ID)||'">'||:OUTSTANDING_INVITES||' Oustanding Invitations</a></p>');
                end if;
                ```
        }
        layout {
            sequence: 30
            parentRegion: @right-content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: oustanding_invitations
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_comm_invites
                 where poll_id = :POLL_ID
                   and nvl(:OUTSTANDING_INVITES,0) > 0
                ```
        }
    )

    region published (
        name: Published!
        type: staticContent
        source {
            htmlCode: <p>Now that your poll has been published, you can send invitations to pre-defined communities and/or individuals using the Invite button on the right.</p>
        }
        layout {
            sequence: 30
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--success
            ]
        }
        serverSideCondition {
            type: request=Value
            value: NEW
        }
    )

    region questions (
        name: Questions
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    q.ID,
                    s.title,
                    q.QUESTION,
                    q.CREATED,
                    q.UPDATED,
                    q.display_sequence, 
                    q.mandatory_yn,
                    case when q.QUESTION_TYPE in ('TEXTAREA','TEXT') then null
                         else decode(USE_CUSTOM_ANSWERS_YN,
                           'N', a.answer_01||
                                decode(a.answer_02,null,null,', '||a.answer_02)||
                                decode(a.answer_03,null,null,', '||a.answer_03)||
                                decode(a.answer_04,null,null,', '||a.answer_04)||
                                decode(a.answer_05,null,null,', '||a.answer_05)||
                                decode(a.answer_06,null,null,', '||a.answer_06)||
                                decode(a.answer_07,null,null,', '||a.answer_07)||
                                decode(a.answer_08,null,null,', '||a.answer_08)||
                                decode(a.answer_09,null,null,', '||a.answer_09)||
                                decode(a.answer_10,null,null,', '||a.answer_10)||
                                decode(a.answer_11,null,null,', '||a.answer_11)||
                                decode(a.answer_12,null,null,', '||a.answer_12),
                           q.answer_01||
                                decode(q.answer_02,null,null,', '||q.answer_02)||
                                decode(q.answer_03,null,null,', '||q.answer_03)||
                                decode(q.answer_04,null,null,', '||q.answer_04)||
                                decode(q.answer_05,null,null,', '||q.answer_05)||
                                decode(q.answer_06,null,null,', '||q.answer_06)||
                                decode(q.answer_07,null,null,', '||q.answer_07)||
                                decode(q.answer_08,null,null,', '||q.answer_08)||
                                decode(q.answer_09,null,null,', '||q.answer_09)||
                                decode(q.answer_10,null,null,', '||q.answer_10)||
                                decode(q.answer_11,null,null,', '||q.answer_11)||
                                decode(q.answer_12,null,null,', '||q.answer_12)) end answers,
                    case when p.POLL_OR_QUIZ = 'Q' and question_type = 'CHECKBOX'
                         then eba_qpoll_quiz.delim_answers_disp(q.correct_answer)
                         else q.correct_answer
                         end correct_answer,
                    decode(q.QUESTION_TYPE,
                       'RADIO_GROUP','Pick One',
                       'CHECKBOX','Pick Many',
                       'PICK_TWO','Pick Two',
                       'ALLOCATION','Allocate $100',
                       'STACK','Stack Rank',
                       'TEXTAREA','Free form text',
                       'TEXT','Text field',
                       'Canned Answers') question_type,
                     USE_CUSTOM_ANSWERS_YN 
                from eba_qpoll_polls p,
                     EBA_QPOLL_QUESTIONS q,
                     EBA_QPOLL_CANNED_ANSWERS a,
                     eba_qpoll_sections s
                where p.id = :POLL_ID and
                     p.id = q.POLL_ID and
                     q.question_type = a.code(+) and
                     q.section_id = s.id (+)
                order by s.display_sequence, s.title nulls last, q.display_sequence
                ```
        }
        layout {
            sequence: 90
            parentRegion: @main-content
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hiddenOverflow
            ]
        }
        advanced {
            htmlDomId: questions_report
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
