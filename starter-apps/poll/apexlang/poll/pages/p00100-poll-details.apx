    region response-rate (
        name: Response Rate1
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select round((i.num_responses/i.num_requests) * 100) ||'%' "Response Rate"
                from
                (
                 select
                        (select count (unique r.respondent_id)
                           from eba_qpoll_results r,
                                eba_qpoll_comm_invites c,
                                eba_qpoll_invites i
                          where r.poll_id = :POLL_ID
                            and r.IS_VALID_YN = 'Y'
                            and c.poll_id = :POLL_ID
                            and c.id = i.comm_invite_id 
                            and r.respondent_id = i.respondent_id ) num_responses,
                        (select count (unique respondent_id)
                          from eba_qpoll_comm_invites c,
                               eba_qpoll_invites i
                         where c.poll_id = :POLL_ID
                           and c.id = i.comm_invite_id) num_requests
                    from dual
                ) i
                ```
        }
        layout {
            sequence: 40
            parentRegion: @summary
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: response_rate_a
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_comm_invites 
                 where poll_id = :POLL_ID
                   and :P100_ANONYMOUS_YN = 'N'
                ```
        }
        componentAppearance {
            template: @/badge-list
            templateOptions: [
                #DEFAULT#
                t-BadgeList--large
                t-BadgeList--fixed
                t-BadgeList--circular
            ]
            showNullValuesAs: -
        }

        column "Response Rate" (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Response Rate
                alignment: center
            }
            layout {
                sequence: 1
            }
        )

    )

    region response-rate-2 (
        name: Response Rate2
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select least(round((i.num_responses/i.num_requests) * 100),100) ||'%' "Response Rate"
                from
                (
                 select
                        (select count (*)
                           from eba_qpoll_results r
                          where r.poll_id = :POLL_ID
                            and r.IS_VALID_YN = 'Y' ) num_responses,
                        (select count (unique respondent_id)
                          from eba_qpoll_comm_invites c,
                               eba_qpoll_invites i
                         where c.poll_id = :POLL_ID
                           and c.id = i.comm_invite_id) num_requests
                    from dual
                ) i
                ```
