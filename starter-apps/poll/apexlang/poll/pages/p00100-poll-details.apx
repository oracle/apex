    )

    region invites (
        name: Invites
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c "Unique Invitations"
                from
                (
                select count (unique respondent_id) c
                  from eba_qpoll_comm_invites c,
                       eba_qpoll_invites i
                 where c.poll_id = :POLL_ID
                   and c.id = i.comm_invite_id
                )
                ```
        }
        layout {
            sequence: 10
            parentRegion: @summary
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: invites
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_comm_invites
                 where poll_id = :POLL_ID
                ```
        }
        componentAppearance {
            template: @/badge-list
            templateOptions: [
                #DEFAULT#
                t-BadgeList--large
                t-BadgeList--fixed
                t-BadgeList--circular
            ]
            showNullValuesAs: -
        }

        column "Unique Invitations" (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: Unique Invitations
                alignment: center
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 16
                    items: {
                        IR_POLL_ID: &POLL_ID.
                    }
                    clearCache: [
                        16
                        RIR
                        CIR
                    ]
                    action: resetPagination
                }
                linkText: #Unique Invitations#
            }
        )

    )

