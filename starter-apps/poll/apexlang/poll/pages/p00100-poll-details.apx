                page: 1072
                items: {
                    P1072_POLL_ID: &POLL_ID.
                }
                clearCache: 1072
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 
                  from eba_qpoll_polls p,
                       eba_qpoll_comm_invites c,
                       eba_qpoll_invites i
                 where p.id = :POLL_ID
                   and p.status_id = 3
                   and p.id = c.poll_id
                   and c.id = i.comm_invite_id
                   and i.respondent_id not in
                       (select respondent_id
                          from eba_qpoll_results
                         where poll_id = :POLL_ID
                           and IS_VALID_YN = 'Y')
                ```
        }
    )

