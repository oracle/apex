    button view-your-response (
        buttonName: VIEW_YOUR_RESPONSE
        label: View Your Response
        layout {
            sequence: 80
            region: @button-region
            slot: create
            startNewRow: false
            newColumn: false
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 69
                clearCache: 69
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @can-view-your-response
