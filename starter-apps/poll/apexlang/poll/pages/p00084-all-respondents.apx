page 84 (
    name: All Respondents
    alias: ALL-RESPONDENTS
    title: All Respondents
    pageGroup: @polls
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region poll-responses (
        name: Poll Responses
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    p.ID poll_id,
                    (select count(*) 
                       from eba_qpoll_questions q
                      where p.id = q.poll_id
                        and q.publish_yn = 'Y') nbr_questions,
                    p.POLL_NAME,
                    p.POLL_DETAILS,
                    p.status_id poll_status,
                    p.authentication_req_yn,
                    p.invite_only_yn,
                    p.ANONYMOUS_YN,
                    p.can_update_answers_yn,
                    case when p.score_type in ('C','A') and p.enable_score_yn = 'Y' then apex_lang.message('SCORE_'||p.score_type) end score_type,
                    p.ALL_VIEW_RESULTS_YN,
                    p.START_TIME,
                    p.STOP_TIME,
                    r.id result_id, 
                    lower(r.email) respondent, 
                    round(r.grade,1) || case when r.grade is not null then ' %' end grade, 
                    r.score,
                    r.created, 
                    r.updated,
                    r.preactive_yn
                from EBA_QPOLL_POLLS p,
                     EBA_QPOLL_RESULTS r
                where p.id = r.poll_id
                  and nvl(r.is_valid_yn,'Y') = 'Y'
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 73
                items: {
                    LPOLL_ID: #POLL_ID#
                    P73_RESULT_ID: #RESULT_ID#
                }
                clearCache: 73
            }
            linkIcon: View Response
            linkAttributes: class="t-Button t-Button--small t-Button--hot t-Button--simple t-Button--stretch"
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            pivot: false
            subscription: false
        }
        download {
            formats: [
                csv
                html
            ]
        }
        heading {
            fixedTo: none
        }
        advanced {
            savedReportMappingIdentifier: 1028203515738710356
        }

        column ALL_VIEW_RESULTS_YN (
            type: plainText
            heading {
                heading: Invitees View Results?
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
            enableUsersTo {
                pivot: false
            }
        )

