    computation p68-next-qid (
        itemName: P68_NEXT_QID
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                   l_next_one  varchar2(1) := 'N';
                begin
                
                for c1 in (
                  select ID question_id
                  from EBA_QPOLL_QUESTIONS
                  where poll_id = :POLL_ID
                  order by display_sequence, id
                ) loop
                
                   if l_next_one = 'Y' then
                      return c1.question_id;
                   end if;
                
                   if c1.question_id = :P68_QUESTION_ID
                      then l_next_one := 'Y';
                   end if;
                
                end loop;
                
                end;
                ```
        }
    )

    computation p68-prev-qid (
        itemName: P68_PREV_QID
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                   c           number := 0;
                   l_prev_qid  number;
                begin
                
                for c1 in (
                  select ID question_id
                  from EBA_QPOLL_QUESTIONS
                  where POLL_ID = :POLL_ID
                  order by display_sequence, id
                ) loop
                
                   c := c + 1;
                
                   if c1.question_id = :P68_QUESTION_ID then
                      :P68_QUESTION_NBR := c;
                      return l_prev_qid;
                   end if;
                
                   l_prev_qid := c1.question_id;
                
                end loop;
                
                end;
                ```
        }
    )

)

