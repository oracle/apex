    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 50
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
                t-Button--pillEnd
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 68
                items: {
                    P68_QUESTION_ID: &P68_NEXT_QID.
                }
                clearCache: 68
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P68_NEXT_QID
        }
    )

