    pageItem P10024_INVALID_COUNT (
        type: hidden
        layout {
            sequence: 30
            region: @hidden-items
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select count(*)
                  from apex_collections
                 where collection_name = 'ACL_BULK_USER_VALID'
                ```
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10024_ROLE (
        type: hidden
        layout {
            sequence: 10
            region: @hidden-items
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select LISTAGG( role_name, ', ')
                         WITHIN GROUP (ORDER BY role_name) role_name
                from APEX_APPL_ACL_ROLES
                where application_id = :APP_ID
                and instr(:P10023_ROLE, role_id, 1) > 0
                ```
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10024_VALID_COUNT (
        type: hidden
        layout {
            sequence: 20
            region: @hidden-items
