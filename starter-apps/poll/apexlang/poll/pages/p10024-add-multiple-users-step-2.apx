    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 10
            region: @button-bar
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-chevron-left
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:history.back();
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button submit (
        buttonName: SUBMIT
        label: Add Users
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from apex_collections
                 where collection_name = 'ACL_BULK_USER_VALID'
                ```
        }
    )

    dynamicAction cancel-modal (
        name: Cancel Modal
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process add-users-to-access-control-list (
        name: Add Users to Access Control List
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_user_role_ids apex_application_global.vc_arr2;
                begin
                    for c in (  select distinct c001 as username, c003 as user_roles
                                from   apex_collections
                                where  collection_name = 'ACL_BULK_USER_VALID' ) loop
                         l_user_role_ids := apex_util.string_to_table(c.user_roles);
                         for i in 1..l_user_role_ids.count loop
                             apex_acl.add_user_role(p_application_id => :APP_ID, p_user_name => c.username, p_role_id => l_user_role_ids(i));
                         end loop;
                    end loop;
                
                    apex_collection.DELETE_COLLECTION('ACL_BULK_USER_INVALID');
                    apex_collection.DELETE_COLLECTION('ACL_BULK_USER_VALID');
                    :P10023_PRELIM_USERS := null;
                end;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: User(s) added.
        }
        advanced {
            executionMappingIdentifier: 148899441723404030
        }
        serverSideCondition {
            whenButtonPressed: @submit
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 148899814876404030
        }
    )

)

