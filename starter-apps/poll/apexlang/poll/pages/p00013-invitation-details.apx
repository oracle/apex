                    ```sql
                    select 1
                      from eba_qpoll_polls p,
                           eba_qpoll_comm_invites ci,
                           eba_qpoll_invites i
                     where p.id = :P13_POLL_ID
                       and p.id = ci.poll_id
                       and ci.id = i.comm_invite_id
                       and i.id = :P13_INVITE_ID
                       and ci.community_name is not null
