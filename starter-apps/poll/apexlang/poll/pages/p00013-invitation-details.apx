page 13 (
    name: Invitation Details
    alias: INVITATION-DETAILS
    title: Invitation Details
    pageGroup: @polls
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region email-body (
        name: Email Body
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   l_poll_url   varchar2(4000);
                   l_body       clob;
                   l_subject    varchar2(4000);
                   l_html_body  clob;
                   l_text_body  clob;
                begin
                
                l_poll_url := '<a href="#">'||apex_escape.html(:POLL_NAME)||'</a>';
                                                                     
                l_body := replace(:P72_INVITE_BODY,'#POLL_LINK#',l_poll_url);
                   
                for c1 in (
                    select
                        sent_time,
                        subject,
                        apex_escape.html(text_body) message
                    from
                        eba_qpoll_emails
                    where
                        id = :P13_EMAIL_ID
                    and
                        poll_id = :P13_POLL_ID
                ) loop
                
                   apex_mail.prepare_template (
                      p_static_id       => 'INVITE',
                      p_placeholders    => '{' || 
                                           '    "SUBJECT":'           || apex_json.stringify( c1.subject ) || 
                                           '   ,"APPLICATION_TITLE":' || apex_json.stringify( apex_escape.html(:APPLICATION_TITLE) ) || 
                                           '   ,"OPT_OUT_TEXT":'      || apex_json.stringify( apex_lang.message('OPT_OUT_TEXT', 
                                                                                              :APP_PATH || '/f?p=' || :APP_ID || ':optout',
                                                                                              apex_escape.html(:APPLICATION_TITLE)) ) || 
                                           '   ,"BODY":'  || apex_json.stringify( replace(c1.message,'#POLL_LINK#','<a href="#">'||:POLL_NAME||'</a>') ) || 
                                           '}' , 
                      p_application_id  => :APP_ID,
                      p_subject         => l_subject,
                      p_html            => l_html_body,
                      p_text            => l_text_body );
                      
                   return l_html_body;
                   
                end loop;
                      
                end;
                ```
            pageItemsToSubmit: [
                P13_EMAIL_ID
                P13_POLL_ID
            ]
        }
        layout {
            sequence: 75
            parentRegion: @invitation-details
            slot: subRegions
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--removeHeader js-removeLandmark
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_emailS
                 where id = :P13_EMAIL_ID
                   and poll_id = :P13_POLL_ID
                ```
        }
    )

