                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1
                  from eba_qpoll_emailS
                 where id = :P13_EMAIL_ID
                   and poll_id = :P13_POLL_ID
                ```
        }
    )

