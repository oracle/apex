    region products-grid (
        name: Products Grid
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.id,
                  p.product_name,
                  p.row_key, 
                  p.product_sku,
                  p.product_family_id,
                  p.product_description,
                  p.tags,
                  (
                    select count(*)
                    from eba_sales_links
                    where product_id = p.id
                  ) links,
                  (
                    select count(*)
                    from eba_sales_files
                    where product_id = p.id
                  ) attachments,
                  (
                    select count(*)
                    from eba_sales_comments
                    where product_id = p.id
                  ) comments,
                  (
                    select count(*)
                    from eba_sales_verifications
                    where product_id = p.id
                  ) validations,
                  (
                    select max(created)
                    from eba_sales_verifications
                    where product_id = p.id
                  ) last_validation,
                  (
                    select count(*)
                    from eba_sales_clicks
                    where product_id = p.id
                      and view_timestamp >= sysdate - 90
                  ) views_90_days,
                    (   select count(distinct(app_username))
                        from eba_sales_clicks
                        where product_id = p.id
                            and view_timestamp >= sysdate - 90
                    ) users_90_days,
                  p.created,
                  p.created_by,
                  p.updated,
                  p.updated_by,
                  (
                    select count(*)
                    from eba_sales_deals
                    where id in (
                      select deal_id
                      from eba_sales_deal_products
                      where product_id = p.id
                    )
                  ) opportunities,
                  (
                    select count(*)
                    from eba_sales_customers
                    where id in (
                      select customer_id
                      from eba_sales_deals
                      where id in (
                        select deal_id
                        from eba_sales_deal_products
                        where product_id = p.id
                      )
                    )
                  ) customers
                from eba_sales_products p
                ```
            pageItemsToSubmit: P68_DISPLAY_AS
        }
