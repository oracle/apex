        page {
            width: 8.5
            height: 11
            borderWidth: 0.5
            borderColor: #666666
        }
        columnHeadings {
            fontWeight: normal
            backgroundColor: #9bafde
        }
        columns {
            backgroundColor: #efefef
        }

        savedReport 7209308 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CUSTOMERS (
                sequence: 7
            )

            displayColumn OPPORTUNITIES (
                sequence: 6
            )

            displayColumn PRODUCT_DESCRIPTION (
                sequence: 5
            )

            displayColumn PRODUCT_FAMILY_ID (
                sequence: 3
            )

            displayColumn PRODUCT_NAME (
                sequence: 1
            )

            displayColumn PRODUCT_SKU (
                sequence: 4
            )

            displayColumn ROW_KEY (
                sequence: 2
            )

            sort (
                column: PRODUCT_NAME
                sort {
                    sequence: 1
                }
            )

        )

    )

    region products-report (
        name: Products Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                with base_products as (
                  select p.id,
                    p.product_name,
                    p.row_key, 
                    p.product_sku,
                    p.product_family_id,
                    p.updated,
                    (
                      select count(*)
                      from eba_sales_deals
                      where id in (
                        select deal_id
                        from eba_sales_deal_products
                        where product_id = p.id
                      )
                    ) opportunities,
                    (
                      select count(*)
                      from eba_sales_customers
                      where id in (
                        select customer_id
                        from eba_sales_deals
                        where id in (
                          select deal_id
                          from eba_sales_deal_products
                          where product_id = p.id
                        )
                      )
                    ) customers
                  from eba_sales_products p
                )
                select *
                from base_products
                where :P68_DISPLAY_AS = 'REPORT'
                  and (
                    :P68_ACCOUNT_ID is null 
                      or id in (
                        select product_id
                        from eba_sales_deal_products dp
                        where deal_id in (
                          select id
                          from eba_sales_deals
                          where customer_id = :P68_ACCOUNT_ID
                        )
                      )
                  )
                  and (
                    :P68_QUARTER is null 
                      or id in (
                        select product_id
                        from eba_sales_deal_products dp
                        where deal_id in (
                          select id
                          from eba_sales_deals
                          where qtr = :P68_QUARTER
                        )
                      )   
                  )
                  and (
                    :P68_SEARCH is null
                      or instr(upper(product_name), upper(:P68_SEARCH)) > 0
                      or instr(upper(row_key), upper(:P68_SEARCH)) > 0
                      or instr(upper(product_sku), upper(:P68_SEARCH)) > 0
                      or instr(opportunities, upper(:P68_SEARCH)) > 0
                      or instr(customers, upper(:P68_SEARCH)) > 0
                      or instr(upper(apex_util.get_since(updated)), upper(:P68_SEARCH)) > 0
                  )
                ```
            pageItemsToSubmit: [
                P68_SEARCH
                P68_ACCOUNT_ID
                P68_QUARTER
                P68_DISPLAY_AS
                P68_SORT
            ]
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: report_region
            customAttributes: style="display:none"
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column CUSTOMERS (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Accounts
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column OPPORTUNITIES (
            reportColumnQueryId: 7
            derivedColumn: N
            type: link
            heading {
                heading: Opportunities
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
            link {
                target: {
                    page: 135
                    items: {
                        IR_PRODUCT_ID: #ID#
                    }
                    clearCache: [
                        RIR
                        CIR
                    ]
                    action: resetPagination
                }
                linkText: #OPPORTUNITIES#
            }
        )

        column PRODUCT_FAMILY_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Family
            }
            lov {
                type: sharedComponent
                lov: @product-families
            }
            layout {
                sequence: 4
            }
        )

        column PRODUCT_NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            type: link
            heading {
                heading: Product
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 61
                    items: {
                        P61_ID: #ID#
                    }
                    clearCache: 61
                    action: resetPagination
                }
                linkText: #PRODUCT_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column PRODUCT_SKU (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: SKU
            }
            layout {
                sequence: 5
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 3
            }
        )

        column UPDATED (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

    pageItem P68_ACCOUNT_ID (
        type: selectList
        label {
            label: Account
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @accounts
            displayExtraValues: false
            nullDisplayValue: - All -
        }
        layout {
            sequence: 30
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
    )

    pageItem P68_DISPLAY_AS (
        type: radioGroup
        label {
            label: Display
            alignment: left
        }
        settings {
            noOfCols: 4
        }
        lov {
            type: sharedComponent
            lov: @pill-display-as
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @page-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        default {
            type: static
            staticValue: CARDS
        }
        sessionState {
            storage: user
        }
        security {
            escapeSpecialChars: false
        }
    )

    pageItem P68_QUARTER (
        type: selectList
        label {
            label: Quarter
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select	 distinct d.qtr d, d.qtr r
                 from	 "EBA_SALES_DEALS" d
                where d.qtr is not null
                order by substr(d.qtr,3), substr(d.qtr,1,2)
                ```
            nullDisplayValue: - All -
        }
        layout {
            sequence: 40
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
    )

    pageItem P68_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 10
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
            ]
            icon: fa-search
            width: 30
            valuePlaceholder: Search Products
        }
        validation {
            maxLength: 4000
        }
    )

    pageItem P68_SORT (
        type: selectList
        label {
            label: Sort
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Product;NAME,Opportunities;OPPORTUNITIES,Customers;CUSTOMERS,Updated;UPDATED
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 50
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        default {
            type: static
            staticValue: NAME
        }
        sessionState {
            storage: user
        }
    )

    button manage-products (
        buttonName: MANAGE_PRODUCTS
        label: Manage Products
        layout {
            sequence: 10
            region: @products
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 4
                clearCache: 4
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @filters
            slot: close
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: definedByDynamicAction
        }
        advanced {
            htmlDomId: reset_button
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @products-grid
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    RIR
                    CIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

