        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                items: {
                    IRNE_STATUS_CODE: \Opportunity Closed / Lost\
                }
                clearCache: RIR
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button upload (
        buttonName: UPLOAD
        label: Upload Data
        layout {
            sequence: 120
            region: @opportunities
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
                t-Button--gapLeft
            ]
            icon: fa-upload
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 210
                clearCache: 210
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    dynamicAction refresh-on-add (
        name: Refresh on add
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @create-deal
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @opportunities-cards
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @opportunities-report
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-3 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @opportunities-grid
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

)

