    pageItem P7_REP_MANAGER_ID (
        type: selectList
        label {
            label: Manager
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select REP_LAST_NAME||', '||rep_first_name display_value, ID return_value 
                from eba_sales_SALESREPS
                where id != nvl(:P7_ID,0)
                order by 1
                ```
            displayExtraValues: false
            nullDisplayValue: - Select a Manager -
        }
        layout {
            sequence: 50
            region: @rep-title-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: REP_MANAGER_ID
            used: always
