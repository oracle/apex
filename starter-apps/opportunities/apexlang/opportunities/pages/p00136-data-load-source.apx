page 136 (
    name: Data Load Source
    alias: DATA-LOAD-SOURCE
    title: Data Load Source
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: <p>This wizard allows the uploading of accounts into this application. Two options are provided to upload data, by uploading a comma separated file (.CSV), or to copy and paste data directly into the page. The second step maps database column names with the uploaded data. The third step, shows the data after lookups keys have been detected and validated. Row keys that match are updated, otherwise the opportunity is added. Lookup codes that do not match are not inserted or updated and are ignored.</p>
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region data-load-source (
        name: Data Load Source
        type: staticContent
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
        }
        settings {
            outputAs: text
        }
    )

    region data-load-wizard-progress (
        name: Data Load Wizard Progress
        type: list
        source {
            list: @data-load-wizard-progress-upload-accounts
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            listTemplate: @/wizard-progress
            templateOptions: [
                #DEFAULT#
                t-WizardSteps--displayLabels
            ]
        }
    )

    pageItem P136_APP_DATE_FORMAT (
        type: radioGroup
        label {
            label: Date / Number Formats to use
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @date-format-opt
            displayNullValue: false
        }
        layout {
            sequence: 150
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Y
        }
        help {
            helpText: Choose whether to provide custom or to use standard format masks
        }
    )

    pageItem P136_CHAR_SET (
        type: selectList
        label {
            label: File Character Set
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @data-load-charset
            displayNullValue: false
        }
        layout {
            sequence: 140
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        default {
            type: static
            staticValue: UTF-8
        }
        help {
            helpText: DATA_LOAD.CHAR_SET_ITEM_HELP
        }
    )

    pageItem P136_COPY_PASTE (
        type: textarea
        label {
            label: Copy and Paste Delimited Data
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 15
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 80
            height: 10
        }
        advanced {
            customAttributes: spellcheck="false"
        }
    )

    pageItem P136_CURRENCY (
        type: textField
        label {
            label: Currency Symbol
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 130
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 2
        }
        validation {
            maxLength: 2
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select value
                  from nls_session_parameters
                 where parameter = 'NLS_CURRENCY'
                ```
        }
        default {
            type: static
            staticValue: $
        }
        help {
            helpText: If your data contains international currency symbol, enter it here. For example, if your data has "&euro;1,234.56" or "&yen;1,234.56", enter "&euro;" or "&yen;".  Otherwise the data will not load correctly.
        }
    )

    pageItem P136_DECIMAL_CHARACTER (
        type: textField
        label {
            label: Decimal Character
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 110
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 2
        }
        validation {
            maxLength: 2
        }
        source {
            type: expression
            plsqlExpression: apex_application.get_nls_decimal_separator
        }
        help {
            helpText:
                ```html
                <p>The decimal character separates the integer and decimal parts of a number.</p>
                <p> Any character can be the decimal character. The character specified must be single-byte, and the decimal character must be different from group separator. The character can be a space, but cannot be any numeric character or any of the following characters:</p>
                <ul class="noIndent">
                <li>plus (+)</li>
                <li>hyphen (-)</li> 
                <li>less than sign (<)</li>
                <li>greater than sign (>)</li> 
                </ul>
                ```
        }
    )

    pageItem P136_ENCLOSED_BY (
        type: textField
        label {
            label: Optionally Enclosed By
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 40
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 2
        }
        validation {
            maxLength: 2
        }
        default {
            type: static
            staticValue: "
        }
        help {
            helpText: Enter a delimiter character. You can use this character to delineate the starting and ending boundary of a data value. If you specify a delimiter character, Data Workshop ignores whitespace occurring before the starting and ending boundary of a data value. You can also use this option to enclose a data value with the specified delimiter character.
        }
    )

    pageItem P136_FILE_NAME (
        type: fileUpload
        label {
            label: File Name
            alignment: right
        }
        storage {
            type: appTempFiles
            purgeFileAt: endOfRequest
        }
        layout {
            sequence: 20
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
        }
        help {
            helpText: Name of the file to upload
        }
    )

    pageItem P136_FIRST_ROW (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:First Row has Column Names;Y
        }
        layout {
            sequence: 50
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Y
        }
        help {
            helpText: Select this box if your data contains column names in the first row.
        }
    )

    pageItem P136_GROUP_SEPARATOR (
        type: textField
        label {
            label: Group Separator
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 120
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            width: 2
        }
        validation {
            maxLength: 2
        }
        source {
            type: expression
            plsqlExpression: apex_application.get_nls_group_separator
        }
        help {
            helpText:
                ```html
                <p>A group separator is a character that separates integer groups, for example to show thousands and millions.</p>
                <p>Any character can be the group separator. The character specified must be single-byte, and the group separator must be different from any other decimal character. The character can be a space, but cannot be a numeric character or any of the following:</p>
                <ul class="noIndent">
                <li>plus (+)</li>
                <li>hyphen (-)</li> 
                <li>less than sign (<)</li>
                <li>greater than sign (>)</li> 
                </ul>
                ```
        }
    )

    pageItem P136_IMPORT_FROM (
        type: radioGroup
        label {
            label: Import From
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @data-load-option
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        default {
            type: static
            staticValue: PASTE
        }
    )

    pageItem P136_SEPARATOR (
        type: textField
        label {
            label: Separator
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 30
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 2
        }
        validation {
            valueRequired: true
            maxLength: 2
        }
        default {
            type: static
            staticValue: \t
        }
        help {
            helpText: Identify a column separator character. Use <code>\t</code> for tab separators.
        }
    )

    pageItem P136_SHOW_ADV_SETTINGS (
        type: checkboxGroup
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Use Advanced Settings;Y
        }
        layout {
            sequence: 55
            region: @data-load-source
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        help {
            helpText:
                ```html
                Display advanced settings for data loading: Currency Symbol, Decimal Characters, File Encoding or Date Formats
                
                ```
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @data-load-source
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 33
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 20
            region: @data-load-source
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.widget.textareaClob.uploadNonEmpty('P136_COPY_PASTE', 'NEXT');
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction import-from-copy-and-paste (
        name: Import From Copy and Paste
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P136_IMPORT_FROM
        }
        clientSideCondition {
            type: item=value
            item: P136_IMPORT_FROM
            value: PASTE
        }

        action native-hide (
            action: hide
            settings {
                hidePageItemsOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P136_COPY_PASTE
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: \t
            }
            affectedElements {
                selectionType: items
                items: P136_SEPARATOR
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            settings {
                showAllOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P136_COPY_PASTE
            }
            execution {
                sequence: 20
            }
        )

    )

    dynamicAction import-from-file (
        name: Import from File
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P136_IMPORT_FROM
        }
        clientSideCondition {
            type: item=value
            item: P136_IMPORT_FROM
            value: UPLOAD
        }

        action native-hide (
            action: hide
            settings {
                hidePageItemsOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P136_FILE_NAME
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                value: ,
            }
            affectedElements {
                selectionType: items
                items: P136_SEPARATOR
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-show (
            action: show
            settings {
                showAllOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P136_FILE_NAME
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction show-hide-advanced-settings (
        name: Show/Hide Advanced Settings
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P136_SHOW_ADV_SETTINGS
        }
        clientSideCondition {
            type: item=value
            item: P136_SHOW_ADV_SETTINGS
            value: Y
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: [
                    P136_CURRENCY
                    P136_GROUP_SEPARATOR
                    P136_DECIMAL_CHARACTER
                    P136_APP_DATE_FORMAT
                    P136_CHAR_SET
                ]
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: [
                    P136_CURRENCY
                    P136_GROUP_SEPARATOR
                    P136_DECIMAL_CHARACTER
                    P136_APP_DATE_FORMAT
                    P136_CHAR_SET
                ]
            }
            execution {
                sequence: 10
            }
        )

    )

    validation filename-is-not-null (
        name: Filename is not null
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P136_FILE_NAME
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P136_FILE_NAME
        }
        serverSideCondition {
            whenButtonPressed: @next
            type: item=value
            item: P136_IMPORT_FROM
            value: UPLOAD
        }
    )

    validation uploaded-data-is-not-null (
        name: Uploaded data is not null
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNotNull
            item: P136_COPY_PASTE
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P136_COPY_PASTE
        }
        serverSideCondition {
            whenButtonPressed: @next
            type: item=value
            item: P136_IMPORT_FROM
            value: PASTE
        }
    )

    process parse-uploaded-data (
        name: Parse Uploaded Data
        type: parseUploadedData
        dataLoading {
            dataLoadDefinition: @upload-accounts
        }
        sourceData {
            importFromItem: P136_IMPORT_FROM
            fileNameItem: P136_FILE_NAME
            copyAndPasteItem: P136_COPY_PASTE
            charSetItem: P136_CHAR_SET
            dateFormatItem: P136_APP_DATE_FORMAT
        }
        parsingOptions {
            separatorItem: P136_SEPARATOR
            enclosedByItem: P136_ENCLOSED_BY
            firstRowItem: P136_FIRST_ROW
            currencySymbolItem: P136_CURRENCY
            groupSeparatorItem: P136_GROUP_SEPARATOR
            decimalCharItem: P136_DECIMAL_CHARACTER
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 8466790136784226255
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 137
            }
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

)

