    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button next (
        buttonName: NEXT
        label: Create Opportunity
        layout {
            sequence: 10
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
            icon: fa-chevron-right
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cancel-clicked (
        name: Cancel clicked
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction show-hide-existing-account-item (
        name: show hide existing account item
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P71_NEW_OR_EXISTING
        }
        clientSideCondition {
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: EXISTING
        }

        action native-hide (
            action: hide
            settings {
                hidePageItemsOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P71_ACCOUNT
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P71_ACCOUNT
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            settings {
                showAllOnSameLine: true
            }
            affectedElements {
                selectionType: items
                items: P71_ACCOUNT
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction show-hide-new-account-region (
        name: show hide new account region
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P71_NEW_OR_EXISTING
        }
        clientSideCondition {
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: NEW
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @new-account
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P71_CUSTOMER_NAME
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @new-account
            }
            execution {
                sequence: 10
            }
        )

    )

    validation p71-account-not-null-when-existing (
        name: P71_ACCOUNT not null when existing
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P71_ACCOUNT
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P71_ACCOUNT
        }
        serverSideCondition {
            whenButtonPressed: @next
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: EXISTING
        }
    )

    validation p71-customer-name-not-duplicated (
        name: P71_CUSTOMER_NAME not duplicated
        execution {
            sequence: 40
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_sales_customers
                where upper(customer_name) = upper(:P71_CUSTOMER_NAME)
                ```
        }
        error {
            errorMessage: An account with that name already exists.
            associatedItem: @P71_CUSTOMER_NAME
        }
        serverSideCondition {
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: NEW
        }
    )

    validation p71-customer-name-not-null-when-new (
        name: P71_CUSTOMER_NAME not null when new
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNotNull
            item: P71_CUSTOMER_NAME
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P71_CUSTOMER_NAME
        }
        serverSideCondition {
            whenButtonPressed: @next
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: NEW
        }
    )

    validation p71-opportunity-name-not-duplicated (
        name: P71_OPPORTUNITY_NAME not duplicated
        execution {
            sequence: 30
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_sales_deals
                where upper(deal_name) = upper(:P71_OPPORTUNITY_NAME)
                ```
        }
        error {
            errorMessage: An opportunity with that name already exists.
            associatedItem: @P71_OPPORTUNITY_NAME
        }
    )

    validation p71-territory-id-not-null (
        name: P71_TERRITORY_ID not null
        execution {
            sequence: 50
        }
        validation {
            type: itemIsNotNull
            item: P71_TERRITORY_ID
        }
        error {
            errorMessage: #LABEL# must have some value.
            associatedItem: @P71_TERRITORY_ID
        }
        serverSideCondition {
            type: item=value
            item: P71_NEW_OR_EXISTING
            value: NEW
        }
    )

    validation valid-tag-characters (
        name: Valid Tag Characters
        execution {
            sequence: 60
        }
        validation {
            plsqlExpression: "not regexp_like( :P71_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P71_TAGS
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    validation valid-tag-characters-opportunity (
        name: Valid Tag Characters Opportunity
        execution {
            sequence: 70
        }
        validation {
            plsqlExpression: "not regexp_like( :P71_OPP_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P71_OPP_TAGS
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    process clear-session-data (
        name: Clear Session Data
        type: clearSessionState
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 7957990420757602394
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 7957990506257602395
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    process create-opportunity (
        name: create opportunity
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_account_id   number;
                    l_opp_id       number;
                    
                    la_product     apex_application_global.vc_arr2;
                    la_team        apex_application_global.vc_arr2;
                    la_competition apex_application_global.vc_arr2;
                begin
                    if :P71_NEW_OR_EXISTING = 'NEW' then
                        insert into eba_sales_customers (
                        customer_name,
                        customer_territory_id,
                        customer_web_site,
                        customer_duns,
                        customer_sic,
                        customer_stock_symb,
                        customer_is_key_account_yn,
                        default_rep_id,
                        customer_description,
                        tags              
                        )
                        values (
                        :P71_CUSTOMER_NAME,
                        :P71_TERRITORY_ID,
                        :P71_CUSTOMER_WEB_SITE,
                        :P71_CUSTOMER_DUNS,
                        :P71_CUSTOMER_SIC,
                        :P71_CUSTOMER_STOCK_SYMB,
                        :P71_CUSTOMER_IS_KEY_ACCOUNT_YN,
                        :P71_DEFAULT_REP_ID,
                        :P71_CUSTOMER_DESCRIPTION,
                        :P71_TAGS
                        ) returning id into l_account_id;
                    else
                        l_account_id := :P71_ACCOUNT;
                    end if;
                    
                    insert into EBA_SALES_DEALS (
                    DEAL_NAME,
                    CUSTOMER_ID,
                    SALESREP_ID_01,
                    DEAL_AMOUNT,
                    DEAL_CLOSE_DATE,
                    DEAL_STATUS_CODE_ID,
                    SPONSOR_CONTACT_ID,
                    VP_ID,
                    DEAL_SUMMARY,
                    TAGS,
                    SVP_ID
                    )
                    values (
                    :P71_OPPORTUNITY_NAME,
                    l_account_id,
                    :P71_SALESREP,
                    :P71_AMOUNT,
                    :P71_CLOSE_DATE,
                    :P71_STATUS,
                    :P71_SPONSOR_CONTACT_ID,
                    :P71_SVP,
                    :P71_DEAL_SUMMARY,
                    :P71_OPP_TAGS,
                    :P71_SVP
                    )
                    returning id into l_opp_id;
                    
                    :P71_OPP_ID := l_opp_id; -- used to branch later
                    
                -- The code below is remarked out because this functionality was removed from the wizard
