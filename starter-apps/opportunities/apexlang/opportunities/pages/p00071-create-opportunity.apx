page 71 (
    name: Create Opportunity
    alias: CREATE-OPPORTUNITY
    title: Create Opportunity
    pageGroup: @opportunities
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/wizard-modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <style>
            
            a.simpleButton{display:inline-block;padding:0 8px;font:normal 11px/20px Arial,sans-serif;color:#666;background-color:#F0F0F0;border:1px solid #CCC;text-align:center;-moz-border-radius:4px;-webkit-border-radius:4px;border-radius:8px; text-decoration: none !important}
            a.simpleButton:hover {background-color: #FFF}
            </style>
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: wizardButtons
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region new-account (
        name: New Account
        type: staticContent
        layout {
            sequence: 20
            slot: wizardBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region opportunity-information (
        name: Opportunity Information
        type: staticContent
        layout {
            sequence: 10
            slot: wizardBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region other-opportunity-attributes (
        name: Other Opportunity Attributes
        type: staticContent
        layout {
            sequence: 1210
            slot: wizardBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    pageItem P71_ACCOUNT (
        type: popupLov
        label {
            label: Account
            alignment: left
        }
        settings {
            displayAs: modalDialog
        }
        lov {
            type: sharedComponent
            lov: @accounts
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @opportunity-information
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            maxLength: 4000
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P71_AMOUNT (
        type: numberField
        label {
            label: Amount
            alignment: left
        }
        settings {
            minValue: 1
            maxValue: 10000000000
            numberAlignment: end
            virtualKeyboard: text
        }
        layout {
            sequence: 50
            region: @other-opportunity-attributes
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            formatMask: FML999G999G999G999G999
            width: 32
            valuePlaceholder: $0
        }
        validation {
            valueRequired: true
            maxLength: 50
        }
        default {
            type: static
            staticValue: 0
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        config {
            buildOption: !@opportunity-amount-set-at-product-level
        }
    )

    pageItem P71_CLOSE_DATE (
        type: datePicker
        label {
            label: Close Date
            alignment: left
        }
        layout {
            sequence: 60
            region: @other-opportunity-attributes
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        default {
            type: functionBody
            plsqlFunctionBody: return to_char((sysdate + 90),'&APP_DATE_FORMAT.');
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        config {
            buildOption: !@product-level-close-dates
        }
    )

    pageItem P71_CUSTOMER_DESCRIPTION (
        type: textarea
