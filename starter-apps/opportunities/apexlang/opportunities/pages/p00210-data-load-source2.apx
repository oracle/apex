page 210 (
    name: Data Load Source
    alias: DATA-LOAD-SOURCE2
    title: Data Load Source
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            function set_item()
            {
            $x('P210_COPY_PASTE').value= $v('P210_SAMPLE_DATA');
            $x('P210_SEPARATOR').value= ',';
            $s('P210_FIRST_ROW', 'Y');
            }
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText:
            ```html
            <p>This wizard allows the uploading of opportunities into this application. Two options are provided to upload data, by uploading a comma separated file (.CSV), or to copy and paste data directly into the page.  The second step maps database column names with the uploaded data.  The third step, shows the data after lookups keys have been detected and validated.  Row keys that match are updated, otherwise the opportunity is added.  Lookup codes that do not match are not inserted or updated and are ignored.</p>
            <p>To see how it works, click the <strong>Try Sample Data</strong> button and then the <strong>Next</strong> button.</p>
            ```
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 60
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region data-load-process-train (
        name: Data Load Process Train
        type: list
        source {
            list: @data-load-process-train-load-opportunities
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/wizard-container
            templateOptions: [
                #DEFAULT#
                t-Wizard--hideStepsSmall
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            listTemplate: @/wizard-progress
            templateOptions: [
                #DEFAULT#
                t-WizardSteps--displayLabels
            ]
        }
    )

    region data-load-source (
        name: Data Load Source
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
            regionDisplaySelector: true
        }
    )

    region globalization (
        name: Globalization
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @data-load-source
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        advanced {
            customAttributes: style="width:100%;max-width:none;"
        }
    )

    region loading-data-from-spreadsheets (
        name: Loading Data From Spreadsheets
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>To load or update opportunity data from a spreadsheet follow these instructions:</p> 
                
                
                <ol>
                <li>Organize data in a spreadsheet with column headings of "Row Key" (for updates), "Account", "Opportunity Name", "Close Date", "Deal Amount", and so forth. </li>
                
                <li>Ensure the various code values match the codes defined in this application.  Administrators of this application can define code values.  The current values are displayed on this page for reference.</li>
                
                <li>Once you have your data organized in your spreadsheet you can export the data to CSV format (recommended for larger data sets), or simply cut and paste the data (including column headings) into the text field on this page.</li>
                
                <li>Follow the wizard and load your data.</li>
                </ol>
                
                ```
        }
        layout {
            sequence: 10
            parentRegion: @data-load-source
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-expanded
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region loading-sample-data (
        name: Loading Sample Data
        type: staticContent
        source {
            htmlCode:
                ```html
                <p>Click the <strong>Try Sample Data</strong> button to test data loading functionality.  The sample data has 5 columns. The first record uses the Row Key to perform an update. If the Opportunity Row Key is not AACN then it will be treated as an insert.</p> 
                </p>
                
                <table summary="sample data" class="uReport uReportStandard">
                  <thead>
                    <tr>
                      <th>Row Key</th>
                      <th>Account</th>
                      <th>Opportunity Name</th>
                      <th>Close Date</th>
                      <th>Deal Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>AACN</td>
                      <td>ACME Guardians</td>
                      <td>Change Account from Lexington Exports to ACME</td>
                      <td>01-JAN-2016</td>
                      <td>54321</td>
                    </tr>
                    <tr>
                      <td></td>
                      <td>ACME Gaurdians</td>
                      <td>New Opportunity for ACME</td>
                      <td></td>
                      <td>22333</td>
                    </tr>
                    <tr>
                      <td></td>
                      <td>army</td>
                      <td>New tank equipment (Note the account name is lower case instead of upper case)</td>
                      <td>01-JAN-2016</td>
                      <td>50000</td>
                    </tr>
                    <tr>
                      <td></td>
                      <td>Department of energy</td>
                      <td>Solar and wind equipment</td>
                      <td></td>
                      <td>100000</td>
                    </tr>
                  </tbody>
                </table>
                
                ```
        }
        layout {
            sequence: 20
            parentRegion: @data-load-source
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region valid-account-standings (
        name: Valid Account Standings
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select standing_text standing
                ,      standing_description description
                from eba_sales_account_standing
                order by display_order
                ```
        }
        layout {
            sequence: 80
            parentRegion: @data-load-source
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: -
        }
        pagination {
            type: setPaginationSelectList
        }

        column DESCRIPTION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column STANDING (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Standing
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region valid-accounts (
        name: Valid Accounts
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select customer_name account
                from eba_sales_customers
                order by upper(customer_name)
                ```
        }
        layout {
            sequence: 30
            parentRegion: @data-load-source
            slot: subRegions
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: -
        }
        pagination {
            type: setPaginationSelectList
        }

        column ACCOUNT (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Account
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region valid-risks (
