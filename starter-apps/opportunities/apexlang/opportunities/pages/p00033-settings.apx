    region acl-info (
        name: ACL Info
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                    l_acl_enabled varchar2(45);
                    l_acl_scope   varchar2(45);
                begin
                    l_acl_enabled := eba_sales_acl_api.get_preference_value('ACCESS_CONTROL_ENABLED');
                    l_acl_scope   := eba_sales_acl_api.get_preference_value('ACCESS_CONTROL_SCOPE');
                
                    if l_acl_enabled = 'N' then
                        sys.htp.p(apex_lang.message('ACL_DISABLED'));
                    else
                        case l_acl_scope
                            when 'ACL_ONLY' then sys.htp.p(apex_lang.message('ACL_ENABLED'));
                            when 'PUBLIC_CONTRIBUTE' then sys.htp.p(apex_lang.message('ACL_PUBLIC_CONTRIBUTE'));
                            when 'PUBLIC_READONLY' then sys.htp.p(apex_lang.message('ACL_PUBLIC_READONLY'));
                        end case;
                    end if;
                end;
                ```
        }
        layout {
            sequence: 45
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--horizontal
                t-Alert--noIcon
                t-Alert--warning
                t-Alert--accessibleHeading
                margin-top-sm
                margin-bottom-sm
                margin-left-sm
                margin-right-sm
            ]
        }
    )

    region acl-status (
        name: ACL Status
        type: plugin/aclStatus
        source {
            sqlQuery:
                ```sql
                select 
                  sum(case when access_level_id = 1 then 1 else 0 end) reader_count,
                  sum(case when access_level_id = 2 then 1 else 0 end) contributor_count,
                  sum(case when access_level_id = 3 then 1 else 0 end) admin_count,
                  sum(case when access_level_id = 0 then 1 else 0 end) pending_count
                from eba_sales_users
                ```
        }
        layout {
            sequence: 35
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: never
        }
        security {
            authorizationScheme: @administration-rights
        }
        settings {
            configurationPage: 113
            aclPage: 115
            administratorCountColumn: ADMIN_COUNT
            contributorCountColumn: CONTRIBUTOR_COUNT
            readerCountColumn: READER_COUNT
            scopePreferenceValue: eba_sales_fw.get_preference_value('ACCESS_CONTROL_SCOPE')
            aclEnabledPreference: eba_sales_fw.get_preference_value('ACCESS_CONTROL_ENABLED')
        }
    )

