page 8 (
    name: Territories
    alias: TERRITORIES2
    title: Territories
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Accounts are organized into territories. Each account must be in one and only one territory. Territory's facilitate reporting and organization of opportunities. Click the <strong>Create Territory</strong> button to create a new territory. Click the pencil icon in the report to edit any specific territory's details. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
    }
    config {
        buildOption: @territories
    }

    region territories (
        name: Territories
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id, 
                  territory_name,
                  initcap(replace(territory_type, '_', ' ')) territory_type,
                  territory_description,
                  (
                    select count(*) 
                    from eba_sales_customers 
                    where customer_territory_id = t.id
                  ) accounts,
                  (
                    select count(*) 
                    from eba_sales_deals 
                    where customer_id in (
                      select id 
                      from eba_sales_customers 
                      where customer_territory_id = t.id
                    )
                  ) opportunities,
                  (
                    select count(*) 
                    from eba_sales_states s
                    join eba_sales_terr_map m 
                      on s.id = m.state_id
                    where m.territory_id = t.id
                  ) states,
                  (
                    select svp_name 
                    from eba_sales_svps svp 
                    where svp.id = t.svp_id
                  ) default_svp,
                  created,
                  lower(created_by) created_by,
                  updated,
                  lower(updated_by) updated_by
                from eba_sales_territories t
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 9
                items: {
                    P9_ID: #ID#
                }
                clearCache: 9
                action: resetPagination
            }
            linkIcon: <span class="fa fa-edit" aria-hidden="true"></span>
            linkAttributes: title="Edit #TERRITORY_NAME#"
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 3737039726578743932
        }

        column ACCOUNTS (
            type: plainText
            heading {
                heading: Accounts
                alignment: end
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: D
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: H
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column DEFAULT_SVP (
            type: plainText
            heading {
                heading: SVP
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column OPPORTUNITIES (
            type: plainText
            heading {
                heading: Opportunities
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: E
            }
        )

        column STATES (
            type: plainText
            heading {
                heading: States
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column TERRITORY_DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column TERRITORY_NAME (
            type: plainText
            heading {
                heading: Territory
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column TERRITORY_TYPE (
            type: plainText
            heading {
                heading: Type
            }
            layout {
                sequence: 11
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 21
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: L
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated by
            }
            layout {
                sequence: 31
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        savedReport 9094860 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn ACCOUNTS (
                sequence: 3
            )

            displayColumn DEFAULT_SVP (
                sequence: 6
            )

            displayColumn OPPORTUNITIES (
                sequence: 4
            )

            displayColumn STATES (
                sequence: 5
            )

            displayColumn TERRITORY_NAME (
                sequence: 1
            )

            displayColumn TERRITORY_TYPE (
                sequence: 2
            )

            sort (
                column: TERRITORY_NAME
                sort {
                    sequence: 1
                }
            )

        )

    )

    button create-territory (
        buttonName: CREATE_TERRITORY
        label: Create Territory
        layout {
            sequence: 20
            region: @territories
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 9
                clearCache: 9
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @territories
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 8
                clearCache: [
                    8
                    RIR
                    CIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dialog-closed (
        name: Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Action Processed.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @territories
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

