    region records-changed-by-another-user (
        name: Records Changed by Another User.
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select n001 as row_num,
                       c049 as action,
                       c048 as error,
                       c001, c002, c003,
                       c004, c005, c006,
                       c007, c008, c009,
                       c010, c011, c012,
                       c013, c014, c015,
                       c016, c017, c018,
                       c019, c020, c021,
                       c022, c023, c024,
                       c025, c026, c027,
                       c028, c029, c030,
                       c031, c032, c033,
                       c034, c035, c036,
                       c037, c038, c040,
                       c041, c042, c043,
                       c044, c045
                  from apex_collections
                 where collection_name = 'LOAD_CONTENT'
                   and c049 in ('REVIEW') 
                 order by seq_id
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: data-upload-result
        }
        advanced {
            customAttributes: "style=\"width:100%;max-width:none;\" "
        }
        serverSideCondition {
            type: itemIsNotNullAndNotZero
            item: P143_REVIEW_COUNT
        }
        componentAppearance {
            templateType: predefined
        }
        pagination {
            type: setPaginationSelectList
            partialPageRefresh: false
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }
        heading {
            type: plsqlFunctionBody
            plsqlFunctionBody:
                ```plsql
                declare  
                    l_string varchar(32667);
                begin
                    l_string := wwv_flow_lang.system_message('DATA_LOAD.SEQUENCE_ACTION');
                    l_string := l_string ||':'|| wwv_flow_lang.system_message('ERROR');
                    for l_heading in ( select c005 as label
                                         from apex_collections
                                        where collection_name = 'LOAD_COL_HEAD'
                                        order by seq_id )
                    loop
                        l_string := l_string || ':' || apex_escape.html(l_heading.label);
                    end loop;
                    return l_string;
                end;
                ```
        }

