    pageItem P143_ERROR_COUNT (
        type: displayOnly
        label {
            label: Failed Row(s):
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 30
            region: @data-load-results
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select count(*) c from apex_collections where collection_name = 'LOAD_CONTENT' and c047 = 'FAILED'
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

