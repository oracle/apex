            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
        advanced {
            htmlDomId: search_btn
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 116
                successMessage: false
            }
        }
        comments {
            comments: Created 14-DEC-2011 09:16 by SHAKEEB
        }
