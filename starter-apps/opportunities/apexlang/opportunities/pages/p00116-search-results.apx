    )

    pageItem P116_INCLUDE (
        type: checkboxGroup
        label {
            label: Include
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @search-page-include-options
            displayExtraValues: false
        }
        layout {
            sequence: 20
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        default {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                if apex_util.get_build_option_status(
                  p_application_id    => :APP_ID,
                  p_build_option_name => 'Territories'
                ) = 'INCLUDE'
                then
                  return 'LEADS:OPPORTUNITIES:TERRITORIES:ACCOUNTS:CONTACTS:PRODUCTS';
                else
                  return 'LEADS:OPPORTUNITIES:ACCOUNTS:CONTACTS:PRODUCTS';
                end if;
                ```
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P116_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
