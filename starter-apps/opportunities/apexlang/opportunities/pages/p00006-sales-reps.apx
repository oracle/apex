page 6 (
    name: &REP_TITLE.s
    alias: SALES-REPS
    title: &REP_TITLE_RAW.s
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Manage your team. Click the pencil icon to edit a specific team member. Click the <strong>Create</strong> button to create a new team member. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
    }

    region rep-title-s (
        name: &REP_TITLE.s
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.id, 
                  r.rep_last_name,
                  r.rep_first_name,
                  r.rep_email,
                  (
                    select rep_first_name || ' ' || rep_last_name
                    from eba_sales_salesreps m
                    where m.id = r.rep_manager_id
                  ) as manager,
                  r.rep_office,
                  r.rep_office_phone,
                  r.rep_cell_phone,
                  r.rep_pager,
                  srr.role_name role,
                  case
                    when srr.is_sales_rep = 'Y'
                    then 'Yes'
                    else 'No'
                  end is_sales_rep,
                  r.created,
                  r.created_by,
                  r.updated,
                  r.updated_by
                from eba_sales_salesreps r
                left join eba_sales_salesrep_roles srr
                  on srr.id = r.rep_role
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 7
                items: {
                    P7_ID: #ID#
                }
                clearCache: 7
                action: resetPagination
            }
            linkIcon: <span class="fa fa-edit" aria-hidden="true"></span>
            linkAttributes: title="Edit"
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 3737702211060074440
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 42
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: P
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created by
            }
            layout {
                sequence: 52
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Q
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Edit
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column IS_SALES_REP (
            type: plainText
            heading {
                heading: &REP_TITLE. Role
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column MANAGER (
            type: plainText
            heading {
                heading: Manager
            }
            layout {
                sequence: 32
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column REP_CELL_PHONE (
            type: plainText
            heading {
                heading: Cell Phone
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        column REP_EMAIL (
            type: plainText
            heading {
                heading: Email
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column REP_FIRST_NAME (
            type: plainText
            heading {
                heading: First Name
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column REP_LAST_NAME (
            type: plainText
            heading {
                heading: Last Name
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column REP_OFFICE (
            type: hidden
            heading {
                heading: Office
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
            security {
                escapeSpecialChars: false
            }
        )

        column REP_OFFICE_PHONE (
            type: plainText
            heading {
                heading: Office Phone
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column REP_PAGER (
            type: hidden
            heading {
                heading: Pager
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ROLE (
            type: plainText
            heading {
                heading: Role
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 62
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: R
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated by
            }
            layout {
                sequence: 72
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: S
            }
        )

        savedReport 9101486 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn IS_SALES_REP (
                sequence: 5
            )

            displayColumn MANAGER (
                sequence: 6
            )

            displayColumn REP_EMAIL (
                sequence: 3
            )

            displayColumn REP_FIRST_NAME (
                sequence: 1
            )

            displayColumn REP_LAST_NAME (
                sequence: 2
            )

            displayColumn ROLE (
                sequence: 4
            )

            sort (
                column: REP_FIRST_NAME
                sort {
                    sequence: 1
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Create &REP_TITLE.
        layout {
            sequence: 30
            region: @rep-title-s
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 7
                clearCache: 7
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @rep-title-s
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: #DEFAULT#
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
                request: RIR
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dialog-closed (
        name: Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Action Processed.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @rep-title-s
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

