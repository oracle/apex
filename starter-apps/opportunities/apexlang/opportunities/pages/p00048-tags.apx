page 48 (
    name: Tags
    alias: TAGS
    title: Tags
    pageGroup: @reports
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText:
            ```html
            This page shows tags with click through to tag references.
            
            
            ```
    }

    region account-tags (
        name: Account Tags
        type: plugin/tagCloud
        source {
            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'ACCOUNT'
                  and tag_count > 0
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        settings {
            linkTarget: {
                page: 2
                items: {
                    IRC_TAGS: #TAG#
                }
            }
        }
        messages {
            whenNoDataFound: No tags found.
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region contact-tags (
        name: Contact Tags
        type: plugin/tagCloud
        source {
            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'CONTACT'
                  and tag_count > 0
                ```
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        settings {
            linkTarget: {
                page: 23
                items: {
                    IRC_TAGS: #TAG#
                }
            }
        }
        messages {
            whenNoDataFound: No tags found.
        }
    )

