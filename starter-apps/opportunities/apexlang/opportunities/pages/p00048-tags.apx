            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'DEAL'
                  and tag_count > 0
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        settings {
            linkTarget: {
                page: 1
                items: {
                    IRC_TAGS: #TAG#
                }
            }
        }
        messages {
            whenNoDataFound: No tags found.
        }
    )

    region product-tags (
        name: Product Tags
        type: plugin/tagCloud
        source {
            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'PRODUCT'
                  and tag_count > 0
                ```
