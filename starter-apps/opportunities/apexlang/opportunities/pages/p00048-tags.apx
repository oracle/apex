    region territory-tags (
        name: Territory Tags
        type: plugin/tagCloud
        source {
            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'TERRITORY'
                  and tag_count > 0
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        config {
            buildOption: @territories
        }
        settings {
            linkTarget: {
                page: 1
                items: {
                    IRC_TAGS: #TAG#
