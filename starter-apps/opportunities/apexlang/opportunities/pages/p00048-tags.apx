        source {
            sqlQuery:
                ```sql
                select tag, 
                  tag_count
                from eba_sales_tags_type_sum
                where content_type = 'LEAD'
                  and tag_count > 0
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: #DEFAULT#
        }
        settings {
            linkTarget: {
                page: 2
                items: {
                    IRC_TAGS: #TAG#
                }
            }
        }
        messages {
            whenNoDataFound: No tags found.
        }
    )

