        }
        settings {
            rememberSelection: false
        }
    )

    region usage-metrics-90-days (
        name: Usage Metrics - 90 days
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select count(*) c,
                  'Views' l,
                  1 disp
                from eba_sales_clicks
                where lead_id = :P133_ID 
                  and view_timestamp > sysdate - 90
                union all
                select count(distinct(app_username)) c,
                    'Users' l,
                    2 disp
                from eba_sales_clicks
                where lead_id = :P133_ID 
                    and view_timestamp > sysdate - 90
                order by disp
                ```
        }
        layout {
            sequence: 30
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @usage-metrics
        }
        settings {
            badgeStyle: circular
            value: C
            bottomLabel: L
            linkTarget: {
                page: 138
                items: {
                    P138_ENTITY_TYPE: LEAD
                    P138_ENTITY_ID: &P133_ID.
                }
                clearCache: 138
            }
            layout: 2Columns
        }
    )

    region validations (
        name: Validations
        type: plugin/contentValidator
        source {
            sqlQuery:
                ```sql
                select v.verified_by,
                  v.created
                from eba_sales_verifications v
                where lead_id = :P133_ID
                order by v.created desc
                ```
        }
        layout {
            sequence: 20
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hiddenOverflow
            ]
            cssClasses: js-validateRegion
        }
        config {
            buildOption: @validations
        }
        settings {
            validationLink: {
                page: 146
                items: {
                    P146_ENTITY_TYPE: LEAD
                    P146_ENTITY_ID: &P133_ID.
                }
                clearCache: 146
            }
            previousValidationsLink: {
                page: 147
                items: {
                    P147_ENTITY_TYPE: LEAD
                    P147_ENTITY_ID: &P133_ID.
                }
                clearCache: 147
                action: resetPagination
            }
        }
    )

