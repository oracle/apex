    dynamicAction edit-lead-dialog-closed (
        name: Edit Lead dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 29
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.t-Breadcrumb-item.is-active > span').text(this.data.P29_LEAD_NAME_01);
                    apex.message.showPageSuccess('Action Processed.');
                    ```
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @lead-details
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction link-details-dialog-closed (
        name: Link Details dialog closed
        execution {
            sequence: 50
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 114
        }
    )

    dynamicAction refresh-validations (
        name: Refresh Validations
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId ===130
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @validations
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process init-page (
        name: Init page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_sales_clicks (
                  entity_type,
                  lead_id,
                    app_username
                ) values (
                  'LEAD',
                  :P133_ID,
                    lower(:APP_USER)
                );
                
                delete from eba_sales_clicks 
                where view_timestamp < (sysdate - 90) 
                  and lead_id = :P133_ID;
                
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 7378375536519605013
        }
    )

)

