page 61 (
    name: Product
    alias: PRODUCT
    title: Product
    pageGroup: @products
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Manage an product's details, links, attachments, and/or comments. You can also validate the product.
    }
    config {
        buildOption: @products
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region product (
        name: Product
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.id,
                  p.product_name,
                  p.product_family_id,
                  p.row_key, 
                  p.product_sku,
                  p.product_description,
                  p.created,
                  lower(p.created_by) created_by,
                  p.updated,
                  lower(p.updated_by) updated_by
                from eba_sales_products p
                where p.id = :P61_ID
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: -
        }

        column CREATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #CREATED# by #CREATED_BY#
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column PRODUCT_DESCRIPTION (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 6
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                    from eba_sales_products p
                    where p.id = :P61_ID
                    and p.product_description is not null
                    ```
            }
        )

        column PRODUCT_FAMILY_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Family
            }
            lov {
                type: sharedComponent
                lov: @product-families
            }
            layout {
                sequence: 4
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                    from eba_sales_products p
                    where p.id = :P61_ID
                    and p.product_family_id is not null
                    ```
            }
        )

        column PRODUCT_NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
        )

        column PRODUCT_SKU (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: SKU
            }
            layout {
                sequence: 5
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                    from eba_sales_products p
                    where p.id = :P61_ID
                    and p.product_sku is not null
                    ```
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 3
            }
        )

        column UPDATED (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #UPDATED# by #UPDATED_BY#
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

    )

    region product-actions (
        name: Product Actions
        type: list
        source {
            list: @actions-product
        }
        layout {
            sequence: 10
            slot: rightSideColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/links-list
            templateOptions: [
                #DEFAULT#
                t-LinksList--actions
                t-LinksList--showTopIcons
            ]
        }
    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            rememberSelection: false
        }
    )

    region summary (
        name: Summary
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select d, 
                  c
                from (
                  select 'Accounts' d, 
                    count(*) c, 
                    1 s
                  from eba_sales_customers
                  where id in (
                    select customer_id
                    from eba_sales_deals
                    where id in (
                      select deal_id
                      from eba_sales_deal_products
                      where product_id = :P61_ID
                    )
                  )
                  union all
                  select 'Opportunities' d, count(*) c, 2 s
                  from eba_sales_deals
                  where id in (
                    select deal_id
                    from eba_sales_deal_products
                    where product_id = :P61_ID
                  )
                  union all
                  select 'Open Opportunities' d, count(*) c, 3 s
                  from eba_sales_deals
                  where deal_probability != 0 and deal_probability != 100
                    and id in (
                      select deal_id
                      from eba_sales_deal_products
                      where product_id = :P61_ID
                    )
                )
                order by s
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            value: C
            bottomLabel: D
        }
    )

    region usage-metrics-90-days (
        name: Usage Metrics - 90 days
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select count(*) c,
                  'Views' l,
                  1 disp
                from eba_sales_clicks
                where product_id = :P61_ID 
                  and view_timestamp > sysdate - 90
                union all
                select count(distinct(app_username)) c,
                    'Users' l,
                    2 disp
                from eba_sales_clicks
                where product_id = :P61_ID 
                    and view_timestamp > sysdate - 90
                order by disp
                ```
        }
        layout {
            sequence: 50
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @usage-metrics
        }
        settings {
            badgeStyle: circular
            value: C
            bottomLabel: L
            linkTarget: {
                page: 138
                items: {
                    P138_ENTITY_TYPE: PRODUCT
                    P138_ENTITY_ID: &P61_ID.
                }
                clearCache: 138
            }
            layout: 2Columns
        }
    )

    region validations (
        name: Validations
        type: plugin/contentValidator
        source {
            sqlQuery:
                ```sql
                select v.verified_by,
                  v.created
                from eba_sales_verifications v
                where product_id = :P61_ID
                order by v.created desc
                ```
        }
        layout {
            sequence: 40
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--stacked
                t-Region--hiddenOverflow
            ]
            cssClasses: js-validateRegion
        }
        config {
            buildOption: @validations
        }
        settings {
            validationLink: {
                page: 146
                items: {
                    P146_ENTITY_TYPE: PRODUCT
                    P146_ENTITY_ID: &P61_ID.
                }
                clearCache: 146
            }
            previousValidationsLink: {
                page: 147
                items: {
                    P147_ENTITY_TYPE: PRODUCT
                    P147_ENTITY_ID: &P61_ID.
                }
                clearCache: 147
                action: resetPagination
            }
        }
    )

    pageItem P61_ID (
        type: hidden
        layout {
            sequence: 10
            region: @product
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button pop-link (
        buttonName: POP_LINK
        label: Add Link
        layout {
            sequence: 240
            region: @/links
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 114
                items: {
                    P114_ENTITY_TYPE: PRODUCT
                    P114_ENTITY_ID: &P61_ID.
                }
                clearCache: 114
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button popattachment (
        buttonName: POPATTACHMENT
        label: Add Attachment
        layout {
            sequence: 10
            region: @/attachments
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 99
                items: {
                    P99_ENTITY_TYPE: PRODUCT
                    P99_ENTITY_ID: &P61_ID.
                }
