            region: @/links
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-external-link-square
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 89
                items: {
                    P89_ENTITY_TYPE: PRODUCT
                    P89_ENTITY_ID: &P61_ID.
                }
                clearCache: 89
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction link-details-dialog-closed (
        name: Link Details dialog closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 114
        }
    )

    process init-page (
        name: Init page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_sales_clicks (
                  entity_type,
                  product_id,
                    app_username
                ) values (
                  'PRODUCT',
                  :P61_ID,
                    lower(:APP_USER)
                );
                
                delete from eba_sales_clicks 
                where view_timestamp < (sysdate - 90) 
                  and product_id = :P61_ID;
                ```
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 6661028942656044654
        }
    )

)

