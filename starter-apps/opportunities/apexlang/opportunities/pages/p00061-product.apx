        label: View Comments
        layout {
            sequence: 270
            region: @/comments
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-external-link-square
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 88
                items: {
                    P88_ENTITY_TYPE: PRODUCT
