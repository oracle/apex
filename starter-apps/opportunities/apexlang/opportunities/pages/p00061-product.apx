                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 22
                items: {
                    P22_ENTITY_TYPE: PRODUCT
                    P22_ENTITY_ID: &P61_ID.
                }
                clearCache: 22
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button view-attachments (
        buttonName: VIEW_ATTACHMENTS
        label: View Attachments
        layout {
            sequence: 20
            region: @/attachments
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-external-link-square
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 92
                items: {
                    P92_ENTITY_TYPE: PRODUCT
                    P92_ENTITY_ID: &P61_ID.
                }
                clearCache: 92
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button view-comments (
