    dynamicAction add-country-dialog-closed (
        name: Add Country dialog closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 124
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @countries
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction add-state-dialog-closed (
        name: Add State dialog closed
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 126
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @states
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction edit-territory-dialog-closed (
        name: Edit Territory dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @edit-territory
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $('.t-Breadcrumb-item.is-active > span').text(this.data.P9_TERRITORY_NAME);
            }
            affectedElements {
                selectionType: region
                region: @breadcrumb
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @territory
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction validate-dialog-closed (
        name: Validate dialog closed
        execution {
            sequence: 60
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 146
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @validations
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
