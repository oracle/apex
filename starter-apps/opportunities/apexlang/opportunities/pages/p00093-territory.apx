page 93 (
    name: Territory
    alias: TERRITORY
    title: Territory
    pageGroup: @territories
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline: .tooltip-hint .t-Icon { color: rgba(0,0,0,.5); vertical-align: top; }
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Manage a territory's country assignment, state assignment, links, attachments, and/or comments. You can also validate the territory.
    }
    config {
        buildOption: @territories
    }

    region accounts (
        name: Accounts
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.customer_name,
                  case customer_is_key_account_yn
                    when 'Y' then 'Yes'
                    when 'N' then 'No'
                  end key_account,
                  c.id
                from eba_sales_customers c
                where customer_territory_id = :P93_ID
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No accounts are associated with this territory, click the "+" icon to add an account
        }
        breakFormatting {
            reportSumLabel: &nbsp;
        }
        componentAdvanced {
            stripHtml: true
        }

        column CUSTOMER_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: Account
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_ID: #ID#
                    }
                    clearCache: 94
                    action: resetPagination
                }
                linkText: #CUSTOMER_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column KEY_ACCOUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Key
                alignment: center
            }
            layout {
                sequence: 2
                columnAlignment: center
            }
        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region countries (
        name: Countries
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.country_name,
                  m.created added_date, 
                  c.country_code,
                  lower(m.created_by) added_by
                from eba_sales_countries c
                join eba_sales_terr_map m
                  on m.country_id = c.id
                where m.territory_id = :P93_ID
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No countries are associated with this territory, click the "+" icon to add a country
        }
        componentAdvanced {
            stripHtml: true
        }

        column ADDED_BY (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column ADDED_DATE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 3
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #ADDED_DATE# by #ADDED_BY#
            }
        )

        column COUNTRY_CODE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Code
            }
            layout {
                sequence: 2
            }
        )

        column COUNTRY_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Country
            }
            layout {
                sequence: 1
            }
            sorting {
                defaultSequence: 1
            }
        )

    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 20
            slot: masterDetail
        }
        settings {
            rememberSelection: false
        }
    )

    region states (
        name: States
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select s.state, 
                  m.created date_added, 
                  lower(m.created_by) added_by
                from eba_sales_states s
                join eba_sales_terr_map m
                  on m.state_id = s.id
                where m.territory_id = :P93_ID
                ```
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No states are associated with this territory, click the "+" icon to add a state
        }
        componentAdvanced {
            stripHtml: true
        }

        column ADDED_BY (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column DATE_ADDED (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #DATE_ADDED# by #ADDED_BY#
            }
        )

        column STATE (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: State
            }
            layout {
                sequence: 1
            }
            sorting {
                defaultSequence: 1
            }
        )

    )

    region summary (
        name: Summary
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select d, c
                from (  select 'Accounts' d, count(*) c, 1 s
                        from eba_sales_customers c
                        where customer_territory_id = :P93_ID
                        union all
                        select 'Opportunities' d, count(*) c, 2 s
                        from eba_sales_deals
                        where CUSTOMER_ID in
                               (select id from eba_sales_customers where CUSTOMER_TERRITORY_ID = :P93_ID)
                        union all
                        select 'Open Opportunities' d, count(*) c, 3 s
                        from eba_sales_deals
                        where deal_probability != 0 and deal_probability != 100 and CUSTOMER_ID in
                               (select id from eba_sales_customers where CUSTOMER_TERRITORY_ID = :P93_ID)
                    )
                order by s
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            topLabel: D
            value: C
        }
    )

    region territory (
        name: Territory
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.id, 
                  t.row_key,
                  territory_description,
                  created,
                  lower(created_by) created_by,
                  updated,
                  lower(updated_by) updated_by,
                  (
                    select svp_name 
                    from eba_sales_svps svp 
                    where svp.id = t.svp_id
                  ) svp_name,
                  territory_type
                from eba_sales_territories t
                where t.id = :P93_ID
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no territory found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #CREATED# by #CREATED_BY#
            }
            sorting {
                sortable: false
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column SVP_NAME (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: SVP
            }
            layout {
                sequence: 5
            }
        )

        column TERRITORY_DESCRIPTION (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column TERRITORY_TYPE (
            reportColumnQueryId: 9
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Type
            }
            lov {
                type: sharedComponent
                lov: @territory-types
            }
            layout {
                sequence: 3
            }
        )

        column UPDATED (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #UPDATED# by #UPDATED_BY#
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

    )

    region territory-actions (
        name: Territory Actions
        type: list
        source {
            list: @actions-territory
        }
        layout {
            sequence: 10
            slot: rightSideColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/links-list
            templateOptions: [
                #DEFAULT#
                t-LinksList--actions
                t-LinksList--showIcons
            ]
        }
    )

    region usage-metrics-90-days (
        name: Usage Metrics - 90 days
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select count(*) c,
                  'Views' l,
                  1 disp
                from eba_sales_clicks
                where territory_id = :P93_ID 
                  and view_timestamp > sysdate - 90
                union all
                select count(distinct(app_username)) c,
                  'Users' l,
                  2 disp
                from eba_sales_clicks
                where territory_id = :P93_ID 
                  and view_timestamp > sysdate - 90
                order by disp
                ```
        }
        layout {
            sequence: 80
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @usage-metrics
        }
        settings {
            badgeStyle: circular
            value: C
            bottomLabel: L
            linkTarget: {
                page: 138
                items: {
                    P138_ENTITY_TYPE: TERRITORY
                    P138_ENTITY_ID: &P93_ID.
                }
                clearCache: 138
            }
            layout: 2Columns
        }
    )

    region validations (
        name: Validations
        type: plugin/contentValidator
        source {
            sqlQuery:
                ```sql
                select v.verified_by,
                  v.created
                from eba_sales_verifications v
                where territory_id = :P93_ID
                order by v.created desc
                ```
