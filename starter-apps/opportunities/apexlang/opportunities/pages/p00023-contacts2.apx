                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 106
                items: {
                    P106_SHOW_ACCOUNT: Y
                }
                clearCache: 106
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

