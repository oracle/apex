                clearCache: [
                    RIR
                    CIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction create-contact-dialog-closed (
        name: Create Contact dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @create-contact
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var display = $v('P23_DISPLAY_AS');
                    
                    if (display === 'CARDS') {
                      $('#cards_region').trigger('apexrefresh');
                    } else if (display === 'REPORT') {
                      $('#report_region').trigger('apexrefresh');
                    } else if (display === 'GRID') {
                      $('#grid_region').trigger('apexrefresh');
                    }
                    
                    apex.message.showPageSuccess('Action Processed.');
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 23
        }
    )

)

