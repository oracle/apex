            backgroundColor: #efefef
        }

        savedReport 7219667 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACCOUNT (
                sequence: 4
            )

            displayColumn CONTACT_CELL (
                sequence: 7
            )

            displayColumn CONTACT_EMAIL (
                sequence: 5
            )

            displayColumn CONTACT_NAME (
                sequence: 1
            )

            displayColumn CONTACT_PHONE (
                sequence: 6
            )

            displayColumn CONTACT_TITLE (
                sequence: 2
            )

            displayColumn ROW_KEY (
                sequence: 3
            )

        )

    )

    region contacts-report (
        name: Contacts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select cc.id, 
                  cc.row_key,
                  cc.contact_name,
                  cc.contact_email,
                  cc.customer_id,
                  c.customer_name account,
                  cc.updated,
                  t.territory_name,
                  t.id territory_id
                from eba_sales_customer_contacts cc
                join eba_sales_customers c
                  on c.id = cc.customer_id
                join eba_sales_territories t
                  on t.id = c.customer_territory_id
                where :P23_DISPLAY_AS = 'REPORT'
                  and (
                    :P23_TERRITORY_ID is null 
                      or t.id = :P23_TERRITORY_ID
                  )
                  and (
                    :P23_ACCOUNT_ID is null 
                      or cc.customer_id = :P23_ACCOUNT_ID
                  )
                  and (
                    :P23_SEARCH is null
                      or instr(upper(cc.contact_name), upper(:P23_SEARCH)) > 0
                      or instr(upper(cc.row_key), upper(:P23_SEARCH)) > 0
                      or instr(upper(cc.contact_email), upper(:P23_SEARCH)) > 0
                      or instr(upper(c.customer_name), upper(:P23_SEARCH)) > 0
                      or instr(upper(t.territory_name), upper(:P23_SEARCH)) > 0
                      or instr(upper(apex_util.get_since(cc.updated)), upper(:P23_SEARCH)) > 0
                  )
                ```
            pageItemsToSubmit: [
                P23_SEARCH
                P23_TERRITORY_ID
                P23_ACCOUNT_ID
                P23_DISPLAY_AS
                P23_SORT
            ]
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: report_region
            customAttributes: style="display:none"
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No contacts found
        }

        column ACCOUNT (
            reportColumnQueryId: 6
            derivedColumn: N
            type: link
            heading {
                heading: Account
            }
            layout {
                sequence: 5
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_ID: #CUSTOMER_ID#
                    }
                    clearCache: 94
                    action: resetPagination
                }
                linkText: #ACCOUNT#
            }
        )

        column CONTACT_EMAIL (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Email
            }
            layout {
                sequence: 7
            }
        )

        column CONTACT_NAME (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Contact
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 24
                    items: {
                        P24_ID: #ID#
                    }
                    clearCache: 24
                    action: resetPagination
                }
                linkText: #CONTACT_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column CUSTOMER_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 3
            }
        )

        column TERRITORY_ID (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

        column TERRITORY_NAME (
            reportColumnQueryId: 8
            derivedColumn: N
            type: link
            heading {
                heading: Account Territory
            }
            layout {
                sequence: 6
            }
            link {
                target: {
                    page: 93
                    items: {
                        P93_ID: #TERRITORY_ID#
                    }
                    clearCache: 93
                    action: resetPagination
                }
                linkText: #TERRITORY_NAME#
            }
            serverSideCondition {
                type: expression
                plsqlExpression:
                    ```plsql
                    apex_util.get_build_option_status(
                      p_application_id    => :APP_ID,
                      p_build_option_name => 'Territories'
                    ) = 'INCLUDE'
                    ```
            }
        )

        column UPDATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

