    region support-amounts (
        name: Support Amounts
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    name,
                    close_date,
                    term_id,
                    amount_id,
                    quote_price,
                    created_by,
                    created,
                    updated_by,
                    updated
                from
                    EBA_SALES_CUST_SPT_AMT_MAP
                where
                    customer_id = :P94_ID;
                ```
            pageItemsToSubmit: P94_ID
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @support-amounts
        }
        reportLayout {
            numberOfRows: 5000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }

        column AMOUNT_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Support Amount
            }
            lov {
                type: sharedComponent
                lov: @support-amounts
            }
            layout {
                sequence: 3
            }
        )

        column CLOSE_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Close Date
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: DD-MON-YYYY
            }
        )

        column CREATED (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Account Support Amount
            }
            layout {
                sequence: 2
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from EBA_SALES_CUST_SPT_AMT_MAP m
                     where m.name not in (select distinct name from EBA_SALES_SUPPORT_AMTS where id = m.amount_id)
                      and m.customer_id = :P94_ID
                    ```
            }
        )

        column QUOTE_PRICE (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Quote Price
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G999
            }
        )

        column TERM_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Term
            }
            lov {
                type: sharedComponent
                lov: @terms-id-return-value
            }
            layout {
                sequence: 5
            }
        )

        column UPDATED (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 10
            }
            appearance {
                formatMask: SINCE
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Updated by
            }
            layout {
                sequence: 9
            }
        )

    )

    region usage-metrics-90-days (
        name: Usage Metrics - 90 days
        type: plugin/badgeList
        source {
            sqlQuery:
                ```sql
                select count(*) c,
                  'Views' l,
                  1 disp
                from eba_sales_clicks
                where cust_id = :P94_ID 
                  and view_timestamp > sysdate - 90
                union all
                select count(distinct(app_username)) c,
                    'Users' l,
                    2 disp
                from eba_sales_clicks
                where cust_id = :P94_ID 
                  and view_timestamp > sysdate - 90
                order by disp
                ```
        }
        layout {
            sequence: 100
            slot: rightSideColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @usage-metrics
        }
        settings {
            badgeStyle: circular
            value: C
            bottomLabel: L
            linkTarget: {
                page: 138
                items: {
                    P138_ENTITY_TYPE: ACCOUNT
                    P138_ENTITY_ID: &P94_ID.
                }
                clearCache: 138
            }
            layout: 2Columns
        }
    )

