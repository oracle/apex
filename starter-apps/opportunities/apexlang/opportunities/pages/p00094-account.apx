            }
        )

        column COUNTRY (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Country
            }
            layout {
                sequence: 6
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column CUSTOMER_POSTAL_CODE (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

        column CUSTOMER_TERRITORY_ID (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column LOCATION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Location
            }
            layout {
                sequence: 2
            }
            sorting {
                defaultSequence: 1
            }
        )

        column LOCATION_CREATED (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 9
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #LOCATION_CREATED# by #CREATED_BY#
            }
        )

        column STATE (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

    )

    region open-opportunities (
        name: Open Opportunities
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select	 
                   d.id,
                   (select sr."REP_LAST_NAME"||', '|| 
                	     sr."REP_FIRST_NAME" x
                	    from "EBA_SALES_SALESREPS" sr
                	    where sr.id = d.salesrep_id_01) REP_NAME,
                   d."DEAL_NAME",
                   d."DEAL_CLOSE_DATE",
                   (select sc."STATUS_CODE" 
                    from "EBA_SALES_DEAL_STATUS_CODES" sc 
                    where sc.id = d.DEAL_STATUS_CODE_ID) STATUS_CODE,
                   decode(d."DEAL_PROBABILITY",0,'No',100,'No',
                              decode(greatest(sysdate,d."DEAL_CLOSE_DATE"),
                              sysdate,'Yes','No')) overdue,
                    d.qtr as quarter
                from	 
                    "EBA_SALES_DEALS" d
                where   
                     d.CUSTOMER_ID = :P94_ID and
                     d."DEAL_PROBABILITY" > 0 and 
                     d."DEAL_PROBABILITY" < 100
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 50
        }
        messages {
            whenNoDataFound: No open opportunities found for this account
        }
        breakFormatting {
            reportSumLabel: &nbsp;
        }
        componentAdvanced {
            stripHtml: true
        }

        column DEAL_CLOSE_DATE (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column DEAL_NAME (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Opportunity
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 80
                    items: {
                        P80_ID: #ID#
                    }
                    clearCache: 80
                }
                linkText: #DEAL_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column OVERDUE (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 6
            }
        )

        column QUARTER (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Quarter
            }
            layout {
                sequence: 7
            }
        )

        column REP_NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: &REP_TITLE.
            }
            layout {
                sequence: 3
            }
        )

        column STATUS_CODE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Stage
            }
            layout {
                sequence: 5
            }
        )

    )

