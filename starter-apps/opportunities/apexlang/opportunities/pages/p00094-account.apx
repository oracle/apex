    process init-page (
        name: Init page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_sales_clicks (
                  entity_type,
                  cust_id,
                    app_username
                ) values (
                  'ACCOUNT',
                  :P94_ID,
                    lower(:APP_USER)
                );
                
                delete from eba_sales_clicks 
                where view_timestamp < (sysdate - 90) 
                  and cust_id = :P94_ID;
                ```
        }
        execution {
            sequence: 70
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 7378376165609613420
        }
    )

