    dynamicAction agreements-irr-dialog-closed (
        name: Agreements IRR dialog closed
        execution {
            sequence: 140
            eventScope: dynamic
        }
        when {
            event: custom
            customEvent: dialogclose
            selectionType: jQuerySelector
            jquerySelector: .view-agreements-dialog
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @agreements
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction competitors-irr-dialog-closed (
        name: Competitors IRR dialog closed
        execution {
            sequence: 130
            eventScope: dynamic
        }
        when {
            event: custom
            customEvent: dialogclose
            selectionType: jQuerySelector
            jquerySelector: .view-competition-dialog
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @competition
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction contacts-irr-dialog-closed (
        name: Contacts IRR dialog closed
        execution {
            sequence: 110
            eventScope: dynamic
        }
        when {
            event: custom
            customEvent: dialogclose
            selectionType: jQuerySelector
            jquerySelector: .view-contacts-dialog
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @contacts
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction link-details-dialog-closed (
        name: Link Details dialog closed
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 114
        }
    )

    dynamicAction locations-irr-dialog-closed (
        name: Locations IRR dialog closed
        execution {
            sequence: 120
            eventScope: dynamic
        }
        when {
            event: custom
            customEvent: dialogclose
            selectionType: jQuerySelector
            jquerySelector: .view-locations-dialog
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @locations
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-account-details (
        name: Refresh Account Details
        execution {
            sequence: 5
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
