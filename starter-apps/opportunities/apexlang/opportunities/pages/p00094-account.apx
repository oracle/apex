page 94 (
    name: Account
    alias: ACCOUNT
    title: Account
    pageGroup: @accounts
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Manage an account's contact information, competitors, locations, links, attachments, and/or comments. You can also validate the account.
    }

    region account (
        name: Account
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id,
                  c.row_key,
                    case customer_is_key_account_yn
                      when 'Y' then 'Yes'
                      when 'N' then 'No'
                    end key_account,
                  c.customer_stock_symb,
                  c.customer_duns,
                  c.secondary_rep,
                  c.customer_sic,
                  c.customer_industry_id as industry,
                  c.customer_web_site,
                  c.customer_facebook,
                  c.customer_linkedin,
                  c.customer_twitter,
                  c.customer_description,
                  c.tags,
                  c.created,
                  lower(c.created_by) created_by,
                  c.updated,
                  lower(c.updated_by) updated_by,
                  t.id territory_id,
                  t.territory_name,
                  case
                    when c.default_rep_id is not null
                    then (
                      select rep_first_name || ' ' || rep_last_name
                      from eba_sales_salesreps sr
                      where sr.id = c.default_rep_id
                    )
                  end default_rep
                from eba_sales_customers c
                left join eba_sales_territories t
                  on t.id = c.customer_territory_id
                where c.id = :P94_ID
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column CREATED (
            reportColumnQueryId: 15
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 17
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #CREATED# by #CREATED_BY#
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 16
            derivedColumn: N
            type: hidden
            layout {
                sequence: 18
            }
        )

        column CUSTOMER_DESCRIPTION (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 8
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_DESCRIPTION is not null
                    ```
            }
        )

        column CUSTOMER_DUNS (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: DUNS
            }
            layout {
                sequence: 11
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_DUNS is not null
                    ```
            }
        )

        column CUSTOMER_FACEBOOK (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Facebook
            }
            layout {
                sequence: 15
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_FACEBOOK is not null
                    ```
            }
        )

        column CUSTOMER_LINKEDIN (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: LinkedIn
            }
            layout {
                sequence: 14
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_LINKEDIN is not null
                    ```
            }
        )

        column CUSTOMER_SIC (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: SIC
            }
            layout {
                sequence: 12
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_SIC is not null
                    ```
            }
        )

        column CUSTOMER_STOCK_SYMB (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Stock Symbol
            }
            layout {
                sequence: 10
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customers
                     where id = :P94_ID
                       and CUSTOMER_STOCK_SYMB is not null
                    ```
            }
        )

        column CUSTOMER_TWITTER (
            reportColumnQueryId: 12
            derivedColumn: N
