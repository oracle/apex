                sequence: 1
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Account Agreement
            }
            layout {
                sequence: 2
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from EBA_SALES_CUST_AGRMNT_MAP m
                     where m.name not in (select distinct name from eba_sales_agreements where id = m.agreement_id)
                      and m.customer_id = :P94_ID
                    ```
            }
        )

        column QUOTE_PRICE (
            reportColumnQueryId: 6
            derivedColumn: N
