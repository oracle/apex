    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region competition (
        name: Competition
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                   (select COMPETITOR_NAME from EBA_SALES_COMPETITORS x where x.id = c.COMPETITOR_ID) competitor, 
                   (select COMPETITOR_THREAT  from EBA_SALES_COMPETITOR_THREATS x where x.id = c.COMPETITOR_THREAT_ID) threat, 
                   COMPETITION_DESC,
                   created AS "COMPETITION_CREATED",
                   lower(created_by) created_by
                from EBA_SALES_ACT_COMPETITION c
                where    CUSTOMER_ID = :P94_ID
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
                t-Form--labelsAbove
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @competitors
        }
        reportLayout {
            numberOfRows: 20
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
            showNullValuesAs: " "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No competitors identified, click "+" icon to add a competitor
        }
        componentAdvanced {
            stripHtml: true
        }

        column COMPETITION_CREATED (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #COMPETITION_CREATED# by #CREATED_BY#
            }
        )

        column COMPETITION_DESC (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 3
            }
        )

        column COMPETITOR (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Competitor
            }
            layout {
                sequence: 1
            }
            sorting {
                defaultSequence: 1
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

        column THREAT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Threat
            }
            layout {
                sequence: 2
            }
        )

    )

    region contacts (
        name: Contacts
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                	 "CONTACT_NAME" as "CONTACT",
                	 "CONTACT_EMAIL" as "EMAIL",
                	 "CONTACT_PHONE" as "PHONE",
                	 "CONTACT_CELL" as "CELL",
                	 "CONTACT_ADDRESS" as "CONTACT_ADDRESS",
                         created as "CONTACT_CREATED",
                         lower(created_by) created_by
                 from	 "EBA_SALES_CUSTOMER_CONTACTS" c
                where customer_id = :P94_ID
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
                t-Form--noPadding
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @contacts
        }
        reportLayout {
            numberOfRows: 500
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No contacts identified, click "+" icon to add a contact
        }
        componentAdvanced {
            stripHtml: true
        }

        column CELL (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

        column CONTACT (
            reportColumnQueryId: 2
            derivedColumn: N
            type: link
            heading {
                heading: Contact
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 24
                    items: {
                        P24_ID: #ID#
                    }
                    clearCache: 24
                    action: resetPagination
                }
                linkText: #CONTACT#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column CONTACT_ADDRESS (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 6
            }
        )

        column CONTACT_CREATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #CONTACT_CREATED# by #CREATED_BY#
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column EMAIL (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Email
            }
            layout {
                sequence: 3
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column PHONE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Phone
            }
            layout {
                sequence: 4
            }
        )

    )

    region locations (
        name: Locations
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                	CUSTOMER_LOCATION_NAME location,
                	CUSTOMER_ADDRESS1||
                        decode(CUSTOMER_ADDRESS2,null,null,' '|| CUSTOMER_ADDRESS2) address,
                        CUSTOMER_CITY city,
                        CUSTOMER_STATE state,
                	CUSTOMER_COUNTRY country,
                        CUSTOMER_POSTAL_CODE,
                        CUSTOMER_DESCRIPTION
                        CUSTOMER_TERRITORY_ID,
                        created as location_created,
                        lower(created_by) created_by
                 from	 "EBA_SALES_CUSTOMER_LOCATIONS"
                where customer_id = :P94_ID
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @account-locations
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 50
        }
        messages {
            whenNoDataFound: No locations identified, click "+" icon to add a customer location
        }
        componentAdvanced {
            stripHtml: true
        }

        column ADDRESS (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column CITY (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
