    region account-actions (
        name: Account Actions
        type: list
        source {
            list: @actions-account
        }
        layout {
            sequence: 10
            slot: rightSideColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/links-list
            templateOptions: [
                #DEFAULT#
                t-LinksList--actions
                t-LinksList--showIcons
            ]
        }
    )

    region agreements (
        name: Agreements
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    id,
                    name,
                    close_date,
                    term_id,
                    agreement_id,
                    quote_price,
                    created_by,
                    created,
                    updated_by,
                    updated
                from
                    EBA_SALES_CUST_AGRMNT_MAP
                where
                    customer_id = :P94_ID;
                ```
            pageItemsToSubmit: P94_ID
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @agreements
        }
        reportLayout {
            numberOfRows: 5000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }

        column AGREEMENT_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Agreement
            }
            lov {
                type: sharedComponent
                lov: @agreements
            }
            layout {
                sequence: 3
            }
        )

        column CLOSE_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Close Date
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: DD-MON-YYYY
            }
        )

        column CREATED (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
