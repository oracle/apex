page 125 (
    name: Territory States
    alias: TERRITORY-STATES
    title: States
    pageGroup: @territories
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText:
            ```html
            <p>
                To edit a state assignment, click the <strong>Edit</strong> icon (pencil) next to the country assignment. Click the <strong>Add State</strong> button to assign a new state to the territory. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
            </p>
            ```
    }
    config {
        buildOption: @territories
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region territory-states (
        name: Territory States
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select s.id,
                  m.state_id, 
                  s.state,
                  s.code,
                  m.created date_added, 
                  lower(m.created_by) added_by,
                  null remove_button 
                from eba_sales_states s, eba_sales_terr_map m
                where s.id = m.state_id
                and m.territory_id = :P125_TERRITORY_ID
                order by 1
                
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2538385322816516813
        }

        column ADDED_BY (
            type: plainText
            heading {
                heading: Added By
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column CODE (
            type: plainText
            heading {
                heading: Code
            }
            layout {
                sequence: 36
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column DATE_ADDED (
            type: plainText
            heading {
                heading: Added
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: B
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 26
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
            security {
                escapeSpecialChars: false
            }
        )

        column REMOVE_BUTTON (
            type: link
            heading {
                heading: Remove
                alignment: center
            }
            layout {
                sequence: 16
                columnAlignment: center
            }
            link {
                target: {
                    type: url
                    url: javascript:void(0);
                }
                linkText: <span class="t-Icon fa fa-trash-o"></span>
                linkAttributes: class="t-Button t-Button--small t-Button--noUI t-Button--danger js-removeTerritoryState" data-territory-state-id="#ID#"
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
            enableUsersTo {
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column STATE (
            type: plainText
            heading {
                heading: State
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column STATE_ID (
            type: hidden
            heading {
                heading: State Id
            }
            layout {
                sequence: 6
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: F
            }
            security {
                escapeSpecialChars: false
            }
        )

        savedReport 25383860 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn ADDED_BY (
                sequence: 4
            )

            displayColumn CODE (
                sequence: 2
            )

            displayColumn DATE_ADDED (
                sequence: 3
            )

            displayColumn REMOVE_BUTTON (
                sequence: 5
            )

            displayColumn STATE (
                sequence: 1
            )

            sort (
                column: DATE_ADDED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    pageItem P125_TERRITORY_ID (
        type: hidden
        layout {
            sequence: 10
            region: @territory-states
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P125_TERRITORY_STATE_ID (
        type: hidden
        layout {
            sequence: 20
            region: @territory-states
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button add-state (
        buttonName: ADD_STATE
        label: Add State
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 126
                items: {
                    P126_TERRITORY_ID: &P125_TERRITORY_ID.
                }
                clearCache: 126
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 10
            region: @territory-states
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 125
                clearCache: RIR
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction add-state-dialog-closed (
        name: Add State dialog closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @add-state
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('State Added');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @territory-states
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction remove-territory-state-button-clicked (
        name: Remove territory state button clicked
        execution {
            sequence: 10
            eventScope: dynamic
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: .js-removeTerritoryState
        }

        action native-confirm (
            action: confirm
            settings {
                message: Are you sure you want to remove this state from the territory?
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    delete from eba_sales_terr_map
                    where state_id = :P125_TERRITORY_STATE_ID;
                    ```
                itemsToSubmit: P125_TERRITORY_STATE_ID
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var id = $(this.triggeringElement).data('territory-state-id');
                    
                    $s('P125_TERRITORY_STATE_ID', id);
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code-2 (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('State Removed');
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @territory-states
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    computation p93-id (
        itemName: P93_ID
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: item
            itemName: P125_TERRITORY_ID
        }
    )

)

