    region territories-grid (
        name: Territories Grid
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.id, 
                  t.row_key,
                  territory_name,
                  t.tags,
                  (
                    select count(*)
                    from eba_sales_links
                    where territory_id = t.id
                  ) links,
                  (
                    select count(*)
                    from eba_sales_files
                    where territory_id = t.id
                  ) attachments,
                  (
                    select count(*)
                    from eba_sales_comments
                    where territory_id = t.id
                  ) comments,
                  (
                    select count(*)
                    from eba_sales_verifications
                    where territory_id = t.id
                  ) validations,
                  (
                    select max(created)
                    from eba_sales_verifications
                    where territory_id = t.id
                  ) last_validation,
                  (
                    select count(*)
                    from eba_sales_clicks
                    where territory_id = t.id
                      and view_timestamp >= sysdate - 90
                  ) views_90_days,
                    (   select count(distinct(app_username))
                        from eba_sales_clicks
                        where territory_id = t.id
                            and view_timestamp >= sysdate - 90
                    ) users_90_days,
                  created,
                  created_by,
                  updated,
                  updated_by,
                  territory_description description,
                  (
                    select count(*) 
                    from eba_sales_customers c
                    where t.id = c.customer_territory_id
                  ) accounts,
                  (
                    select count(*) 
                    from eba_sales_deals 
                    where customer_id in (
                      select id 
                      from eba_sales_customers 
                      where customer_territory_id = t.id
                    )
                  ) opportunities,
                  (
                    select count(*) 
                    from eba_sales_deals 
                    where deal_probability != 0 
                      and deal_probability != 100 
                      and customer_id in (
                        select id 
                        from eba_sales_customers 
                        where customer_territory_id = t.id
                      )
                  ) open_opportunities
                from eba_sales_territories t
                where :P50_DISPLAY_AS = 'GRID'
                ```
