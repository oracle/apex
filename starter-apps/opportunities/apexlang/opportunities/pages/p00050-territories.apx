    region territories-report (
        name: Territories Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                with base_territories as (
                  select t.id, 
                    t.row_key,
                    territory_name,
                    updated,
                    case 
                      when length(territory_description) < 50
                      then territory_description
                      when territory_description is not null
                      then substr(territory_description, 1, 50) || '...'
                    end description,
                    (
                      select count(*) 
                      from eba_sales_customers c
                      where t.id = c.customer_territory_id
                    ) accounts,
                    (
                      select count(*) 
                      from eba_sales_deals 
                      where customer_id in (
                        select id 
                        from eba_sales_customers 
                        where customer_territory_id = t.id
                      )
                    ) opportunities,
                    (
                      select count(*) 
                      from eba_sales_deals 
                      where deal_probability != 0 
                        and deal_probability != 100 
                        and customer_id in (
                          select id 
                          from eba_sales_customers 
                          where customer_territory_id = t.id
                        )
                    ) open_opportunities,
                    territory_description
                  from eba_sales_territories t
                  where :P50_DISPLAY_AS = 'REPORT'
                )
                select *
                from base_territories
                where (
                  :P50_SEARCH is null
                    or instr(upper(territory_name), upper(:P50_SEARCH)) > 0
                    or instr(upper(row_key), upper(:P50_SEARCH)) > 0
                    or instr(upper(territory_description), upper(:P50_SEARCH)) > 0
                    or instr(upper(accounts), upper(:P50_SEARCH)) > 0
                    or instr(upper(opportunities), upper(:P50_SEARCH)) > 0
                    or instr(upper(open_opportunities), upper(:P50_SEARCH)) > 0
                    or instr(upper(apex_util.get_since(updated)), upper(:P50_SEARCH)) > 0
                )
                ```
            pageItemsToSubmit: [
                P50_SEARCH
                P50_DISPLAY_AS
                P50_SORT
            ]
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: report_region
            customAttributes: style="display: none"
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }
        pagination {
            type: setPaginationSelectList
        }
        messages {
            whenNoDataFound: No territory found
        }

        column ACCOUNTS (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Accounts
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
        )

        column DESCRIPTION (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column OPEN_OPPORTUNITIES (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Open Opp.
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
            sorting {
                defaultSequence: 1
                direction: desc
            }
        )

        column OPPORTUNITIES (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Opportunities
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 3
            }
        )

        column TERRITORY_DESCRIPTION (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 9
            }
        )

        column TERRITORY_NAME (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Territory
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 93
                    items: {
                        P93_ID: #ID#
                    }
                    action: resetPagination
                }
                linkText: #TERRITORY_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column UPDATED (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

    pageItem P50_DISPLAY_AS (
        type: radioGroup
        label {
            label: Display
            alignment: left
        }
        settings {
            noOfCols: 4
        }
        lov {
            type: sharedComponent
            lov: @pill-display-as
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @page-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        default {
            type: static
            staticValue: CARDS
        }
        sessionState {
            storage: user
        }
        security {
            escapeSpecialChars: false
        }
    )

    pageItem P50_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            trimSpaces: none
            submitWhenEnterPressed: true
        }
        layout {
            sequence: 30
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
            ]
            icon: fa-search
            width: 30
            valuePlaceholder: Search Territories
        }
        validation {
            maxLength: 4000
        }
    )

    pageItem P50_SORT (
        type: selectList
        label {
            label: Sort
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Territory;NAME,Accounts;ACC,Open Opportunities;OPENOPP,Opportunities;OPP,Updated;UPDATED
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 50
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        default {
            type: static
            staticValue: NAME
        }
        sessionState {
            storage: user
        }
    )

    button manage-territory (
        buttonName: MANAGE_TERRITORY
        label: Manage Territories
        layout {
            sequence: 60
            region: @territories
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 8
                clearCache: 8
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button reset (
        buttonName: Reset
        label: Reset
        layout {
            sequence: 10
            region: @filters
            slot: close
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: definedByDynamicAction
        }
        advanced {
            htmlDomId: reset_button
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 70
            region: @territories-grid
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    RIR
                    CIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 50
        }
    )

)

