page 22 (
    name: Comment Details
    alias: COMMENT-DETAILS
    title: Comment Details
    pageGroup: @opportunities
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            //-->
            </script>
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region comment (
        name: Comment
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P22_ACCOUNT_ID (
        type: hidden
        layout {
            sequence: 110
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ACCOUNT_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_CONTACT_ID (
        type: hidden
        layout {
            sequence: 120
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: CONTACT_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_ENTITY_ID (
        type: hidden
        layout {
            sequence: 70
            region: @comment
            slot: regionBody
        }
        serverSideCondition {
            type: never
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_ENTITY_TYPE (
        type: hidden
        layout {
            sequence: 60
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ENTITY_TYPE
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_ID (
        type: hidden
        layout {
            sequence: 20
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_LEAD_ID (
        type: hidden
        layout {
            sequence: 90
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: LEAD_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_NOTE (
        type: textarea
        label {
            label: Note
            alignment: left
        }
        settings {
            resizable: false
            trimSpaces: none
        }
        layout {
            sequence: 40
            region: @comment
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
            ]
            height: 10
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: NOTE
            used: always
        }
    )

    pageItem P22_OPPORTUNITY_ID (
        type: hidden
        layout {
            sequence: 80
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: DEAL_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_PRODUCT_ID (
        type: hidden
        layout {
            sequence: 130
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: PRODUCT_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P22_TERRITORY_ID (
        type: hidden
        layout {
            sequence: 100
            region: @comment
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: TERRITORY_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 20
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Comment
        layout {
            sequence: 30
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P22_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 40
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P22_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P22_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            itemsToReturn: REQUEST
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 6563078785782594957
        }
    )

    process fetch-row-from-eba-sales-comments (
        name: Fetch Row from EBA_SALES_COMMENTS
        type: autoRowFetch
        source {
            tableName: EBA_SALES_COMMENTS
            pkColumn: ID
            pkItem: P22_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 10495875604094479107
        }
    )

    process process-row-of-eba-sales-comments (
        name: Process Row of EBA_SALES_COMMENTS
        type: autoRowProcessing
        target {
            tableName: EBA_SALES_COMMENTS
            pkColumn: ID
            pkItem: P22_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_SALES_COMMENTS.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10495875810748479110
        }
    )

    process proxy-p22-entity-id-on-create (
        name: Proxy P22_ENTITY_ID on create
        type: executeCode
        source {
            plsqlCode: apex_util.set_session_state('P22_' || :P22_ENTITY_TYPE || '_ID', :P22_ENTITY_ID);
        }
        execution {
            sequence: 10
            point: afterSubmit
        }
        advanced {
            executionMappingIdentifier: 6637008599821819664
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10495875993288479110
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

