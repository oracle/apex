    dynamicAction edit-lead-statuses-clicked (
        name: Edit lead statuses clicked
        execution {
            sequence: 40
        }
        when {
            event: click
            selectionType: button
            button: @edit-statuses
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: openModal('select_lead_statuses');
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction lead-status-changed (
        name: Lead Status changed
        execution {
            sequence: 20
        }
        when {
            selectionType: items
            items: P100_LEAD_STATUSES
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var $leadStatuses = $('#P100_LEAD_STATUSES'),
                      statuses = '';
                    
                    $leadStatuses.find(':checked').each(function(idx) {
                      if (idx > 0) {
                        statuses += ', ';
                      }
                    
                      statuses  += $leadStatuses.find('label[for="' + this.id + '"]').text();
                    });
                    
                    $s('P100_LEAD_STATUSES_DISPLAY', statuses || 'None', null, true);
                    ```
            }
            execution {
                sequence: 10
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @total-leads-by-source
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

