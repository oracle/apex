    region top-open-opportunities (
        name: Top Open Opportunities
        type: plugin/html5BarChart
        source {
            sqlQuery:
                ```sql
                select sd.id,
                  sd.deal_name || ' - '  || c.customer_name as deal_name,
                  case when apex_util.get_build_option_status(
                                p_application_id    => :APP_ID,
                                p_build_option_name => 'Opportunity Amount Set at Product Level'
                            ) = 'EXCLUDE' then
                      nvl(sd.deal_amount,0)
                  else
                      nvl((select sum(nvl(dp.quote_price, 0)) from EBA_SALES_DEAL_PRODUCTS dp where dp.deal_id = sd.id and (nvl(:P100_FY_PCD, 0) = 0 or :P100_FY_PCD = substr(dp.qtr, -2))),0)
                  end as deal_amount
                from eba_sales_deals sd
                join eba_sales_customers c
                  on sd.customer_id = c.id
                join eba_sales_deal_status_codes sdsc
                  on sd.deal_status_code_id = sdsc.id
                where sdsc.corresponding_prob_pct not in (0, 100)
                  and (
                          (apex_util.get_build_option_status(
                                    p_application_id    => :APP_ID,
                                    p_build_option_name => 'Opportunity Amount Set at Product Level'
                                ) = 'EXCLUDE'
                           and 
                           (nvl(:P100_FY_OCD, 0) = 0 or :P100_FY_OCD = substr(sd.qtr, -2))
                          )
                          or 
                          apex_util.get_build_option_status(
                                p_application_id    => :APP_ID,
                                p_build_option_name => 'Opportunity Amount Set at Product Level'
                          ) = 'INCLUDE'
                      )
                order by case when apex_util.get_build_option_status(
                             p_application_id    => :APP_ID,
                             p_build_option_name => 'Opportunity Amount Set at Product Level'
                         ) = 'EXCLUDE' then
                      nvl(sd.deal_amount,0)
                  else
                      nvl((select sum(nvl(dp.quote_price, 0)) from EBA_SALES_DEAL_PRODUCTS dp where dp.deal_id = sd.id and (nvl(:P100_FY_PCD, 0) = 0 or :P100_FY_PCD = substr(dp.qtr, -2))),0)
                  end desc
                
                ```
        }
        layout {
            sequence: 140
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: i-h400
        }
        config {
            buildOption: @show-top-open-opportunities-on-home-page
        }
        settings {
            labelColumn: DEAL_NAME
            valueColumn: DEAL_AMOUNT
            formatMask: 999G999G999G999G999G990
            labelLinkTarget: {
                page: 80
                items: {
                    P80_ID: &ID.
                }
                clearCache: 80
                action: resetPagination
            }
            textPosition: above
            colorScheme: default
            maximumRows: 50
        }
    )

    region total-leads-by-source (
        name: Total Leads by Source
        type: chart
        layout {
            sequence: 120
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: i-h400
            renderComponents: belowContent
        }
        config {
            buildOption: @leads
        }
        chartLayout {
            height: 330
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        tooltip {
            showSeriesName: false
            showValue: false
        }
        legend {
            show: false
        }

        series leads-by-source (
            name: Leads by source
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select nvl(sls.lead_source, 'Unidentified') lead_source,
                      count(*) cnt
                    from eba_sales_leads sl
                    left join eba_sales_lead_sources sls
                      on sl.lead_source_id = sls.id
                    where instr(':' || :P100_LEAD_STATUSES || ':', ':' || sl.lead_status_id || ':') > 0
                    group by sls.lead_source
                    order by cnt desc
                    ```
                pageItemsToSubmit: P100_LEAD_STATUSES
            }
            columnMapping {
                label: LEAD_SOURCE
                value: CNT
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
            }
            minorTicks {
                show: false
            }
        )

    )

