page 100 (
    name: Opportunities
    alias: HOME
    title: Opportunities
    pageGroup: @home
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText:
            ```html
            <h2>About this Application</h2>
            <p>
            	Manage opportunities, track leads, manage accounts and contacts. Opportunities are organized by territory and account. For each opportunity you can track products, competition, team members, and add hypertext links and file attachments. Use interactive reports to slice and dice your pipeline. You can upload leads from spreadsheets and convert leads to opportunities.
            </p>
            ```
    }

    region acl-warning (
        name: ACL Warning
        type: plugin/aclWarning
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--horizontal
                t-Alert--defaultIcons
                t-Alert--warning
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: expression
            plsqlExpression: EBA_sales_fw.get_preference_value('ACCESS_CONTROL_ENABLED') = 'N'
        }
        settings {
            administrationPageLink: {
                page: SETTINGS
                action: resetPagination
            }
        }
    )

    region filters (
        name: Filters
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
                t-Form--stretchInputs
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @opportunity-amount-set-at-product-level
        }
    )

    region home (
        name: Home
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region notifications (
        name: Notifications
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                decode(lower(NOTIFICATION_TYPE),'yellow','warning','red','danger',lower(NOTIFICATION_TYPE)) as ALERT_TYPE,
                    NOTIFICATION_NAME as ALERT_TITLE,
                    NOTIFICATION_DESCRIPTION as ALERT_DESC,
                    '' alert_action
                  from EBA_SALES_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                 order by nvl(DISPLAY_SEQUENCE,0),NOTIFICATION_NAME
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from EBA_SALES_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                ```
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/alerts
            templateOptions: #DEFAULT#
        }
        componentAdvanced {
            stripHtml: true
        }

        column ALERT_ACTION (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Alert action
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column ALERT_DESC (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Alert desc
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column ALERT_TITLE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Alert title
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column ALERT_TYPE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Alert type
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: ID
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region open-leads-by-status (
        name: Open Leads by Status
        type: chart
        layout {
            sequence: 110
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: i-h400
            renderComponents: belowContent
        }
        config {
            buildOption: @leads
        }
        chartLayout {
            height: 330
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        tooltip {
            showSeriesName: false
            showValue: false
        }
        legend {
            show: false
        }

        series leads-by-status (
            name: Leads by status
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select slsc.status_code,
                      slsc.display_order,
                      count(*) cnt
                    from eba_sales_leads sl
                    join eba_sales_lead_status_codes slsc
                      on sl.lead_status_id = slsc.id
                    where sl.lead_status_id not in (1, 5)
                    group by slsc.status_code,
                      slsc.display_order
                    order by slsc.display_order
                    ```
            }
            columnMapping {
                label: STATUS_CODE
                value: CNT
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            value {
                format: decimal
                decimalPlaces: 0
            }
            minorTicks {
                show: false
            }
        )

    )

    region opportunities (
        name: Opportunities
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                for c1 in ( select preference_value
                            from eba_sales_preferences
                            where preference_name = 'APPLICATION_SUBTITLE'
                            union all
                            select 'Manage Opportunities'
                            from dual
                            where not exists ( select null
                                               from eba_sales_preferences
                                               where preference_name = 'APPLICATION_SUBTITLE')
                          ) loop
                    sys.htp.p('<p>'||apex_escape.html(c1.preference_value)||'</p>');
                end loop;
                ```
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/hero
            templateOptions: [
                #DEFAULT#
                #DEFAULT#
            ]
            icon: app-opportunity-tracker
        }
    )

    region opportunity-pipeline (
        name: Opportunity Pipeline
        type: chart
        layout {
            sequence: 130
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: i-h400
            renderComponents: belowContent
        }
        config {
            buildOption: @show-opportunity-pipeline-on-home-page
        }
        chart {
            type: funnel
        }
        chartLayout {
            height: 330
        }
        dataCursor {
            dimOnHover: false
        }
        value {
            format: decimal
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series opportunity-pipeline (
            name: Opportunity Pipeline
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select sdsc.status_code,
                      sdsc.corresponding_prob_pct,
                      count(*) cnt
                    from eba_sales_deals sd
                    join eba_sales_deal_status_codes sdsc
                      on sd.deal_status_code_id = sdsc.id
                    where sdsc.corresponding_prob_pct != 0
                    group by sdsc.status_code,
                      sdsc.corresponding_prob_pct
                    order by sdsc.corresponding_prob_pct
                    ```
            }
            columnMapping {
                label: STATUS_CODE
                value: CNT
            }
            label {
                show: true
            }
        )

    )

    region revenue-by-product-family (
        name: Revenue By Product Family
        type: chart
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @opportunity-amount-set-at-product-level
        }
        chart {
            type: pie
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series revenue-by-product-family (
            name: Revenue By Product Family
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select
                           sum(case 
                               when :OPP_SET_PROD_LEV_BO = 'Include' then
                                   case when dp.term is null then nvl(dp.quote_price, 0) else nvl(dp.quote_price, 0) * dp.term/12 end
                           else
                                   d.deal_amount
                           end) as revenue,
                           pf.product_family
                      from eba_sales_deal_products dp,
                           eba_sales_products p,
                           eba_sales_product_families pf,
                           eba_sales_deals d
                     where dp.product_id = p.id
                       and dp.deal_id = d.id
                       and p.product_family_id = pf.id
                       and (
                               nvl(:P100_FY_PCD, 0) = 0
                               or
                               instr(dp.qtr, :P100_FY_PCD) > 0
                           )
                       and (
                               :P100_QUARTER is null
                               or
                               instr(:P100_QUARTER, substr(dp.qtr,1,2)) > 0
                           )
                       and (
                               nvl(:P100_SALES_MGR_ID, 0) = 0
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_01 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_02 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_03 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_04 and r.rep_manager_id = :P100_SALES_MGR_ID)
                           )
                       and (
                               :P100_TERRITORY_ID is null
                               or exists
                               (select null from eba_sales_customers a, eba_sales_territories t where d.customer_id = a.id and dp.deal_id = d.id and dp.product_id = p.id and p.product_family_id = pf.id and a.customer_territory_id = :P100_TERRITORY_ID)
                           )
                     group by pf.product_family
                    ```
            }
            columnMapping {
                label: PRODUCT_FAMILY
                value: REVENUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 135
                    items: {
                        IR_PRODUCT_FAMILY_ID: &PRODUCT_FAMILY.
                        IR_PFYO: &P100_FY_PCD.
                        IR_SALES_MGR: \&P100_SALES_MGR_NAME.\
                        IR_TERRITORY_NAME: &P100_TERRITORY_NAME.
                        IRIN_PQO: \&P100_QTR_NAME.\
                    }
                    clearCache: [
                        135
                        RIR
                    ]
                    action: resetPagination
                }
            }
            label {
                show: true
                displayAs: percentage
            }
        )

    )

    region revenue-by-product-type (
        name: Revenue By Product Type
        type: chart
        layout {
            sequence: 60
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @opportunity-amount-set-at-product-level
        }
        chart {
            type: pie
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            hideAndShowBehavior: none
        }

        series revenue-by-product-type (
            name: Revenue By Product Type
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select
                           sum(case 
                               when :OPP_SET_PROD_LEV_BO = 'Include' then
                                   case when dp.term is null then nvl(dp.quote_price, 0) else nvl(dp.quote_price, 0) * dp.term/12 end
                           else
                                   d.deal_amount
                           end) as revenue,
                           decode(p.sold_as, 'SUBSCRIPTION', 'Cloud Subscription', 'PURCHASE', 'On-Premise Purchase', p.sold_as) as product_type
                      from eba_sales_deal_products dp,
                           eba_sales_products p,
                           eba_sales_deals d
                     where dp.product_id = p.id
                       and dp.deal_id = d.id
                       and (
                               nvl(:P100_FY_PCD, 0) = 0
                               or
                               instr(dp.qtr, :P100_FY_PCD) > 0
                           )
                       and (
                               :P100_QUARTER is null
                               or
                               instr(:P100_QUARTER, substr(dp.qtr,1,2)) > 0
                           )
                       and (
                               nvl(:P100_SALES_MGR_ID, 0) = 0
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_01 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_02 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_03 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_04 and r.rep_manager_id = :P100_SALES_MGR_ID)
                           )
                       and (
                               :P100_TERRITORY_ID is null
                               or exists
                               (select null from eba_sales_customers a, eba_sales_territories t where d.customer_id = a.id and dp.deal_id = d.id and dp.product_id = p.id and a.customer_territory_id = :P100_TERRITORY_ID)
                           )
                     group by decode(p.sold_as, 'SUBSCRIPTION', 'Cloud Subscription', 'PURCHASE', 'On-Premise Purchase', p.sold_as)
                    ```
            }
            columnMapping {
                label: PRODUCT_TYPE
                value: REVENUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 135
                    items: {
                        IR_PRODUCT_TYPE: &PRODUCT_TYPE.
                        IR_PFYO: &P100_FY_PCD.
                        IR_SALES_MGR: \&P100_SALES_MGR_NAME.\
                        IR_TERRITORY_NAME: &P100_TERRITORY_NAME.
                        IRIN_PQO: \&P100_QTR_NAME.\
                    }
                    clearCache: [
                        135
                        RIR
                    ]
                    action: resetPagination
                }
            }
            label {
                show: true
                displayAs: percentage
            }
        )

    )

    region revenue-by-quarter (
        name: Revenue By Quarter
        type: chart
        layout {
            sequence: 80
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @opportunity-amount-set-at-product-level
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            show: false
        }

        series revenue-by-quarter (
            name: Revenue By Quarter
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    with qtrs as (
                        select level q
                        from dual
                        connect by level <= 4
                    ), data as (
                        select sum(case 
                                when :OPP_SET_PROD_LEV_BO = 'Include' then
                                    case when dp.term is null then nvl(dp.quote_price, 0) else nvl(dp.quote_price, 0) * dp.term/12 end
                                else d.deal_amount
                                end) as revenue,
                            dp.qtr as fiscal_quarter,
                            pf.product_family
                        from eba_sales_deals d
                            join eba_sales_customers c on c.id = d.customer_id
                            join eba_sales_deal_products dp on dp.deal_id = d.id
                            join eba_sales_products p on p.id = dp.product_id
                            join eba_sales_product_families pf on pf.id = p.product_family_id
                            left join eba_sales_territories t on t.id = c.customer_territory_id
                        where dp.qtr is not null
                            and ( nvl(:P100_FY_PCD, 0) = 0
                                or instr(dp.qtr, :P100_FY_PCD) > 0
                            )
                    /*      -- This doesn't work.
                            and ( nvl(:P100_QUARTER, 0) = 0
                                or substr(dp.qtr,1,2) = :P100_QUARTER
                            )*/
                    /*      -- This works, but I think we can do better.
                            and ( :P100_QUARTER is null
                               or instr(:P100_QUARTER, substr(dp.qtr,1,2)) > 0
                            )*/
                            and ( nvl(:P100_SALES_MGR_ID, 0) = 0
                                or exists ( select null
                                            from EBA_SALES_SALESREPS r
                                            where r.id = d.salesrep_id_01
                                                and r.rep_manager_id = :P100_SALES_MGR_ID )
                            )
                            and ( nvl(:P100_TERRITORY_ID, 0) = 0
                                or t.id = :P100_TERRITORY_ID
                            )
                        group by dp.qtr, pf.product_family
                    ), yrrng as (
                        select min(substr(data.fiscal_quarter,-2)) start_year, max(substr(data.fiscal_quarter,-2)) end_year
                        from data
                    ), yrs as (
                        select yrrng.start_year + (level - 1) y
                        from yrrng
                        connect by level <= 1 + (yrrng.end_year - yrrng.start_year)
                    ), fyqtr as (
                        select 'Q'||qtrs.q||'FY'||yrs.y qt, yrs.y, qtrs.q
                        from qtrs, yrs
                    ), pf as (
                        select distinct product_family
                        from data
                    )
                    select nvl(data.revenue,0) revenue,
                        fyqtr.qt fiscal_quarter,
                        pf.product_family
                    from fyqtr, pf, data
                    where data.fiscal_quarter(+) = fyqtr.qt
                        and data.product_family(+) = pf.product_family
                        -- This works, and only displays the selected quarter(s).
                        and (:P100_QUARTER is null or ':'||:P100_QUARTER||':' like '%:Q'||fyqtr.q||':%')
                    order by fyqtr.y, fyqtr.q
                    ```
            }
            columnMapping {
                seriesName: PRODUCT_FAMILY
                label: FISCAL_QUARTER
                value: REVENUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 135
                    items: {
                        IR_PRODUCT_FAMILY_ID: &PRODUCT_FAMILY.
                        IRIN_PQO: \&P100_QTR_NAME.\
                        IR_PFYO: &P100_FY_PCD.
                        IR_TERRITORY_NAME: &P100_TERRITORY_NAME.
                        IR_SALES_MGR: &P100_SALES_MGR_NAME.
                        IR_PRODUCT_QTR: &FISCAL_QUARTER.
                    }
                    clearCache: [
                        135
                        RIR
                    ]
                    action: resetPagination
                }
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

    )

    region revenue-by-territories (
        name: Revenue By Territories
        type: chart
        layout {
            sequence: 70
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @opportunity-amount-set-at-product-level
        }
        dataCursor {
            dimOnHover: false
        }
        animation {
            onDisplay: none
            onDataChange: none
        }
        legend {
            show: false
        }

        series revenue-by-territories (
            name: Revenue By Territories
            execution {
                sequence: 10
            }
            source {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select sum(case 
                               when :OPP_SET_PROD_LEV_BO = 'Include' then
                                   case when dp.term is null then nvl(dp.quote_price, 0) else nvl(dp.quote_price, 0) * dp.term/12 end
                           else
                                   d.deal_amount
                           end) as revenue,
                           t.territory_name as territory
                      from eba_sales_deals d,
                           eba_sales_deal_products dp,
                           eba_sales_territories t
                     where d.customer_id in (select id from eba_sales_customers c where c.customer_territory_id = t.id)
                       and dp.deal_id = d.id
                       and (
                               nvl(:P100_FY_PCD, 0) = 0
                               or
                               instr(dp.qtr, :P100_FY_PCD) > 0
                           )
                       and (
                               :P100_QUARTER is null
                               or
                               instr(:P100_QUARTER, substr(dp.qtr,1,2)) > 0
                           )
                       and (
                               nvl(:P100_SALES_MGR_ID, 0) = 0
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_01 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_02 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_03 and r.rep_manager_id = :P100_SALES_MGR_ID)
                               or exists
                               (select null from EBA_SALES_SALESREPS r where r.id = d.salesrep_id_04 and r.rep_manager_id = :P100_SALES_MGR_ID)
                           )
                       and (
                               :P100_TERRITORY_ID is null
                               or
                               t.id = :P100_TERRITORY_ID
                           )
                     group by t.territory_name
                    ```
            }
            columnMapping {
                label: TERRITORY
                value: REVENUE
            }
            link {
                type: redirectThisApp
                target: {
                    page: 135
                    items: {
                        IR_TERRITORY_NAME: &TERRITORY.
                        P1_DISPLAY_AS: GRID
                        IR_SALES_MGR: &P100_SALES_MGR_NAME.
                        IRIN_PQO: \&P100_QTR_NAME.\
                        IR_PFYO: &P100_FY_PCD.
                    }
                    clearCache: [
                        1
                        RIR
                    ]
                    action: resetPagination
                }
            }
            label {
                show: true
            }
        )

        axis x (
            name: x
            minorTicks {
                show: false
            }
        )

        axis y (
            name: y
            minorTicks {
                show: false
            }
        )

