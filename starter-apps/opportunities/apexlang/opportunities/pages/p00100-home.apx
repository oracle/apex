    dynamicAction set-quarter-name (
        name: Set Quarter Name
        execution {
            sequence: 70
        }
        when {
            selectionType: items
            items: [
                P100_QUARTER
                P100_FY_PCD
            ]
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P100_QUARTER
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: null;
                itemsToSubmit: P100_QTR_NAME
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: plsqlFunctionBody
                plsqlFunctionBody:
                    ```plsql
                    declare
                        l_vc_arr2    apex_application_global.vc_arr2;
                        l_retval     varchar2(200);
                    begin
                        l_vc_arr2 := apex_util.string_to_table(:P100_QUARTER);
                        for i in 1..l_vc_arr2.count
                        loop
                            l_retval := l_retval || l_vc_arr2(i) || ',';
                        end loop;
                        l_retval := rtrim(l_retval, ',');
                        return l_retval;
                    end;
                    ```
                itemsToSubmit: [
                    P100_QUARTER
                    P100_FY_PCD
                ]
            }
            affectedElements {
                selectionType: items
                items: P100_QTR_NAME
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction set-sales-manager-name (
        name: Set Sales Manager Name
        execution {
            sequence: 2
        }
        when {
            selectionType: items
            items: P100_SALES_MGR_ID
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P100_SALES_MGR_ID is null then
                        :P100_SALES_MGR_NAME := null;
                    end if;
                    ```
                itemsToSubmit: P100_SALES_MGR_NAME
                itemsToReturn: P100_SALES_MGR_NAME
                showProcessing: true
            }
            execution {
                sequence: 30
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: items
                items: P100_SALES_MGR_NAME
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select initcap(rep_first_name) || ' ' || initcap(rep_last_name)
                    from EBA_SALES_SALESREPS
                    where id = :P100_SALES_MGR_ID
                    ```
                itemsToSubmit: P100_SALES_MGR_ID
            }
            affectedElements {
                selectionType: items
                items: P100_SALES_MGR_NAME
            }
            execution {
                sequence: 20
            }
        )

    )

