            used: always
        }
    )

    pageItem P52_URL_3 (
        type: textField
        label {
            label: Link 3 URL
            alignment: left
        }
        settings {
            subtype: url
            trimSpaces: none
        }
        layout {
            sequence: 120
            region: @competitor-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 80
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: URL_3
            used: always
        }
    )

    pageItem P52_URL_3_NAME (
        type: textField
        label {
            label: Link 3 Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 110
            region: @competitor-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
