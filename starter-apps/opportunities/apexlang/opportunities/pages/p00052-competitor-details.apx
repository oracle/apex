        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 60
            region: @competitor-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: URL_1_NAME
            used: always
        }
    )

