            used: always
        }
    )

    pageItem P52_URL_4 (
        type: textField
        label {
            label: Link 4 URL
            alignment: left
        }
        settings {
            subtype: url
            trimSpaces: none
        }
        layout {
            sequence: 140
            region: @competitor-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
