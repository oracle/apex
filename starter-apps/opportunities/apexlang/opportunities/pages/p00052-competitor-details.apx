page 52 (
    name: Competitor Details
    alias: COMPETITOR-DETAILS
    title: Competitor Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }
    config {
        buildOption: @competitors
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region competitor-details (
        name: Competitor Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P52_COMPETITOR_DESC (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        settings {
            resizable: false
            trimSpaces: none
        }
        layout {
            sequence: 150
            region: @competitor-details
            slot: regionBody
            alignment: left
            columnSpan: 12
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
            height: 5
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: COMPETITOR_DESC
            used: always
        }
    )

    pageItem P52_COMPETITOR_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @competitor-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: COMPETITOR_NAME
            used: always
        }
    )

    pageItem P52_ID (
        type: hidden
        layout {
            sequence: 10
            region: @competitor-details
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P52_TAGS (
        type: popupLov
        label {
            label: Tags
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select tag
                  from eba_sales_tags_type_sum
                 where content_type = 'COMPETITOR'
                ```
        }
        layout {
            sequence: 160
            region: @competitor-details
            slot: regionBody
            alignment: left
            columnSpan: 12
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            width: 96
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: TAGS
            used: always
        }
    )

    pageItem P52_URL_1 (
        type: textField
        label {
            label: Link 1 URL
            alignment: left
        }
        settings {
            subtype: url
            trimSpaces: none
        }
        layout {
            sequence: 70
            region: @competitor-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 80
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: URL_1
            used: always
        }
    )

    pageItem P52_URL_1_NAME (
        type: textField
        label {
            label: Link 1 Name
