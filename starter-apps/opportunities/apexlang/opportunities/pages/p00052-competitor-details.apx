        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: URL_4_NAME
            used: always
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button create (
        buttonName: CREATE
        label: Create Competitor
        layout {
            sequence: 20
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P52_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 40
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation url1-must-start-with-http (
        name: URL1 must start with http
        execution {
            sequence: 20
        }
        validation {
            plsqlExpression: substr(:P52_URL_1, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P52_URL_1
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_URL_1
        }
    )

    validation url2-must-start-with-http (
        name: URL2 must start with http
        execution {
            sequence: 30
        }
        validation {
            plsqlExpression: substr(:P52_URL_2, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P52_URL_2
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_URL_2
        }
    )

    validation url3-must-start-with-http (
        name: URL3 must start with http
        execution {
            sequence: 40
        }
        validation {
            plsqlExpression: substr(:P52_URL_3, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P52_URL_3
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_URL_3
        }
    )

    validation url4-must-start-with-http (
        name: URL4 must start with http
        execution {
            sequence: 50
        }
        validation {
            plsqlExpression: substr(:P52_URL_4, 1, 4) = 'http'
        }
        error {
            errorMessage: Please provide a URL that begins with, "http".
            associatedItem: @P52_URL_4
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P52_URL_4
        }
    )

    validation valid-tag-characters (
        name: Valid Tag Characters
        execution {
            sequence: 10
        }
        validation {
            plsqlExpression: "not regexp_like( :P52_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P52_TAGS
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: SAVE,CREATE
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 6527633996244112070
        }
    )

    process fetch-row-from-eba-sales-competitors (
        name: Fetch Row from EBA_SALES_COMPETITORS
        type: autoRowFetch
        source {
            tableName: EBA_SALES_COMPETITORS
            pkColumn: ID
            pkItem: P52_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 10247736174391458975
        }
    )

    process process-row-of-eba-sales-competitors (
        name: Process Row of EBA_SALES_COMPETITORS
        type: autoRowProcessing
        target {
            tableName: EBA_SALES_COMPETITORS
            pkColumn: ID
            pkItem: P52_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_SALES_COMPETITORS.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10247736355975458984
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10247736545468458984
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

