        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 80
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: URL_2
            used: always
        }
    )

