page 20 (
    name: Past Due Opportunities
    alias: PAST-DUE-OPPORTUNITIES
    title: Past Due Opportunities
    pageGroup: @reports
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: This page identifies opportunities that are past due, or about to become past due. Change the "Closing Timeframe" filter value to vary the report's results. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region filters (
        name: Filters
        type: staticContent
        layout {
            sequence: 10
            slot: body-3
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            excludeTitleFromTranslation: true
        }
    )

    region past-due-opportunities (
        name: Past Due Opportunities
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select deal_id as id, 
                  customer_name,
                  customer_stock_symb,
                  customer_id account_id,
                  rep_first_name || ' ' || rep_last_name as rep,
                  rep_email,
                  deal_name,
                  deal_close_date,
                  deal_amount,
                  deal_probability,
                  status_code 
                from eba_sales_opp_v v
                where deal_close_date < trunc(sysdate) + :P20_CLOSING_TIMEFRAME 
                  and nvl(deal_probability, 0) < 100
                ```
            pageItemsToSubmit: P20_CLOSING_TIMEFRAME
        }
        layout {
            sequence: 20
            slot: body-3
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 10000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
                pdf
            ]
            filename: past_due.csv
        }
        advanced {
            savedReportMappingIdentifier: 3725340719174444261
        }

        column ACCOUNT_ID (
            type: hidden
            heading {
                heading: Account id
            }
            layout {
                sequence: 32
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
            security {
                escapeSpecialChars: false
            }
        )

        column CUSTOMER_NAME (
            type: link
            heading {
                heading: Account
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_ID: #ACCOUNT_ID#
                    }
                    clearCache: 94
                    action: resetPagination
                }
                linkText: #CUSTOMER_NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: A
            }
        )

        column CUSTOMER_STOCK_SYMB (
            type: hidden
            heading {
                heading: Stock
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
            security {
                escapeSpecialChars: false
            }
        )

        column DEAL_AMOUNT (
            type: plainText
            heading {
                heading: &AMT_HDR.
                alignment: end
            }
            layout {
                sequence: 9
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G999
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column DEAL_CLOSE_DATE (
            type: plainText
            heading {
                heading: Close Date
            }
            layout {
                sequence: 12
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: L
            }
        )

        column DEAL_NAME (
            type: link
            heading {
                heading: Opportunity
            }
            layout {
                sequence: 7
            }
            link {
                target: {
                    page: 80
                    items: {
                        P80_ID: #ID#
                    }
                    clearCache: 80
                    action: resetPagination
                }
                linkText: #DEAL_NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column DEAL_PROBABILITY (
            type: plainText
            heading {
                heading: Probability
                alignment: end
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column ID (
            type: hidden
            heading {
                heading: Id
            }
            layout {
                sequence: 22
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: M
            }
            security {
                escapeSpecialChars: false
            }
        )

        column REP (
            type: plainText
            heading {
                heading: Rep
            }
            layout {
                sequence: 1
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column REP_EMAIL (
            type: plainText
            heading {
                heading: Email
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column STATUS_CODE (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }

        savedReport 8977878 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn ACCOUNT_ID (
                sequence: 10
            )

            displayColumn CUSTOMER_NAME (
                sequence: 2
            )

            displayColumn DEAL_AMOUNT (
                sequence: 5
            )

            displayColumn DEAL_CLOSE_DATE (
                sequence: 8
            )

            displayColumn DEAL_NAME (
                sequence: 1
            )

            displayColumn DEAL_PROBABILITY (
                sequence: 7
            )

            displayColumn ID (
                sequence: 9
            )

            displayColumn REP (
                sequence: 3
            )

            displayColumn REP_EMAIL (
                sequence: 4
            )

            displayColumn STATUS_CODE (
                sequence: 6
            )

        )

    )

    pageItem P20_CLOSING_TIMEFRAME (
        type: selectList
        label {
            label: Closing Timeframe
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Within 7 days;7,Within 30 days ;30,Within 90 days;90,Within 180 days;180,Past Due;0
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: staticValue
            staticValue: 7
        }
        default {
            type: static
            staticValue: 7
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @past-due-opportunities
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction p20-closing-timeframe-changed (
        name: P20_CLOSING_TIMEFRAME changed
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P20_CLOSING_TIMEFRAME
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @past-due-opportunities
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 20
        }
    )

)

