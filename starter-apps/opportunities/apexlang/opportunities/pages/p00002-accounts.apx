            backgroundColor: #efefef
        }

        savedReport 7219182 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CUSTOMER_IS_KEY_ACCOUNT_YN (
                sequence: 4
            )

            displayColumn CUSTOMER_NAME (
                sequence: 1
            )

            displayColumn LEADS (
                sequence: 7
            )

            displayColumn OPEN_DEALS (
                sequence: 5
            )

            displayColumn PAST_DUE (
                sequence: 6
            )

            displayColumn ROW_KEY (
                sequence: 2
            )

            displayColumn TERRITORY_NAME (
                sequence: 3
            )

        )

    )

    region accounts-report (
        name: Accounts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                with base_accounts as (
                  select c.id,
                    c.row_key,
                    c.customer_name,
                    t.territory_name,
                    c.customer_territory_id,
                    c.customer_industry_id as industry,
                    c.updated,
                    (
                      select count(*)
                      from eba_sales_deals dx
                      where dx.customer_id = c.id
                        and dx.deal_probability > 0
                        and dx.deal_probability < 100
                    ) open_deals,
                    (
                      select count(*)
                      from eba_sales_deals
                      where customer_id = c.id
                        and deal_close_date < sysdate
                        and deal_probability != 0
                        and deal_probability != 100
                    ) past_due,
                    (
                      select count(*) 
                      from eba_sales_leads 
                      where account_id = c.id
                    ) leads
                  from eba_sales_customers c
                  left join eba_sales_territories t
                    on c.customer_territory_id = t.id
                  where :P2_DISPLAY_AS = 'REPORT'
                    and (:P2_TERRITORY_ID is null or t.id = :P2_TERRITORY_ID)
                    and (:P2_KEY is null or customer_is_key_account_yn = :P2_KEY)
                )
                select *
                from base_accounts
                where (
                  :P2_SEARCH is null
                    or instr(upper(customer_name), upper(:P2_SEARCH)) > 0
                    or instr(upper(row_key), upper(:P2_SEARCH)) > 0
                    or instr(upper(territory_name), upper(:P2_SEARCH)) > 0
                    or instr(upper(apex_util.get_since(updated)), upper(:P2_SEARCH)) > 0
                    or instr(open_deals, upper(:P2_SEARCH)) > 0
                    or instr(past_due, upper(:P2_SEARCH)) > 0
                    or instr(leads, upper(:P2_SEARCH)) > 0
                )
                ```
            pageItemsToSubmit: [
                P2_DISPLAY_AS
                P2_TERRITORY_ID
                P2_KEY
                P2_SEARCH
            ]
        }
        layout {
            sequence: 60
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: report_region
            customAttributes: style="display: none"
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: -
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No accounts found
        }

        column CUSTOMER_NAME (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Account
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_ID: #ID#
                    }
                    action: resetPagination
                }
                linkText: #CUSTOMER_NAME#
            }
            sorting {
                defaultSequence: 1
            }
        )

        column CUSTOMER_TERRITORY_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 8
            }
        )

        column INDUSTRY (
            reportColumnQueryId: 6
            derivedColumn: N
            type: plainTextBasedOnLov
            heading {
                heading: Industry
            }
            lov {
                type: sharedComponent
                lov: @industries
            }
            layout {
                sequence: 2
            }
        )

        column LEADS (
            reportColumnQueryId: 10
            derivedColumn: N
            type: link
            heading {
                heading: Leads
                alignment: end
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            link {
                target: {
                    page: 19
                    items: {
                        P19_DISPLAY_AS: GRID
                        IR_ACCOUNT_ID: #ID#
                    }
                    clearCache: [
                        RIR
                        CIR
                    ]
                    action: resetPagination
                }
                linkText: #LEADS#
            }
            serverSideCondition {
                type: expression
                plsqlExpression: wwv_flow_utilities.is_build_option_enabled('Leads')
            }
        )

        column OPEN_DEALS (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Open Opp.
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
        )

        column PAST_DUE (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Past due
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
        )

        column ROW_KEY (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Key
            }
            layout {
                sequence: 3
            }
        )

        column TERRITORY_NAME (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Territory
            }
            layout {
                sequence: 7
            }
            serverSideCondition {
                type: expression
                plsqlExpression:
                    ```plsql
                    apex_util.get_build_option_status(
                      p_application_id    => :APP_ID,
                      p_build_option_name => 'Territories'
                    ) = 'INCLUDE'
                    ```
            }
        )

        column UPDATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 9
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

    region filters (
        name: Filters
        type: staticContent
        layout {
            sequence: 10
            slot: leftColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
                t-Form--stretchInputs
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
    )

    region page-settings (
        name: Page Settings
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @accounts
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P2_DISPLAY_AS (
        type: radioGroup
        label {
            label: Display as
            alignment: left
        }
        settings {
            noOfCols: 4
        }
        lov {
            type: sharedComponent
            lov: @pill-display-as
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @page-settings
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        default {
            type: static
            staticValue: CARDS
        }
        sessionState {
            storage: user
        }
        security {
            escapeSpecialChars: false
        }
    )

    pageItem P2_KEY (
        type: selectList
        label {
            label: Key Accounts
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes;Y,No;N
            displayExtraValues: false
            nullDisplayValue: - All -
        }
        layout {
            sequence: 40
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
    )

    pageItem P2_SEARCH (
        type: textField
        label {
            label: Search
            alignment: left
        }
        settings {
            trimSpaces: none
            submitWhenEnterPressed: true
        }
        layout {
            sequence: 10
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--large
            ]
            icon: fa-search
            width: 30
            valuePlaceholder: Search Accounts
        }
        validation {
            maxLength: 4000
        }
    )

    pageItem P2_SORT (
        type: selectList
        label {
            label: Sort
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Account;NAME,Open Deals;OPEN_DEALS,Past Due Deals;PAST_DUE,Open Leads;OPEN_LEADS,Updated;UPDATED
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 60
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        default {
            type: static
            staticValue: NAME
        }
        sessionState {
            storage: user
        }
    )

    pageItem P2_TERRITORY_ID (
        type: selectList
        label {
            label: Territory
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @territory
            displayExtraValues: false
            nullDisplayValue: - All -
        }
        layout {
            sequence: 30
            region: @filters
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            height: 1
        }
        config {
            buildOption: @territories
        }
    )

    button create (
        buttonName: CREATE
        label: Create Account
        layout {
            sequence: 20
            region: @accounts
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 3
                clearCache: 3
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @filters
            slot: close
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
        advanced {
            htmlDomId: reset_button
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 30
            region: @accounts-grid
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    RIR
                    CIR
                ]
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dialog-closed (
        name: Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var display = $v('P2_DISPLAY_AS');
                    
                    if (display === 'CARDS') {
                      $('#cards_region').trigger('apexrefresh');
                    } else if (display === 'REPORT') {
                      $('#report_region').trigger('apexrefresh');
                    } else if (display === 'GRID') {
                      $('#grid_region').trigger('apexrefresh');
                    }
                    
                    apex.message.showPageSuccess('Account Created.');
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 2
        }
    )

)

