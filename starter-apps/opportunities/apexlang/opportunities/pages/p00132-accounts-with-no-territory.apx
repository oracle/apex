page 132 (
    name: Accounts with No Territory
    alias: ACCOUNTS-WITH-NO-TERRITORY
    title: Accounts with No Territory
    pageGroup: @reports
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: This is an interactive report of all accounts with no territory specified. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
    }

    region accounts-with-no-territory (
        name: Accounts with No Territory
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id,
                  c.row_key,
                  c.customer_name,
                  c.customer_territory_id,
                  case c.customer_is_key_account_yn
                    when 'Y' then 'Yes'
                    when 'N' then 'No'
                  end customer_is_key_account_yn,
                  c.created,
                  c.created_by,
                  c.updated,
                  c.updated_by,
                  (
                    select count(*)
                    from eba_sales_deals dx
                    where dx.customer_id = c.id
                      and dx.deal_probability > 0
                      and dx.deal_probability < 100
                  ) open_deals,
                  (
                    select count(*)
                    from eba_sales_deals
                    where customer_id = c.id
                      and deal_close_date < sysdate
                      and deal_probability != 0
                      and deal_probability != 100
                  ) past_due,
                  (
                    select count(*) 
                    from eba_sales_leads 
                    where account_id = c.id
                  ) leads
                from eba_sales_customers c
                where c.customer_territory_id is null
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        messages {
            whenNoDataFound: No territories found.
        }
        advanced {
            savedReportMappingIdentifier: 1593796581996025096
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 110
            }
            appearance {
                formatMask: &APP_DATE_TIME_FMT.
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: K
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 120
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column CUSTOMER_IS_KEY_ACCOUNT_YN (
