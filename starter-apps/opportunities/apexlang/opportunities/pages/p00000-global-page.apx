    dynamicAction marquee-pages-attachment-details-dialog-closed (
        name: Marquee Pages - Attachment Details dialog closed
        execution {
            sequence: 60
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 99
        }
        serverSideCondition {
            type: currentPageInList
            pages: [
                80
                94
                133
                93
                24
                61
            ]
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.js-attachmentsRegion').trigger('apexrefresh');
                    
                    if (this.data.REQUEST === 'CREATE') {
                      apex.message.showPageSuccess('Attachment Added.');
                    } if (this.data.REQUEST === 'SAVE') {
                      apex.message.showPageSuccess('Attachment Updated.');
                    } if (this.data.REQUEST === 'DELETE') {
                      apex.message.showPageSuccess('Attachment Deleted.');
                    }
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

