        column CALCULATED_AMOUNT (
            reportColumnQueryId: 19
            derivedColumn: N
            heading {
                heading: Amount by "Sold As"
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            appearance {
                formatMask: FML999G999G999G999G990
            }
            columnFormatting {
                htmlExpression: <div style="white-space:pre;">#CALCULATED_AMOUNT#</div>
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select
                        null
                      from EBA_SALES_DEAL_PRODUCTS dp,
                           EBA_SALES_PRODUCTS p,
                           EBA_SALES_PRODUCT_FAMILIES f
                     where dp.deal_id = :P80_ID 
                       and dp.product_id = p.id
                       and p.product_family_id = f.id (+)
                       and dp.quote_price > 0
                    ```
            }
            config {
                buildOption: @opportunity-amount-set-at-product-level
            }
        )

