page 80 (
    name: Opportunity
    alias: OPPORTUNITY
    title: Opportunity
    pageGroup: @opportunities
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Manage an opportunity's details, products, competitors, team members, links, attachments, and/or comments. You can also validate the opportunity.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--showBreadcrumb
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region competition (
        name: Competition
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.competitor_name competitor,
                  dc.competition_desc,
                  dc.competitor_threat_id,
                  (
                    select competitor_threat 
                    from eba_sales_competitor_threats x 
                    where x.id = dc.competitor_threat_id
                  ) threat,
                  dc.created,
                  lower(dc.created_by) created_by
                from eba_sales_deal_competition dc
                join eba_sales_competitors c
                  on c.id = dc.competitor_id
                where dc.deal_id = :P80_ID
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                t-Region--noPadding
                #DEFAULT#
                t-Region--scrollBody
            ]
            cssClasses: js-dynamicHideShowRegion
        }
        advanced {
            regionDisplaySelector: true
        }
        config {
            buildOption: @competitors
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                t-Report--stretch
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--inline
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No competition identified, click "+" icon to add a competitor
        }
        componentAdvanced {
            stripHtml: true
        }

        column COMPETITION_DESC (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 3
            }
        )

        column COMPETITOR (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Competitor
            }
            layout {
                sequence: 1
            }
            sorting {
                defaultSequence: 1
            }
        )

        column COMPETITOR_THREAT_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 4
            }
        )

        column CREATED (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Added
            }
            layout {
                sequence: 5
            }
            appearance {
                formatMask: SINCE
            }
            columnFormatting {
                htmlExpression: #CREATED# by #CREATED_BY#
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 6
            }
        )

        column THREAT (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Threat
            }
            layout {
                sequence: 2
            }
        )

    )

    region history (
        name: History
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                    l_history varchar2(4000);
                begin
                    for c1 in
                    (
                        select
                            '<p class="audit-info">Last updated <strong>'||apex_util.get_since(updated)
                                ||'</strong> by <strong>' ||
                                apex_escape.html(lower(updated_by))||'</strong>.
                             <br />Created '||apex_util.get_since(created) ||' by '||apex_escape.html(lower(created_by))
                                ||'.</span>' as history
                          from eba_sales_deals
                         where id = :P80_ID
                    )
                    loop
                        l_history := c1.history;
                    end loop;
                    sys.htp.p( l_history );
                end;
                ```
        }
        layout {
            sequence: 1500
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
                t-Alert--accessibleHeading
            ]
            icon: fa-clock-o
        }
    )

    region opportunity-actions (
        name: Opportunity Actions
        type: list
        source {
            list: @actions-opportunity
        }
        layout {
            sequence: 10
            slot: rightSideColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/links-list
            templateOptions: [
                #DEFAULT#
                t-LinksList--actions
                t-LinksList--showTopIcons
            ]
        }
    )

    region opportunity-details (
        name: Opportunity Details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select d.id,
                  d.row_key,
                  d.svp_id,
                  t.id territory_id,
                  t.territory_name,
                  c.id account_id,
                  c.customer_name account,
                  d.deal_probability || '%' deal_probability,
                  case
                    when deal_probability > 0 and deal_probability < 100
                    then 'Yes'
                    else 'No'
                  end open,
                  case
                    when deal_close_date < sysdate and deal_probability != 0 and deal_probability != 100
                    then 'Yes'
                    else 'No'
                  end past_due,
                  d.deal_amount,
                  d.qtr || ' ' || 
                    to_char(deal_close_date,'Day DD-MON-YYYY') || 
                    ' (' || apex_util.get_since(deal_close_date) || ')' deal_close_date,
                  dsc.status_code,
                  d.updated,
                  lower(d.updated_by) updated_by,
                  d.created,
                  lower(d.created_by) created_by,
                  sr.rep_first_name || ' ' || sr.rep_last_name as sales_rep_name,
                  (select listagg(decode(inv.sold_as, 'SUBSCRIPTION', 'Cloud Subscription ARR', 'PURCHASE', 'On-Premise Purchase', 'TCV', 'Cloud Subscription TCV', inv.sold_as)
                        || ': ' || to_char(inv.value, 'FML999G999G999G999G990'), chr(10))
                        within group (order by inv.sold_as desc, inv.value)
                from (  select p.sold_as, nvl(sum(dp.quote_price),0) value
                        from eba_sales_deal_products dp, eba_sales_products p
                        where dp.deal_id = :P80_ID
                            and dp.product_id = p.id
                        group by p.sold_as
                        union all
                        select 'TCV', nvl(sum(dp.tcv),0) value
                        from eba_sales_deal_products dp, eba_sales_products p
                        where dp.deal_id = :P80_ID
                            and dp.product_id = p.id
                            and p.sold_as = 'SUBSCRIPTION'
                    ) inv) as calculated_amount
                from eba_sales_deals d
                join eba_sales_customers c
                  on c.id = d.customer_id
                left join eba_sales_deal_status_codes dsc
                  on dsc.id = d.deal_status_code_id
                left join eba_sales_territories t
                  on t.id = c.customer_territory_id
                left join eba_sales_salesreps sr
                  on sr.id = d.salesrep_id_01
                where d.id = :P80_ID;
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: " - "
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }

        column ACCOUNT (
            reportColumnQueryId: 7
            derivedColumn: N
            type: link
            heading {
                heading: Account
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_ID: #ACCOUNT_ID#
                    }
                    clearCache: 94
                    action: resetPagination
                }
                linkText: #ACCOUNT#
            }
        )

