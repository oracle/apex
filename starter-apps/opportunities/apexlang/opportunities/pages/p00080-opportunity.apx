    dynamicAction edit-opportunity-dialog-closed (
        name: Edit Opportunity dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 16
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.t-Breadcrumb-item.is-active > span').text(this.data.P16_DEAL_NAME);
                    apex.message.showPageSuccess('Action Processed.');
                    ```
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @opportunity-details
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

