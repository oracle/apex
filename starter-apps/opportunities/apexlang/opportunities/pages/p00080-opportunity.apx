    computation last-page (
        itemName: LAST_PAGE
        execution {
            sequence: 20
            point: afterFooter
        }
        computation {
            type: staticValue
            staticValue: 80
        }
    )

    computation p16-id (
        itemName: P16_ID
        execution {
            sequence: 10
            point: afterFooter
        }
        computation {
            type: staticValue
            staticValue: &P80_ID.
        }
    )

    process init-page (
        name: Init page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_sales_clicks (
                    entity_type,
                    opp_id,
                    app_username  
                ) values (
                    'OPPORTUNITY',
                    :P80_ID,
                    lower(:APP_USER)
                );
                
                delete from eba_sales_clicks 
                where view_timestamp < (sysdate - 90) 
                  and opp_id = :P80_ID;
                
                ```
        }
        execution {
            sequence: 70
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 7378375953142609741
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 80
                items: {
                    P80_ID: &P80_ID.
                }
            }
        }
        comments {
            comments: Created 11-JAN-2012 16:02 by MIKE
        }
    )

)

