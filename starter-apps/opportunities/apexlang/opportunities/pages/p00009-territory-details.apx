page 9 (
    name: Territory Details
    alias: TERRITORY-DETAILS
    title: Territory Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    htmlHeader {
        htmlHeader:
            ```html
            <script language="JavaScript" type="text/javascript">
            <!--
            
             htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            
            //-->
            </script>
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: No help is available for this page.
    }
    config {
        buildOption: @territories
    }

    region button-bar (
        name: Button Bar
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region territory-details (
        name: Territory Details
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P9_ID (
        type: hidden
        layout {
            sequence: 10
            region: @territory-details
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P9_SVP_ID (
        type: selectList
        label {
            label: SVP
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery: select svp_name, id from eba_sales_svps order by upper(svp_name)
            nullDisplayValue: - Select SVP -
        }
        layout {
            sequence: 40
            region: @territory-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: databaseColumn
            databaseColumn: SVP_ID
            used: always
        }
    )

    pageItem P9_TAGS (
        type: popupLov
        label {
            label: Tags
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select tag
                  from eba_sales_tags_type_sum
                 where content_type = 'TERRITORY'
                ```
        }
        layout {
            sequence: 60
            region: @territory-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
            width: 96
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: TAGS
            used: always
        }
    )

    pageItem P9_TERRITORY_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        settings {
            resizable: false
            trimSpaces: none
        }
        layout {
            sequence: 50
            region: @territory-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 64
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            type: databaseColumn
            databaseColumn: TERRITORY_DESCRIPTION
            used: always
        }
    )

    pageItem P9_TERRITORY_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @territory-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: TERRITORY_NAME
            used: always
        }
    )

    pageItem P9_TERRITORY_TYPE (
        type: selectList
        label {
            label: Type
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @territory-types
            nullDisplayValue: - Select Type -
        }
        layout {
            sequence: 30
            region: @territory-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            type: databaseColumn
            databaseColumn: TERRITORY_TYPE
            used: always
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @button-bar
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create Territory
        layout {
            sequence: 20
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P9_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 40
            region: @button-bar
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P9_ID
        }
    )

    dynamicAction cancel-clicked (
        name: Cancel clicked
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation p9-territory-name-not-duplicated (
        name: P9_TERRITORY_NAME not duplicated
        execution {
            sequence: 10
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select null
                from eba_sales_territories
                where (:P9_ID is null or :P9_ID != id)
                    and upper(territory_name) = upper(:P9_TERRITORY_NAME)
                ```
        }
        error {
            errorMessage: A territory with that name already exists.
            associatedItem: @P9_TERRITORY_NAME
        }
    )

    validation valid-tag-characters (
        name: Valid Tag Characters
        execution {
            sequence: 20
        }
        validation {
            plsqlExpression: "not regexp_like( :P9_TAGS, '[:;#\\/\\\\\\?\\&]' )"
        }
        error {
            errorMessage: Tags may not contain the following characters: : ; \ / ? &
            associatedItem: @P9_TAGS
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: SAVE,CREATE
        }
    )

    process close-dialog (
        name: close dialog
        type: closeDialog
        settings {
            itemsToReturn: P9_TERRITORY_NAME
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 6400532414179872473
        }
    )

    process fetch-row-from-eba-sales-territories (
        name: Fetch Row from eba_sales_TERRITORIES
        type: autoRowFetch
        source {
            tableName: EBA_SALES_TERRITORIES
            pkColumn: ID
            pkItem: P9_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 10495516682272716426
        }
    )

    process process-row-of-eba-sales-territories (
        name: Process Row of eba_sales_TERRITORIES
        type: autoRowProcessing
        target {
            tableName: EBA_SALES_TERRITORIES
            pkColumn: ID
            pkItem: P9_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table eba_sales_TERRITORIES.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10495516902364716427
        }
    )

    process reset-page (
        name: reset page
        type: clearSessionState
        execution {
            sequence: 30
        }
        error {
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 10495517090606716428
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

