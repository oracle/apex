page 212 (
    name: Data Validation
    alias: DATA-VALIDATION2
    title: Data Validation
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Verify all rows contain the value "INSERT" or "UPDATE" in the "Action" column before clicking the <strong>Load Data</strong> button.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region data-load-process-train (
        name: Data Load Process Train
        type: list
        source {
            list: @data-load-process-train-load-opportunities
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/wizard-container
            templateOptions: [
                #DEFAULT#
                t-Wizard--hideStepsSmall
            ]
        }
        advanced {
            excludeTitleFromTranslation: true
        }
        componentAppearance {
            listTemplate: @/wizard-progress
            templateOptions: [
                #DEFAULT#
                t-WizardSteps--displayLabels
            ]
        }
    )

    region data-validation (
        name: Data Validation
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select n001 as row_num,
                       c049 as action,
                       c001, c002, c003,
                       c004, c005, c006,
                       c007, c008, c009,
                       c010, c011, c012,
                       c013, c014, c015,
                       c016, c017, c018,
                       c019, c020, c021,
                       c022, c023, c024,
                       c025, c026, c027,
                       c028, c029, c030,
                       c031, c032, c033,
                       c034, c035, c036,
                       c037, c038, c040,
                       c041, c042, c043,
                       c044, c045
                  from apex_collections
                 where collection_name = 'LOAD_CONTENT'
                   and c049 in ('INSERT','UPDATE', 'FAILED')
                 order by seq_id
                ```
        }
        layout {
            sequence: 20
            parentRegion: @data-load-process-train
            slot: wizardSubRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            customAttributes: "style=\"width:100%;max-width:none;\" "
        }
        componentAppearance {
            templateType: predefined
        }
        pagination {
            type: setPaginationSelectList
            partialPageRefresh: false
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        componentAdvanced {
            stripHtml: true
        }
        heading {
            type: plsqlFunctionBody
            plsqlFunctionBody:
                ```plsql
                declare  
                    l_string varchar(32667);
                begin
                    l_string := wwv_flow_lang.system_message('DATA_LOAD.SEQUENCE_ACTION');
                    for l_heading in ( select c002 as label
                                         from apex_collections
                                        where collection_name = 'LOAD_COL_HEAD'
                                        order by seq_id )
                    loop
                        l_string := l_string || ':' || apex_escape.html(l_heading.label);
                    end loop;
                    return l_string;
                end;
                ```
        }

        column ACTION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: ACTION
            }
            layout {
                sequence: 2
            }
            sorting {
                sortable: false
            }
        )

