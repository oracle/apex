    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @data-load-process-train
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next (
        buttonName: NEXT
        label: Load Data
        layout {
            sequence: 30
            region: @data-load-process-train
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: PREVIOUS
        label: Previous
        layout {
            sequence: 20
            region: @data-load-process-train
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 211
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process prepare-uploaded-data (
        name: Prepare Uploaded Data
        type: loadUploadedData
        dataLoading {
            dataLoadDefinition: @upload-opportunities
        }
        processingResult {
            insertCountItem: P213_INSERT_COUNT
            updateCountItem: P213_UPDATE_COUNT
            errorCountItem: P213_ERROR_COUNT
        }
        execution {
            sequence: 10
        }
        error {
            errorMessage: Data Loading Failed
        }
        advanced {
            executionMappingIdentifier: 9046557243415424721
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 213
            }
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

)

