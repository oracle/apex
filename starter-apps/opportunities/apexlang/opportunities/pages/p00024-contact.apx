    dynamicAction edit-contact-dialog-closed (
        name: Edit Contact dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @edit-contact
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.t-Breadcrumb-item.is-active > span').text(this.data.P106_CONTACT_NAME);
                    
                    apex.message.showPageSuccess('Action Processed.');
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @contact-details
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction handle-no-data-found-regions (
        name: Handle No Data Found Regions
        execution {
            sequence: 20
        }
        when {
            event: ready
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    (function() {
                        
                      function toggleRegion() {
                        var $region = $(this),
                            noDataFound = $region.find('.nodatafound').length === 1;
                          
                          //triggering after hide/show because that what the RDS response to
                          if (noDataFound) {
                            $region.hide();
                            $region.trigger('apexafterhide');
                          } else {
                            $region.show();
                            $region.trigger('apexaftershow');
                          }
                      }
                      
                      function initHideShowRegions() {
                        var $regions = $('.js-dynamicHideShowRegion');
                            $rds = $('.apex-rds');
                    
                        $regions
                          .each(toggleRegion)
                          .on('apexafterrefresh', toggleRegion);
                    
                          //using visiblity over display to avoid DOM movement issues
                          $rds.css('visibility', 'visibile');
                      } 
                    
                      //using load because document.ready here goes before the RDS has added its listeners
                      $(window).on('theme42ready',initHideShowRegions);
                     
                    }())
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction link-details-dialog-closed (
        name: Link Details dialog closed
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: this.data && this.data.dialogPageId === 114
        }
    )

    dynamicAction page-loaded-and-or-report-refreshed (
        name: Page loaded and/or report refreshed
        execution {
            sequence: 30
        }
        when {
            event: apexafterrefresh
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('.t-Report-pagination--bottom').each(function(){
                      var $self = $(this);
                      var links = $self.find('a');
                      
                      if (links.length === 0) {
                        $self.hide();
                      } else {
                        $self.show();
                      }
                    });
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    process init-page (
        name: Init page
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                insert into eba_sales_clicks (
                  entity_type,
                  contact_id,
                    app_username
                ) values (
                  'CONTACT',
                  :P24_ID,
                    lower(:APP_USER)
                );
                
                delete from eba_sales_clicks 
                where view_timestamp < (sysdate - 90) 
                  and contact_id = :P24_ID;
                ```
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 6661028916598044653
        }
    )

)

