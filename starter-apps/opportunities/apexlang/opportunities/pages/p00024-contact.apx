page 24 (
    name: Contact
    alias: CONTACT
    title: Contact
    appearance {
        pageTemplate: @/marquee
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Manage a contact's details, links, attachments, and/or comments. You can also validate the contact.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region contact-actions (
        name: Contact Actions
        type: list
        source {
            list: @actions-contact
        }
        layout {
            sequence: 10
            slot: rightSideColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/links-list
            templateOptions: [
                #DEFAULT#
                t-LinksList--actions
                t-LinksList--showTopIcons
            ]
        }
    )

    region contact-details (
        name: Contact Details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select cc.id,
                  cc.row_key,
                  cc.contact_name,
                  cc.contact_title,
                  cc.contact_email,
                  cc.contact_phone,
                  cc.contact_cell,
                  cc.contact_address,
                  cc.contact_description,
                  cc.contact_linkedin,
                  cc.contact_facebook,
                  cc.tags,
                  cc.created,
                  cc.updated,
                  lower(cc.created_by) created_by,
                  lower(cc.updated_by) updated_by,
                  c.id account_id,
                  c.customer_name account_name
                from eba_sales_customer_contacts cc
                join eba_sales_customers c
                  on c.id = cc.customer_id
                where cc.id = :P24_ID
                ```
        }
        layout {
            sequence: 10
            slot: masterDetail
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
            showNullValuesAs: -
        }
        messages {
            whenNoDataFound: no data found
        }

        column ACCOUNT_ID (
            reportColumnQueryId: 17
            derivedColumn: N
            type: hidden
            layout {
                sequence: 18
            }
        )

        column ACCOUNT_NAME (
            reportColumnQueryId: 18
            derivedColumn: N
            heading {
                heading: Account
            }
            layout {
                sequence: 4
            }
        )

        column CONTACT_ADDRESS (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Address
            }
            layout {
                sequence: 11
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select null
                      from eba_sales_customer_contacts cc
                      join eba_sales_customers c
                        on c.id = cc.customer_id
                     where cc.id = :P24_ID
                       and cc.contact_address is not null
                    ```
            }
        )

        column CONTACT_CELL (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Cell
            }
            layout {
                sequence: 8
