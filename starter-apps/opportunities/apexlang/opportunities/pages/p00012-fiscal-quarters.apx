page 12 (
    name: Fiscal Quarters
    alias: FISCAL-QUARTERS
    title: Fiscal Quarters
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
            t-Dialog--noPadding
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
    }
    advanced {
        reloadOnSubmit: always
    }
    help {
        helpText: Manage the fiscal quarters used for reporting. Companies have different quarter start and end dates, click here to manage those dates. Click the <strong>Create Fiscal Quarter</strong> button to create a new fiscal quarter. Click the pencil icon in the report to edit any specific fiscal quarter's details. Click the <strong>Reset</strong> button to reset the interactive report. Click the <strong>Actions</strong> button to define the number of rows displayed per page, filter, format, download, and/or save the interactive report.
    }

    region fiscal-quarters (
        name: Fiscal Quarters
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                  period_name,
                  first_day,
                  last_day,
                  fiscal_year,
                  case
                    when rank() over (order by first_day) = 1
                    then 'First Date'
                    when (trunc(first_day) - 1) = lag(trunc(last_day)) over (order by first_day)
                    then 'No Gap'
                    else 'Error in data range'
                  end status
                from eba_sales_sales_periods
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 13
                items: {
                    P13_ID: #ID#
                }
                clearCache: 13
                action: resetPagination
            }
            linkIcon: <span class="fa fa-edit" aria-hidden="true"></span>
            linkAttributes: title="Edit #PERIOD_NAME#"
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToYOfZ
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }
        advanced {
            savedReportMappingIdentifier: 2373008000870865617
        }

        column FIRST_DAY (
            type: plainText
            heading {
                heading: First Day
            }
            layout {
                sequence: 3
            }
            appearance {
                formatMask: &APP_DATE_FORMAT.
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: C
            }
        )

        column FISCAL_YEAR (
            type: plainText
            heading {
                heading: Fiscal Year
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: &nbsp;
            }
            layout {
                sequence: 1
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
            security {
                escapeSpecialChars: false
            }
        )

        column LAST_DAY (
            type: plainText
            heading {
                heading: Last Day
            }
            layout {
                sequence: 4
            }
            appearance {
                formatMask: &APP_DATE_FORMAT.
            }
            source {
                dataType: DATE
                timezoneAware: Y
            }
            advanced {
                endUserAlias: D
            }
        )

        column PERIOD_NAME (
            type: plainText
            heading {
                heading: Fiscal Quarter
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 15
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        savedReport 23730162 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn FIRST_DAY (
                sequence: 3
            )

            displayColumn FISCAL_YEAR (
                sequence: 5
            )

            displayColumn ID (
                sequence: 1
            )

            displayColumn LAST_DAY (
                sequence: 4
            )

            displayColumn PERIOD_NAME (
                sequence: 2
            )

            displayColumn STATUS (
                sequence: 6
            )

            sort (
                column: FIRST_DAY
                sort {
                    sequence: 1
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Create Fiscal Quarter
        layout {
            sequence: 30
            region: @fiscal-quarters
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                clearCache: 13
            }
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            htmlDomId: CREATE
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 20
            region: @fiscal-quarters
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: [
                    &APP_PAGE_ID.
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dialog-closed (
        name: Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: jsExpression
            javaScriptExpression: window
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Action Processed.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @fiscal-quarters
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

