upgradeScript "Set data model version to 2.1.5" (
    execution {
        sequence: 60
    }
    script {
        contentFile: set-data-model-version-to-2-1-5.sql
    }
    serverSideCondition {
        type: functionBody
        plsqlFunctionBody:
            ```plsql
            declare
            
              l_data_model_version eba_sales_preferences.preference_value%type;
            
            begin
            
              select preference_value
              into l_data_model_version
              from eba_sales_preferences
              where preference_name = 'DATA_MODEL_VERSION';
            
              return false;
            
            exception
            
              when no_data_found
              then
                return true;
            
            end;
            ```
    }
)

upgradeScript "Set data model version to 3.0.0" (
    execution {
        sequence: 230
    }
    script {
        contentFile: set-data-model-version-to-3-0-0.sql
    }
    serverSideCondition {
        type: expression
        plsqlExpression: eba_sales_fw.get_preference_value('DATA_MODEL_VERSION') = '2.1.5'
    }
)

