appComputation rep-title (
    itemName: REP_TITLE
    execution {
        sequence: 10
    }
    computation {
        type: functionBody
        plsqlFunctionBody: return apex_escape.html(eba_sales_fw.get_preference_value('REP_TITLE'));
    }
)

appComputation rep-title-raw (
    itemName: REP_TITLE_RAW
    execution {
        sequence: 10
    }
    computation {
        type: functionBody
        plsqlFunctionBody: return eba_sales_fw.get_preference_value('REP_TITLE');
    }
)

