appComputation amt-hdr (
    itemName: AMT_HDR
    execution {
        sequence: 10
    }
    computation {
        staticValue: Annual Recurring Revenue
    }
    config {
        buildOption: @opportunity-amount-set-at-product-level
    }
)

appComputation amt-hdr-2 (
    itemName: AMT_HDR
    execution {
        sequence: 10
    }
    computation {
        staticValue: Amount
    }
    config {
        buildOption: !@opportunity-amount-set-at-product-level
    }
)

appComputation application-title (
    itemName: APPLICATION_TITLE
    execution {
        sequence: 10
    }
    computation {
        type: functionBody
        plsqlFunctionBody:
            ```plsql
            declare
                l_app_name varchar2(255);
            begin
                select nvl(preference_value,:APP_NAME)
                  into l_app_name
                  from eba_sales_preferences
                 where preference_name = 'APPLICATION_TITLE';
                return l_app_name;
            exception
                when others then
                    return :APP_NAME;
            end;
            ```
    }
    error {
        errorMessage: An error was encountered while in the application title computation.
    }
)

appComputation last-page (
    itemName: LAST_PAGE
    execution {
        sequence: 10
    }
    computation {
        staticValue: 1
    }
    error {
        errorMessage: Error
    }
)

