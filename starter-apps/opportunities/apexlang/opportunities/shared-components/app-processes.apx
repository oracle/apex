appProcess breadcrumb-for-account (
    name: Breadcrumb for Account
    type: executeCode
    source {
        plsqlCode:
            ```plsql
            declare
            
              l_id number;
            
            begin
            
              l_id := 
                case :APP_PAGE_ID
                  when '94' then nv('P94_ID')
                end;
            
              select apex_escape.html(customer_name)
              into :BREADCRUMB_DISPLAY
              from eba_sales_customers
              where id = l_id;
            
            end;
            ```
    }
    execution {
        sequence: 1
    }
    serverSideCondition {
        type: currentPageInList
        pages: 94
    }
)

