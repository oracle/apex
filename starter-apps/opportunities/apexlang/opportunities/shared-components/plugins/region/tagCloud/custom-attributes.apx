customAttribute attribute_01 (
    apexlangName: linkTarget
    attribute: 1
    name: Link Target
    type: linkToTargetPageUrl
    validation {
        required: true
    }
    appearance {
        sequence: 10
    }
    help {
        helpText: Enter a target page to be called when the user clicks a tag. Use the #TAG# substitution for the tag that is clicked.
    }
    examples {
        examples: f?p=&APP_ID.:69:&APP_SESSION.::::P69_SEARCH:#TAG#
    }
)

customAttribute attribute_02 (
    apexlangName: maximumTags
    attribute: 2
    name: Maximum Tags
    type: integer
    validation {
        maxLength: 4
    }
    appearance {
        sequence: 20
    }
    builder {
        displayWidth: 4
    }
    help {
        helpText: Enter the maximum number of tags to display.
    }
    comments {
        comments: Enter the maximum number of tags to display in the region.
    }
)

customAttribute attribute_03 (
    apexlangName: showCount
    attribute: 3
    name: Show Count
    type: yesNo
    appearance {
        sequence: 30
    }
    default {
        value: true
    }
    help {
        helpText: Select whether to show the tag count next to the tag.
    }
)

