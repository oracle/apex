lov p93-country-r-id (
    name: P93_COUNTRY_R_ID
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select COUNTRY_NAME display_value, id return_value 
            from eba_sales_COUNTRIES
            where id not in (select country_id
                             from eba_sales_terr_map
                             where territory_id = :P93_ID
                             and country_id is not null)
            order by 1
            ```
    }
)

lov p93-state-r-id (
    name: P93_STATE_R_ID
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select state d, id r
            from  eba_sales_states
            where id not in (select state_id
                             from eba_sales_terr_map
                             where territory_id = :P93_ID
                             and state_id is not null)
            order by 1
            ```
    }
)

lov pill-display-as (
    name: PILL_DISPLAY_AS
    source {
        location: staticValues
    }

    entry cards-view (
        sequence: 1
        display: Cards View
        return: CARDS
        globalization {
            template: <span class="t-Icon fa fa-cards" title="#DISPLAY_VALUE#"></span><span class="u-VisuallyHidden">#DISPLAY_VALUE#</span>
        }
    )

    entry customizable-grid (
        sequence: 3
        display: Customizable Grid
        return: GRID
        globalization {
            template: <span class="t-Icon fa fa-table" title="#DISPLAY_VALUE#"></span><span class="u-VisuallyHidden">#DISPLAY_VALUE#</span>
        }
    )

    entry report-view (
        sequence: 2
        display: Report View
        return: REPORT
        globalization {
            template: <span class="t-Icon fa fa-reorder" title="#DISPLAY_VALUE#"></span><span class="u-VisuallyHidden">#DISPLAY_VALUE#</span>
        }
    )

)

lov primary-sales-rep (
    name: PRIMARY_SALES_REP
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select r.rep_email||' - '||r2.role_name display_value, 
                     r.ID return_value 
            from eba_sales_SALESREPS r, 
                    eba_sales_salesrep_roles r2
            where r.rep_role = r2.id(+) and r2.is_sales_rep = 'Y'
            order by 1
            ```
    }
)

