    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select name as d,
                   id as r
              from EBA_SALES_SUPPORT_AMTS
             order by 1
            ```
    }
)

lov svps (
    name: SVPS
    source {
        type: legacySqlQuery
        sqlQuery: select svp_name, id from eba_sales_svps order by upper(svp_name)
    }
)

lov team-member (
    name: TEAM MEMBER
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select r.rep_email||' - '||r2.role_name display_value, 
                     r.ID return_value 
            from eba_sales_SALESREPS r, 
                    eba_sales_salesrep_roles r2
            where r.rep_role = r2.id(+)
            order by 1
            ```
    }
)

lov terms-id-return-value (
    name: TERMS - ID RETURN VALUE
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select name as d,
                   id as r
              from eba_sales_terms
             order by 2
            ```
    }
)

lov terms-num-months-return-value (
    name: TERMS - NUM_MONTHS RETURN VALUE
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select name as d,
                   month_equiv as r
              from eba_sales_terms
             order by 2
            ```
    }
)

lov territory (
