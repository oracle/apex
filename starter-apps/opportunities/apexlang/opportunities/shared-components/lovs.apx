lov quarter (
    name: QUARTER
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select PERIOD_NAME display_value, PERIOD_NAME return_value 
            from EBA_SALES_SALES_PERIODS
            order by first_day
            ```
    }
)

lov quarter-begin (
    name: QUARTER BEGIN
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select PERIOD_NAME ||
                   case when sysdate between first_day and last_day then ' *' end d,
                   to_char(first_day,'YYYYMMDD') r 
              from EBA_SALES_SALES_PERIODS
             where sysdate >= first_day
            order by first_day
            ```
    }
)

lov quarter-end (
    name: QUARTER END
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select PERIOD_NAME ||
                   case when sysdate between first_day and last_day then ' *' end d,
                   to_char(last_day,'YYYYMMDD') r 
              from EBA_SALES_SALES_PERIODS
             where sysdate >= first_day
             order by first_day
            ```
    }
)

lov quarter-past-and-current (
    name: QUARTER - PAST AND CURRENT
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select PERIOD_NAME  ||
                   case when sysdate between first_day and last_day then ' *' end d,
                   PERIOD_NAME r 
              from EBA_SALES_SALES_PERIODS
             where sysdate >= first_day
             order by first_day
            ```
    }
)

