        language: en
    }
)

textMessage ACCESS_CONTROL_INFO (
    message {
        text:
            ```
            <p>When Access Control is enabled, Administrators have the ability to restrict access to certain application features, for authenticated users. Opportunities supports the following 3 access levels; Reader, Contributor and Administrator.
              <b>Readers</b> have read-only access and can also view reports.
              <b>Contributors</b> can create, edit, delete and view reports.
              <b>Administrators</b>, in addition to Contributor's capability, can also perform Opportunities administration, including configuration of access control, managing application look-up data and installing or uninstalling sample data.</p> 
            
            ```
        language: en
    }
)

textMessage ACCESS_CONTROL_IS_DISABLED (
    message {
        text: Access control for this application is currently disabled.  All users are currently Administrators. Navigate to <a href="%0">application administration</a> to enable access control.
        language: en
    }
)

textMessage ACL_DISABLED (
    message {
        text: <p>All users are currently <strong>Administrators</strong>. Please enable Access Control to restrict user access to this application.</p>
        language: en
    }
)

textMessage ACL_ENABLED (
    message {
        text: <p>Only users defined in the Access Control List have access to this application.</p>
        language: en
    }
)

textMessage ACL_PUBLIC_CONTRIBUTE (
    message {
        text: <p>All authenticated users have <strong>Reader</strong> and <strong>Contributor</strong> access.</p><p>Administrators are restricted by the Access Control List.</p>
        language: en
    }
)

textMessage ACL_PUBLIC_READONLY (
    message {
        text: <p>All authenticated users have <strong>Reader</strong> access.</p><p>Contributors and Administrators are restricted by the Access Control List.</p>
        language: en
    }
)

textMessage AC_CONFIGURATION_INFO (
    message {
        text:
            ```
            <p><b>Enabling Access Control</b> means that access to the application and its features are controlled by the current <b>Access Control List</b>, as defined by the application administrator. Opportunities has 3 access levels available that can be granted to a user; Administrator, Contributor and Reader. Please see the Manage Access Control List page for further details on what each level provides.</p>
            <p>In addition, if you don't want to have to define every 'Reader' of your application, you can select <b>Any Authenticated User</b> from the <b>Reader Access</b> configuration option. This opens read-only access to any user who can authenticate into your application.</p>
            <br />
            <p><b>Disabling Access Control</b> means that access to the application and all of its features including Administration are open to any user who can authenticate to the application.</p>
            <br />
            <p><em>Note: Whether Access Control is enabled or disabled, a user still has to authenticate successfully into the application.</em></p>
            ```
        language: en
    }
)

