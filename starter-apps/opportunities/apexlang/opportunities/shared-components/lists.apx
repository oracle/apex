        }
        layout {
            sequence: 3
        }
        link {
            target: {
                page: 139
            }
        }
        userDefinedAttributes {
            1: Monthly calendar of application activity, reporting distinct users and total page views by day.
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    entry page-views (
        label: Page Views
        icon {
            imageIconCssClasses: fa-file-text
        }
        layout {
