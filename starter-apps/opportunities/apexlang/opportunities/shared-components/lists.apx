        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    entry add-competition (
        label: Add Competition
        icon {
            imageIconCssClasses: fa-user-plus
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 145
                items: {
                    P145_CUSTOMER_ID: &P94_ID.
                }
                clearCache: 145
            }
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @competitors
        }
    )

    entry add-contact (
        label: Add Contact
        icon {
            imageIconCssClasses: fa-phone
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 106
                items: {
                    P106_CUSTOMER_ID: &P94_ID.
                    P106_SHOW_ACCOUNT: N
                }
                clearCache: 106
            }
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @contacts
        }
    )

    entry add-link (
        label: Add Link
        icon {
            imageIconCssClasses: fa-link
        }
        layout {
            sequence: 60
        }
        link {
            target: {
                page: 114
                items: {
                    P114_ENTITY_TYPE: ACCOUNT
                    P114_ENTITY_ID: &P94_ID.
                }
                clearCache: 114
            }
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    entry add-location (
        label: Add Location
        icon {
            imageIconCssClasses: fa-map-marker
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 32
                items: {
                    P32_CUSTOMER_ID: &P94_ID.
                }
                clearCache: 32
            }
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @account-locations
        }
    )

    entry add-support-amount (
        label: Add Support Amount
        icon {
            imageIconCssClasses: fa-money
        }
        layout {
            sequence: 50
        }
        link {
            target: {
                page: 122
                items: {
                    P122_CUSTOMER_ID: &P94_ID.
                }
                clearCache: 122
            }
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                from apex_application_build_options bo
                where application_id = :APP_ID
                  and build_option_name = 'Support Amounts'
                  and build_option_status = 'Include'
                  and (select count(*) from EBA_SALES_SUPPORT_AMTS) > 0
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @support-amounts
        }
    )

)

