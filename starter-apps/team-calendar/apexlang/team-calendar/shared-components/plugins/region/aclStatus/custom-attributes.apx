customAttribute attribute_01 (
    apexlangName: configurationPage
    attribute: 1
    name: Configuration Page
    type: pageNumber
    validation {
        required: true
    }
    appearance {
        sequence: 10
    }
    help {
        helpText: Enter the application page number used to maintain the ACL settings.
    }
)

customAttribute attribute_02 (
    apexlangName: aclPage
    attribute: 2
    name: ACL Page
    type: pageNumber
    validation {
        required: true
    }
    appearance {
        sequence: 20
    }
    help {
        helpText: Enter the application page number used to maintain users and their access level.
    }
)

customAttribute attribute_03 (
    apexlangName: administratorCountColumn
    attribute: 3
    name: Administrator Count Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
    appearance {
        sequence: 30
    }
    supports {
        dataTypes: number
    }
    help {
        helpText: Select the column from the region SQL Query which holds the count of Administrators.
    }
)

customAttribute attribute_04 (
    apexlangName: contributorCountColumn
    attribute: 4
    name: Contributor Count Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
    appearance {
        sequence: 40
    }
    supports {
        dataTypes: number
    }
    help {
        helpText: Select the column from the region SQL Query which holds the count of Contributors.
    }
)

customAttribute attribute_05 (
    apexlangName: readerCountColumn
    attribute: 5
    name: Reader Count Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
