customAttribute attribute_01 (
    apexlangName: groupByColumn
    attribute: 1
    name: Group By Column
    type: regionSqlQueryColumn
    validation {
        required: true
    }
    appearance {
        sequence: 10
    }
    supports {
        dataTypes: [
            varchar2
            number
            date
            timestamp
            timestampWithTimeZone
            timestampWithLocalTimeZone
        ]
    }
    help {
        helpText: Select the column from the region SQL Query that holds the column the report will be grouped by.
    }
)

customAttribute attribute_02 (
    apexlangName: colorColumn
    attribute: 2
    name: Color Column
    type: regionSqlQueryColumn
    appearance {
        sequence: 120
    }
    help {
        helpText: Select the column from the region SQL Query that holds the color for the list.
    }
)

customAttribute attribute_03 (
