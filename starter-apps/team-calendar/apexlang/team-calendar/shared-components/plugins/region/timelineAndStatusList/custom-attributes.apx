    }
)

customAttribute attribute_14 (
    apexlangName: colorLabel
    attribute: 14
    name: Color Label
    type: regionSqlQueryColumn
    appearance {
        sequence: 140
    }
    builder {
        showInWizard: false
    }
    dependingOn {
        attribute: @attribute_02/component
        conditionType: isNotNull
    }
)

