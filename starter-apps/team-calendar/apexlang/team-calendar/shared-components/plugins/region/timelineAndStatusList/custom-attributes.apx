customAttribute attribute_12 (
    apexlangName: displayAs
    attribute: 12
    name: Display As
    type: selectList
    validation {
        required: true
    }
    appearance {
        sequence: 5
    }
    default {
        value: D
    }
    help {
        helpText: Select whether the region should be displayed as a timeline, based on a given date, or a list.
    }

    entry statusList (
        sequence: 20
        display: Status List
        return: L
    )

    entry timeline (
        sequence: 10
        display: Timeline
        return: D
    )

)

customAttribute attribute_13 (
    apexlangName: statusColumn
