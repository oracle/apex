customAttribute attribute_01 (
    apexlangName: pageReportPage
    attribute: 1
    name: Page Report Page
    type: pageNumber
    appearance {
        sequence: 10
    }
    help {
        helpText: Enter or select the page number which has a report listing the pages within the application and the respective role required to access that page.
    }
)

customAttribute attribute_02 (
    apexlangName: publicPagesLabel
    attribute: 2
    name: Public Pages Label
    validation {
        required: true
    }
    appearance {
        sequence: 20
    }
    builder {
        translatable: true
    }
    default {
        value: Public Pages
    }
    help {
        helpText: Enter the label displayed for pages with no authorization defined.
    }
)

customAttribute attribute_03 (
    apexlangName: authenticatedPagesLabel
    attribute: 3
    name: Authenticated Pages Label
    validation {
        required: true
    }
    appearance {
        sequence: 30
    }
    builder {
        translatable: true
    }
    default {
        value: Login Required Pages
    }
    help {
        helpText: Enter the label displayed for pages that require authentication.
    }
)

customAttribute attribute_04 (
    apexlangName: authorizedPagesLabel
    attribute: 4
    name: Authorized Pages Label
    validation {
        required: true
    }
    appearance {
        sequence: 40
    }
    builder {
        translatable: true
    }
    default {
        value: Authorization Protected
    }
    help {
        helpText: Enter the label displayed for pages where a specific authorization is defined.
    }
)

