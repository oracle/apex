list access-control (
    name: Access Control

    entry access-control (
        label: Access Control
        icon {
            imageIconCssClasses: fa-key
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 27
            }
        }
        userDefinedAttributes {
            1: Use to change the Access Control Scope or to disable Access Control.
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    entry username-format (
        label: Username Format
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 40
        }
        link {
            target: {
                page: 38
            }
        }
        userDefinedAttributes {
            1: Define the username format for new users in this application.
            2: formIcon
        }
        serverSideCondition {
            type: never
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    entry users (
        label: Users
        icon {
            imageIconCssClasses: fa-users
        }
        layout {
            sequence: 30
        }
        isCurrent {
            type: pages
            pages: 29
        }
        link {
            target: {
                page: 29
                clearCache: [
                    29
                    RIR
                ]
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Administrators can define the domain of users and assign each a role.
            2: userIcon
        }
        serverSideCondition {
            type: expression
            plsqlExpression: eba_ca_fw.get_preference_value('ACCESS_CONTROL_ENABLED') = 'Y'
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

)

