lov access-control-scope (
    name: ACCESS CONTROL SCOPE
    source {
        location: staticValues
    }

    entry contributor-access-for-any-authenticated-user (
        sequence: 2
        display: Contributor access for any authenticated user
        return: PUBLIC_CONTRIBUTE
    )

    entry reader-access-for-any-authenticated-user (
        sequence: 1
        display: Reader access for any authenticated user
        return: PUBLIC_READONLY
    )

    entry restricted-to-users-defined-in-access-control-list (
        sequence: 3
        display: Restricted to users defined in access control list
        return: ACL_ONLY
    )

)

lov access-control-scope-2 (
    name: ACCESS CONTROL SCOPE1
    source {
        location: staticValues
    }

    entry contributors (
        sequence: 2
        display: Contributors
        return: PUBLIC_CONTRIBUTE
    )

    entry readers (
        sequence: 1
        display: Readers
        return: PUBLIC_READONLY
    )

)

lov access-level (
    name: ACCESS_LEVEL
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select access_level d, id r
              from eba_ca_access_levels
             order by 1
            ```
    }
)

lov calendars (
    name: CALENDARS
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select short_name || ' - ' || calendar_name || decode(public_view_yn, 'Y', null, ' (Private)') d
            , calendar_id r
            from eba_ca_calendars c
            where public_view_yn = 'Y'
            or    exists (select 'x'
                          from eba_ca_users u
                          where u.username = :APP_USER
                          and   (   instr(u.restricted_to, c.calendar_id) > 0
                                 or (access_level_id = 3 and restricted_to is null)
                                )
                         ) 
            order by 1
            ```
    }
)

lov calendars-full-name (
    name: CALENDARS FULL NAME
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select d, r
              from
            (
            select 'Default' d,
                   -1 r,
                   1 ob
              from dual
             where exists (select 1 from eba_ca_events
                            where calendar_id is null)
            union
            select short_name ||' - '|| calendar_name || decode(public_view_yn, 'Y', null, ' (Private)') d,
                   calendar_id r,
                   2 ob
              from eba_ca_calendars c
              where public_view_yn = 'Y'
              or    exists (select 'x'
                            from eba_ca_users u
                            where u.username = :APP_USER
                            and   (   instr(u.restricted_to, c.calendar_id) > 0
                                   or (access_level_id = 3 and restricted_to is null)
                                  )
                           ) 
            )
             order by ob, d
            ```
    }
)

lov calendars-with-default (
