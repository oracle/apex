lov start-time-selector (
    name: START TIME SELECTOR
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select to_char(trunc(sysdate)+((i-1)/48),v('APP_TIME_FORMAT')) d,
                   to_char(trunc(sysdate)+((i-1)/48),v('APP_TIME_FORMAT')) r
              from wwv_flow_dual100
             where i < 49
            order by i
            
            ```
    }
)

lov std-time-zones (
    name: STD TIME ZONES
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select distinct tzname d, tzname r
              from V$TIMEZONE_NAMES
             order by 1
            ```
    }
)

lov timeframes-for-ir-col-headings (
    name: TIMEFRAMES (FOR IR COL HEADINGS)
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select tf_name d, 
                   tf_name r
              from EBA_ca_timeframes
             where sysdate <= end_date
             order by start_date
            
            ```
    }
)

lov timeframes-showing-dates (
    name: TIMEFRAMES (SHOWING DATES)
    source {
        type: legacySqlQuery
        sqlQuery:
            ```sql
            select tf_name || ' (' || start_date || ' to ' ||
                                      end_date || ')' d, 
                   tf_id r
              from EBA_ca_timeframes
             order by start_date
            
            ```
    }
)

