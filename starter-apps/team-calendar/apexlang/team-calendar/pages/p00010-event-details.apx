page 10 (
    name: Event Details
    alias: EVENT-DETAILS
    title: Event Details
    pageGroup: @events
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
            var groupCal = groupCal || {};
            
            groupCal.defaultDuration = 1;
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-information (
        name: Audit Information
        type: staticContent
        layout {
            sequence: 60
            parentRegion: @event
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10_EVENT_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region event (
        name: Event
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region links (
        name: Links
        type: staticContent
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-expanded
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    region recurrence (
        name: Recurrence
        type: staticContent
        layout {
            sequence: 40
            parentRegion: @event
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

