    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 30
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &LAST_VIEW.
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button create (
        buttonName: CREATE
        label: Create Event
        layout {
            sequence: 20
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P10_EVENT_ID
        }
    )

    button delete (
        buttonName: DELETE2
        label: Delete
        layout {
            sequence: 50
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P10_EVENT_ID is not null and
                :P10_SERIES_ID is not null
                ```
        }
    )

    button delete-2 (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 40
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P10_EVENT_ID is not null and
                :P10_SERIES_ID is null
                ```
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 10
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10_EVENT_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction display-recurrence-region (
        name: display recurrence region
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P10_RECUR_FLAG
        }
        clientSideCondition {
            type: item=value
            item: P10_RECUR_FLAG
            value: Y
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @recurrence
            }
            execution {
                sequence: 10
                fireWhenEventResultIs: false
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @recurrence
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction hide-time-if-all-day-event (
        name: Hide time if All Day event
        execution {
            sequence: 60
        }
        when {
            selectionType: items
            items: P10_SUPPRESS_TIME
        }
        clientSideCondition {
            type: item=value
            item: P10_SUPPRESS_TIME
