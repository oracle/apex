    computation p10-event-start-time-d (
        itemName: P10_EVENT_START_TIME_D
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select to_char(trunc(to_date(to_char(current_timestamp,'&APP_TIME_FORMAT.'),'&APP_TIME_FORMAT.'),'HH')+1/24,'&APP_TIME_FORMAT.') from dual
                
                ```
        }
        serverSideCondition {
            type: itemIsNull
            item: P10_EVENT_ID
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
