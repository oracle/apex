    dynamicAction redefault-recur-end-date (
        name: redefault recur end date
        execution {
            sequence: 50
        }
        when {
            selectionType: items
            items: P10_EVENT_DATE_D
        }
        serverSideCondition {
            type: expression
            plsqlExpression: "(:P10_EVENT_ID is null or :P10_RECUR_FLAG is null) and regexp_like(:P10_EVENT_DATE_D,'^[:digit:]+\\-[:alpha:]+\\-[:digit:]+$')"
        }

        action native-set-value (
            action: setValue
            settings {
                type: plsqlExpression
                plsqlExpression: to_date(:P10_EVENT_DATE_D,'&APP_DATE_FORMAT.')+7
                itemsToSubmit: P10_EVENT_DATE_D
            }
            affectedElements {
                selectionType: items
                items: P10_RECUR_END_DATE
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction reset-duration-after-refresh (
        name: reset duration after refresh
        execution {
            sequence: 20
        }
