    validation recur-end-date-event-date (
        name: recur end date > event date
        execution {
            sequence: 60
        }
        validation {
            plsqlExpression:
                ```plsql
                to_date(:P10_RECUR_END_DATE,'&APP_DATE_FORMAT.') >=
                to_date(:P10_EVENT_DATE_D,'&APP_DATE_FORMAT.')
                ```
        }
        error {
            errorMessage: Recur End Date must be after Event Date
            associatedItem: @P10_RECUR_END_DATE
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P10_RECUR_END_DATE is not null and 
                :P10_RECUR_FLAG is not null
                ```
        }
    )

