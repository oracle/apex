            formatMask: &APP_DATE_FORMAT.
            width: 15
        }
        validation {
            maxLength: 30
        }
        default {
            type: expression
            plsqlExpression:
                ```plsql
                case when :P10_EVENT_ID is null
                     then sysdate+7
                     else to_date(:P10_EVENT_DATE_D,'&APP_DATE_FORMAT.')+7
                     end
                ```
        }
