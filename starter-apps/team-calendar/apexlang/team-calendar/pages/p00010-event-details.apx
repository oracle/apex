        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: items
                items: [
                    P10_EVENT_START_TIME_D
                    P10_DURATION
                ]
            }
            execution {
                sequence: 10
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: items
                items: [
                    P10_EVENT_START_TIME_D
                    P10_DURATION
                ]
            }
            execution {
                sequence: 20
                fireWhenEventResultIs: false
            }
        )

