page 1000 (
    name: Getting Started
    alias: GETTING-STARTED
    title: Getting Started
    appearance {
        pageTemplate: @/minimal-no-navigation
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .step-container { max-width: 768px; margin: 1.6rem auto }
            .step-container .t-HeroRegion:not(.t-HeroRegion--featured) .t-HeroRegion-wrap { padding: 0 }
            .t-Alert--info .t-Alert-icon { vertical-align: top }
            .t-Alert--horizontal .t-Alert-title { line-height: 2.8rem }
            .content-well { background: rgba(0, 0, 0, .05); border-radius: 2px; padding: 1.6rem }
            .users-table .t-Report-report thead { display: none }
            .users-table .t-Report-cell { padding: 0.8rem 0; font-size: 1.4rem; line-height: 1.5 }
            .cta-button {padding: 16px 32px; font-size: 16px;}
            .t-Card-info {
              margin-top: 0;
            }
            
            .t-Card-desc {
              display: none;
            }
            
            .t-Card-title {
              font-weight: 400;
            }
            .apex-item-yes-no {white-space:pre;}
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region access-control (
        name: Access Control
        type: staticContent
        source {
            htmlCode: <p>Access Control enables you to control the level of access users have to the application.  Your user account is automatically configured as an Administrator.</p>
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            cssClasses: step-container
            icon: fa-number-1
            renderComponents: belowContent
        }
        serverSideCondition {
            type: expression
            plsqlExpression: eba_ca_fw.get_preference_value('FIRST_RUN') = 'YES'
        }
    )

    region acl-level (
        name: ACL Level
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @access-control
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region application-options (
        name: Application Options
        type: staticContent
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            cssClasses: step-container
            icon: fa-number-4
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select null
                  from apex_application_build_options
                 where application_id = :APP_ID
                   and eba_ca_fw.get_preference_value('FIRST_RUN') = 'YES'
                ```
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 80
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
            cssClasses: step-container
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region feature-configuration (
        name: Feature Configuration
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                    build_option_id ID, 
                    build_option_name build_option, 
                    build_option_status, 
                    apex_item.hidden(p_idx => 1, p_value => build_option_id) ||
                    apex_item.hidden(p_idx => 2, p_value => build_option_status) ||
                    apex_item.switch ( 
                       p_idx => 3,
                       p_value => build_option_status,
                       p_on_value => 'Include',
                       p_on_label => 'Yes',
                       p_off_value => 'Exclude',
                       p_off_label => 'No',
                       p_item_id => 'BO_OPT_' || rownum,
                       p_item_label => apex_escape.html(build_option_name) || ': Is Enabled',
                       p_attributes => 'style="white-space:pre;"') toggle_build_option,
                    component_comment,
                    last_updated_on updated,
                    lower(last_updated_by) updated_by
                from
                    apex_application_build_options bo
                where
                    application_id = :APP_ID
                order by
                    2 asc
                ```
        }
        layout {
            sequence: 10
            parentRegion: @application-options
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 500
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlightOff
                t-Report--horizontalBorders
            ]
            showNullValuesAs: -
        }

        column BUILD_OPTION (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Feature
            }
            layout {
                sequence: 2
            }
            columnFormatting {
                htmlExpression:
                    ```html
                    <strong>#BUILD_OPTION#</strong><br>
                    #COMPONENT_COMMENT#
                    ```
            }
            sorting {
                sortable: false
            }
        )

        column BUILD_OPTION_STATUS (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 3
            }
        )

        column COMPONENT_COMMENT (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 5
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 1
            }
        )

        column TOGGLE_BUILD_OPTION (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Enabled
                alignment: center
            }
            layout {
                sequence: 4
                columnAlignment: center
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column UPDATED (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 6
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 7
            }
        )

    )

