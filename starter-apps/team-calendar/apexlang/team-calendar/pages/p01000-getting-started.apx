    region users (
        name: Users
        type: staticContent
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
                t-Alert--customIcons
                t-Alert--info
            ]
            cssClasses: step-container
            icon: fa-number-2
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: expression
            plsqlExpression: eba_ca_fw.get_preference_value('FIRST_RUN') = 'YES'
        }
    )

    region users-2 (
        name: Users
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                    apex_util.prepare_url( 'f?p=' || :APP_ID || ':92:' || :APP_SESSION
                                          || '::::P92_USERNAME,P92_ACCESS_LEVEL_ID,P92_SEQUENCE:'
                                          || lower(apex_escape.html(c001)) || ',' || n001 || ',' || seq_id ) as card_link,
                    lower(c001) as username,
                    case n001 
                        when 3 then 'Administrator' 
                        when 2 then 'Contributor' 
                        when 1 then 'Reader'
                        when 0 then 'Pending Approval'
                        when -99 then 'No Access'
                    end as card_subtext,
                    case n001 
                        when 3 then 'fa-user-wrench' 
                        when 2 then 'fa-user-edit' 
                        when 1 then 'fa-user'
                        when 0 then 'fa-user-clock'
                        when -99 then 'fa-user-ban'
                    end as card_icon,
                    case n001 
                        when 3 then 'u-color-15' 
                        when 2 then 'u-color-4' 
                        when 1 then 'u-color-1'
                        when 0 then 'u-color-7'
                        when -99 then 'u-color-9'
                    end as card_color,
                    rownum,
                    lower(c001) card_title,
                    null card_text
                from
                    apex_collections
                where
                    collection_name = 'NEW_USERS'
                order by n001 desc, c001
                ```
        }
        layout {
            sequence: 10
            parentRegion: @users
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 500
        }
        componentAppearance {
            template: @/cards
            templateOptions: [
                #DEFAULT#
                t-Cards--compact
                t-Cards--displayIcons
                t-Cards--4cols
                t-Cards--animColorFill
            ]
            cssClasses: users-table
        }

        column CARD_COLOR (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Card color
                alignment: center
            }
            layout {
                sequence: 8
            }
            sorting {
                sortable: false
            }
        )

        column CARD_ICON (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Card icon
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column CARD_LINK (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Card link
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column CARD_SUBTEXT (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Card subtext
            }
            layout {
                sequence: 7
            }
            sorting {
                sortable: false
            }
        )

        column CARD_TEXT (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Card text
            }
            layout {
                sequence: 6
            }
            sorting {
                sortable: false
            }
        )

        column CARD_TITLE (
            reportColumnQueryId: 7
            derivedColumn: N
