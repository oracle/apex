            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-user-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 92
                clearCache: 92
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            customAttributes: style="margin-top:10px;"
        }
    )

    button complete (
        buttonName: COMPLETE
        label: Complete Setup
        layout {
            sequence: 10
            region: @buttons
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
                t-Button--iconRight
            ]
