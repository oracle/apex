                heading: Card title
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column ROWNUM (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
        )

        column USERNAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Username
            }
            layout {
                sequence: 1
            }
            columnFormatting {
                htmlExpression: <a href="#CARD_LINK#" role="button" class="t-Button t-Button--icon t-Button--noUI t-Button--iconLeft"><span aria-hidden="true" class="t-Icon t-Icon--left fa #CARD_ICON#" title="#USERNAME# - #CARD_SUBTEXT#"></span>#USERNAME#</a>
            }
            sorting {
                sortable: false
            }
        )

    )

    region welcome-to-application-title (
        name: Welcome to &APPLICATION_TITLE.
        type: staticContent
        source {
            htmlCode: Please take a moment to complete this first time setup.
        }
        layout {
            sequence: 10
            parentRegion: @introduction-wizard
            slot: subRegions
        }
        appearance {
            template: @/hero
            templateOptions: t-HeroRegion--noPadding
            icon: app-group-calendar
        }
        image {
            fileUrl: #APP_FILES#icons/app-icon-192.png
        }
    )

    pageItem P1000_ACL_CONFIG (
        type: radioGroup
        label {
            label: Access Control Level
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @access-control-scope
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @acl-level
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: PUBLIC_READONLY
        }
    )

    pageItem P1000_LOAD_SAMPLE_YN (
        type: radioGroup
        label {
            label: Load Sample Data
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Yes - Load Sample Data;Y,No - Do Not Load Sample Data;N
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @sample-data
            slot: regionBody
            alignment: left
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        default {
            type: static
            staticValue: Y
        }
    )

    pageItem P1000_USERNAME_FORMAT (
        type: radioGroup
        label {
            label: Username Format
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @username-format
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @acl-level
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-above
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            type: expression
            plsqlExpression: eba_ca_fw.get_preference_value ('USERNAME_FORMAT')
            used: always
        }
        serverSideCondition {
            type: expression
            plsqlExpression: instr(:APP_USER,'@') > 0
        }
    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 10
