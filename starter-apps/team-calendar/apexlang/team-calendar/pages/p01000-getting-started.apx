            htmlCode: Loading Sample Data will enable you to explore the functionality of the app with pre-populated sample data.
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--horizontal
