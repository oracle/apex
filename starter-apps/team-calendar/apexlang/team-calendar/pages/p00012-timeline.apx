            affectedElements {
                selectionType: region
                region: @calendars
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-3 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @contact-email
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh-4 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @filters
            }
