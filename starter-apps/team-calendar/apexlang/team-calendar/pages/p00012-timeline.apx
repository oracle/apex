    dynamicAction refresh-timeline (
        name: Refresh Timeline
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: [
                P12_EVENT_TYPE
                P12_CONTACT
            ]
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @timeline-of-future-events
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-timeline-for-create (
        name: Refresh Timeline for Create
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @create
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Event added.');
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @timeline-of-future-events
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-timeline-for-filter (
        name: Refresh Timeline for Filter
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @filter
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.showPageSuccess('Filters applied.');
            }
