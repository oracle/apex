page 24 (
    name: Reporting Time Frame Details
    alias: REPORTING-TIME-FRAME-DETAILS
    title: Reporting Time Frame Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        height: 600
        chained: false
        resizable: false
    }
    navigation {
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration: var htmldb_delete_message='"DELETE_CONFIRM_MSG"';
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: No help is available for this page.
    }

    region audit-information (
        name: Audit Information
        type: staticContent
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P24_TF_ID
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region reporting-time-frame-details (
        name: Reporting Time Frame Details
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P24_CREATED_BY (
        type: displayOnly
        label {
            label: Created By:
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 60
            region: @audit-information
            slot: regionBody
            alignment: left
            labelColumnSpan: 3
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The user who created the record.
        }
    )

    pageItem P24_CREATED_ON (
        type: displayOnly
        label {
            label: Created:
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 50
            region: @audit-information
            slot: regionBody
            alignment: left
            labelColumnSpan: 3
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: CREATED_ON
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the record was created.
        }
    )

    pageItem P24_END_DATE (
        type: datePicker
        label {
            label: End Date
            alignment: left
        }
        layout {
            sequence: 40
            region: @reporting-time-frame-details
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
            width: 20
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: END_DATE
            used: always
        }
        help {
            helpText: End Date of Reporting Timeframe.
        }
    )

    pageItem P24_LAST_UPDATED_BY (
        type: displayOnly
        label {
            label: Last Updated By:
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 80
            region: @audit-information
            slot: regionBody
            alignment: left
            labelColumnSpan: 3
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: LAST_UPDATED_BY
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The user who last updated the record.
        }
    )

    pageItem P24_LAST_UPDATED_ON (
        type: displayOnly
        label {
            label: Last Updated:
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 70
            region: @audit-information
            slot: regionBody
            alignment: left
            labelColumnSpan: 3
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
        }
        source {
            type: databaseColumn
            databaseColumn: LAST_UPDATED_ON
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the record was last updated.
        }
    )

    pageItem P24_START_DATE (
        type: datePicker
        label {
            label: Start Date
            alignment: left
        }
        layout {
            sequence: 30
            region: @reporting-time-frame-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            formatMask: &APP_DATE_FORMAT.
            width: 20
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: START_DATE
            used: always
        }
        help {
            helpText: Start Date of Reporting Timeframe.
        }
    )

    pageItem P24_TF_ID (
        type: hidden
        layout {
            sequence: 10
            region: @reporting-time-frame-details
            slot: regionBody
        }
        source {
            type: databaseColumn
            databaseColumn: TF_ID
            used: always
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P24_TF_NAME (
        type: textField
        label {
            label: Time Frame Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @reporting-time-frame-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 64
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            type: databaseColumn
            databaseColumn: TF_NAME
            used: always
        }
        help {
            helpText: Name of Reporting Timeframe.
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create Time Frame
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P24_TF_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--simple
                t-Button--danger
            ]
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:apex.confirm(htmldb_delete_message,'DELETE');
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P24_TF_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--gapLeft
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P24_TF_ID
        }
    )

    dynamicAction cnx (
        name: CNX
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation p24-tf-name-unique (
        name: P24_TF_NAME unique
        execution {
            sequence: 10
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1 from EBA_ca_timeframes
                 where lower(:P24_TF_NAME) = lower(tf_name)
                   and (:P24_TF_ID != tf_id or :P24_TF_ID is null)
                ```
        }
        error {
            errorMessage: Timeframe Name already exists.
            associatedItem: @P24_TF_NAME
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 1696197467482451789
        }
    )

    process fetch-row-from-eba-ca-timeframes (
        name: Fetch Row from EBA_ca_timeframes
        type: autoRowFetch
        source {
            tableName: EBA_CA_TIMEFRAMES
            pkColumn: TF_ID
            pkItem: P24_TF_ID
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        error {
            errorMessage: Unable to fetch row.
        }
        advanced {
            executionMappingIdentifier: 8014447663900403680
        }
    )

    process process-row-of-eba-ca-timeframes (
        name: Process Row of EBA_ca_timeframes
        type: autoRowProcessing
        target {
            tableName: EBA_CA_TIMEFRAMES
            pkColumn: TF_ID
            pkItem: P24_TF_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action Processed.
        }
        error {
            errorMessage: Unable to process row of table EBA_ca_timeframes.
            displayLocation: onErrorPage
        }
        advanced {
            executionMappingIdentifier: 8014447872744403693
        }
    )

)

