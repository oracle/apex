    region hidden-items (
        name: hidden Items
        type: staticContent
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region notifications (
        name: Notifications
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id, 
                       nvl(lower(NOTIFICATION_TYPE),'yellow') as ALERT_TYPE,
                       NOTIFICATION_NAME alert_title,
                       NOTIFICATION_DESCRIPTION alert_desc,
                       '' alert_action
                  from EBA_CA_NOTIFICATIONS
                 where (DISPLAY_FROM is null or DISPLAY_FROM <= current_date) and
                       (DISPLAY_UNTIL is null or DISPLAY_UNTIL >= current_date)
                 order by nvl(DISPLAY_SEQUENCE,0),NOTIFICATION_NAME
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/alerts
            templateOptions: #DEFAULT#
        }
        componentAdvanced {
            stripHtml: true
        }

        column ALERT_ACTION (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Alert Action
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
        )

        column ALERT_DESC (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Alert Desc
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column ALERT_TITLE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Alert Title
            }
            layout {
                sequence: 3
            }
            sorting {
