        savedReport 4487536 (
            visibility: primaryDefault
            view {
                rowsPerPage: 15
            }

            displayColumn CALENDAR (
                sequence: 3
            )

            displayColumn CONTACT_PERSON (
                sequence: 7
            )

            displayColumn DISP_DURATION (
                sequence: 6
            )

            displayColumn EVENT_DATE (
                sequence: 4
            )

