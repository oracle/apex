page 12 (
    name: Session Ended
    alias: SESSION-ENDED
    title: Session Ended
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authentication: public
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    comments {
        comments: Page used to indicate a question and answer session is now closed
    }

    region thanks-for-participating (
        name: Thanks for participating!
        type: staticContent
        source {
            htmlCode: This qAsk session (<em>&SESSION_CODE.</em>) has ended. Thank you for your participation.
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--wizard
                t-Alert--noIcon
                t-Alert--info
            ]
            cssClasses: u-tC
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    button ok (
        buttonName: OK
        label: OK
        layout {
            sequence: 20
            region: @thanks-for-participating
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
            cssClasses: mnw120
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    branch (
        name: home if no session or session is not closed
        execution {
            sequence: 10
            point: beforeHeader
        }
        behavior {
            target: {
                page: 1
            }
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :SESSION_ID is null or 
                qask_util.get_session_status (
                    p_session_id => :SESSION_ID) != 'CLOSED'
                ```
        }
    )

)

