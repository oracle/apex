    button ask-new-question (
        buttonName: ask_new_question
        label: Ask New Question
        layout {
            sequence: 20
            region: @button-container
            slot: change
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
            cssClasses: [
                w260
                padding-md
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 112
                items: {
                    P112_SESSION_ID: &P121_SESSION_ID.
                }
                clearCache: 112
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button close-session (
        buttonName: close_session
        label: Close Session
        layout {
            sequence: 10
            region: @button-container
            slot: change
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--large
            ]
            cssClasses: [
                w260
                padding-md
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button next-question (
        buttonName: next_question
        label: Next Question
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--mobileHideLabel
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 121
                items: {
                    P121_SESSION_ID: &P121_SESSION_ID.
                    P121_QUESTION_ID: &P121_NEXT_QUESTION_ID.
                }
                clearCache: 121
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P121_NEXT_QUESTION_ID
        }
    )

    button previous-question (
        buttonName: previous_question
        label: Previous Question
        layout {
            sequence: 1
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--mobileHideLabel
                t-Button--iconLeft
            ]
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 121
                items: {
                    P121_SESSION_ID: &P121_SESSION_ID.
                    P121_QUESTION_ID: &P121_PREV_QUESTION_ID.
                }
                clearCache: 121
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P121_PREV_QUESTION_ID
        }
    )

    computation p121-next-question-id (
        itemName: P121_NEXT_QUESTION_ID
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                return qask_util.get_next_question_id (
                    p_session_id  => :P121_SESSION_ID,
                    p_question_id => :P121_QUESTION_ID,
                    p_status      => 'ANY' );
                ```
        }
    )

    computation p121-prev-question-id (
        itemName: P121_PREV_QUESTION_ID
        execution {
            sequence: 40
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                return qask_util.get_prev_question_id (
                    p_session_id  => :P121_SESSION_ID,
                    p_question_id => :P121_QUESTION_ID,
                    p_status      => 'ANY' );
                ```
        }
    )

    computation p121-qr-url (
        itemName: P121_QR_URL
        execution {
            sequence: 70
            point: afterHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare
                    x  varchar2(4000);
                begin 
                    x := apex_page.get_url (
                           p_page => 'home',
                           p_session => 0,
                           p_items => 'P1_CODE',
                           p_values => :P121_SESSION_CODE );
                    x := substr(x,1,instr(x,'&')-1);
                
                    return rtrim(owa_util.get_cgi_env('HTTP_REFERER'),'/') || x;
                end;
                ```
        }
    )

    process close-session (
        name: Close Session
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                qask_util.close_session (
                    p_session_id => :P121_SESSION_ID );
                
                    
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 70667560092865095692
        }
        serverSideCondition {
            whenButtonPressed: @close-session
        }
    )

    process get-question-details (
        name: get question details
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                   l_dont_need  varchar2(4000);
                begin
                qask_util.get_question_details (
                    p_question_id          => :P121_QUESTION_ID,
                    p_question_number      => :P121_QUESTION_NUMBER,
                    p_question_status      => :P121_QUESTION_STATUS,
                    p_question             => :P121_QUESTION,
                    p_answer_type          => :P121_ANSWER_TYPE,
                    p_ask_for_comments_yn  => :P121_ASK_FOR_COMMENTS_YN,
                    p_question_explanation => l_dont_need );
                end;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 63879910059550505326
        }
    )

    process get-session-details (
        name: get session details
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                   l_dont_need  varchar2(4000);
                begin
                qask_util.get_session_details (
                    p_session_id             => :P121_SESSION_ID,
                    p_session_name           => :P121_SESSION_NAME,
                    p_session_code           => :P121_SESSION_CODE,
                    p_purpose                => l_dont_need,
                    p_resp_name_required_yn  => :P121_RESP_NAME_REQUIRED_YN,
                    p_resp_email_required_yn => :P121_RESP_EMAIL_REQUIRED_YN,
                    p_session_status         => :P121_SESSION_STATUS );
                end;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
