    pageItem P121_QUESTION_FILE (
        type: displayImage
        label {
            alignment: left
        }
        settings {
            basedOn: blobColSql
            sqlQuery:
                ```sql
                select question_file
                  from qask_session_questions
                 where id = :P121_QUESTION_ID
                ```
        }
        layout {
            sequence: 140
            region: @p121-question-number-p121-question
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from qask_session_questions
                 where id = :P121_QUESTION_ID
                   and question_filename is not null
                ```
        }
    )

