page 10031 (
    name: Manage User Access
    alias: MANAGE-USER-ACCESS
    title: Manage User Access
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>This page shows a report of the application users and the access level granted.</p>
            <p>Click on the column headings to sort and filter data, or click on the <strong>Actions</strong> button to customize column display and many additional advanced features.<br>
            Click the <strong>Reset</strong> button to reset the interactive report back to the default settings.</p>
            <p>Click the edit icon (yellow pencil) to edit the user details and access level, or to delete the user.</p>
            <p>Click <strong>Add User</strong>, at the top of the report, to add a new user and their access level.</p>
            ```
    }
    config {
        buildOption: @feature-access-control
    }

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region manage-user-access (
        name: Manage User Access
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                   user_name_lc USERNAME,
                   role_names ACCESS_ROLE,
                   (select max(updated_on) from qask_verify_tokens
                     where username = u.user_name_lc
                       and verified_yn = 'Y') last_login
                from APEX_APPL_ACL_USERS u
                where APPLICATION_ID = :APP_ID
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 46428996447761432901
        }

        column ACCESS_ROLE (
            type: plainText
            heading {
                heading: Role
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column LAST_LOGIN (
            type: plainText
            heading {
                heading: Last Login
            }
            layout {
                sequence: 13
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: D
            }
        )

        column USERNAME (
            type: link
            heading {
                heading: Username
            }
            layout {
                sequence: 2
            }
            link {
                target: {
                    page: 10032
                    items: {
                        P10032_ID: #ID#
                    }
                    clearCache: 10032
                }
                linkText: #USERNAME#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Manage User Access
        }

        savedReport 464289992 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACCESS_ROLE (
                sequence: 2
            )

            displayColumn LAST_LOGIN (
                sequence: 3
            )

            displayColumn USERNAME (
                sequence: 1
            )

            sort (
                column: USERNAME
                sort {
                    sequence: 1
                }
            )

        )

    )

    region note (
        name: Note
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                if :P10031_RESTRICT_USERS_YN = 'Y' then
                    return apex_lang.message('USERS_AND_ACCESS_REQUESTS_RESTRICTED_BY_EMAIL_DOMAIN');
                elsif :P10031_RESTRICT_REQUESTS_YN = 'Y' then
                    return apex_lang.message('ACCESS_REQUESTS_RESTRICTED_BY_EMAIL_DOMAIN');
                end if;
                ```
            pageItemsToSubmit: [
                P10031_RESTRICT_USERS_YN
                P10031_RESTRICT_REQUESTS_YN
            ]
        }
        layout {
            sequence: 5
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
    )

    pageItem P10031_RESTRICT_REQUESTS_YN (
        type: hidden
        layout {
            sequence: 10
            region: @note
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10031_RESTRICT_USERS_YN (
        type: hidden
        layout {
            sequence: 20
            region: @note
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button add-multiple-users (
        buttonName: ADD_MULTIPLE_USERS
        label: Add Multiple Users
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10033
                clearCache: 10033
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 40
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10032
                clearCache: 10032
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @manage-user-access
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                t-Button--iconLeft
                t-Button--gapRight
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report-after-create (
        name: Refresh Report after create
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @manage-user-access
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-report-after-edit (
        name: Refresh Report after edit
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @manage-user-access
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @manage-user-access
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p10031-restrict-requests-yn (
        itemName: P10031_RESTRICT_REQUESTS_YN
        execution {
            sequence: 10
        }
        computation {
            type: expression
            language: sql
            sqlExpression: qask_util.get_setting('restrict_requests_to_email_domains_yn')
        }
    )

    computation p10031-restrict-users-yn (
        itemName: P10031_RESTRICT_USERS_YN
        execution {
            sequence: 20
        }
        computation {
            type: expression
            language: sql
            sqlExpression: qask_util.get_setting('restrict_users_to_email_domains_yn')
        }
    )

)

