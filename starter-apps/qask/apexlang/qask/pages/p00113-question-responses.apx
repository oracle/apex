page 113 (
    name: Question Responses
    alias: QUESTION-RESPONSES
    title: Question Responses
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        fileUrls: #APP_FILES#jquery.qrcode.min.js
        executeWhenPageLoads:
            ```javascript-browser
            	jQuery('#qr_code').qrcode({
                    render	: "table",
            		text	: '&P113_QR_URL!RAW.'
            	});
            ```
    }
    css {
        inline:
            ```css
            :root {
                --a-button-gap-x: 1rem;
            }
            .qr-container {
                min-height: 348px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-direction: column;
            }
            #qr_code {
                padding: 8px;
                background-color: white;
            }
            .qr-container h2 {
                margin: 0 0 16px 0;
                font-weight: 700;
            }
            
            .t-BadgeList + .t-Report-pagination {
                display: none;
            }
            
            /* Style Responses Badge */
            .t-ContextualInfo-label {
                position: absolute;
                overflow: hidden;
                clip: rect(0 0 0 0);
                margin: -1px;
                padding: 0;
                width: 1px;
                height: 1px;
                border: 0;
            }
            .t-ContextualInfo-value {
                margin-top: 4px;
                padding: 4px 8px;
                background: rgba(0,0,0,.1);
                border-radius: 4px;
                font-weight: 600;
                min-width: 32px;
                display: block;
                text-align: center;
            }
            ```
    }
    security {
        authorizationScheme: @host
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region answers-by-participant (
        name: Answers by Participant
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.name,
                       r.email,
                       r.apex_session,
                       r.user_agent,
                       r.x_forwarded_for,
                       r.remote_addr,
                       a.answer_id,
                       a.answer_text,
                       a.comment_text,
                       a.created_on
                  from qask_responses r,
                       qask_response_answers a
                 where r.session_id = :P113_SESSION_ID
                   and r.id = a.response_id
                   and :P113_QUESTION_ID = a.question_id
                order by r.id, a.answer_text
                ```
        }
        layout {
            sequence: 60
            parentRegion: @live-responses-2
            slot: subRegions
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                js-showMaximizeButton
            ]
        }
        advanced {
            htmlDomId: live_responses_report
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 238839073197339895270
        }

        column ANSWER_ID (
            type: hidden
            heading {
                heading: Answer Id
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column ANSWER_TEXT (
            type: plainText
            heading {
                heading: Answer
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: S
            }
        )

        column APEX_SESSION (
            type: plainText
            heading {
                heading: Session ID
            }
            layout {
                sequence: 20
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: U
            }
        )

        column COMMENT_TEXT (
            type: plainText
            heading {
                heading: Comment Text
            }
            layout {
                sequence: 70
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: X
            }
            serverSideCondition {
                type: expression
                language: sql
                sqlExpression: :P113_ASK_FOR_COMMENTS_YN = 'Y'
            }
        )

        column CREATED_ON (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 110
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: Y
            }
        )

        column EMAIL (
            type: plainText
            heading {
                heading: Email
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: T
            }
            serverSideCondition {
                type: expression
                plsqlExpression: :P113_RESP_EMAIL_REQUIRED_YN = 'Y'
            }
        )

        column NAME (
            type: plainText
            heading {
                heading: Name
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: R
            }
            serverSideCondition {
                type: expression
                plsqlExpression: :P113_RESP_NAME_REQUIRED_YN = 'Y'
            }
        )

        column REMOTE_ADDR (
            type: plainText
            heading {
                heading: Remote Address
            }
            layout {
                sequence: 100
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: W
            }
        )

        column USER_AGENT (
            type: plainText
            heading {
                heading: User Agent
            }
            layout {
                sequence: 80
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column X_FORWARDED_FOR (
            type: plainText
            heading {
                heading: X Forwarded For
            }
            layout {
                sequence: 90
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: V
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Answers by Participant
        }

        savedReport 300483001 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ANSWER_TEXT (
                sequence: 4
            )

            displayColumn APEX_SESSION (
                sequence: 1
            )

            displayColumn COMMENT_TEXT (
                sequence: 5
            )

            displayColumn EMAIL (
                sequence: 3
            )

            displayColumn NAME (
                sequence: 2
            )

            sort (
                column: CREATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
