                       qask_response_answers a
                 where r.session_id = :P113_SESSION_ID
                   and r.id = a.response_id
                   and a.question_id = :P113_QUESTION_ID
                ```
            pageItemsToSubmit: P113_SESSION_CODE
        }
        layout {
            sequence: 10
