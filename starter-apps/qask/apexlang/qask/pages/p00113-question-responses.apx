                ```plsql
                qask_util.get_session_status (
                    p_session_id => :P113_SESSION_ID) = 'OPEN'  and
                :P113_QUESTION_STATUS = 'CLOSED' and
                :P113_NEXT_QUESTION_ID is not null
                ```
        }
    )

