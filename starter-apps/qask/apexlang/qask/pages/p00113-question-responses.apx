    button ask-new-question (
        buttonName: ASK_NEW_QUESTION
        label: Ask New Question
        layout {
            sequence: 40
            region: @button-container
            slot: change
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
            cssClasses: [
                w200
                padding-md
                u-bold
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 112
                items: {
                    P112_SESSION_ID: &P113_SESSION_ID.
                }
                clearCache: 112
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                qask_util.get_session_status (
                    p_session_id => :P113_SESSION_ID) = 'OPEN' and
                :P113_QUESTION_STATUS = 'CLOSED' and
                :P113_NEXT_QUESTION_ID is null
                ```
        }
    )

