page 10038 (
    name: Restricted To Email Domain Details
    alias: RESTRICTED-TO-EMAIL-DOMAIN-DETAILS
    title: Restricted To Email Domain Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region restricted-to-email-domain-details (
        name: Restricted To Email Domain Details
        type: form
        source {
            location: localDatabase
            tableName: QASK_RESTRICTED_EMAIL_DOMAINS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P10038_COMMENTS (
        type: textField
        label {
            label: Comments
            alignment: left
        }
        layout {
            sequence: 30
            region: @restricted-to-email-domain-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: COMMENTS
            dataType: varchar2
        }
    )

    pageItem P10038_CREATED_BY (
        type: hidden
        layout {
            sequence: 60
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The user who created the record.
        }
    )

    pageItem P10038_CREATED_ON (
        type: hidden
        layout {
            sequence: 50
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: CREATED_ON
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the record was created.
        }
    )

    pageItem P10038_EMAIL_DOMAIN (
        type: textField
        label {
            label: Email Domain
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 20
            region: @restricted-to-email-domain-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 15
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: EMAIL_DOMAIN
            dataType: varchar2
        }
    )

    pageItem P10038_ID (
        type: hidden
        layout {
            sequence: 10
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10038_ROW_VERSION (
        type: hidden
        layout {
            sequence: 40
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: ROW_VERSION
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10038_UPDATED_BY (
        type: hidden
        layout {
            sequence: 80
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10038_UPDATED_ON (
        type: hidden
        layout {
            sequence: 70
            region: @restricted-to-email-domain-details
            slot: regionBody
        }
        source {
            formRegion: @restricted-to-email-domain-details
            column: UPDATED_ON
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P10038_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10038_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10038_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation valid-domain (
        name: valid domain
        execution {
            sequence: 10
        }
        validation {
            type: itemMatchesRegexp
            item: P10038_EMAIL_DOMAIN
            regexp: "[a-z0-9.-]+\\.[a-z]{2,4}"
        }
        error {
            errorMessage: This is not a valid email domain.
            associatedItem: @P10038_EMAIL_DOMAIN
        }
    )

    computation p10038-email-domain (
        itemName: P10038_EMAIL_DOMAIN
        execution {
            sequence: 10
            point: afterSubmit
        }
        computation {
            type: expression
            language: sql
            sqlExpression: replace(lower(:P10038_EMAIL_DOMAIN),'@','')
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 12145154826417162565
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-restricted-to-email-domain-details (
        name: Initialize form Restricted To Email Domain Details
        type: formInitialization
        formRegion: @restricted-to-email-domain-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 12145154011468162565
        }
    )

    process process-form-restricted-to-email-domain-details (
        name: Process form Restricted To Email Domain Details
        type: formAutoRowProcessing
        formRegion: @restricted-to-email-domain-details
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 12145154431744162565
        }
    )

)

