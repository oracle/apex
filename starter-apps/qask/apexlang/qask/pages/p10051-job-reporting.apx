page 10051 (
    name: Job Reporting
    alias: JOB-REPORTING
    title: Job Reporting
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region job-reporting (
        name: Job Reporting
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select job_name, 
                       comments, 
                       state, 
                       last_start_date, 
                       last_run_duration, 
                       next_run_date 
                  from user_scheduler_jobs 
                 where job_name like 'QASK%'
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 55932911527001376266
        }

        column COMMENTS (
            type: plainText
            heading {
                heading: Comments
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: W
            }
        )

        column JOB_NAME (
            type: plainText
            heading {
                heading: Job Name
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: V
            }
        )

        column LAST_RUN_DURATION (
            type: plainText
            heading {
                heading: Last Run Duration
            }
            layout {
                sequence: 50
            }
            source {
                dataType: OTHER
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: Z
            }
            enableUsersTo {
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column LAST_START_DATE (
            type: plainText
            heading {
                heading: Last Started
            }
            layout {
                sequence: 40
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: Y
            }
        )

        column NEXT_RUN_DATE (
            type: plainText
            heading {
                heading: Next Run Date
            }
            layout {
                sequence: 60
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: AA
            }
        )

        column STATE (
            type: plainText
            heading {
                heading: State
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: X
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Email Reporting
        }

        savedReport 464359010 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn COMMENTS (
                sequence: 2
            )

            displayColumn JOB_NAME (
                sequence: 1
            )

            displayColumn LAST_RUN_DURATION (
                sequence: 5
            )

            displayColumn LAST_START_DATE (
                sequence: 4
            )

            displayColumn STATE (
                sequence: 3
            )

            sort (
                column: JOB_NAME
                sort {
                    sequence: 1
                }
            )

            sort (
                column: MAIL_MESSAGE_CREATED
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @job-reporting
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: t-Button--iconLeft
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

