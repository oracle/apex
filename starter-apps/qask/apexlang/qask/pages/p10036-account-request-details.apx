page 10036 (
    name: Account Request Details
    alias: ACCOUNT-REQUEST-DETAILS
    title: Account Request Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region account-request-details (
        name: Account Request Details
        type: form
        source {
            location: localDatabase
            tableName: QASK_ACCOUNT_REQUESTS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    pageItem P10036_ACCEPTED_TERMS_ID (
        type: hidden
        layout {
            sequence: 40
            region: @account-request-details
            slot: regionBody
        }
        source {
            formRegion: @account-request-details
            column: ACCEPTED_TERMS_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10036_CREATED_BY (
        type: hidden
        layout {
            sequence: 120
            region: @account-request-details
            slot: regionBody
        }
        source {
            formRegion: @account-request-details
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The user who created the record.
        }
    )

