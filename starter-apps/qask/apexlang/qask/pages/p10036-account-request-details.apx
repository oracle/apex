        }
    )

    pageItem P10036_STATUS_REASON (
        type: textarea
        label {
            label: Reason (mandatory if declining)
            alignment: left
        }
        layout {
            sequence: 90
            region: @account-request-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @account-request-details
            column: STATUS_REASON
            dataType: varchar2
        }
    )

    pageItem P10036_UPDATED_BY (
        type: hidden
        layout {
            sequence: 140
            region: @account-request-details
            slot: regionBody
        }
        source {
