page 10005 (
    name: All Sessions
    alias: ALL-SESSIONS
    title: All Sessions
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: <p>This report shows all email queued to be sent and those already sent.</p>
    }
    config {
        buildOption: @feature-email-reporting
    }

    region all-sessions (
        name: All Sessions
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       session_code,
                       case session_status when 'OPEN' then 'Active'
                                           when 'CLOSED' then 'Closed'
                                           when 'STAGED' then 'Draft'
                            end session_status,
                       session_name,
                       purpose,
                       owner,
                       (select count(*) from qask_session_questions
                         where session_id = s.id) question_cnt,
                       (select count(*) from qask_responses
                         where session_id = s.id) response_cnt,
                       nvl(started_on,created_on) created_on
                  from qask_sessions s
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 134310308854935412977
        }

        column CREATED_ON (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 82
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: AC
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 2
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column OWNER (
            type: plainText
            heading {
                heading: Owner
            }
            layout {
                sequence: 52
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Z
            }
        )

        column PURPOSE (
            type: plainText
            heading {
                heading: Purpose
            }
            layout {
                sequence: 42
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Y
            }
        )

        column QUESTION_CNT (
            type: plainText
            heading {
                heading: Questions
                alignment: end
            }
            layout {
                sequence: 62
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: AA
            }
        )

        column RESPONSE_CNT (
            type: plainText
            heading {
                heading: Responses
                alignment: end
            }
            layout {
                sequence: 72
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: AB
            }
        )

        column SESSION_CODE (
            type: plainText
            heading {
                heading: Session Code
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: V
            }
        )

        column SESSION_NAME (
            type: plainText
            heading {
                heading: Name
            }
            layout {
                sequence: 32
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: X
            }
        )

        column SESSION_STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: W
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Email Reporting
        }

        savedReport 464359010 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CREATED_ON (
                sequence: 7
            )

            displayColumn OWNER (
                sequence: 4
            )

            displayColumn QUESTION_CNT (
                sequence: 5
            )

            displayColumn RESPONSE_CNT (
                sequence: 6
            )

            displayColumn SESSION_CODE (
                sequence: 1
            )

            displayColumn SESSION_NAME (
                sequence: 2
            )

            displayColumn SESSION_STATUS (
                sequence: 3
            )

            sort (
                column: CREATED_ON
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @all-sessions
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: t-Button--iconLeft
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

