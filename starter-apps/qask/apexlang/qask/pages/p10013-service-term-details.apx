page 10013 (
    name: Service Term Details
    alias: SERVICE-TERM-DETAILS
    title: Service Term Details
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: #DEFAULT#
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region service-term-details (
        name: Service Term Details
        type: form
        source {
            location: localDatabase
            tableName: QASK_SERVICE_TERMS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P10013_CREATED_BY (
        type: hidden
        layout {
            sequence: 60
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The user who created the record.
        }
    )

    pageItem P10013_CREATED_ON (
        type: hidden
        layout {
            sequence: 50
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: CREATED_ON
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
        help {
            helpText: The date on which the record was created.
        }
    )

    pageItem P10013_CURRENT_YN (
        type: switch
        label {
            label: Current
            alignment: left
        }
        layout {
            sequence: 30
            region: @service-term-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @service-term-details
            column: CURRENT_YN
            dataType: varchar2
        }
    )

    pageItem P10013_ID (
        type: hidden
        layout {
            sequence: 10
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10013_ROW_VERSION (
        type: hidden
        layout {
            sequence: 40
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: ROW_VERSION
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10013_SERVICE_TERMS (
        type: textarea
        label {
            label: Service Terms
            alignment: left
        }
        layout {
            sequence: 20
            region: @service-term-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 10
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @service-term-details
            column: SERVICE_TERMS
            dataType: clob
        }
        sessionState {
            dataType: clob
        }
    )

    pageItem P10013_UPDATED_BY (
        type: hidden
        layout {
            sequence: 80
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10013_UPDATED_ON (
        type: hidden
        layout {
            sequence: 70
            region: @service-term-details
            slot: regionBody
        }
        source {
            formRegion: @service-term-details
            column: UPDATED_ON
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNull
            item: P10013_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10013_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10013_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 57354167453016445536
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process delete-service-terms (
        name: delete service terms
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                qask_util.delete_service_terms (
                    p_service_terms_id => :P10013_ID);
                ```
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Service Terms deleted.
        }
        error {
            errorMessage: Error deleting Service Terms.
        }
        advanced {
            executionMappingIdentifier: 52530738849655758333
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process initialize-form-service-term-details (
        name: Initialize form Service Term Details
        type: formInitialization
        formRegion: @service-term-details
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 57354166601650445536
        }
    )

    process insert-service-terms (
        name: insert service terms
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                qask_util.insert_service_terms (
                    p_service_terms => :P10013_SERVICE_TERMS,
                    p_current_yn    => :P10013_CURRENT_YN);
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Service Terms created.
        }
        error {
            errorMessage: Error creating Service Terms.
        }
        advanced {
            executionMappingIdentifier: 52530738620659758331
        }
        serverSideCondition {
            whenButtonPressed: @create
        }
    )

    process update-service-terms (
        name: update service terms
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                qask_util.update_service_terms (
                    p_service_terms_id => :P10013_ID,
                    p_service_terms    => :P10013_SERVICE_TERMS,
                    p_current_yn       => :P10013_CURRENT_YN);
                ```
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Service Terms updated.
        }
        error {
            errorMessage: Error updating Service Terms.
        }
        advanced {
            executionMappingIdentifier: 52530738772264758332
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

)

