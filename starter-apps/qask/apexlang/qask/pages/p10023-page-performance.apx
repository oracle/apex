            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column PAGE_NAME (
            type: plainText
            heading {
                heading: Page Name
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column PAGE_VIEWS (
            type: plainText
            heading {
                heading: Page Views
                alignment: end
            }
            layout {
                sequence: 8
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column PARTIAL_PAGE_VIEWS (
            type: plainText
            heading {
                heading: Partial Page Views
                alignment: end
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column TOTAL_ROWS (
            type: plainText
            heading {
                heading: Total Rows
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column WEIGHTED_PERFORMANCE (
            type: plainText
            heading {
                heading: Weighted Performance
                alignment: end
            }
            layout {
                sequence: 4
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D99
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: D
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Page Performance
        }

        savedReport 464289533 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn APPLICATION_SESSIONS (
                sequence: 7
            )

            displayColumn DISTINCT_USERS (
                sequence: 6
            )

            displayColumn ERRORS (
                sequence: 5
            )

            displayColumn MEDIAN_ELAPSED (
                sequence: 3
            )

            displayColumn PAGE (
                sequence: 1
            )

            displayColumn PAGE_NAME (
                sequence: 2
            )

            displayColumn PAGE_VIEWS (
                sequence: 8
            )

            displayColumn WEIGHTED_PERFORMANCE (
                sequence: 4
            )

            sort (
                column: WEIGHTED_PERFORMANCE
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            sort (
                column: PAGE_VIEWS
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    pageItem P10023_TIMEFRAME (
        type: selectList
        label {
            label: Timeframe
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @timeframe-4-weeks
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @buttons
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional
            templateOptions: #DEFAULT#
            height: 1
        }
        source {
            type: staticValue
            staticValue: 900
        }
    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @page-performance
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: t-Button--iconLeft
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P10023_TIMEFRAME
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @page-performance
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

