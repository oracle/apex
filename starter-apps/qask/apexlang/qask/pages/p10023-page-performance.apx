page 10023 (
    name: Page Performance
    alias: PAGE-PERFORMANCE
    title: Page Performance
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>This page provides an interactive report of the page performance and popularity. The report is ordered by <strong>Weighted Performance</strong> which is calculated by multiplying the Median Elapsed time and number of Page Views.</p>
            <p>Select the reporting timeframe (Default = 1 day) at the top of the page as necessary.<br>
            Click on the column headings to sort and filter data, or click on the <strong>Actions</strong> button to customize column display and many additional advanced features. Click the <strong>Reset</strong> button to reset the interactive report back to the default settings.</p>
            ```
    }
    config {
        buildOption: @feature-activity-reporting
    }

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--slimPadding
                t-ButtonRegion--noUI
                t-Form--large
            ]
        }
    )

    region page-performance (
        name: Page Performance
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select step_id page,
                    (   select page_name
                        from apex_application_pages p
                        where p.page_id = l.step_id
                            and p.application_id = :app_id ) page_name,
                    median(elap)                   median_elapsed,
                    count(*) * median(elap)        weighted_performance,
                    sum(decode(sqlerrm,null,0,1))  errors,
                    count(distinct userid)         distinct_users,
                    count(distinct session_id)     application_sessions,
                    count(*)                       page_views,
                    max(elap)                      max_elapsed,
                    sum(nvl(num_rows,0))           total_rows,
                    sum(decode(page_mode,'P',1,0)) partial_page_views,
                    sum(decode(page_mode,'D',1,0)) full_page_views,
                    min(elap)                      min_elapsed,
                    avg(elap)                      avg_elapsed
                from apex_activity_log l
                where flow_id = :app_id
                    and time_stamp >= sysdate - ( 1/24/60/60 * :P10023_TIMEFRAME )
                    and userid is not null
                group by step_id
                ```
            pageItemsToSubmit: P10023_TIMEFRAME
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 46428942792578432853
        }

        column APPLICATION_SESSIONS (
            type: plainText
            heading {
                heading: Application Sessions
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column AVG_ELAPSED (
            type: plainText
            heading {
                heading: Avg Elapsed
                alignment: end
            }
            layout {
                sequence: 14
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D9999
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
        )

        column DISTINCT_USERS (
            type: plainText
            heading {
                heading: Distinct Users
                alignment: end
            }
            layout {
                sequence: 6
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: F
            }
        )

        column ERRORS (
            type: plainText
            heading {
                heading: Errors
                alignment: end
            }
            layout {
                sequence: 5
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: E
            }
        )

        column FULL_PAGE_VIEWS (
            type: plainText
            heading {
                heading: Full Page Views
                alignment: end
            }
            layout {
                sequence: 12
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column MAX_ELAPSED (
            type: plainText
            heading {
                heading: Max Elapsed
                alignment: end
            }
            layout {
                sequence: 9
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D9999
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column MEDIAN_ELAPSED (
            type: plainText
            heading {
                heading: Median Elapsed
                alignment: end
            }
            layout {
                sequence: 3
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D9999
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: C
            }
        )

        column MIN_ELAPSED (
            type: plainText
            heading {
                heading: Min Elapsed
                alignment: end
            }
            layout {
                sequence: 13
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G990D9999
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: M
            }
        )

        column PAGE (
            type: plainText
            heading {
                heading: Page
                alignment: end
