page 10000 (
    name: Administration
    alias: ADMIN
    title: Administration
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administrator
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>The administration page allows application owners (Administrators) to configure the application and maintain common data used across the application.
            By selecting one of the available settings, administrators can potentially change how the application is displayed and/or features available to the end users.</p>
            <p>Access to this page should be limited to Administrators only.</p>
            ```
    }

    region access-control (
        name: Access Control
        type: staticContent
        layout {
            sequence: 70
            parentRegion: @column-2
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-access-control
        }
    )

    region activity-reports (
        name: Activity Reports
        type: list
        source {
            list: @activity-reports
        }
        layout {
            sequence: 60
            parentRegion: @column
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @feature-activity-reporting
        }
        componentAppearance {
            listTemplate: @/media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region column (
        name: Column 1
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region column-2 (
        name: Column 2
        type: staticContent
        layout {
            sequence: 20
            slot: body
            startNewRow: false
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region user-counts-report (
        name: User Counts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select role_name, user_count
                  from
                  (
                select case when r.role_name = 'Host' then 1 else 2 end ob,
                       r.role_name, 
                       (select count(*) 
                          from apex_appl_acl_user_roles ur
                         where r.role_id = ur.role_id) user_count
                  from apex_appl_acl_roles r
                 where r.application_id = :APP_ID
                 group by r.role_name, r.role_id
                 union
                 select 3 ob,
                        apex_lang.message('ACCESS_REQUESTS') role_name,
                        count(*) user_count
                   from qask_account_requests 
                  where request_status = 'REQUESTED'
                  )
                 order by ob
                ```
        }
        layout {
            sequence: 20
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @/value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column ROLE_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Role Name
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column USER_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: User Count
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    region user-interface (
        name: User Interface
        type: list
        source {
            list: @user-interface
        }
        layout {
            sequence: 100
            parentRegion: @column-2
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            listTemplate: @/media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region user-related-actions (
        name: User Related Actions
        type: list
        source {
            list: @user-related-actions
        }
        layout {
            sequence: 30
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 10
            region: @access-control
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-user-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10032
                clearCache: 10032
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report-after-add (
        name: Refresh Report after add
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @add-user
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @user-counts-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-report-when-user-closed (
        name: Refresh Report when user closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @user-related-actions
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @user-counts-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

