authorization administration-rights (
    name: Administration Rights
    type: isInRoleOrGroup
    settings {
        names: Administrator
    }
    error {
        errorMessage: Insufficient privileges, user is not an Administrator
    }
)

authorization contribution-rights (
    name: Contribution Rights
    type: isInRoleOrGroup
    settings {
        names: [
            Administrator
            Contributor
        ]
    }
    error {
        errorMessage: Insufficient privileges, user is not a Contributor
    }
)

authorization reader-rights (
    name: Reader Rights
    type: plSqlFunctionBody
    settings {
        plsqlFunctionBody:
            ```plsql
            if nvl(apex_app_setting.get_value(
               p_name => 'ACCESS_CONTROL_SCOPE'),'x') = 'ALL_USERS' then
                -- allow user not in the ACL to access the application
                return true;
            else
                -- require user to have at least one role
                return apex_acl.has_user_any_roles (
                    p_application_id => :APP_ID, 
                    p_user_name      => :APP_USER);
            end if;
            ```
    }
    error {
        errorMessage: You not been granted access to this application. Please contact the application administrator.
    }
    advanced {
        evaluationType: perSession
    }
)

