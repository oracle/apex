componentSetting (
    type: dynamicAction
    name: showAiAssistant
)

componentSetting (
    type: item
    name: colorPicker
)

componentSetting (
    type: item
    name: datePicker
    settings {
        appearanceBehavior: [
            monthPicker
            yearPicker
        ]
    }
)

componentSetting (
    type: item
    name: geocodedAddress
    settings {
        mapPreview: [
            resultsPopup
            item
        ]
    }
)

componentSetting (
    type: item
    name: selectMany
)

componentSetting (
    type: item
    name: checkbox
    settings {
        uncheckedValue: N
    }
)

componentSetting (
    type: item
    name: starRating
    settings {
        tooltip: #VALUE#
    }
)

componentSetting (
    type: item
    name: switch
    settings {
        onValue: Y
    }
)

componentSetting (
    type: process
    name: serverSideGeocoding
)

componentSetting (
    type: region
    name: regionDisplaySelector
)

componentSetting (
    type: region
    name: interactiveReport
)

componentSetting (
    type: region
    name: map
)

componentSetting (
    type: restDataSource
    name: oracleCloudAppsSaas
)

componentSetting (
    type: restDataSource
    name: oracleCloudAppsBoss
)

