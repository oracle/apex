list admin-access-control (
    name: Admin - Access Control
    config {
        buildOption: @access-control
    }

    entry access-control (
        label: Access Control
        icon {
            imageIconCssClasses: fa-key
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                page: 10010
            }
        }
        userDefinedAttributes {
            1: Change access control settings and disable access control
        }
    )

    entry users (
        label: Users
        icon {
            imageIconCssClasses: fa-users
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 10011
                action: resetPagination
            }
        }
        userDefinedAttributes {
            1: Access level for authenticated users of this application <br/>Currently &P10000_USER_COUNTS.
        }
    )

)

