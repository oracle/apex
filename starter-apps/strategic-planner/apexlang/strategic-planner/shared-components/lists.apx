list navigation-bar (
    name: Navigation Bar

    entry about-this-app (
        label: About this App
        icon {
            imageIconCssClasses: fa-info
        }
        layout {
            sequence: 50
            parentEntry: @app-user-first-name
        }
        link {
            target: {
                page: 10820
            }
        }
        config {
            buildOption: @about-page
        }
    )

    entry administration (
        label: Administration
        icon {
            imageIconCssClasses: fa-users
        }
        layout {
            sequence: 75
            parentEntry: @app-user-first-name
        }
        link {
            target: {
                page: 10000
                action: resetPagination
            }
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    entry alerts (
        label: Alerts
        icon {
            imageIconCssClasses: fa-bell
        }
        layout {
            sequence: 10
        }
        link {
            target: {
                page: 2
                clearCache: 2
            }
        }
        userDefinedAttributes {
            2: icon-only
            4: Alerts
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_team_member_notifications
                 where team_member_id = :APP_USER_ID
                   and dismissed_yn = 'N'
                   and instr(':'||notification_pref||':',':APP:') > 0
                ```
        }
    )

    entry app-user-first-name (
        label: &APP_USER_FIRST_NAME.
        icon {
            imageIconCssClasses: fa-user
        }
        layout {
            sequence: 20
        }
        link {
            target: {
                type: url
                url: #
            }
        }
        userDefinedAttributes {
            2: has-username
        }
    )

    entry approval-requests (
        label: Approval Requests
        icon {
            imageIconCssClasses: fa-workflow
        }
        layout {
            sequence: 15
        }
        link {
            target: {
                page: 132
            }
        }
        userDefinedAttributes {
            2: icon-only
            4: Approval Requests
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :APPROVALS_PENDING_CNT > 0 or
                :APPROVALS_MORE_INFO_CNT > 0
                ```
        }
        config {
            buildOption: @approvals
        }
    )

    entry feedback (
        label: Feedback
        icon {
            imageIconCssClasses: fa-comment-o
        }
        layout {
            sequence: 30
        }
        link {
            target: {
                page: 12120
                items: {
                    P12120_PAGE_ID: &APP_PAGE_ID.
                }
                clearCache: 12120
            }
        }
        userDefinedAttributes {
            2: icon-only
        }
        serverSideCondition {
            type: expression
            plsqlExpression: apex_util.feedback_enabled
        }
        security {
            authorizationScheme: @reader-rights
        }
        config {
            buildOption: @feedback
        }
    )

    entry list_item (
        label: ---
        layout {
            sequence: 5
            parentEntry: @app-user-first-name
        }
        link {
            target: {
                type: url
                url: separator
            }
        }
