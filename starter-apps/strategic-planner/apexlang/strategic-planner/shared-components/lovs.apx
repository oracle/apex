    }

    entry acknowledged (
        sequence: 2
        display: Acknowledged
        return: 1
    )

    entry closed (
        sequence: 4
        display: Closed
        return: 4
    )

    entry no-action (
        sequence: 1
        display: No Action
        return: 0
    )

    entry open (
        sequence: 3
        display: Open
        return: 3
    )

)

lov projects-detail (
    name: PROJECTS DETAIL
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select 
                 p.id, 
                 decode(rt.release,null,p.project,rt.release_train||' '||rt.release||': '||project)|| ' - '||pct_complete||'%' display
            from SP_PROJECTS p,
                 SP_RELEASE_TRAINS rt
            where p.release_id = rt.id(+) and
                  p.ARCHIVED_YN = 'N' and
                  p.DUPLICATE_OF_PROJECT_ID is null
            order by p.project
            ```
    }
    columnMapping {
        return: ID
        display: DISPLAY
    }
)

lov releases (
    name: RELEASES
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select 
                   id,
                   RELEASE_TRAIN||' '||release release,
                   to_char(release_open_date,'YYYY.MM.DD')||' - '||
                   to_char(release_target_date,'YYYY.MM.DD') window
            from SP_RELEASE_TRAINS
            order by release_target_date
            ```
    }
    columnMapping {
        return: ID
        display: RELEASE
    }

    column ID (
        show: false
        layout {
            sequence: 10
        }
        source {
            dataType: number
        }
        advanced {
            searchable: false
        }
    )

    column RELEASE (
        heading {
            heading: Release
        }
        layout {
            sequence: 20
        }
        source {
            dataType: varchar2
        }
    )

    column WINDOW (
        heading {
            heading: Window
        }
        layout {
            sequence: 30
        }
        source {
            dataType: varchar2
        }
    )

)

