lov sp-team-members-current-only (
    name: SP_TEAM_MEMBERS - CURRENT ONLY
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select last_name||', '||first_name||' ('||lower(email)||')' d, id r
            from SP_TEAM_MEMBERS
            where is_current_yn = 'Y'
            order by 1
            ```
    }
    columnMapping {
        return: R
        display: D
    }
)

lov task-names-for-display-lovs (
    name: TASK NAMES FOR DISPLAY LOVS
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select r.id r,
                   (select task_type from sp_task_types rt where rt.id = r.task_type_id)||
                       case when r.task_sub_type_id is not null then ': ' end ||
                       (select task_type from sp_task_types rt where rt.id = r.task_sub_type_id) ||
                       case when r.task is not null then ' - '||r.task end d
              from sp_tasks r
            ```
    }
    columnMapping {
        return: R
        display: D
        defaultSort: D
    }
)

lov unified-task-list-lov-due (
    name: UNIFIED_TASK_LIST.LOV.DUE
    source {
        location: staticValues
    }

    entry more-than-30-days (
        sequence: 6
        display: More than 30 days
        return: 720|
    )

    entry next-24-hours (
        sequence: 3
        display: Next 24 hours
        return: 1|24
    )

    entry next-30-days (
        sequence: 5
        display: Next 30 days
        return: 168|720
    )

    entry next-7-days (
        sequence: 4
        display: Next 7 days
        return: 24|168
    )

    entry next-hour (
        sequence: 2
        display: Next hour
        return: 0|1
    )

    entry overdue (
        sequence: 1
        display: Overdue
        return: |0
    )

)

