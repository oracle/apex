            )

            sort (
                column: APPROVAL_TYPE
                sort {
                    sequence: 2
                }
            )

            sort (
                column: APPROVAL_SEQ
                sort {
                    sequence: 3
                }
            )

            filter ir-condition (
                column: ACTIVE
                value: Active
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Add Entry
        layout {
            sequence: 10
            region: @breadcrumb
