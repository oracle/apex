page 10791 (
    name: Notification Email Contents
    alias: NOTIFICATION-EMAIL-CONTENTS
    title: Notification Email Contents
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region notification-email-contents (
        name: Notification Email Contents
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select EMAIL_CONTENTS
                  from SP_TEAM_MEMBER_NOTIFICATIONS
                 where id =:P10791_ID
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlightOff
                t-Report--noBorders
                t-Report--hideNoPagination
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }
        heading {
            type: none
        }

        column EMAIL_CONTENTS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Email Contents
            }
            layout {
                sequence: 3
            }
            sorting {
                defaultSequence: 1
            }
            security {
                escapeSpecialChars: false
            }
        )

    )

    pageItem P10791_ID (
        type: hidden
        layout {
            sequence: 10
            region: @notification-email-contents
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

)

