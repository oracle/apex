page 45 (
    name: Archived &NOMENCLATURE_PROJECTS.
    alias: ARCHIVED-NOMENCLATURE-PROJECTS
    title: Archived &NOMENCLATURE_PROJECTS.
    pageGroup: @reporting
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: All &NOMENCLATURE_PROJECTS. that have been archived and by whom and when they were archived.
    }

    region archived-nomenclature-projects (
        name: Archived &NOMENCLATURE_PROJECTS.
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       friendly_identifier,
                       (select initiative from sp_initiatives i where i.id = p.INITIATIVE_ID) initiative,
                       (select area from sp_areas f where id = (select area_id from sp_initiatives i where i.id = p.INITIATIVE_ID)) area,
                       PROJECT,
                       (select FIRST_NAME ||' '||last_name from SP_TEAM_MEMBERS x where x.ID = p.OWNER_ID) owner,
                       TARGET_COMPLETE,
                       pct_complete,
                       (select t.release_train||' '||t.release from SP_RELEASE_TRAINS t where t.id = p.release_id) release,
                       PROJECT_SIZE,
                       DESCRIPTION,
                       --
                       -- initiative focus area
                       --
                       nvl((select focus_area from sp_initiative_focus_areas ifa where ifa.id = p.focus_area_id),'Not Identified') Init_focus_area,
                       --
                       --
                       --
                       TAGS,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY,
                       ARCHIVED_YN,
                       ARCHIVED_DATE,
                       archived_date archived_since,
                       lower(archived_by) ARCHIVED_BY,
                       (select project from sp_projects p2 where p2.id = p.DUPLICATE_OF_PROJECT_ID) duplicate_of
                  from SP_PROJECTS p
                where ARCHIVED_YN = 'Y'
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 11664821743972252886
        }

        column ARCHIVED_BY (
            type: plainText
            heading {
                heading: Archived By
            }
            layout {
                sequence: 27
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: AA
            }
        )

        column ARCHIVED_DATE (
            type: plainText
