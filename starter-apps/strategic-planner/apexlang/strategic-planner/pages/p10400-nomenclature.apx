page 10400 (
    name: Nomenclature
    alias: NOMENCLATURE
    title: Nomenclature
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action publish-draft-labels (
            position: primaryActions
            template: button
            label: Publish Draft Labels
            layout {
                sequence: 5
            }
            behavior {
                target: {
                    page: 10400
                    request: PUBLISH
                }
            }
            appearance {
                hot: true
            }
        )

    )

    region nomenclature (
        name: Nomenclature
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       static_id,
                       default_order,
                       DEFAULT_VALUE,
                       --
                       v('NOMENCLATURE_'||STATIC_ID) current_label,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY
                  from SP_APP_NOMENCLATURE
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        headerAndFooter {
            headerText:
                ```html
                <p>Customize the application name and select primary attribute names to conform to your organization's terminology.</p>
                <p>Edit any of the attributes, changing the draft value.  
                    Once all changes have been made, use the Publish Draft Labels button to apply the changes to the application.</p>
                ```
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10410
                items: {
                    P10410_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 7966157291350330425
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 102
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 112
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column CURRENT_LABEL (
            type: plainText
            heading {
                heading: Current Label
                alignment: center
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column DEFAULT_ORDER (
            type: plainText
            heading {
                heading: Order
                alignment: end
            }
            layout {
                sequence: 92
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
        )

        column DEFAULT_VALUE (
            type: plainText
            heading {
                heading: Draft Label
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column STATIC_ID (
            type: plainText
            heading {
                heading: Static ID
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 122
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 132
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Nomenclature
        }

        savedReport 79661737 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CURRENT_LABEL (
                sequence: 2
            )

            displayColumn DEFAULT_ORDER (
                sequence: 1
            )

            displayColumn DEFAULT_VALUE (
                sequence: 3
            )

            displayColumn UPDATED (
                sequence: 4
            )

            sort (
                column: DEFAULT_ORDER
                sort {
                    sequence: 1
                }
            )

            sort (
                column: STATIC_ID
                sort {
                    sequence: 2
                }
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 3
                }
            )

        )

    )

    region sql (
        name: SQL
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'insert into SP_APP_NOMENCLATURE (static_ID, default_order, default_value) values ('||
                       ''''||static_id||''', '||
                       default_order||', '||
                       ''''||replace(default_value,'''','''''')||''''||
                       ');' sql
                  from SP_APP_NOMENCLATURE n
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column SQL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: SQL
            }
            layout {
                sequence: 10
            }
        )

    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @nomenclature
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @nomenclature
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process set-draft (
        name: set_draft
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                update SP_APP_NOMENCLATURE
                   set CUSTOM_VALUE = DEFAULT_VALUE;
                   
                sp_util.set_nomenclature;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        successMessage {
            successMessage: Application Nomenclature reset to Draft Values
        }
        advanced {
            executionMappingIdentifier: 7670135776080873627
        }
        serverSideCondition {
            type: request=Value
            value: PUBLISH
        }
    )

    process set-nomenclature (
        name: set_nomenclature
        type: executeCode
        source {
            plsqlCode: sp_util.set_nomenclature;
        }
        execution {
            sequence: 10
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 7670135875477873628
        }
    )

)

