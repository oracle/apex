page 504 (
    name: Task Document
    alias: TASK-DOCUMENT
    title: Document
    pageGroup: @projects
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region document (
        name: Document
        type: form
        source {
            location: localDatabase
            tableName: SP_TASK_DOCUMENTS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P504_CREATED (
        type: hidden
        layout {
            sequence: 120
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: CREATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P504_CREATED_BY (
        type: hidden
        layout {
            sequence: 130
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P504_DOCUMENT_BLOB (
        type: fileUpload
        label {
            label: Document
            alignment: left
        }
        display {
            displayAs: inlineDropzone
        }
        storage {
            mimeTypeColumn: DOCUMENT_MIMETYPE
            filenameColumn: DOCUMENT_FILENAME
            charSetColumn: DOCUMENT_CHARSET
            bobLastUpdatedColumn: DOCUMENT_LASTUPD
        }
        layout {
            sequence: 30
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @document
            column: DOCUMENT_BLOB
            dataType: blob
        }
    )

    pageItem P504_DOCUMENT_CHARSET (
        type: hidden
        layout {
            sequence: 90
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_CHARSET
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P504_DOCUMENT_FILENAME (
        type: hidden
        layout {
            sequence: 70
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_FILENAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P504_DOCUMENT_LASTUPD (
        type: hidden
        layout {
            sequence: 100
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_LASTUPD
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P504_DOCUMENT_MIMETYPE (
        type: hidden
        layout {
            sequence: 80
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_MIMETYPE
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P504_DOC_DESCRIPTION (
        type: richTextEditor
        label {
            label: Description
            alignment: left
        }
        settings {
            minHeight: 180
            allowCustomHtml: true
        }
        layout {
            sequence: 40
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @document
            column: DOC_DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P504_ID (
        type: hidden
        layout {
            sequence: 10
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P504_IMPORTANT_YN (
        type: switch
        label {
            label: Important
            alignment: left
        }
        layout {
            sequence: 60
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @document
            column: IMPORTANT_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: N
        }
    )

    pageItem P504_TAGS (
        type: textField
        label {
            label: Tags
            alignment: left
        }
        layout {
            sequence: 50
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @document
            column: TAGS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P504_TASK_ID (
        type: displayOnly
        label {
            label: Link For
            alignment: left
        }
        settings {
            basedOn: lov
        }
        lov {
            type: sharedComponent
            lov: @task-names-for-display-lovs
            displayExtraValues: false
        }
        layout {
            sequence: 20
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @document
            column: TASK_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P504_UPDATED (
        type: hidden
        layout {
            sequence: 140
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: UPDATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P504_UPDATED_BY (
        type: hidden
        layout {
            sequence: 150
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Document
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P504_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P504_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P504_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 90
        }
        advanced {
            executionMappingIdentifier: 18160054331824749421
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form (
        name: Initialize form
        type: formInitialization
        formRegion: @document
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 18160051496318749418
        }
    )

    process log (
        name: log
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select project_id
                      from sp_tasks
                     where id = :P504_TASK_ID
                ) loop
                    sp_log.log_interaction(
                        p_project_id => c1.project_id);
                end loop;
                ```
        }
        execution {
            sequence: 100
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 1437017425099642222
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P504_TASK_ID
        }
    )

    process process-form (
        name: Process form
        type: formAutoRowProcessing
        formRegion: @document
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 18160051860861749418
        }
    )

)

