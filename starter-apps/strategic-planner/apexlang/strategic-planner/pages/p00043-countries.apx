page 43 (
    name: Countries
    alias: COUNTRIES
    title: Countries
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region countries (
        name: Countries
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       COUNTRY_CODE,
                       COUNTRY_NAME,
                       REGION,
                       DISPLAY_YN,
                       QUICK_PICK_YN,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY,
                       LAT,
                       LON,
                       COUNTRY_CODE3
                  from SP_COUNTRIES
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 44
                items: {
                    P44_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 10830960206355433861
        }

        column COUNTRY_CODE (
            type: plainText
            heading {
                heading: Country Code
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column COUNTRY_CODE3 (
            type: plainText
            heading {
                heading: 3 Digit Country Code
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column COUNTRY_NAME (
            type: plainText
            heading {
                heading: Country Name
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column DISPLAY_YN (
            type: plainText
            heading {
                heading: "Display "
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column LAT (
            type: plainText
            heading {
                heading: Latitude
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column LON (
            type: plainText
            heading {
                heading: Longitude
            }
            layout {
                sequence: 12
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column QUICK_PICK_YN (
            type: plainText
            heading {
                heading: "Quick Pick "
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column REGION (
            type: plainText
            heading {
                heading: Region
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 9
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: I
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Countries
        }

        savedReport 108310478 (
            visibility: primaryDefault
            view {
                rowsPerPage: 1000
            }

            displayColumn COUNTRY_CODE (
                sequence: 1
            )

            displayColumn COUNTRY_NAME (
                sequence: 2
            )

            displayColumn QUICK_PICK_YN (
                sequence: 4
            )

            displayColumn REGION (
                sequence: 3
            )

            displayColumn UPDATED (
                sequence: 5
            )

            sort (
                column: COUNTRY_NAME
                sort {
                    sequence: 1
                }
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 2
                }
            )

            filter ir-condition (
                column: QUICK_PICK_YN
                value: Y
            )

        )

    )

    region sql (
        name: SQL
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'insert into SP_COUNTRIES (ID, COUNTRY_CODE, COUNTRY_NAME, REGION, DISPLAY_YN, QUICK_PICK_YN, LAT, LON, COUNTRY_CODE3) values ('||
                      id||', '''||
                      COUNTRY_CODE||''', '''||
                      replace(COUNTRY_NAME,'''','''''')||''', '''||
                      REGION||''', '''||
                      DISPLAY_YN||''', '''||
                      QUICK_PICK_YN||''', '||
                      nvl(to_char(LAT),'null')||', '||
                      nvl(to_char(LON),'null')||', '''||
                      COUNTRY_CODE3||''');' SQL
                  from SP_COUNTRIES
                 order by COUNTRY_NAME
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 1500
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column SQL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: SQL
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

    )

    button create (
        buttonName: CREATE
        label: Add Country
        layout {
            sequence: 20
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 44
                clearCache: 44
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: reset
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 43
                clearCache: 43
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @countries
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @countries
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

