page 10000 (
    name: Administration
    alias: ADMIN
    title: Administration
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>The administration page allows application owners (Administrators) to configure the application and maintain common data used across the application.
            By selecting one of the available settings, administrators can potentially change how the application is displayed and/or features available to the end users.</p>
            <p>Access to this page should be limited to Administrators only.</p>
            ```
    }

    region access-control (
        name: Access Control
        type: staticContent
        layout {
            sequence: 30
            parentRegion: @access-control-content
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        config {
            buildOption: @access-control
        }
    )

    region access-control-actions (
        name: Access Control Actions
        type: list
        source {
            list: @admin-access-control
        }
        layout {
            sequence: 20
            parentRegion: @access-control
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            listTemplate: @/media-list
            templateOptions: [
                #DEFAULT#
                u-colors
            ]
        }
    )

    region access-control-content (
        name: Access Control Content
        type: staticContent
        layout {
            sequence: 20
            parentRegion: @column
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
    )

    region acl-information (
        name: ACL Information
        type: plSqlDynamicContent
        source {
            plsqlCode:
                ```plsql
                declare
                    l_acl_scope varchar2(45);
                begin
                    l_acl_scope := apex_app_setting.get_value( p_name => 'ACCESS_CONTROL_SCOPE' );
                
                    if l_acl_scope = 'ALL_USERS' then
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ALL_USERS') );
                    elsif l_acl_scope = 'ACL_ONLY' then
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_ONLY') );
                    else
                        sys.htp.p( apex_lang.message('APEX.FEATURE.ACL.INFO.ACL_VALUE_INVALID', l_acl_scope) );
                    end if;
                end;
                ```
        }
        layout {
            sequence: 10
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @/alert
            templateOptions: [
                #DEFAULT#
                t-Alert--colorBG
                t-Alert--horizontal
                t-Alert--noIcon
                t-Alert--warning
                t-Alert--accessibleHeading
            ]
            cssClasses: margin-sm
        }
    )

    region administration (
        name: Administration
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
