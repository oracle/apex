    button add-user (
        buttonName: ADD_USER
        label: Add User
        layout {
            sequence: 10
            region: @access-control
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-user-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10012
                clearCache: 10012
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @administration
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: button
            button: @add-user
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @user-counts-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

