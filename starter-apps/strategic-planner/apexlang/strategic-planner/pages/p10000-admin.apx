    region report (
        name: Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select l.display_value feedback_status, 
                (select count(*) from apex_team_feedback f where f.application_id = :APP_ID and f.feedback_status = l.return_value) feedback_count 
                from apex_application_lov_entries l
                where l.application_id = :APP_ID
                and l.list_of_values_name = 'FEEDBACK_STATUS'
                order by 2 desc, 1
                ```
        }
        layout {
            sequence: 10
            parentRegion: @feedback
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        componentAppearance {
            template: @/value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column FEEDBACK_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Feedback Count
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

        column FEEDBACK_STATUS (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Feedback Status
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

    )

    region user-counts-report (
        name: User Counts Report
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.role_name, (select count(*) from apex_appl_acl_user_roles ur where r.role_id = ur.role_id) user_count, r.role_id
                from apex_appl_acl_roles r
                where r.application_id = :APP_ID
                group by r.role_name, r.role_id
                order by 2 desc, 1
                ```
        }
        layout {
            sequence: 50
            parentRegion: @access-control
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--stacked
                t-Region--scrollBody
                t-Region--noPadding
            ]
        }
        serverSideCondition {
            type: never
        }
        componentAppearance {
            template: @/value-attribute-pairs-row
            templateOptions: [
                #DEFAULT#
                t-AVPList--rightAligned
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column ROLE_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Role Id
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
        )

        column ROLE_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Role Name
            }
            layout {
                sequence: 1
            }
            sorting {
                sortable: false
            }
        )

        column USER_COUNT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: User Count
            }
            layout {
                sequence: 2
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

