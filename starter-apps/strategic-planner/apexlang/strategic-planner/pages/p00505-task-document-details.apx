page 505 (
    name: Task Document Details
    alias: TASK-DOCUMENT-DETAILS
    title: Task Document Details
    pageGroup: @projects
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    javaScript {
        fileUrls: #PRISMJS_DIRECTORY#prism#MIN#.js
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        reloadOnSubmit: always
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region document-description (
        name: Document Description
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT DOC_description
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID 
                ```
            pageItemsToSubmit: P505_ID
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                SELECT 1
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID 
                   and DOC_description is not null
                ```
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
            ]
        }
        heading {
            type: none
        }

        column DOC_DESCRIPTION (
            reportColumnQueryId: 1
            derivedColumn: N
            layout {
                sequence: 10
            }
        )

    )

    region document-details (
        name: Document Details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select d.ID,
                       p.id project_id,
                       p.project,
                       (select task_type from sp_task_types rt where rt.id = t.task_type_id)||
                           case when t.task_sub_type_id is not null then ': ' end ||
                           (select task_type from sp_task_types rt where rt.id = t.task_sub_type_id) type,
                       t.id task_id,
                       d.DOCUMENT_FILENAME,
                       d.UPDATED,
                       d.created,
                       --d.doc_description,
                       lower(d.created_by) author,
                       dbms_lob.getlength(d.DOCUMENT_BLOB) doc_size,
                       d.created date_created,
                       substr(d.DOCUMENT_FILENAME,instr(d.DOCUMENT_FILENAME,'.',-1)+1,length(d.DOCUMENT_FILENAME)-instr(d.DOCUMENT_FILENAME,'.',-1)) file_extension
                  from SP_TASK_DOCUMENTS d,
                       sp_tasks t,
                       sp_projects p
                 where d.id = :P505_ID and d.task_id = t.id and t.project_id = p.id
                
                ```
            pageItemsToSubmit: P505_ID
        }
        layout {
            sequence: 100
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-left-md
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
            ]
        }

        column AUTHOR (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Author
                alignment: center
            }
            layout {
                sequence: 110
            }
        )

        column CREATED (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 100
            }
        )

        column DATE_CREATED (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 130
            }
        )

        column DOCUMENT_FILENAME (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Document Filename
            }
            layout {
                sequence: 60
            }
        )

        column DOC_SIZE (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Size
                alignment: center
            }
            layout {
                sequence: 120
            }
            appearance {
                formatMask: FILESIZE
            }
        )

        column FILE_EXTENSION (
            reportColumnQueryId: 12
            derivedColumn: N
            type: hidden
            layout {
                sequence: 140
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 50
            }
        )

        column PROJECT (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 70
            }
            link {
                target: {
                    page: 3
                    items: {
                        P3_PROJECT_ID: #PROJECT_ID#
                    }
                    clearCache: 3
                }
                linkText: #PROJECT#
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 150
            }
        )

        column TASK_ID (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 160
            }
        )

        column TYPE (
            reportColumnQueryId: 4
            derivedColumn: N
            type: link
            heading {
                heading: Task
            }
            layout {
                sequence: 80
            }
            link {
                target: {
                    page: 502
                    items: {
                        P502_TASK_ID: #TASK_ID#
                    }
                    clearCache: 502
                }
                linkText: #TYPE#
            }
        )

        column UPDATED (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Updated
                alignment: center
            }
            layout {
                sequence: 90
            }
            appearance {
                formatMask: SINCE_SHORT
            }
        )

    )

    region html-display-of-markdown (
        name: HTML Display of Markdown
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   r clob;
                begin
                    for c1 in (
                        select TO_CLOB(DOCUMENT_BLOB) x
                          from SP_TASK_DOCUMENTS
                         where id = :P505_ID
                    ) loop
                        r := apex_markdown.to_html(c1.x);
                    end loop;
                return r;
                
                end;
                ```
            pageItemsToSubmit: P505_ID
        }
        layout {
            sequence: 52
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsInColonDelimitedList
            item: P505_FILE_EXTENSION
            list: MD
        }
    )

    region java (
        name: Java
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   s clob;
                   l number;
                   r clob;
                   l_offset int := 1;
                begin
                   for c1 in (
                       select TO_CLOB(DOCUMENT_BLOB) x
                       from SP_TASK_DOCUMENTS
                       where id = :P505_ID) loop
                          s := c1.x;
                   end loop;
                   l := dbms_lob.getlength(s);
                   r := '<pre><code class="lang-java">'||chr(10);
                   for i in 1..2000 loop
                       if l_offset > dbms_lob.getlength(s) then 
                          exit;
                       else
                          r := r||apex_escape.html(dbms_lob.substr(s,5000,l_offset));
                          l_offset := l_offset + 5000;
                       end if;
                   end loop;
                   r := r||chr(10)||'</code></pre>';
                   return r;
                end;
                
                ```
        }
        layout {
            sequence: 110
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: itemIsInColonDelimitedList
            item: P505_FILE_EXTENSION
            list: JAVA
        }
    )

