    region no-preview-available (
        name: No Preview Available
        type: staticContent
        source {
            htmlCode: This file type cannot be previewed.
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                :P505_FILE_EXTENSION not in ('SQL','TXT','PLS','PLSQL','PLB','YAML','JSON','XML','JAVA','PYC','PDF','MD') and
                :P505_DOCUMENT_IS_IMAGE is null
                ```
        }
    )

