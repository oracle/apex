    button edit (
        buttonName: Edit
        label: Edit
        layout {
            sequence: 30
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-edit
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 504
                items: {
                    P504_ID: &P505_ID.
                }
                clearCache: 504
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button next (
        buttonName: Next
        label: Next
        layout {
            sequence: 20
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-chevron-right
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 505
                items: {
                    P505_ID: &P505_NEXT_ID.
                    P505_PREV_PAGE: &P505_PREV_PAGE.
                }
                clearCache: 505
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button previous (
        buttonName: Previous
        label: Previous
        layout {
            sequence: 10
            region: @breadcrumb
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 505
                items: {
                    P505_ID: &P505_PREV_ID.
                    P505_PREV_PAGE: &P505_PREV_PAGE.
                }
                clearCache: 505
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &P505_PREV_PAGE.
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button view-html-of-md (
        buttonName: VIEW_HTML_OF_MD
        label: View HTML of Markdown
        layout {
            sequence: 20
            region: @markdown
            slot: copy
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button view-md (
        buttonName: VIEW_MD
        label: View Markdown
        layout {
            sequence: 30
            region: @html-display-of-markdown
            slot: copy
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction dc (
        name: DC
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @document-details
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction disable-next-button (
        name: Disable Next Button
        execution {
            sequence: 30
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNull
            item: P505_NEXT_ID
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @next
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction disable-previous-button (
        name: Disable Previous Button
        execution {
            sequence: 40
        }
        when {
            event: ready
        }
        clientSideCondition {
            type: itemIsNull
            item: P505_PREV_ID
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @previous
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction download-doc (
        name: Download doc
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @download
        }

        action native-download (
            action: download
            source {
                sqlQuery:
                    ```sql
                    select DOCUMENT_BLOB, DOCUMENT_FILENAME, DOCUMENT_MIMETYPE 
                      from SP_TASK_DOCUMENTS 
                     where id = :P505_ID
                    ```
                itemsToSubmit: P505_ID
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction hide-html-md-on-load (
        name: Hide HTML MD on load
        execution {
            sequence: 80
        }
        when {
            event: ready
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @html-display-of-markdown
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction load-pdf (
        name: Load PDF
        execution {
            sequence: 20
        }
        when {
            event: ready
        }
        serverSideCondition {
            type: item=value
            item: P505_FILE_EXTENSION
            value: PDF
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    $('#pdf_viewer').html('');
                    var url = $v('P505_PDF_LINK');
                    var preview = document.createElement('embed'); 
                    preview.type = "application/pdf";
                    preview.width="100%";
                    preview.height="1000px";
                    preview.src = url;
                    $("#pdf_viewer").append(preview);
                    ```
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction view-html-of-md (
        name: View HTML of MD
        execution {
            sequence: 60
        }
        when {
            event: click
            selectionType: button
            button: @view-html-of-md
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @markdown
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @html-display-of-markdown
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction view-md (
        name: View MD
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @view-md
        }

        action native-hide (
            action: hide
            affectedElements {
                selectionType: region
                region: @html-display-of-markdown
            }
            execution {
                sequence: 20
            }
        )

        action native-show (
            action: show
            affectedElements {
                selectionType: region
                region: @markdown
            }
            execution {
                sequence: 10
            }
        )

    )

    computation p505-document-is-image (
        itemName: P505_DOCUMENT_IS_IMAGE
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select 'Y'
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID
                and upper(substr(d.DOCUMENT_FILENAME,instr(d.DOCUMENT_FILENAME,'.',-1)+1,length(d.DOCUMENT_FILENAME)-instr(d.DOCUMENT_FILENAME,'.',-1)))
                 in ('JPG','JPEG','PNG','GIF','AVIF','WEBP')
                
                ```
        }
    )

    computation p505-document-name (
        itemName: P505_DOCUMENT_NAME
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select DOCUMENT_FILENAME
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID
                
                ```
        }
    )

    computation p505-file-extension (
        itemName: P505_FILE_EXTENSION
        execution {
            sequence: 10
        }
        computation {
            sqlQuery:
                ```sql
                select upper(substr(d.DOCUMENT_FILENAME,instr(d.DOCUMENT_FILENAME,'.',-1)+1,length(d.DOCUMENT_FILENAME)-instr(d.DOCUMENT_FILENAME,'.',-1))) ext
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID
                ```
        }
    )

    computation p505-file-name (
        itemName: P505_FILE_NAME
        execution {
            sequence: 50
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                SELECT DOCUMENT_FILENAME
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID 
                ```
        }
    )

    computation p505-next-id (
        itemName: P505_NEXT_ID
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                SELECT id
                  from SP_TASK_DOCUMENTS d
                 where task_id = (select task_id from SP_TASK_DOCUMENTS d2 where d2.id = :P505_ID) and
                       created < (select created from SP_TASK_DOCUMENTS d2 where d2.id = :P505_ID) and
                          dbms_lob.getlength(DOCUMENT_BLOB) > 0 
                order by created desc
                fetch first 1 rows only
                ```
        }
    )

    computation p505-pdf-link (
        itemName: P505_PDF_LINK
        execution {
            sequence: 60
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                return APEX_PAGE.GET_URL (
                            p_page      => 505,
                            p_request   => 'APPLICATION_PROCESS=viewTaskPDF',
                            p_plain_url => TRUE );
                ```
        }
    )

    computation p505-prev-id (
        itemName: P505_PREV_ID
        execution {
            sequence: 40
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                SELECT id
                  from SP_TASK_DOCUMENTS d
                 where task_id = (select task_id from SP_TASK_DOCUMENTS d2 where d2.id = :P505_ID) and
                       created > (select created from SP_TASK_DOCUMENTS d2 where d2.id = :P505_ID) and
                          dbms_lob.getlength(DOCUMENT_BLOB) > 0 
                order by created 
                fetch first 1 rows only
                ```
        }
    )

)

