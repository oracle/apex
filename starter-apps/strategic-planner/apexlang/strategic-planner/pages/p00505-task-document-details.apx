    pageItem P505_DOCUMENT_BLOB (
        type: displayImage
        label {
            label: Document
            alignment: left
        }
        settings {
            basedOn: blobColSql
            sqlQuery:
                ```sql
                SELECT DOCUMENT_BLOB 
                  from SP_TASK_DOCUMENTS d
                 where id = :P505_ID 
                
                ```
