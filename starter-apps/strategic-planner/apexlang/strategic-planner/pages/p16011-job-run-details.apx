            }
            layout {
                sequence: 3
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: C
            }
        )

        column LOG_ID (
            type: plainText
            heading {
                heading: Log ID
                alignment: end
            }
            layout {
                sequence: 1
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column OUTPUT (
            type: plainText
            heading {
                heading: Output
            }
            layout {
                sequence: 21
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: U
            }
        )

        column OWNER (
            type: plainText
            heading {
                heading: Owner
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column REQ_START_DATE (
            type: plainText
            heading {
                heading: Requested Start Date
            }
            layout {
                sequence: 8
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: H
            }
        )

        column RUN_DURATION (
            type: plainText
            heading {
                heading: Run Duration
            }
            layout {
                sequence: 10
            }
            source {
                dataType: OTHER
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: J
            }
            enableUsersTo {
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column SESSION_ID (
            type: plainText
            heading {
                heading: Session ID
            }
            layout {
