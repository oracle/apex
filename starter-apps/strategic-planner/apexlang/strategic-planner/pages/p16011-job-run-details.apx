page 16011 (
    name: Job Run Details
    alias: JOB-RUN-DETAILS
    title: Job Run Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/modal-dialog
        templateOptions: [
            #DEFAULT#
            ui-dialog--stretch
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: <p>This report includes the run details about the jobs selected to be monitored by this application.</p>
    }

    region job-run-details (
        name: Job Run Details
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select LOG_ID,
                       JOB_NAME,
                       LOG_DATE,
                       OWNER,
                       JOB_SUBNAME,
                       STATUS,
                       ERROR#,
                       REQ_START_DATE,
                       ACTUAL_START_DATE,
                       RUN_DURATION,
                       INSTANCE_ID,
                       SESSION_ID,
                       SLAVE_PID,
                       CPU_USED,
                       CREDENTIAL_OWNER,
                       CREDENTIAL_NAME,
                       DESTINATION_OWNER,
                       DESTINATION,
                       ADDITIONAL_INFO,
                       ERRORS,
                       OUTPUT
                  from user_scheduler_job_run_details 
                 where job_name in ('SP_NOTIF_SUBSCRIPTIONS','SP_GENERATE_AI_SUMMARIES_JOB')
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 11093357450141617281
        }

        column ACTUAL_START_DATE (
            type: plainText
            heading {
                heading: Actual Start Date
            }
            layout {
                sequence: 9
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: I
            }
        )

        column ADDITIONAL_INFO (
            type: plainText
            heading {
                heading: Additional Information
            }
            layout {
                sequence: 19
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: S
            }
        )

        column CPU_USED (
            type: plainText
            heading {
                heading: CPU Used
            }
            layout {
                sequence: 14
            }
            source {
                dataType: OTHER
            }
            columnFilter {
                type: none
            }
            advanced {
                endUserAlias: N
            }
            enableUsersTo {
                sort: false
                filter: false
                highlight: false
                controlBreak: false
                aggregate: false
                compute: false
                chart: false
                groupBy: false
                pivot: false
            }
        )

        column CREDENTIAL_NAME (
            type: plainText
            heading {
                heading: Credential Name
            }
            layout {
                sequence: 16
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
        )

        column CREDENTIAL_OWNER (
            type: plainText
            heading {
                heading: Credential Owner
            }
            layout {
                sequence: 15
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column DESTINATION (
            type: plainText
            heading {
                heading: Destination
            }
            layout {
                sequence: 18
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: R
            }
        )

        column DESTINATION_OWNER (
            type: plainText
            heading {
                heading: Destination Owner
            }
            layout {
                sequence: 17
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: Q
            }
        )

        column ERROR# (
            type: plainText
            heading {
                heading: Error Number
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column ERRORS (
            type: plainText
            heading {
                heading: Errors
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: T
            }
        )

        column INSTANCE_ID (
            type: plainText
            heading {
                heading: Instance ID
                alignment: end
            }
            layout {
                sequence: 11
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column JOB_NAME (
            type: plainText
            heading {
                heading: Job Name
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column JOB_SUBNAME (
            type: plainText
