            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Job Run Details
        }

        savedReport 110933733 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ERROR# (
                sequence: 4
            )

            displayColumn ERRORS (
                sequence: 6
            )

            displayColumn JOB_NAME (
                sequence: 1
            )

            displayColumn LOG_DATE (
                sequence: 2
            )

            displayColumn RUN_DURATION (
                sequence: 5
            )

            displayColumn STATUS (
                sequence: 3
            )

            sort (
                column: JOB_NAME
                sort {
                    sequence: 1
                }
            )

            sort (
                column: LOG_DATE
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    button reset-report (
        buttonName: RESET_REPORT
        label: Reset
        layout {
            sequence: 20
            region: @job-run-details
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: t-Button--iconLeft
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: &APP_PAGE_ID.
                clearCache: &APP_PAGE_ID.
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

