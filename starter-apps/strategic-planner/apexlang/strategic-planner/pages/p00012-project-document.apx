page 12 (
    name: Project Document
    alias: PROJECT-DOCUMENT
    title: &NOMENCLATURE_PROJECT. Document
    pageGroup: @projects
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region nomenclature-project-document (
        name: &NOMENCLATURE_PROJECT. Document
        type: form
        source {
            location: localDatabase
            tableName: SP_PROJECT_DOCUMENTS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P12_DOCUMENT_BLOB (
        type: fileUpload
        label {
            label: Document
            alignment: left
        }
        display {
            displayAs: inlineDropzone
        }
        storage {
            mimeTypeColumn: DOCUMENT_MIMETYPE
            filenameColumn: DOCUMENT_FILENAME
            charSetColumn: DOCUMENT_CHARSET
            bobLastUpdatedColumn: DOCUMENT_LASTUPD
        }
        layout {
            sequence: 50
            region: @nomenclature-project-document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOCUMENT_BLOB
            dataType: blob
        }
    )

    pageItem P12_DOCUMENT_CHARSET (
        type: hidden
        layout {
            sequence: 120
            region: @nomenclature-project-document
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOCUMENT_CHARSET
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P12_DOCUMENT_FILENAME (
        type: hidden
        layout {
            sequence: 100
            region: @nomenclature-project-document
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOCUMENT_FILENAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P12_DOCUMENT_LASTUPD (
        type: hidden
        layout {
            sequence: 130
            region: @nomenclature-project-document
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOCUMENT_LASTUPD
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P12_DOCUMENT_MIMETYPE (
        type: hidden
        layout {
            sequence: 110
            region: @nomenclature-project-document
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOCUMENT_MIMETYPE
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P12_DOC_DESCRIPTION (
        type: richTextEditor
        label {
            label: Description
            alignment: left
        }
        settings {
            minHeight: 180
            allowCustomHtml: true
        }
        layout {
            sequence: 70
            region: @nomenclature-project-document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @nomenclature-project-document
            column: DOC_DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P12_ID (
        type: hidden
        layout {
            sequence: 10
            region: @nomenclature-project-document
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-project-document
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P12_IMPORTANT_YN (
        type: switch
        label {
            label: Important
            alignment: left
        }
        layout {
            sequence: 90
            region: @nomenclature-project-document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @nomenclature-project-document
            column: IMPORTANT_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: N
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P12_PROJECT_ID (
        type: selectList
        label {
            label: &NOMENCLATURE_PROJECT.
            alignment: left
        }
        lov {
            type: sharedComponent
            lov: @sp-projects-project
        }
        layout {
            sequence: 30
            region: @nomenclature-project-document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @nomenclature-project-document
            column: PROJECT_ID
            dataType: number
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P12_TAGS (
        type: textField
        label {
            label: Tags
            alignment: left
        }
        layout {
            sequence: 80
            region: @nomenclature-project-document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @nomenclature-project-document
            column: TAGS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Document
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P12_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P12_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P12_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 90
        }
        advanced {
            executionMappingIdentifier: 115042188616539737721
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-document (
        name: Initialize form Document
        type: formInitialization
        formRegion: @nomenclature-project-document
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 115042187813762737721
        }
    )

    process log (
        name: log
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_log.log_interaction(
                    p_project_id => :P12_PROJECT_ID);
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 1205028287082313449
        }
    )

    process process-form-document (
        name: Process form Document
        type: formAutoRowProcessing
        formRegion: @nomenclature-project-document
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 115042188197335737721
        }
    )

)

