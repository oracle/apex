page 76 (
    name: Delete Release
    alias: DELETE-RELEASE
    title: Delete Release
    pageGroup: @releases
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @releases
    }

    region associated-with-this-release (
        name: Associated with this Release
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 1 ob, count(*) v, :NOMENCLATURE_PROJECTS||' will have the associated Release removed' d
                  from sp_projects
                 where release_id = :P76_ID 
                union all
                select 2 ob, count(*) v, 'Release Milestones will be deleted' d
                  from SP_RELEASE_MILESTONES
                 where release_Id = :P76_ID
                union all
                select 3 ob, count(*) v, 'Release Comments will be deleted' d
                  from sp_release_comments rc
                 where rc.release_id = :P76_ID 
                union all
                select 4 ob, count(*) v, 'Release Links will be deleted' d
                  from sp_release_links
                 where release_id = :P76_ID
                 order by ob
                ```
            pageItemsToSubmit: P76_ID
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--staticRowColors
                t-Report--rowHighlightOff
                t-Report--noBorders
            ]
        }
        heading {
            type: none
        }

        column D (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: D
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

        column OB (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 30
            }
        )

        column V (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: V
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region release (
        name: Release
        type: form
        source {
            location: localDatabase
            tableName: SP_RELEASE_TRAINS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P76_ID (
        type: displayOnly
        label {
            label: Release
            alignment: left
        }
        settings {
            basedOn: lov
        }
        lov {
            type: sharedComponent
            lov: @sp-release-trains-release-train
        }
        layout {
            sequence: 10
            region: @release
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @release
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P76_RELEASE_OWNER_ID (
        type: displayOnly
        label {
            label: Owner
            alignment: left
        }
        settings {
            basedOn: lov
        }
        lov {
            type: sharedComponent
            lov: @sp-team-members
        }
        layout {
            sequence: 30
            region: @release
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @release
            column: RELEASE_OWNER_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P76_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process delete-related-to-avoid-mutation-on-history-table (
        name: delete related to avoid mutation on history table
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select image_ref_id
                      from sp_release_comments
                     where release_id = :P76_ID
                       and image_ref_id is not null
                ) loop
                    delete from sp_comment_images
                     where image_ref_id = c1.image_ref_id;
                end loop;
                
                delete from sp_release_comments
                 where release_id = :P76_ID;
                
                delete from sp_release_documents
                 where release_id = :P76_ID;
                
                delete from sp_release_links
                 where release_id = :P76_ID;
                
                delete from sp_release_milestones
                 where release_id = :P76_ID;
                
                delete from sp_release_history
                 where release_id = :P76_ID;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 14926172933247381523
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
        comments {
            comments: done to avoid mutating table on sp_projects biu trigger (that references the sp_release_trains table)
        }
    )

    process initialize-form-release (
        name: Initialize form Release
        type: formInitialization
        formRegion: @release
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 4883423931379786283
        }
    )

    process process-form-release (
        name: Process form Release
        type: formAutoRowProcessing
        formRegion: @release
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Release deleted
        }
        advanced {
            executionMappingIdentifier: 4883424330413786284
        }
    )

    process set-project-associations-to-null (
        name: set project associations to null
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                update sp_projects
                   set release_id = null
                 where release_id = :P76_ID;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 4826188495337036518
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
        comments {
            comments: done to avoid mutating table on sp_projects biu trigger (that references the sp_release_trains table)
        }
    )

    branch (
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 8
                clearCache: 76
            }
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

