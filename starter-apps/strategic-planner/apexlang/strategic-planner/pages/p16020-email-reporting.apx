page 16020 (
    name: Email Reporting
    alias: EMAIL-REPORTING
    title: Email Reporting
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: <p>This report shows all email queued to be sent and those already sent.</p>
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region email-reporting (
        name: Email Reporting
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select apex_lang.message('APEX.FEATURE.EMAIL_REPORTING.QUEUED') mail_status,
                       id,
                       mail_to,
                       mail_from,
                       mail_replyto,
                       mail_subj,
                       mail_cc,
                       mail_bcc,
                       mail_send_count,
                       mail_send_error,
                       last_updated_by,
                       last_updated_on,
                       mail_message_created, 
                       lower(mail_message_created_by) message_created_by,
                       app_id,
                       dbms_lob.getlength(mail_body) text_body_size,
                       dbms_lob.getlength(mail_body_html) html_body_size,
                       null send_begin,
                       null send_end,
                       null mail_attachment_count,
                       null mail_attachment_size
                  from apex_mail_queue
                 where app_id = :APP_ID
                union all
                select apex_lang.message('APEX.FEATURE.EMAIL_REPORTING.SENT') mail_status,
                       mail_id id,
                       mail_to,
                       mail_from,
                       mail_replyto,
                       mail_subj,
                       mail_cc,
                       mail_bcc,
                       null mail_send_count,
                       mail_send_error,
                       null last_updated_by,
                       last_updated_on,
                       mail_message_created,
                       null message_created_by,
                       app_id,
                       mail_body_size text_body_size,
                       mail_body_html_size html_body_size,
                       mail_message_send_begin send_begin,
                       mail_message_send_end   send_end,
                       mail_attachment_count,
                       mail_attachment_size
                  from apex_mail_log
                 where app_id = :APP_ID
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 11873708320148250914
        }

        column APP_ID (
            type: plainText
            heading {
                heading: Application ID
                alignment: end
            }
            layout {
                sequence: 15
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: O
            }
        )

        column HTML_BODY_SIZE (
            type: plainText
            heading {
                heading: HTML Body Size
                alignment: end
            }
            layout {
                sequence: 17
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: Q
            }
        )

        column ID (
            type: plainText
            heading {
                heading: ID
                alignment: end
