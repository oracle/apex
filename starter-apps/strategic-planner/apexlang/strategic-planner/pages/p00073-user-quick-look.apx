    button edit-user (
        buttonName: edit_user
        label: Edit (Admin)
        layout {
            sequence: 40
            region: @button-container
            slot: edit
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-edit
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 20
                items: {
                    P20_ID: &P73_TEAM_MEMBER_ID.
                }
                clearCache: 20
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1
                from sp_team_members tm
                where tm.id = :P73_TEAM_MEMBER_ID and
                      tm.email = lower(:APP_USER)
                ```
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button external-link (
        buttonName: external_link
        label: External Directory
        layout {
            sequence: 30
            region: @button-container
            slot: edit
