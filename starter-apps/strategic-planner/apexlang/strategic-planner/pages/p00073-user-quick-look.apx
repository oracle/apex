        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-external-link
        }
        behavior {
            action: redirectUrl
            targetUrl: javascript:window.open('&P73_EXT_LINK.','_blank');
            warnOnUnsavedChanges: doNotCheck
        }
        advanced {
            customAttributes: title="External Directory"
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P73_EXT_LINK
        }
    )

