    pageItem P73_EXT_LINK (
        type: hidden
        layout {
            sequence: 30
            region: @nomenclature-user-details
            slot: regionBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery:
                ```sql
                select replace(apex_app_setting.get_value('EXTERNAL_PERSON_LINK'),'#EMAIL#',lower(email)) 
                  from sp_team_members
                 where id = :P73_TEAM_MEMBER_ID
                   and email is not null
                   and apex_app_setting.get_value('EXTERNAL_PERSON_LINK_DOMAIN') is not null
                   and lower(email) like '%@'||lower(apex_app_setting.get_value('EXTERNAL_PERSON_LINK_DOMAIN'))
                ```
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P73_PHOTO (
        type: displayImage
        label {
            label: Photo
            alignment: left
        }
        settings {
            basedOn: blobColSql
            sqlQuery: select PHOTO from sp_team_members where id = :P73_TEAM_MEMBER_ID
        }
        layout {
            sequence: 10
            slot: contentBody
            alignment: left
            columnSpan: 3
            labelColumnSpan: 0
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 
                from sp_team_members 
                where id = :P73_TEAM_MEMBER_ID and 
                photo is not null
                ```
        }
    )

