page 73 (
    name: User Quick Look
    alias: USER-QUICK-LOOK
    title: &NOMENCLATURE_USER. Quick Look
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .sp-tag {
                padding: 2px 4px;
                display: inline-block;
                vertical-align: text-bottom;
                border-radius: 3px;
                background-color: rgba(0,0,0,.1);
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .sp-tags-container {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 4px;
                justify-content: flex-start;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region active-approvals (
        name: Active Approvals
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.project, p.friendly_identifier, 
                       t.approval_type,
                       case when a.submitted_by_team_member_id = :APP_USER_ID
                            then 'Submitter'
                            else  (select case when status = 'PENDING' then 'Pending Review'
                                               else initcap(replace(status,'-',' '))
                                               end
                                     from (select status,
                                                  updated,
                                                  max(updated) over (partition by team_member_id) last_updated
                                             from sp_project_approval_chain
                                            where project_approval_id = a.id
                                              and team_member_id = :APP_USER_ID)
                                    where last_updated = updated)
                            end role,
                            initcap(replace(a.status,'-',' ')) current_status,
                            a.updated
                  from sp_projects p, 
                       sp_project_approvals a,
                       sp_approval_types t
                 where p.id = a.project_id
                   and p.ARCHIVED_YN = 'N'
                   and p.DUPLICATE_OF_PROJECT_ID is null
                   and a.approval_type_id = t.id
                   and a.status not in ('APPROVED','REJECTED','WITHDRAWN')
                   and ( a.submitted_by_team_member_id = :APP_USER_ID
                         or
                         exists (select 1 from sp_project_approval_chain
                                  where project_approval_id = a.id
                                    and team_member_id = :APP_USER_ID) )
                order by a.updated desc
                ```
            pageItemsToSubmit: P73_TEAM_MEMBER_ID
        }
        layout {
            sequence: 75
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P73_TEAM_MEMBER_ID
        }
        config {
            buildOption: @approvals
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--horizontalBorders
            ]
        }
        messages {
            whenNoDataFound: None Found
        }

