        )

    )

    process sync-roles (
        name: sync roles
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_util.sync_team_members_app_role (
                    p_app_id => :APP_ID);
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 9209641616217814331
        }
    )

)

