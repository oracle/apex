                        page: 74
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-users
                }
            )

        )

        action add-nomenclature-user (
            position: primaryActions
            template: button
            label: Add &NOMENCLATURE_USER.
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 20
                    clearCache: 20
