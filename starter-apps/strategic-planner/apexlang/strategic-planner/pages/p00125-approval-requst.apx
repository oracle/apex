page 125 (
    name: Approval Request
    alias: APPROVAL-REQUST
    title: Approval Request
    pageGroup: @projects
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @approvals
    }

    region approval-history (
        name: Approval History
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id,
                       t.initials user_icon,
                       apex_util.get_since(c.last_status_on) comment_date,
                       t.first_name ||' '|| t.last_name||' ('||lower(t.email)||')' user_name,
                       '<strong>'||apex_escape.html(initcap(replace(c.status,'-',' ')))||'</strong>' comment_text,
                       case when c.comments is not null
                            then '<br/>'||apex_escape.html(c.comments)
                            end attribute_1,
                       case when c.response is not null
                            then '<br/>Response: '||apex_escape.html(c.response) 
                            end attribute_2,
                       case when c.response_by_team_member_id is not null
                            then '<br/>By: '||(select apex_escape.html(first_name || ' ' || last_name) from sp_team_members
                                            where id = c.response_by_team_member_id) 
                            end ||' '||apex_util.get_since(c.responded_on) attribute_3,
                       null attribute_4,
                       null actions,
                       case c.status 
                            when 'PENDING' then 'u-normal-bg'
                            when 'APPROVED' then 'u-success-bg'
                            when 'REJECTED' then 'u-danger-bg'
                            when 'CLARIFICATION-REQUESTED' then 'u-warning-bg'
                            end icon_modifier,
                       c.last_status_on updated,
                       1 ob
                  from sp_project_approval_chain c,
                       sp_team_members t
                 where c.project_approval_id = :P125_PROJECT_APPROVAL_ID
                   and c.team_member_id = t.id
                 union all
                select a.id,
                       t.initials user_icon,
                       apex_util.get_since(a.updated) comment_date,
                       t.first_name ||' '|| t.last_name||' ('||lower(t.email)||')' user_name,
                       '<strong>'||initcap(a.status)||'</strong>' comment_text,
                       null attribute_1,
                       null attribute_2,
                       null attribute_3,
                       null attribute_4,
                       null actions,
                       'u-warning-bg' icon_modifier,
                       a.updated,
                       1 ob
                  from sp_project_approvals a,
                       sp_team_members t  
                 where a.id = :P125_PROJECT_APPROVAL_ID
                   and a.withdrawn_by_team_member_id = t.id
                   and a.status = 'WITHDRAWN' 
                 union all
                select a.id,
                       t.initials user_icon,
                       apex_util.get_since(a.submitted) comment_date,
                       t.first_name ||' '|| t.last_name||' ('||lower(t.email)||')' user_name,
                       '<strong>Submitted</strong>' comment_text,
                       '<br/>'||a.justification attribute_1,
                       null attribute_2,
                       null attribute_3,
                       null attribute_4,
                       null actions,
                       'u-info-bg' icon_modifier,
                       a.submitted updated,
                       2 ob
                  from sp_project_approvals a,
                       sp_team_members t  
                 where a.id = :P125_PROJECT_APPROVAL_ID
                   and a.submitted_by_team_member_id = t.id
                ```
        }
        orderBy {
            type: staticValue
            orderByClause: ob, updated desc nulls first
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P125_PROJECT_APPROVAL_ID
        }
        componentAppearance {
            template: @/comments
            templateOptions: t-Comments--chat
        }

        column ACTIONS (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Actions
            }
            layout {
                sequence: 130
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_1 (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Attribute 1
            }
            layout {
                sequence: 80
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ATTRIBUTE_2 (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Attribute 2
            }
            layout {
                sequence: 100
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ATTRIBUTE_3 (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Attribute 3
            }
            layout {
                sequence: 110
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ATTRIBUTE_4 (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Attribute 4
            }
            layout {
                sequence: 120
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Comment Date
            }
            layout {
                sequence: 40
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_TEXT (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Comment Text
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ICON_MODIFIER (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Icon Modifier
            }
            layout {
                sequence: 140
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Id
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column OB (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Ob
                alignment: end
            }
            layout {
                sequence: 150
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED (
            reportColumnQueryId: 12
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 60
            }
            sorting {
                sortable: false
            }
        )

        column USER_ICON (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: User Icon
            }
            layout {
                sequence: 70
            }
            sorting {
                sortable: false
            }
        )

        column USER_NAME (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: User Name
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

    )

    region p125-approval-type-review (
        name: &P125_APPROVAL_TYPE. Review
        type: staticContent
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noBorder
                t-Region--scrollBody
            ]
            renderComponents: belowContent
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P125_PROJECT_APPROVAL_CHAIN_ID
        }
    )

    region project (
        name: Project
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.project,
                       t.approval_type,
                       a.justification
                  from sp_project_approvals a,
                       sp_projects p,
                       sp_approval_types t
                 where a.project_id = p.id
                   and a.id = :P125_PROJECT_APPROVAL_ID
                   and a.approval_type_id = t.id
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
        }

        column APPROVAL_TYPE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Approval Type
            }
            layout {
                sequence: 20
            }
        )

        column JUSTIFICATION (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Justification
            }
            layout {
                sequence: 30
            }
        )

        column PROJECT (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Project
            }
            layout {
                sequence: 10
            }
        )

    )

    region subsequent-approvers (
        name: Subsequent Approvers
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select case when c.alternate_team_member_id is not null and   
                                 (c.alternate_start_date <= sysdate or c.alternate_start_date is null) and 
                                 (c.alternate_end_date+1 > sysdate or c.alternate_end_date is null)
                            then 'Alternate - '||
                                 (select last_name||', '||first_name||' ('||lower(email)||')'
                                    from sp_team_members
                                   where id = c.alternate_team_member_id)
                            else t.last_name||', '||t.first_name||' ('||lower(t.email)||')' 
                            end reviewer
                  from sp_initiative_approval_chain c,
                       sp_project_approvals a,
                       sp_team_members t
                 where a.id = :P125_PROJECT_APPROVAL_ID
                   and a.initiative_approval_id = c.initiative_approval_id
                   and c.team_member_id = t.id
                   and c.id not in (select initiative_approval_chain_id
                                      from sp_project_approval_chain
                                     where project_approval_id = :P125_PROJECT_APPROVAL_ID)
                 order by c.approval_seq
                ```
        }
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_project_approvals pa,
                       sp_initiative_approval_chain iac
                 where pa.id = :P125_PROJECT_APPROVAL_ID
                   and pa.initiative_approval_id = iac.initiative_approval_id
                    and iac.active_yn = 'Y'
                    and iac.id not in (select initiative_approval_chain_id
                                         from sp_project_approval_chain
                                        where project_approval_id = pa.id
                                          and status in ('PENDING','APPROVED')
                                          and final_yn = 'Y')
                    and iac.approval_seq > nvl((select max(iac2.approval_seq)
                                                  from sp_project_approval_chain pac,
                                                       sp_initiative_approval_chain iac2
                                                 where pac.initiative_approval_chain_id = iac2.id
                                                   and pac.project_approval_id = pa.id
                                                   and pac.status = 'APPROVED'
                                                   and pac.final_yn = 'Y'),-100)
                ```
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }

        column REVIEWER (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Reviewer
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

    )

    pageItem P125_APPROVAL_TYPE (
        type: hidden
        layout {
            sequence: 20
            region: @p125-approval-type-review
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P125_COMMENTS (
        type: textarea
        label {
            label: Comments
            alignment: left
        }
        layout {
            sequence: 70
            region: @p125-approval-type-review
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 3
        }
        validation {
            maxLength: 4000
        }
    )

    pageItem P125_PROJECT_APPROVAL_CHAIN_ID (
        type: hidden
        layout {
            sequence: 10
            region: @p125-approval-type-review
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P125_PROJECT_APPROVAL_ID (
        type: hidden
        layout {
            sequence: 30
            region: @p125-approval-type-review
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P125_WF_TASK_ID (
        type: hidden
        layout {
            sequence: 40
            region: @p125-approval-type-review
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button approve (
        buttonName: APPROVE
        label: Approve
        layout {
            sequence: 100
            region: @p125-approval-type-review
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--success
                t-Button--iconLeft
            ]
            icon: fa-check
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            requiresConfirmation: true
        }
        confirmation {
            message: Do you really want to approve this request?
        }
    )

    button reject (
        buttonName: REJECT
        label: Reject
        layout {
            sequence: 20
            region: @p125-approval-type-review
            slot: delete
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--iconLeft
            ]
            icon: fa-window-close-o
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            requiresConfirmation: true
        }
        confirmation {
            message: Do you really want to reject this request?
        }
    )

    button request-clarification (
        buttonName: REQUEST_CLARIFICATION
        label: Request Clarification
        layout {
            sequence: 10
            region: @p125-approval-type-review
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button withdraw (
        buttonName: Withdraw
        label: Withdraw Request
        layout {
            sequence: 10
            region: @approval-history
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
            ]
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from sp_project_approvals
                 where id = :P125_PROJECT_APPROVAL_ID
                   and submitted_by_team_member_id = :APP_USER_ID
                   and status in ('PENDING','CLARIFICATION-REQUESTED')
                ```
        }
    )

    validation must-have-comments-to-reject-or-request-more-info (
        name: must have comments to reject or request more info
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P125_COMMENTS
        }
        error {
            errorMessage: You must provide comments.
            associatedItem: @P125_COMMENTS
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: REJECT,REQUEST_CLARIFICATION
        }
    )

    computation p125-project-approval-id (
        itemName: P125_PROJECT_APPROVAL_ID
        execution {
            sequence: 140
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select project_approval_id
                  from sp_project_approval_chain
                 where id = :P125_PROJECT_APPROVAL_CHAIN_ID
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P125_PROJECT_APPROVAL_CHAIN_ID
        }
    )

    computation p125-wf-task-id (
        itemName: P125_WF_TASK_ID
        execution {
            sequence: 160
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select task_id
                  from apex_tasks
                 where to_char(detail_pk) = :P125_PROJECT_APPROVAL_CHAIN_ID
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P125_PROJECT_APPROVAL_CHAIN_ID
        }
    )

    process approve (
        name: Approve
        type: humanTaskManage
        humanTask {
            taskIdItem: P125_WF_TASK_ID
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Approval submitted.
        }
        advanced {
            executionMappingIdentifier: 10625334708742529268
        }
        serverSideCondition {
            whenButtonPressed: @approve
        }
    )

    process close-window (
        name: Close window
        type: closeDialog
        execution {
            sequence: 60
        }
        advanced {
            executionMappingIdentifier: 10528790320667238412
        }
    )

    process pass-comments-to-task (
        name: Pass Comments to Task
        type: humanTaskManage
        action {
            type: comment
        }
        humanTask {
            taskIdItem: P125_WF_TASK_ID
            commentText: &P125_COMMENTS.
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 10625516473675307941
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P125_COMMENTS
        }
    )

    process reject (
        name: Reject
        type: humanTaskManage
        action {
            type: reject
        }
        humanTask {
            taskIdItem: P125_WF_TASK_ID
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Rejection submitted.
        }
        advanced {
            executionMappingIdentifier: 10625343632349530904
        }
        serverSideCondition {
            whenButtonPressed: @reject
        }
    )

    process request-info (
        name: Request Info
        type: humanTaskManage
        action {
            type: requestInfo
        }
        humanTask {
            taskIdItem: P125_WF_TASK_ID
            commentText: &P125_COMMENTS.
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: More information requested.
        }
        advanced {
            executionMappingIdentifier: 10625351036877532085
        }
        serverSideCondition {
            whenButtonPressed: @request-clarification
        }
    )

    process withdraw (
        name: Withdraw
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select workflow_id 
                      from apex_workflows
                     where detail_pk = :P125_PROJECT_APPROVAL_ID
                       and application_id = :APP_ID  
                       and workflow_def_static_id = 'PROJECT-REVIEW'
                ) loop
                   apex_workflow.terminate(p_instance_id => c1.workflow_id);
                end loop;
                
                sp_approvals.withdraw (
                    p_project_approval_id => :P125_PROJECT_APPROVAL_ID,
                    p_team_member_id      => :APP_USER_ID );
                ```
        }
        execution {
            sequence: 50
        }
        successMessage {
            successMessage: Request withdrawn.
        }
        advanced {
            executionMappingIdentifier: 10528790956294238418
        }
        serverSideCondition {
            whenButtonPressed: @withdraw
        }
    )

)

