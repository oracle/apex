page 12123 (
    name: Manage Feedback
    alias: MANAGE-FEEDBACK
    title: Manage Feedback
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            /* Color feedback rating icons */
            .feedback-positive { color: var(--ut-feedback-positive-text-color, var(--ut-palette-success)); }
            .feedback-neutral { color: var(--ut-feedback-neutral-text-color, var(--ut-palette-warning)); }
            .feedback-negative { color: var(--ut-feedback-negative-text-color, var(--ut-palette-danger)); }
            ```
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText:
            ```html
            <p>Feedback can be entered by end users from any normal page within the application.</p>
            <p>This report shows the feedback entered, any response enter by administrators, and the status of the feedback.</p>
            <p>Click the edit icon (yellow pencil) to enter a response or update the feedback status.</p>
            <p><em><strong>Note:</strong> If feedback recipients have been defined then feedback submissions will also be emailed to the email addresses in the feedback recipients list.</em></p>
            ```
    }
    config {
        buildOption: @feedback
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region manage-feedback (
        name: Manage Feedback
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select feedback_id id,
                    page_id||'. '||page_name page_name,
                    created_on created,
                    lower(created_by) created_by,
                    feedback,
                    feedback_rating rating,
                    case feedback_rating
                      when 1 then 'fa-frown-o feedback-negative' 
                      when 2 then 'fa-emoji-neutral feedback-neutral'  
                      when 3 then 'fa-smile-o feedback-positive'
                    end rating_icon,
                    feedback_status status,
                    public_response response,
                    http_user_agent user_agent,
                    updated_on updated,
                    lower(updated_by) updated_by,
                    page_id
                from apex_team_feedback f
                where application_id = :APP_ID
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--noBorders
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 12124
                items: {
                    P12124_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span aria-label="Edit"><span class="fa fa-edit" aria-hidden="true" title="Edit"></span></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 8184182842392735882
        }

        column CREATED (
            type: plainText
            heading {
                heading: Filed
            }
            layout {
                sequence: 3
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: C
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Filed By
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column FEEDBACK (
            type: plainText
            heading {
                heading: Feedback
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column PAGE_ID (
            type: plainText
            heading {
                heading: Page
            }
            layout {
                sequence: 13
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: M
            }
        )

        column PAGE_NAME (
            type: plainText
            heading {
                heading: Page
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column RATING (
            type: plainTextBasedOnLov
            heading {
                heading: Rating
            }
            lov {
                lov: @feedback-rating
            }
            layout {
                sequence: 6
            }
            columnFormatting {
                htmlExpression: <span class="fa #RATING_ICON#" aria-hidden="true" title="#RATING#"></span>
            }
            source {
                dataType: NUMBER
            }
            columnFilter {
                type: defaultBasedOnColumnType
            }
            advanced {
                endUserAlias: F
            }
        )

        column RATING_ICON (
            type: hidden
            heading {
                heading: RATING ICON
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column RESPONSE (
            type: plainText
            heading {
                heading: Response
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column STATUS (
            type: plainTextBasedOnLov
            heading {
                heading: Status
            }
            lov {
                lov: @feedback-status
            }
            layout {
                sequence: 8
            }
            source {
                dataType: NUMBER
            }
            columnFilter {
                type: defaultBasedOnColumnType
            }
            advanced {
                endUserAlias: H
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 11
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: K
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column USER_AGENT (
            type: plainText
            heading {
                heading: User Agent
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Manage Feedback
        }

        savedReport 81841926 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn CREATED (
                sequence: 2
            )

            displayColumn CREATED_BY (
                sequence: 3
            )

            displayColumn FEEDBACK (
                sequence: 4
            )

            displayColumn PAGE_NAME (
                sequence: 1
            )

            displayColumn RATING (
                sequence: 5
            )

            displayColumn RESPONSE (
                sequence: 7
            )

            displayColumn STATUS (
                sequence: 6
            )

            displayColumn UPDATED (
                sequence: 8
            )

            displayColumn UPDATED_BY (
                sequence: 9
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 12123
                clearCache: 12123
                action: resetPagination
                request: RESET
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @administration-rights
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-report (
        name: Refresh Report
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @manage-feedback
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @manage-feedback
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

