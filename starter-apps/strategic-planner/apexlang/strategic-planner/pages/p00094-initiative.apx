            action: setValue
            settings {
                type: sqlQuery
                sqlQuery:
                    ```sql
                    select count(*)
                      from SP_INITIATIVE_APPROVALS a,
                           sp_approval_types t,
                           sp_initiatives i
                     where a.initiative_id = i.id
                       and a.approval_type_id = t.id
                       and a.initiative_id = :P94_INITIATIVE_ID
                       and a.active_yn = 'Y'
                    ```
                itemsToSubmit: P94_INITIATIVE_ID
            }
            affectedElements {
                selectionType: items
                items: P94_APPROVAL_TYPE_CNT
            }
            execution {
                sequence: 10
            }
        )

