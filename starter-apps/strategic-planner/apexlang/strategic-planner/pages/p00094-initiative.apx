    region task-content (
        name: task content
        title: Default Tasks
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select case when t.parent_type_id is not null
                            then t2.task_type||': '
                            end ||
                           t.task_type task
                  from sp_task_types t,
                       sp_task_types t2,
                       sp_initiative_default_tasks i
                 where t.parent_type_id = t2.id (+)
                   and t.id = i.type_id
                   and t.include_yn = 'Y'
                   and i.initiative_id = :P94_INITIATIVE_ID
                 order by nvl(t2.display_seq,t.display_seq), t.display_seq nulls first
                ```
            pageItemsToSubmit: P94_INITIATIVE_ID
        }
        layout {
            sequence: 30
            parentRegion: @default-tasks-p94-default-task-cnt
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        headerAndFooter {
            headerText: These tasks will be pre-created for all &NOMENCLATURE_PROJECTS. added to this &NOMENCLATURE_INITIATIVE..
        }
        reportLayout {
            numberOfRows: 1000
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: rowRangesXToYNoPagination
        }
        heading {
            type: none
        }

        column TASK (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Task
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

    )

