        when {
            selectionType: items
            items: P94_THIS_WEEK_EXCLUDE
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @this-week-content
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction when-change-p94-this-week-type (
        name: when change P94_THIS_WEEK_type
        execution {
            sequence: 260
        }
        when {
            selectionType: items
            items: P94_THIS_WEEK_TYPE
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @this-week-content
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-project-view (
        itemName: LAST_PROJECT_VIEW
        execution {
            sequence: 60
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 94
        }
    )

    computation p94-approval-type-cnt (
        itemName: P94_APPROVAL_TYPE_CNT
        execution {
            sequence: 30
        }
        computation {
            sqlQuery:
                ```sql
                select count(*)
                  from SP_INITIATIVE_APPROVALS a,
                       sp_approval_types t,
                       sp_initiatives i
                 where a.initiative_id = i.id
                   and a.approval_type_id = t.id
                   and a.initiative_id = :P94_INITIATIVE_ID
                   and a.active_yn = 'Y'
                ```
        }
    )

    computation p94-area (
        itemName: P94_AREA
        execution {
            sequence: 40
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select area 
                from sp_areas a  
                where a.id = (
                    select area_id
                    from   sp_initiatives i
                    where  id = :P94_INITIATIVE_ID)
                ```
        }
    )

    computation p94-area-id (
        itemName: P94_AREA_ID
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select area_id
                from   sp_initiatives i
                where  id = :P94_INITIATIVE_ID
                ```
        }
    )

    computation p94-default-task-cnt (
        itemName: P94_DEFAULT_TASK_CNT
        execution {
            sequence: 20
        }
        computation {
            sqlQuery:
                ```sql
                select count(*)
                  from sp_task_types t,
                       sp_task_types t2,
                       sp_initiative_default_tasks i
                 where t.parent_type_id = t2.id (+)
                   and t.id = i.type_id
                   and t.include_yn = 'Y'
                   and i.initiative_id = :P94_INITIATIVE_ID
                ```
        }
    )

    computation p94-focus-area-cnt (
        itemName: P94_FOCUS_AREA_CNT
        execution {
            sequence: 10
        }
        computation {
            sqlQuery:
                ```sql
                select count(*)
                  from sp_initiative_focus_areas a
                 where initiative_id = :P94_INITIATIVE_ID
                   and active_yn = 'Y'
                ```
        }
    )

    computation p94-initiative (
        itemName: P94_INITIATIVE
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select INITIATIVE
                from   sp_initiatives i
                where  id = :P94_INITIATIVE_ID
                ```
        }
    )

    computation p94-initiative-id (
        itemName: P94_INITIATIVE_ID
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                return sp_util.get_initiative_id (
                    p_friendly_identifier => :IFI,
                    p_initiative_url_name => :INN);
                ```
        }
        serverSideCondition {
            type: itemIsNull
            item: P94_INITIATIVE_ID
        }
    )

    computation p94-min-pc-for-status (
        itemName: P94_MIN_PC_FOR_STATUS
        execution {
            sequence: 50
        }
        computation {
            sqlQuery:
                ```sql
                select s.min_pc_for_status||'%'
                  from sp_initiatives i,
                       sp_project_scales s
                 where i.id = :P94_INITIATIVE_ID
                   and i.status_scale = s.scale_letter
                ```
        }
    )

    computation p94-permalink-prefix (
        itemName: P94_PERMALINK_PREFIX
        execution {
            sequence: 50
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody: return APEX_UTIL.HOST_URL('SCRIPT') || 'initiative?ifi=';
        }
    )

    computation p94-status-scale (
        itemName: P94_STATUS_SCALE
        execution {
            sequence: 40
        }
        computation {
            sqlQuery:
                ```sql
                select s.scale_name
                  from sp_initiatives i,
                       sp_project_scales s
                 where i.id = :P94_INITIATIVE_ID
                   and i.status_scale = s.scale_letter
                ```
        }
    )

    computation p94-status-scale-letter (
        itemName: P94_STATUS_SCALE_LETTER
        execution {
            sequence: 60
        }
        computation {
            sqlQuery:
                ```sql
                select status_scale
                  from sp_initiatives
                 where id = :P94_INITIATIVE_ID
                ```
        }
    )

)

