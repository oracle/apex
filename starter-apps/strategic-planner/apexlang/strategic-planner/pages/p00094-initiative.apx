    button view-images (
        buttonName: view_images
        label: Image Gallery
        layout {
            sequence: 10
            region: @documents
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 62
                items: {
                    P62_INITIATIVE_ID: &P94_INITIATIVE_ID.
                }
                clearCache: 62
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 
                  from SP_INITIATIVE_DOCUMENTS d
                 where initiative_id = :P94_INITIATIVE_ID and 
                       (
                           lower(DOCUMENT_FILENAME) like '%.png' or 
                           lower(DOCUMENT_FILENAME) like '%.jpg' or 
                           lower(DOCUMENT_FILENAME) like '%.jpeg' or 
                           lower(DOCUMENT_FILENAME) like '%.gif' or 
                           lower(DOCUMENT_FILENAME) like '%.tiff' or 
                           lower(DOCUMENT_FILENAME) like '%.ai' 
                       )
                union all
                select 1 
                  from SP_INIT_focus_area_DOCUMENTS d,
                       SP_INITIATIVE_FOCUS_AREAS f
                   where f.initiative_id = :P94_INITIATIVE_ID and 
                         f.id = d.init_focus_area_id and
                       (
                           lower(d.DOCUMENT_FILENAME) like '%.png' or 
                           lower(d.DOCUMENT_FILENAME) like '%.jpg' or 
                           lower(d.DOCUMENT_FILENAME) like '%.jpeg' or 
                           lower(d.DOCUMENT_FILENAME) like '%.gif' or 
                           lower(d.DOCUMENT_FILENAME) like '%.tiff' or 
                           lower(d.DOCUMENT_FILENAME) like '%.ai' 
                       )
                ```
        }
    )

    dynamicAction add-initiative-link (
        name: add initiative link
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @add-link
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Link Details
                message: Please supply a Link URL and a Link Name.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P94_LINK') === '' || $v('P94_LINK_NAME') === ''
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P94_LINK_NAME is not null and :P94_LINK is not null then
                    insert into SP_INITIATIVE_LINKS (
                        initiative_id, link_name, link_url)
                    values (
                        :P94_INITIATIVE_ID, :P94_LINK_NAME, :P94_LINK);
                    :P94_LINK_NAME := null;
                    :P94_LINK := null;
                    end if;
                    ```
                itemsToSubmit: [
                    P94_INITIATIVE_ID
                    P94_LINK_NAME
                    P94_LINK
                ]
                itemsToReturn: [
                    P94_LINK_NAME
                    P94_LINK
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @links
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @nomenclature-initiative
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

    dynamicAction after-approval-type-action (
        name: After Approval Type action
        execution {
            sequence: 220
        }
        when {
            event: apexafterclosedialog
