    dynamicAction post-comment (
        name: post comment
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @post-comment
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_comment_util.add_initiative_comment (
                        p_app_user_id   => :APP_USER_ID,
                        p_comment       => :P94_COMMENT,
                        p_private_yn    => nvl(:P94_PRIVATE_YN,'N'),
                        p_initiative_id => :P94_INITIATIVE_ID,
                        p_image_ref_id  => :P94_IMAGE_REF_ID );
                    :P94_COMMENT := null;
                    :P94_PRIVATE_YN := null;
                    :P94_IMAGE_REF_ID := to_number(sys_guid(), 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX');
                    ```
                itemsToSubmit: [
                    P94_INITIATIVE_ID
                    P94_COMMENT
                    APP_USER_ID
                    P94_PRIVATE_YN
                    P94_IMAGE_REF_ID
                ]
                itemsToReturn: [
                    P94_COMMENT
                    P94_IMAGE_REF_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Comment Added Successfully");
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

