    region documents (
        name: Documents
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select case doc_type 
                            when 'Initiative'
                            then :NOMENCLATURE_INITIATIVE 
                            when 'Initiative Focus Area'
                            then :NOMENCLATURE_INITIATIVE||' Focus Area'
                            end type,
                       case doc_type
                            when 'Initiative'
                            then '13' 
                            else '56'
                            end edit_page, 
                       case doc_type
                            when 'Initiative'
                            then '53'
                            else '59'
                            end display_page,
                       document_id ID,
                       DOCUMENT_FILENAME,
                       UPDATED,
                       created,
                       doc_description,
                       tags,
                       added_by created_by,
                       filesize doc_size,
                       created date_created,
                       file_extension,
                       important,
                       filesize document,
                       document_id
                  from SP_DOCUMENTS_V
                 where initiative_id = :P94_INITIATIVE_ID
                   and doc_type in ('Initiative', 'Initiative Focus Area')
                ```
            pageItemsToSubmit: P94_INITIATIVE_ID
        }
        layout {
            sequence: 175
            slot: body
            startNewRow: false
            newColumn: false
        }
