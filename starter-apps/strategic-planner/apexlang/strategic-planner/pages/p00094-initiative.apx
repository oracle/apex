    region associated-releases (
        name: Associated Releases
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select rt.id,
                       release_train||' '||release release,
                       RELEASE_TARGET_DATE,
                       RELEASE_OPEN_DATE,
                       decode(nvl(rt.RELEASE_COMPLETED,'N'),'Y','Yes','N','No',RELEASE_COMPLETED) COMPLETED,
                       (select count(*) from sp_projects p where nvl(p.ARCHIVED_YN,'N') = 'N' and 
                      p.DUPLICATE_OF_PROJECT_ID is null and
                      p.initiative_id = :P94_INITIATIVE_ID and
                      p.release_id is not null and 
                      p.release_id = rt.id) project_count
                from   sp_release_trains rt
                where rt.id in (
                select distinct p.release_id
                from  SP_PROJECTS p
                where nvl(p.ARCHIVED_YN,'N') = 'N' and 
                      p.DUPLICATE_OF_PROJECT_ID is null and
                      p.initiative_id = :P94_INITIATIVE_ID and
                      p.release_id is not null)
                
                
                
                ```
        }
        layout {
            sequence: 130
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        headerAndFooter {
            footerText: <p>This reports lists releases that have one or more associated &NOMENCLATURE_PROJECTS. that corresponds to the selected &NOMENCLATURE_INITIATIVE..</p>
        }
        config {
            buildOption: @releases
        }
