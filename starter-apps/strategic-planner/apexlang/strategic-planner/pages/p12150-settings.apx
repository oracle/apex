page 12150 (
    name: Settings
    alias: SETTINGS
    title: Settings
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 5
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region settings (
        name: Settings
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       STATIC_ID || apex_item.hidden(1,id) name,
                       DESCRIPTION,
                       case when static_id != 'APP_ID' then apex_item.text(2,setting_value,40) 
                            else apex_item.display_and_save(2,setting_value) end VALUE,
                       UPDATED,
                       lower(UPDATED_BY) updated_by
                  from SP_APP_SETTINGS
                  order by static_id
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column DESCRIPTION (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 0
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 3
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column UPDATED (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 21
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column UPDATED_BY (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Last Updated By
            }
            layout {
                sequence: 11
            }
            sorting {
                sortable: false
            }
        )

        column VALUE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Value
            }
            layout {
                sequence: 5
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

    )

    button reset (
        buttonName: Reset
        label: Reset
        layout {
            sequence: 30
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 12150
                clearCache: 12150
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process update-settings (
        name: Update settings
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_static_id  sp_app_settings.static_id%type;
                begin
                
                for i in 1..apex_application.g_f01.count loop
                    select static_id
                      into l_static_id
                      from sp_app_settings
                     where id = apex_application.g_f01(i);
                
                    if l_static_id is not null then
                        sp_util.set_setting (
                            p_static_id     => l_static_id,
                            p_setting_value => apex_application.g_f02(i) );
                    end if;
                    
                    l_static_id := null;
                end loop;
                
                end;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Settings saved.
        }
        error {
            errorMessage: Settings failed to be saved.
        }
        advanced {
            executionMappingIdentifier: 11231942375160335527
        }
        serverSideCondition {
            whenButtonPressed: @save
        }
    )

)

