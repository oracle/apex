            templateOptions: #DEFAULT#
            width: 30
        }
    )

    button run-report (
        buttonName: run_report
        label: Run Report
        layout {
            sequence: 70
            region: @filter
            slot: regionBody
            startNewRow: false
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
                t-Button--gapTop
                t-Button--padBottom
            ]
