            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 94
                items: {
                    P94_INITIATIVE_ID: &P112_INITIATIVE_ID.
                }
                clearCache: 94
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction after-edit (
        name: after edit
        execution {
            sequence: 60
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @menubar
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @details-2
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p112-initiative (
        itemName: P112_INITIATIVE
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select i.initiative
                from SP_INITIATIVES i
                where i.id = :P112_INITIATIVE_ID
                ```
        }
    )

)

