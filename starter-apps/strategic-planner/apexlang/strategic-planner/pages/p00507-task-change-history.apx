page 507 (
    name: Task Change History
    alias: TASK-CHANGE-HISTORY
    title: Task Change History
    pageGroup: @projects
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region details (
        name: Details
        type: staticContent
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--noPadding
            ]
            cssClasses: u-flex
        }
    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 10
            slot: leftColumn
            columnSpan: 4
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Filters
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P507_ATTRIBUTE_CHANGE_MONTH (
            type: checkboxGroup
            label {
                label: Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ATTRIBUTE_CHANGE_MONTH
            }
        )

        facet P507_ATTRIBUTE_COLUMN (
            type: checkboxGroup
            label {
                label: Attribute
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ATTRIBUTE_COLUMN
            }
        )

        facet P507_CHANGED_BY (
            type: checkboxGroup
            label {
                label: Changed By
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: CHANGED_BY
            }
        )

        facet P507_CHANGE_TYPE (
            type: checkboxGroup
            label {
                label: Change
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: CHANGE_TYPE
            }
        )

        facet P507_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: ATTRIBUTE_DATATYPE,PROJECT_ID,ATTRIBUTE_COLUMN,OLD_VALUE,NEW_VALUE
            }
        )

    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                       CHANGED_ON             ATTRIBUTE_CHANGE_DATE,
                       to_char(CHANGED_ON,'YYYY.MM') ATTRIBUTE_CHANGE_Month,
                       case change_type when 'CREATE' then 'Added'
                                        when 'UPDATE' then 'Updated'
                                        when 'DELETE' then 'Deleted'
                                        else change_type
                            end change_type,
                       --
                       initcap(replace(attribute_column,'_',' ')) ATTRIBUTE_COLUMN,
                       decode(old_value,'Y','Yes','N','No',old_value) OLD_VALUE,
                       decode(new_value,'Y','Yes','N','No',new_value) NEW_VALUE,
                       changed_by
                  from SP_TASK_HISTORY
                where  task_id = :P507_TASK_ID
                ```
            pageItemsToSubmit: P507_TASK_ID
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: no data found
        }

        column ATTRIBUTE_CHANGE_DATE (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: When
            }
            layout {
                sequence: 54
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            sorting {
                defaultSequence: 1
                direction: desc
            }
        )

        column ATTRIBUTE_CHANGE_MONTH (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 64
            }
        )

        column ATTRIBUTE_COLUMN (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Attribute
            }
            layout {
                sequence: 4
            }
        )

        column CHANGED_BY (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Changed By
            }
            layout {
                sequence: 44
            }
        )

        column CHANGE_TYPE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Change
            }
            layout {
                sequence: 14
            }
        )

        column NEW_VALUE (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: New Value
            }
            layout {
                sequence: 34
            }
        )

        column OLD_VALUE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Old Value
            }
            layout {
                sequence: 24
            }
        )

    )

    region task (
        name: Task
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.ID,
                       (select project from sp_projects where id = r.project_id) project,
                       project_id,
                       (select task_type from sp_task_types rt where rt.id = r.task_type_id)||
                           case when r.task_sub_type_id is not null then ': ' end ||
                           (select task_type from sp_task_types rt where rt.id = r.task_sub_type_id) type,
                       (select case when first_name is not null or last_name is not null
                                    then first_name||' '||last_name
                                    else email
                                    end
                               from sp_team_members t where t.id = r.owner_id) the_owner,
                       owner_id,
                       (select status from sp_task_statuses where id = r.status_id) status,
                       start_date,
                       target_complete,
                       r.updated
                  from sp_tasks r
                where  id = :P507_TASK_ID
                ```
            pageItemsToSubmit: P507_TASK_ID
        }
        layout {
            sequence: 20
            parentRegion: @details
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
                t-Report--hideNoPagination
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 140
            }
        )

        column OWNER_ID (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 220
            }
        )

        column PROJECT (
            reportColumnQueryId: 2
            derivedColumn: N
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 150
            }
            link {
                target: {
                    page: 3
                    items: {
                        P3_PROJECT_ID: #PROJECT_ID#
                    }
                    clearCache: 3
                }
                linkText: #PROJECT#
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 230
            }
        )

        column START_DATE (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Start Date
            }
            layout {
                sequence: 190
            }
            appearance {
                formatMask: DD-MON-YYYY
            }
        )

        column STATUS (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 180
            }
        )

        column TARGET_COMPLETE (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Target Complete
            }
            layout {
                sequence: 200
            }
            appearance {
                formatMask: DD-MON-YYYY
            }
        )

        column THE_OWNER (
            reportColumnQueryId: 5
            derivedColumn: N
            type: link
            heading {
                heading: Owner
            }
            layout {
                sequence: 170
            }
            link {
                target: {
                    page: 5
                    items: {
                        P5_ID: #OWNER_ID#
                    }
                    clearCache: 5
                }
                linkText: #THE_OWNER#
            }
        )

        column TYPE (
            reportColumnQueryId: 4
            derivedColumn: N
            type: link
            heading {
                heading: Task
            }
            layout {
                sequence: 160
            }
            link {
                target: {
                    page: 502
                    items: {
                        P502_TASK_ID: &P507_TASK_ID.
                    }
                    clearCache: 502
                }
                linkText: #TYPE#
            }
        )

        column UPDATED (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 210
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

    pageItem P507_PROJECT_ID (
        type: hidden
        layout {
            sequence: 20
            region: @breadcrumb
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P507_TASK_ID (
        type: hidden
        layout {
            sequence: 10
            region: @breadcrumb
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    button refresh (
        buttonName: refresh
        label: Refresh
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 507
                items: {
                    P507_PROJECT_ID: &P507_PROJECT_ID.
                }
                clearCache: 64
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 502
                items: {
                    P502_TASK_ID: &P507_TASK_ID.
                }
                clearCache: 502
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    computation p507-project-id (
        itemName: P507_PROJECT_ID
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            sqlQuery:
                ```sql
                select project_id
                  from sp_tasks
                 where id = :P507_TASK_ID
                ```
        }
    )

    process log (
        name: log
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_log.log_interaction(
                    p_project_id => :P507_PROJECT_ID);
                ```
        }
        execution {
            sequence: 10
            point: beforeRegions
        }
        advanced {
            executionMappingIdentifier: 1352979512244126408
        }
    )

)

