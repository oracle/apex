    dynamicAction post-comment (
        name: Post Comment
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @post-comment
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P33_COMMENT
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 70
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_comment_util.add_init_focus_area_comment (
                        p_app_user_id        => :APP_USER_ID,
                        p_comment            => :P33_COMMENT,
                        p_init_focus_area_id => :P33_INIT_FOCUS_AREA_ID,
                        p_private_yn         => nvl(:P33_PRIVATE_YN,'N'),
                        p_image_ref_id       => :P33_IMAGE_REF_ID );
                    
                    :P33_COMMENT      := null;
                    :P33_IMAGE_REF_ID := to_number(sys_guid(), 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX');
                    ```
                itemsToSubmit: [
                    P33_COMMENT
                    P33_PRIVATE_YN
                    P33_INIT_FOCUS_AREA_ID
                    P33_IMAGE_REF_ID
                ]
                itemsToReturn: [
                    P33_COMMENT
                    P33_IMAGE_REF_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Comment Added Successfully");
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments-report
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

