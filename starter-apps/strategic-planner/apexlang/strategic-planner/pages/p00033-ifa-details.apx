    region description-2 (
        name: description
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                    x clob;
                begin
                x := 'No description provided.';
                for c1 in (
                    select description 
                      from SP_INITIATIVE_FOCUS_AREAS d
                     where d.id = :P33_INIT_FOCUS_AREA_ID
                       and description is not null
                ) loop
                    x := apex_markdown.to_html(c1.description);
                end loop;
                return x;
                end;
                ```
        }
        layout {
            sequence: 120
            parentRegion: @description
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
    )

