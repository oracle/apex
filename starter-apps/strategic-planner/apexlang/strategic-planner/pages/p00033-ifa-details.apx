                    P68_INIT_FOCUS_AREA_ID: &P33_INIT_FOCUS_AREA_ID.
                }
                clearCache: 68
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 
                  from SP_INIT_FOCUS_AREA_DOCUMENTS d
                 where init_focus_area_id = :P33_INIT_FOCUS_AREA_ID and 
                       (
                           lower(DOCUMENT_FILENAME) like '%.png' or 
                           lower(DOCUMENT_FILENAME) like '%.jpg' or 
                           lower(DOCUMENT_FILENAME) like '%.jpeg' or 
                           lower(DOCUMENT_FILENAME) like '%.gif' or 
                           lower(DOCUMENT_FILENAME) like '%.tiff' or 
                           lower(DOCUMENT_FILENAME) like '%.ai' 
                       )
                ```
        }
    )

    dynamicAction add-link (
        name: add link
        execution {
            sequence: 70
        }
        when {
            event: click
            selectionType: button
            button: @add-link
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Link Details
                message: Please supply a Link URL and a Link Name.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P33_LINK') === '' || $v('P33_LINK_NAME') === ''
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P33_LINK_NAME is not null and :P33_LINK is not null
                    then insert into sp_init_focus_area_links
                             (init_focus_area_id, link_name, link_url )
                         values
                             (:P33_INIT_FOCUS_AREA_ID, :P33_LINK_NAME, :P33_LINK);
                        :P33_LINK_NAME := null;
                        :P33_LINK := null;
                    end if;
                    ```
                itemsToSubmit: [
                    P33_LINK_NAME
                    P33_LINK
                    P33_INIT_FOCUS_AREA_ID
                ]
                itemsToReturn: [
                    P33_LINK
                    P33_LINK_NAME
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @links
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

