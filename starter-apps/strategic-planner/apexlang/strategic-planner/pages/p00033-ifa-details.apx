    region links (
        name: Links
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       LINK_NAME,
                       case when lower(link_url) not like 'http%'
                            then 'http://'||link_url
                            else link_url
                            end for_link,
                       LINK_URL,
                       decode(IMPORTANT_YN,'Y','Yes','N','No',IMPORTANT_YN) IMPORTANT,
                       CREATED,
                       lower(CREATED_BY) created_by,
                       UPDATED,
                       UPDATED_BY
                from SP_INIT_FOCUS_AREA_LINKS
                where  init_focus_area_id = :P33_INIT_FOCUS_AREA_ID
                ```
            pageItemsToSubmit: P33_INIT_FOCUS_AREA_ID
