    pageItem P33_MILESTONE_TYPE_ID (
        type: selectList
        label {
            label: Milestone Type
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select d, r 
                  from
                (
                select task_type d, id r, display_seq
                  from sp_task_types
                 where parent_type_id = (select id from sp_task_types where static_id = 'MILESTONE')
                 union all
                select 'Target Complete' d, -1 r, 1000000 display_seq
                  from dual
                )
                 order by display_seq
                ```
            nullDisplayValue: All Milestone Types
            nullReturnValue: 0
        }
        layout {
            sequence: 20
            region: @nomenclature-project-schedule
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue:
                ```sql
                select id task_id 
                  from sp_task_types 
                 where static_id = 'MILESTONE-MERGED'
                ```
        }
    )

