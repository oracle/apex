page 300 (
    name: release_projects
    alias: RELEASE-PROJECTS
    title: Release &NOMENCLATURE_PROJECTS.
    pageGroup: @releases
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            $(() => { 
                apex.actions.add({
                    name: 'favoriteProject',
                    action: function(event, focusElement, args) {
                        $(event.currentTarget).addClass('js-project-to-favorite');
                        apex.item('P300_PROJECT_TO_FAVORITE').setValue(args.id);
                        return true;
                        }
                });
            });
            ```
    }
    css {
        inline:
            ```css
            .no-item-ui {
              --a-field-input-border-width: 0px;
              --a-field-input-background-color: transparent;
            }
            
            .overline {
              color: var(--ut-region-text-color, var(--ut-component-text-default-color));
            }
            
            /* Vertically Align cells to top */
            .t-Report td {
              vertical-align: top;
            }
            
            @media (min-width: 640px) {
              .t-ContentRow-body {
                align-items: flex-start;
                /* Setting content row alignment to top */
              }
            
              .t-ContentRow-misc {
                flex-basis: 40%;
                /* Setting misc column width so they all line up */
              }
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region facets (
        name: Facets
        type: facetedSearch
        source {
            filteredRegion: @nomenclature-projects
        }
        layout {
            sequence: 20
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            displayChartForTopNValues: 10
        }

        facet P300_ACTIVE_ACTIVITY (
            type: checkboxGroup
            label {
                label: Current Activity
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: ACTIVE_ACTIVITY
            }
        )

        facet P300_CONTRIBUTOR_NAMES (
            type: checkboxGroup
            label {
                label: Contributors
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: CONTRIBUTOR_NAMES
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P300_FAVORITE (
