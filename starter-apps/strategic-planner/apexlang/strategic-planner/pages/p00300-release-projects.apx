    region release (
        name: Release
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.ID,
                       r.RELEASE_TRAIN||' '||r.RELEASE release,
                       decode(r.RELEASE_TARGET_DATE,null,    'No Date',to_char(r.RELEASE_TARGET_DATE,   'DD-MON-YY')) RELEASE_TARGET_DATE,
                       decode(r.RELEASE_OPEN_DATE,null,      'No Date',to_char(r.RELEASE_OPEN_DATE,     'DD-MON-YY')) RELEASE_OPEN_DATE,
                       greatest(round(r.RELEASE_TARGET_DATE - sysdate),0) days_remaining,
                       --
                       -- release projects
                       --
                       (select count(*) 
                        from sp_projects p 
                        where p.release_id = r.id and 
                              p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null) projects,
                       --
                       round(r.RELEASE_TARGET_DATE - r.RELEASE_OPEN_DATE) release_length,
                       --
                       -- contributors
                       --
                       (select count(distinct TEAM_MEMBER_ID) 
                        from SP_PROJECT_CONTRIBUTORS c 
                        where c.PROJECT_ID in (
                            select id 
                            from sp_projects p 
                            where p.release_id = r.id and 
                                  p.ARCHIVED_YN = 'N' and 
                                  p.DUPLICATE_OF_PROJECT_ID is null)
                                  ) contributors,
                       --
                       r.RELEASE_MANAGEMENT_URL url,
                       --
                       -- current activity
                       --
                       (select count(*) 
                        from  sp_projects p, SP_ACTIVITIES a
                        where p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null and 
                              p.release_id = r.id and
                              p.id = a.project_id and
                              sysdate >= a.START_DATE and
                              trunc(sysdate) <= a.END_DATE
                              ) projects_with_current_activity,
                       --
                       -- milestones
                       --
                       (select count(*) from SP_RELEASE_MILESTONES m where m.release_id = r.id) milestones
                  from SP_RELEASE_TRAINS r
                 where r.id = :P300_RELEASE_ID 
                ```
            pageItemsToSubmit: P300_RELEASE_ID
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
                t-Region-orderBy--end
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
            ]
        }

        column CONTRIBUTORS (
            reportColumnQueryId: 8
            derivedColumn: N
            type: link
            heading {
                heading: Contributors
            }
            layout {
                sequence: 140
            }
            link {
                target: {
                    page: 38
                    items: {
                        P38_ID: &P300_RELEASE_ID.
                    }
                    clearCache: 38
                    action: resetPagination
                }
                linkText: #CONTRIBUTORS#
            }
        )

        column DAYS_REMAINING (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Remaining
                alignment: end
            }
            layout {
                sequence: 110
                columnAlignment: end
            }
            appearance {
                formatMask: 99999
            }
            columnFormatting {
                htmlExpression: #DAYS_REMAINING# days
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column MILESTONES (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Milestones
                alignment: end
            }
            layout {
                sequence: 190
                columnAlignment: end
            }
        )

        column PROJECTS (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_PROJECTS.
                alignment: end
            }
            layout {
                sequence: 120
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
        )

        column PROJECTS_WITH_CURRENT_ACTIVITY (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Projects With Current Activity
                alignment: end
            }
            layout {
                sequence: 180
                columnAlignment: end
            }
        )

        column RELEASE (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 40
            }
        )

        column RELEASE_LENGTH (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Length
                alignment: end
            }
            layout {
                sequence: 100
                columnAlignment: end
            }
            columnFormatting {
                htmlExpression: #RELEASE_LENGTH# days
            }
        )

        column RELEASE_OPEN_DATE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Open
                alignment: center
            }
            layout {
                sequence: 60
            }
            appearance {
                formatMask: DD-MON-YY
            }
        )

        column RELEASE_TARGET_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Target Complete
                alignment: center
            }
            layout {
                sequence: 90
            }
            appearance {
                formatMask: DD-MON-YY
            }
        )

        column URL (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: URL
            }
            layout {
                sequence: 170
            }
            columnFormatting {
                htmlExpression: <a href="#URL#" target="_blank">Open URL</a>
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select 1 from SP_RELEASE_TRAINS 
                    where RELEASE_MANAGEMENT_URL is not null and id = :P300_RELEASE_ID
                    ```
            }
        )

    )

