                    }
                }
                appearance {
                    icon: fa-calendar-o
                }
            )

            menu release-dashboard (
                label: Release Dashboard
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 202
                        items: {
                            P202_RELEASE_ID: &P300_RELEASE_ID.
                        }
                        clearCache: 202
