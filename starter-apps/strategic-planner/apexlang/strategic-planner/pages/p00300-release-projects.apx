        }
        layout {
            sequence: 20
            parentRegion: @breadcrumb
            slot: subRegions
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: u-flex-grow-1
        }
        componentAppearance {
            display: report
            cssClasses: header-actions
        }
        plugin-appearance {
            applyThemeColors: false
            style: compact
            hideBorders: true
            removePadding: true
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
