page 62 (
    name: Initiative Images
    alias: INITIATIVE-IMAGES
    title: &P62_INITIATIVE_NAME. - Images
    pageGroup: @initiatives
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region details (
        name: details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select f.area focus_area, 
                       i.initiative, 
                       --
                       -- owner
                       --
                       (select first_name||' '||last_name 
                        from sp_team_members tm 
                        where tm.id = i.SPONSOR_ID) the_owner,
                       --
                       i.sponsor_id owner_id,
                       --
                       i.updated,
                       --
                       i.id,
                       dbms_lob.getlength(i.image) as image,
                       i.image_name,
                       i.image_mimetype,
                       i.image_last_updated
                
                  from SP_INITIATIVES i,
                       SP_AREAS f
                where i.area_id = f.id and
                      i.id = :P62_INITIATIVE_ID
                
                     
                ```
            pageItemsToSubmit: P62_INITIATIVE_ID
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
                t-Report--hideNoPagination
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column FOCUS_AREA (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: &NOMENCLATURE_AREA.
                alignment: center
            }
            layout {
                sequence: 20
            }
            link {
                target: {
                    page: 23
                    items: {
                        P23_FOCUS_AREA: #FOCUS_AREA#
                    }
                    clearCache: 23
                }
                linkText: #FOCUS_AREA#
            }
        )

        column ID (
            reportColumnQueryId: 6
            derivedColumn: N
            type: hidden
            layout {
                sequence: 140
            }
        )

        column IMAGE (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column IMAGE_LAST_UPDATED (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 150
            }
        )

        column IMAGE_MIMETYPE (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 130
            }
        )

        column IMAGE_NAME (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 120
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_INITIATIVE.
                alignment: center
            }
            layout {
                sequence: 30
            }
        )

        column OWNER_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 60
            }
        )

        column THE_OWNER (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Owner
            }
            layout {
                sequence: 90
            }
            link {
                target: {
                    page: 73
                    items: {
                        P73_TEAM_MEMBER_ID: #OWNER_ID#
                    }
                    clearCache: 73
                    action: resetPagination
                }
                linkText: #THE_OWNER#
            }
        )

        column UPDATED (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Updated
            }
            layout {
                sequence: 100
            }
            appearance {
                formatMask: SINCE
            }
        )

    )

    region facets (
        name: Facets
        type: facetedSearch
        source {
            filteredRegion: @images
        }
        layout {
            sequence: 20
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            displayChartForTopNValues: 10
        }

        facet P62_AUTHOR (
            type: checkboxGroup
            label {
                label: Contributor
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: AUTHOR
            }
        )

        facet P62_BELONGS_TO (
            type: checkboxGroup
            label {
                label: Belongs To
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: BELONGS_TO
            }
        )

        facet P62_FILE_EXTENSION (
            type: checkboxGroup
            label {
                label: File Extension
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: FILE_EXTENSION
            }
        )

        facet P62_MONTH_CREATED (
            type: checkboxGroup
            label {
                label: Month Created
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: MONTH_CREATED
            }
        )

        facet P62_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P62_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

    )

    region images (
        name: Images
        type: cards
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select :NOMENCLATURE_INITIATIVE belongs_to,
                       apex_util.prepare_url('f?p='||:APP_ID||':53:'||:APP_SESSION||'::NO:53:P53_PREV_PAGE,P53_ID:62,'||d.id) details_link,
                       null focus_area,
                       d.ID,
                       d.DOCUMENT_FILENAME,
                       d.document_mimetype,
                       d.document_lastupd,
                       UPDATED,
                       d.created,
                       d.tags,
                       case when length(d.doc_description) > 200
                            then substr(d.doc_description,1,200)||'...'
                            else d.doc_description
                            end doc_description,
                       d.DOCUMENT_BLOB,
                       lower(created_by) author,
                       dbms_lob.getlength(d.DOCUMENT_BLOB) doc_size,
                       apex_util.get_since(created) created_since,
                       d.created date_created,
                       lower(substr(DOCUMENT_FILENAME,instr(DOCUMENT_FILENAME,'.',-1)+1,length(DOCUMENT_FILENAME)-instr(DOCUMENT_FILENAME,'.',-1))) file_extension,
                       to_char(d.created,'YYYY.MM') month_created
                  from SP_INITIATIVE_DOCUMENTS d
                 where initiative_id = :P62_INITIATIVE_ID and 
                       (
                           lower(DOCUMENT_FILENAME) like '%.png' or 
                           lower(DOCUMENT_FILENAME) like '%.jpg' or 
                           lower(DOCUMENT_FILENAME) like '%.jpeg' or 
                           lower(DOCUMENT_FILENAME) like '%.gif' or 
                           lower(DOCUMENT_FILENAME) like '%.tiff' or 
                           lower(DOCUMENT_FILENAME) like '%.avif' or 
                           lower(DOCUMENT_FILENAME) like '%.ai' 
                       )
                union all
                select 'Focus Area' belongs_to,
                       apex_util.prepare_url('f?p='||:APP_ID||':59:'||:APP_SESSION||'::NO:59:P59_PREV_PAGE,P59_ID:62,'||d.id) details_link,
                       'Focus Area: '|| t.focus_area focus_area,
                       d.ID,
                       d.DOCUMENT_FILENAME,
                       d.document_mimetype,
                       d.document_lastupd,
                       d.UPDATED,
                       d.created,
                       d.tags,
                       case when length(d.doc_description) > 200
                            then substr(d.doc_description,1,200)||'...'
                            else d.doc_description
                            end doc_description,
                       d.DOCUMENT_BLOB,
                       lower(d.created_by) author,
                       dbms_lob.getlength(d.DOCUMENT_BLOB) doc_size,
                       apex_util.get_since(d.created) created_since,
                       d.created date_created,
                       lower(substr(d.DOCUMENT_FILENAME,instr(d.DOCUMENT_FILENAME,'.',-1)+1,length(d.DOCUMENT_FILENAME)-instr(d.DOCUMENT_FILENAME,'.',-1))) file_extension,
                       to_char(d.created,'YYYY.MM') month_created
                  from SP_INIT_FOCUS_AREA_DOCUMENTS d,
                       SP_INITIATIVE_FOCUS_AREAS t
                 where d.init_focus_area_id = t.id
                   and t.initiative_id = :P62_INITIATIVE_ID and 
                       (
                           lower(d.DOCUMENT_FILENAME) like '%.png' or 
                           lower(d.DOCUMENT_FILENAME) like '%.jpg' or 
                           lower(d.DOCUMENT_FILENAME) like '%.jpeg' or 
                           lower(d.DOCUMENT_FILENAME) like '%.gif' or 
                           lower(d.DOCUMENT_FILENAME) like '%.tiff' or 
                           lower(d.DOCUMENT_FILENAME) like '%.ai' 
                       )
                order by created desc
                
                ```
            pageItemsToSubmit: P62_INITIATIVE_ID
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/cards-container
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        card {
            primaryKeyColumn1: ID
        }
        title {
            column: DOCUMENT_FILENAME
        }
        subtitle {
            advancedFormatting: true
            htmlExpression:
                ```html
                {if FOCUS_AREA/}&FOCUS_AREA.<br/>{endif/}
                &AUTHOR. - &CREATED_SINCE.
                ```
        }
        secondaryBody {
            advancedFormatting: true
            htmlExpression: &DOC_DESCRIPTION.
        }
        media {
            source: blobColumn
            blobColumn: DOCUMENT_BLOB
        }
        blobAttributes {
            mimeTypeColumn: DOCUMENT_MIMETYPE
        }

        action action (
            type: fullCard
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: &DETAILS_LINK.
            }
        )

    )

    pageItem P62_INITIATIVE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @images
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P62_INITIATIVE_NAME (
        type: hidden
        layout {
            sequence: 20
            region: @images
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button add-document (
        buttonName: add_document
        label: Add Document
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 13
                items: {
                    P13_INITIATIVE_ID: &P62_INITIATIVE_ID.
                }
                clearCache: 13
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 94
                items: {
                    P94_INITIATIVE_ID: &P62_INITIATIVE_ID.
                }
                clearCache: 94
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dc (
        name: DC
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @images
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p62-initiative-name (
        itemName: P62_INITIATIVE_NAME
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery: select initiative from sp_initiatives where id = :P62_INITIATIVE_ID
        }
    )

)

