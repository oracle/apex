    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 80
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region links (
        name: Links
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select l.id, 
                       case when lower(l.link_url) not like 'http%' then 'http://' end || l.link_url link_url,
                       l.created, 
                       l.updated, 
                       decode(
                           greatest(length(l.link_url),80),
                           length(l.link_url),
                           substr(l.link_url,1,37)||'...'||substr(l.link_url,length(l.link_url)-40),
                           l.link_url
                           ) link_url_display
                from SP_PROJECT_LINKS l 
                where project_id = :P36_ID
                order by created desc
                ```
            pageItemsToSubmit: P36_ID
        }
        layout {
            sequence: 100
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
        messages {
            whenNoDataFound: None Found
        }
        heading {
            type: none
        }

        column CREATED (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 50
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            sorting {
                sortable: false
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column LINK_URL (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: URL
            }
            layout {
                sequence: 30
            }
            columnFormatting {
                htmlExpression: <a href="#LINK_URL#" target="_blank">#LINK_URL_DISPLAY#</a>
            }
            sorting {
                sortable: false
            }
        )

        column LINK_URL_DISPLAY (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 80
            }
        )

        column UPDATED (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 60
            }
        )

    )

    region milestones (
        name: Milestones
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select r.ID,
                       (select case when first_name is not null or last_name is not null
                                    then first_name||' '||last_name
                                    else email
                                    end
                               from sp_team_members t where t.id = r.owner_id) owner,
                       t.task_type type,
                       r.description,
                       (select status from sp_task_statuses where id = r.status_id) status,
                       to_char(r.start_date,'DD-MON') || case when r.start_date is not null then ' - ' end ||
                       nvl(to_char(r.target_complete,'DD-MON'),'?') dates,
                       t.display_seq ob
                  from sp_tasks r,
                       sp_task_types t
                 where project_id = :P36_ID
                   and nvl(r.task_sub_type_id,r.task_type_id) = t.id
                   and t.static_id like 'MILESTONE%'
                 order by t.display_seq
                ```
            pageItemsToSubmit: P36_ID
        }
        layout {
            sequence: 30
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 30
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
        messages {
            whenNoDataFound: None Found
        }

