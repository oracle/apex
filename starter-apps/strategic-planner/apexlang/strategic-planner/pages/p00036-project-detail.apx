page 36 (
    name: Project Detail
    alias: PROJECT-DETAIL
    title: &NOMENCLATURE_PROJECT.
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .sp-tag {
                padding: 2px 4px;
                display: inline-block;
                vertical-align: text-bottom;
                border-radius: 3px;
                background-color: rgba(0,0,0,.1);
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .sp-tags-container {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 4px;
                justify-content: flex-start;
            }
            
            .resize-region {
              resize: vertical;
              overflow: auto;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region activity (
        name: Activity
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ap.id, 
                       at.activity_type,
                       ap.comments,
                       to_char(ap.start_date,'DD-MON-YYYY')||' to '||to_char(ap.end_date,'DD-MON') TIMELINE,
                       tm.first_name||' '||tm.last_name name,
                       ap.updated
                from sp_activities ap,
                     sp_projects p,
                     sp_activity_types at,
                     sp_team_members tm
                where ap.project_id = p.id and
                      p.id = :P36_ID and
                      ap.activity_type_id = at.id and
                      ap.team_member_id = tm.id and
                      --
                      --
                      --
                      (  
                         sysdate between ap.start_date and ap.end_date 
                      )
                order by ap.start_date, ap.updated desc
                
                
                ```
            pageItemsToSubmit: P36_ID
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
        messages {
            whenNoDataFound: No Open Activity Found
        }
        heading {
            type: none
        }

        column ACTIVITY_TYPE (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 30
            }
        )

        column COMMENTS (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 40
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column NAME (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 20
            }
            columnFormatting {
                htmlExpression: #NAME#: #ACTIVITY_TYPE#: #COMMENTS# - #TIMELINE#
            }
            sorting {
                sortable: false
            }
        )

        column TIMELINE (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 50
            }
        )

        column UPDATED (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Updated
                alignment: end
            }
            layout {
                sequence: 60
                columnAlignment: end
            }
            appearance {
                formatMask: since_short
            }
            sorting {
                sortable: false
            }
        )

    )

    region approvals (
        name: Approvals
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.approval_type,
                       m.first_name||' '||m.last_name submitted_by,
                       a.submitted,
                       initcap(replace(a.status,'-',' ')) status,
                       (select max(nvl(last_status_on,updated)) from sp_project_approval_chain
                         where project_approval_id = a.id) last_action
                  from sp_project_approvals a,
                       sp_approval_types t,
                       sp_team_members m
                 where a.project_id = :P36_ID
                   and a.approval_type_id = t.id    
                   and a.submitted_by_team_member_id = m.id
                ```
        }
        orderBy {
            type: staticValue
            orderByClause: last_action desc
        }
        layout {
            sequence: 70
            slot: contentBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_project_approvals
                 where project_id = :P36_ID
                union
                select 1
                  from sp_initiative_approvals a,
                       sp_projects p
                 where p.id = :P36_ID
                   and p.initiative_id = a.initiative_id
                ```
        }
        config {
            buildOption: @approvals
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: None Found
        }

        column APPROVAL_TYPE (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Type
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

        column LAST_ACTION (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Last Action
            }
            layout {
                sequence: 70
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            sorting {
                sortable: false
            }
        )

        column STATUS (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 50
            }
            sorting {
                sortable: false
            }
        )

        column SUBMITTED (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Submitted
            }
            layout {
                sequence: 40
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            sorting {
                sortable: false
            }
        )

        column SUBMITTED_BY (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Submitted By
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

    )

    region attributes (
        name: Attributes
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.ID,
                       f.area ||' / '|| i.initiative area_initiative,
                       nvl((select t.first_name||' '||t.last_name from sp_team_members t where t.id = p.OWNER_ID),'No Owner') the_owner,
                       p.owner_id,
                       p.project,
                       --
                       -- project group
                       --
                       (select group_name from sp_project_groups pg where pg.id = p.project_group_id) project_group,
                       p.project_group_id,
                       --
                       -- fav icon
                       --
                       nvl((select '<span class="fa fa-heart u-danger-text" aria-hidden="true"></span>' 
                            from sp_favorites fav
                            where fav.project_id = p.id and 
                                  fav.team_member_id = :APP_USER_ID),
                            '<span class="fa fa-heart-o" aria-hidden="true"></span>') favorite_icon,
                       --
                       -- attributes
                       --
                       p.PCT_COMPLETE||'%' PCT_COMPLETE,
                       case when p.pct_complete >= sc.min_pc_for_status 
                             and p.pct_complete != 100
                            then nvl((select status from sp_project_statuses
                                       where id = p.status_id),'Not Set')
                            end status,
                       nvl((select 'P'||priority from sp_project_priorities pp where pp.id = p.priority_id),'Not Prioritized') priority,
                       null attributes,
                       (select t.release_train||' '||t.release from SP_RELEASE_TRAINS t where t.id = p.release_id) release,
                       case when p.target_complete is not null
                            then to_char(p.target_complete,'DD-Mon-YYYY')
                            else 'Not Targeted'
                            end target_complete,
                       --
                       lower(p.CREATED_BY)||' '||apex_util.get_since(p.CREATED) created,
                       lower(p.UPDATED_BY)||' '||apex_util.get_since(p.updated) updated,
                       --
                       p.PROJECT_SIZE,
                       p.project_url_name,
                       p.friendly_identifier friendly_identifier1,
                       --
                       -- external link:
                       --
                       p.external_system_link external_link,
                       '<button type="button" title="Copy Permalink" aria-label="Copy Permalink" data-clipboard-source="'||:P36_PERMALINK||'" class="t-Button t-Button--noLabel t-Button--icon t-Button--link padding-none">'||apex_escape.html(p.friendly_identifier)||'</button>' perma_link,
                       :P36_PERMALINK permalink,
                       --
                       -- focus area
                       --
                       nvl((select focus_area from SP_INITIATIVE_FOCUS_AREAS fa where fa.id = p.FOCUS_AREA_ID),'Unallocated') Focus_area
                  from SP_PROJECTS p, 
                       SP_INITIATIVES i,
                       SP_AREAS f,
                       SP_PROJECT_SIZES s,
                       sp_project_scales sc
                where 
                      p.archived_yn = 'N' and
                      p.initiative_id = i.id and
                      i.status_scale = sc.scale_letter and
                      i.area_id = f.id and
                      p.PROJECT_SIZE = s.project_size and
                      p.DUPLICATE_OF_PROJECT_ID is null and
                      p.id = :P36_ID
                ```
            pageItemsToSubmit: [
                P36_PERMALINK
                P36_ID
                APP_USER_ID
            ]
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        componentAppearance {
            template: @/value-attribute-pairs-column
            templateOptions: [
                #DEFAULT#
                t-AVPList--leftAligned
            ]
        }

        column AREA_INITIATIVE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Area/Initiative
            }
            layout {
                sequence: 40
            }
        )

        column ATTRIBUTES (
            reportColumnQueryId: 12
            derivedColumn: N
            heading {
                heading: Attributes
            }
            layout {
                sequence: 110
            }
            columnFormatting {
                htmlExpression:
                    ```html
                    <div class="sp-tags-container">
                        <span class="sp-tag">#PRIORITY#</span>
                        <span class="sp-tag">#PROJECT_SIZE#</span>
                        <span class="sp-tag">#PCT_COMPLETE#</span>
                    {if STATUS/}    <span class="sp-tag">#STATUS#</span>{endif/}
                        <span class="sp-tag">#RELEASE#</span>
                    </div>
                    ```
            }
        )

        column CREATED (
            reportColumnQueryId: 15
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 190
            }
        )

        column EXTERNAL_LINK (
            reportColumnQueryId: 20
            derivedColumn: N
            heading {
                heading: External Link
            }
            layout {
                sequence: 180
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select 1 from sp_projects
                     where id = :P36_ID
                       and external_system_link is not null
                    ```
            }
        )

        column FAVORITE_ICON (
            reportColumnQueryId: 8
            derivedColumn: N
            type: link
            heading {
                heading: My Favorite
            }
            layout {
                sequence: 220
            }
            link {
                target: {
                    page: 128
                    items: {
                        P128_PROJECT_ID: #ID#
                    }
                    clearCache: 128
                    action: resetPagination
                }
                linkText: #FAVORITE_ICON#
            }
            security {
                escapeSpecialChars: false
            }
        )

        column FOCUS_AREA (
            reportColumnQueryId: 23
