            heading {
                heading: Focus Area
            }
            layout {
                sequence: 50
            }
        )

        column FRIENDLY_IDENTIFIER1 (
            reportColumnQueryId: 19
            derivedColumn: N
            type: hidden
            layout {
                sequence: 150
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column OWNER_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 70
            }
        )

        column PCT_COMPLETE (
            reportColumnQueryId: 9
