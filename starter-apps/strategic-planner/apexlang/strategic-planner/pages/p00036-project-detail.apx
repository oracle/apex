    computation p36-log (
        itemName: P36_LOG
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody: return sp_log.log_and_summarize(:P36_ID);
        }
        error {
            errorMessage: Unable to log view #SQLERRM#
        }
    )

    computation p36-project-name (
        itemName: P36_PROJECT_NAME
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select project
                from SP_PROJECTS p
                where p.id = :P36_ID
                ```
        }
    )

    process determine-permalink (
        name: Determine Permalink
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select friendly_identifier, project_url_name
                      from sp_projects
                     where id = :P36_ID
                ) loop
                    :P36_PERMALINK := APEX_UTIL.HOST_URL('SCRIPT') || 
                                      'project-details?fi='||apex_escape.html(c1.friendly_identifier)||'&pn='||apex_escape.html(c1.project_url_name);
                end loop;
                ```
        }
        execution {
            sequence: 2
            point: afterHeader
        }
        advanced {
            executionMappingIdentifier: 5598303408749678911
        }
    )

)

