            }
        )

        column PROJECT_GROUP (
            reportColumnQueryId: 6
            derivedColumn: N
            type: link
            heading {
                heading: Group
            }
            layout {
                sequence: 100
            }
            link {
                target: {
                    page: 119
                    items: {
                        P119_PROJECT_GROUP_ID: #PROJECT_GROUP_ID#
                    }
                    clearCache: 119
                    action: resetPagination
                }
                linkText: #PROJECT_GROUP#
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select 1 from sp_projects
                     where id = :P36_ID
                       and project_group_id is not null
                    ```
            }
            config {
                buildOption: @project-groups
            }
        )

        column PROJECT_GROUP_ID (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 230
            }
        )

        column PROJECT_SIZE (
            reportColumnQueryId: 17
            derivedColumn: N
            type: hidden
            layout {
                sequence: 130
            }
        )

        column PROJECT_URL_NAME (
            reportColumnQueryId: 18
            derivedColumn: N
            type: hidden
            layout {
                sequence: 140
            }
        )

        column RELEASE (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Release
            }
            layout {
                sequence: 90
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select 1
                    from sp_projects
                    where id = :P36_ID 
                      and RELEASE_ID is not null
                    ```
            }
        )

        column STATUS (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 240
            }
        )

        column TARGET_COMPLETE (
            reportColumnQueryId: 14
            derivedColumn: N
            heading {
                heading: Target Complete
            }
            layout {
                sequence: 80
            }
        )

        column THE_OWNER (
            reportColumnQueryId: 3
