            derivedColumn: N
            heading {
                heading: Type
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

    )

    region related (
        name: Related
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select p.project related_project,
                       p.FRIENDLY_IDENTIFIER related_fi,
                       p.PROJECT_URL_NAME related_pn,
                       p.updated
                  from SP_PROJECT_RELATED r,
                       sp_projects p
                where  r.PROJECT_ID = :P36_ID and 
                       r.RELATED_PROJECT_ID = p.id and 
                       p.DUPLICATE_OF_PROJECT_ID is null and
                       p.ARCHIVED_YN = 'N'
                union
                select rp.project related_project,
                       rp.FRIENDLY_IDENTIFIER related_fi,
                       rp.PROJECT_URL_NAME related_pn, 
                       rp.updated
                  from SP_PROJECT_RELATED r,
                       sp_projects rp
                where  r.RELATED_PROJECT_ID = :P36_ID and
                       r.project_id = rp.id and
                       rp.DUPLICATE_OF_PROJECT_ID is null and
                       rp.ARCHIVED_YN = 'N'
                 order by updated desc
                ```
        }
        layout {
            sequence: 90
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
        messages {
            whenNoDataFound: None Found
        }
        heading {
            type: none
        }

        column RELATED_FI (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 30
            }
        )

        column RELATED_PN (
            reportColumnQueryId: 3
            derivedColumn: N
            type: hidden
            layout {
                sequence: 40
            }
        )

        column RELATED_PROJECT (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: Related Project
            }
            layout {
                sequence: 20
            }
            link {
                target: {
                    page: 3
                    items: {
                        FI: #RELATED_FI#
                        PN: #RELATED_PN#
                    }
                    clearCache: 3
                    action: resetPagination
