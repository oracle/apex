    region tags (
        name: Tags
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select nvl(lower(replace(p.TAGS,',',', ')),'None Found') tags
                  from SP_PROJECTS p
                where 
                      p.archived_yn = 'N' and
                      p.DUPLICATE_OF_PROJECT_ID is null and
                      p.id = :P36_ID
                ```
        }
        layout {
            sequence: 80
            slot: contentBody
