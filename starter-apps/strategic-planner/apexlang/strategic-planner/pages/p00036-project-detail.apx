            layout {
                sequence: 10
            }
        )

        column OB (
            reportColumnQueryId: 7
            derivedColumn: N
            type: hidden
            layout {
                sequence: 60
            }
        )

        column OWNER (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Owner
            }
            layout {
                sequence: 50
            }
            sorting {
                sortable: false
