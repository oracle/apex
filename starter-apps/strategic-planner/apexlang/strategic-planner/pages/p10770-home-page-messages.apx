page 10770 (
    name: Home Page Messages
    alias: HOME-PAGE-MESSAGES
    title: Home Page Messages
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region home-page-messages (
        name: Home Page Messages
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       NOTIFICATION_NAME,
                       NOTIFICATION_DESCRIPTION,
                       decode(IS_ACTIVE_YN,'Y','Yes','N','No','Unknown') IS_ACTIVE_YN,
                       REQUIRED_USER_TAG,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY,
                       FROM_DATE,
                       TO_DATE
                  from SP_APPLICATION_NOTIFICATIONS
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10780
                items: {
                    P10780_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 4476942585305835678
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 6
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: F
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 7
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column FROM_DATE (
            type: plainText
            heading {
                heading: From Date
            }
            layout {
                sequence: 19
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: J
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column IS_ACTIVE_YN (
            type: plainText
            heading {
                heading: "Active "
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column NOTIFICATION_DESCRIPTION (
            type: plainText
            heading {
                heading: Message
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column NOTIFICATION_NAME (
            type: plainText
            heading {
                heading: Message Name
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column REQUIRED_USER_TAG (
            type: plainText
            heading {
                heading: Required User Tag
            }
            layout {
                sequence: 5
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column TO_DATE (
            type: plainText
            heading {
                heading: To Date
            }
            layout {
                sequence: 29
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: K
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 8
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: H
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 9
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Home Page Messages
        }

        savedReport 44769499 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn FROM_DATE (
                sequence: 5
            )

            displayColumn IS_ACTIVE_YN (
                sequence: 3
            )

            displayColumn NOTIFICATION_DESCRIPTION (
                sequence: 2
            )

            displayColumn NOTIFICATION_NAME (
                sequence: 1
            )

            displayColumn REQUIRED_USER_TAG (
                sequence: 4
            )

            displayColumn TO_DATE (
                sequence: 6
            )

            displayColumn UPDATED (
                sequence: 7
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

        )

    )

    button create (
        buttonName: CREATE
        label: Add Message
        layout {
            sequence: 10
            region: @home-page-messages
            slot: rightOfInteractiveReportSearchBar
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10780
                clearCache: 10780
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @home-page-messages
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @home-page-messages
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

