                type: separator
                layout {
                    sequence: 30
                }
            )

            menu edit-group (
                label: Edit Group
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 150
                        items: {
                            P150_ID: &P151_GROUP_ID.
                        }
                        clearCache: 150
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-edit
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 151
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 151
                        clearCache: 151
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

        action add-group-member (
            position: primaryActions
            template: button
            label: Add Group Member
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 152
                    items: {
                        P152_GROUP_ID: &P151_GROUP_ID.
                    }
                    clearCache: 152
                    action: resetPagination
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-plus
                hot: true
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 50
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: [
                u-padding-inline-dynamic
                project-rds-region
            ]
        }
        settings {
            includeShowAll: false
        }
    )

    pageItem P151_GROUP_ID (
        type: hidden
        layout {
            sequence: 10
            region: @group-members
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P151_GROUP_NAME (
        type: hidden
        layout {
            sequence: 20
            region: @group-members
            slot: regionBody
        }
        security {
            sessionStateProtection: restricted
        }
    )

    pageItem P151_GROUP_TAG (
        type: hidden
        layout {
            sequence: 50
            slot: body
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 103
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction create-button-dialog-close (
        name: create button dialog close
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @group-members
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @group-members
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @group-members
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-breadcrumb-dialog-close (
        name: refresh on breadcrumb dialog close
        execution {
            sequence: 40
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @group
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @group-members
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-3 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @description
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-page-edit (
        name: refresh on page edit
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @group-members
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @group-members
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-project-view (
        itemName: LAST_PROJECT_VIEW
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 151
        }
    )

    computation p151-group-name (
        itemName: P151_GROUP_NAME
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery: select group_name from sp_groups g where g.id = :P151_GROUP_ID
        }
    )

    computation p151-group-tag (
        itemName: P151_GROUP_TAG
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            sqlQuery: select group_tag from sp_groups where id = :P151_GROUP_ID
        }
    )

)

