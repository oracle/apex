    region description (
        name: Description
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                   x clob;
                begin
                   for c1 in (select description from SP_GROUPS where id = :P151_GROUP_ID) loop
                       x := apex_escape.html(c1.description);
                   end loop;
                   return x;
                end;
                ```
        }
        layout {
            sequence: 40
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region group (
        name: Group
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select g.group_name, g.id, g.created, g.updated,
                       (select count(*) from SP_GROUP_MEMBERS gm where gm.group_id = g.id) members, group_tag
                from SP_GROUPS  g
                where g.id = :P151_GROUP_ID
                ```
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
                t-Region-orderBy--end
                margin-left-md
            ]
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
            ]
        }

