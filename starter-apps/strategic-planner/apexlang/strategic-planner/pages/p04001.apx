            pageItemsToSubmit: P4001_WORKFLOW_ID
        }
        layout {
            sequence: 110
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
