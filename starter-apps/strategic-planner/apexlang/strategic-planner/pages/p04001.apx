                sequence: 10
            }
            source {
                databaseColumn: STATIC_ID
                dataType: varchar2
            }
        )

    )

    region workflow-diagram (
        name: Workflow Diagram
        type: workflowDiagram
        layout {
            sequence: 130
            slot: contentBody
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                js-useLocalStorage
                is-collapsed
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: region
        }
        settings {
            workflowId: P4001_WORKFLOW_ID
        }
    )

    pageItem P4001_ACTIVITY_ID (
        type: hidden
        settings {
            valueProtected: false
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        sessionState {
            storage: request
        }
        security {
            encryptSessionState: false
        }
    )

    pageItem P4001_PARENT_WORKFLOW_ID (
        type: hidden
        layout {
            sequence: 30
            slot: contentBody
        }
        source {
            type: sqlQuerySingleValue
            sqlQuery: select parent_workflow_id from apex_workflows where workflow_id = :P4001_WORKFLOW_ID
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4001_WORKFLOW_ID (
        type: hidden
        layout {
            sequence: 10
            slot: contentBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Close
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button cancel-activity-audit (
        buttonName: CANCEL_ACTIVITY_AUDIT
        label: Close
        layout {
            sequence: 10
            region: @activity-audit
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button resume (
        buttonName: RESUME
        label: Resume
        layout {
            sequence: 30
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-play-circle u-success-text
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                apex_workflow.is_allowed (
                    p_instance_id => :P4001_WORKFLOW_ID,
                    p_operation   => apex_workflow.c_workflow$_op_resume )
                ```
        }
    )

    button retry (
        buttonName: RETRY
        label: Retry
        layout {
            sequence: 50
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-redo-alt
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                apex_workflow.is_allowed (
                    p_instance_id => :P4001_WORKFLOW_ID,
                    p_operation   => apex_workflow.c_workflow$_op_retry )
                ```
        }
    )

    button suspend (
        buttonName: SUSPEND
        label: Suspend
        layout {
            sequence: 20
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-pause-circle u-warning-text
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                apex_workflow.is_allowed (
                    p_instance_id => :P4001_WORKFLOW_ID,
                    p_operation   => apex_workflow.c_workflow$_op_suspend )
                ```
        }
    )

    button terminate (
        buttonName: TERMINATE
        label: Terminate
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-times u-danger-text
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: expression
            plsqlExpression:
                ```plsql
                apex_workflow.is_allowed (
                    p_instance_id => :P4001_WORKFLOW_ID,
                    p_operation   => apex_workflow.c_workflow$_op_terminate )
                ```
        }
    )

    button to-parent-workflow (
        buttonName: TO_PARENT_WORKFLOW
        label: To Parent Workflow
        layout {
            sequence: 50
            slot: contentBody
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-arrow-left-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 4001
                items: {
                    P4001_WORKFLOW_ID: &P4001_PARENT_WORKFLOW_ID.
                }
                clearCache: 4001
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4001_PARENT_WORKFLOW_ID
        }
    )

    dynamicAction activity-audit (
        name: Activity Audit
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: a.audit
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @activity-audit
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @activity-audit
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: apex.jQuery(this.triggeringElement).attr("data-id")
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P4001_ACTIVITY_ID
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction cancel-activity-audit (
        name: Cancel Activity Audit
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @cancel-activity-audit
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @activity-audit
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 50
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction disable-enable-update-button (
        name: Disable/Enable Update Button
        execution {
            sequence: 60
        }
        when {
            event: keyup
            selectionType: items
            items: P4001_NEW_VALUE
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression: apex.items.P4001_NEW_VALUE.value != apex.items.P4001_CURRENT_VALUE.value
        }
    )

    dynamicAction edit-variable (
        name: Edit Variable
        execution {
            sequence: 30
            eventScope: dynamic
            staticContainer: #VARIABLES
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: a.variable
        }

        action native-set-focus (
            action: setFocus
            affectedElements {
                selectionType: items
                items: P4001_NEW_VALUE
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: apex.jQuery(this.triggeringElement).attr("data-id")
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P4001_VARIABLE_ID
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-set-value-2 (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: apex.jQuery(this.triggeringElement).attr("data-label")
                suppressChangeEvent: true
            }
            affectedElements {
                selectionType: items
                items: P4001_VARIABLE_LABEL
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-set-value-3 (
            action: setValue
            settings {
                type: jsExpression
