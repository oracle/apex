    region subject (
        name: Subject
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select title,
                       workflow_def_name,
                       initiator,
                       created_ago,
                       badge_text,
                       badge_state
                  from table ( apex_workflow.get_workflows (
                                   p_context     => 'SINGLE_WORKFLOW',
                                   p_workflow_id => :P4001_WORKFLOW_ID ) );
                ```
        }
        layout {
            sequence: 60
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: partial
        }
        settings {
            title: &TITLE.
            description:
                ```html
                <strong>&WORKFLOW_DEF_NAME!HTML.</strong>
                {if INITIATOR/}
                    <span role="separator" aria-label="&middot;"> &middot; </span>
                    &{APEX.WORKFLOW.INITIATED_BY_USER_SINCE 0=&INITIATOR!HTML. 1=&CREATED_AGO.}.
                {endif/}
                ```
            displayBadge: true
        }
        plugin-badge {
            label: State
            value: BADGE_TEXT
            state: BADGE_STATE
            size: medium
            columnWidth: auto
        }

        column BADGE_STATE (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: BADGE_STATE
                dataType: varchar2
            }
        )

        column BADGE_TEXT (
            layout {
                sequence: 50
            }
