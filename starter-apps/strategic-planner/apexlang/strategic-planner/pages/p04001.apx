page 4001 (
    name: Workflow Details
    title: Workflow Details
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    advanced {
        enableDuplicatePageSubmissions: false
    }
    config {
        buildOption: @approvals
    }

    region activities (
        name: Activities
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select activity_id,
                       type,
                       name,
                       state,
                       error_message,
                       due_on,
                       retry_count,
                       start_time,
                       end_time,
                       initcap(state) as badge_text,
                       case state
                           when 'WAITING'    then 'danger'
                           when 'COMPLETED'  then 'success'
                           when 'TERMINATED' then 'warning'
                           when 'FAULTED'    then 'danger'
                       end as badge_state,
                       ( select max(workflow_id)
                           from apex_workflows w
                          where w.parent_workflow_id = :P4001_WORKFLOW_ID
                            and w.parent_activity_id = a.activity_id ) as invoked_workflow_id
                  from apex_workflow_activities a
                 where workflow_id = :P4001_WORKFLOW_ID
                 order by start_time
                ```
            pageItemsToSubmit: P4001_WORKFLOW_ID
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &NAME.
            description: &ERROR_MESSAGE.
            miscellaneous:
                ```html
                {case STATE/}
                    {when COMPLETED/}
                        &{APEX.WORKFLOW.COMPLETED_SINCE 0=&END_TIME.}.
                    {otherwise/}
                        &{APEX.WORKFLOW.STARTED_SINCE 0=&START_TIME.}.
                {endcase/}
                {if DUE_ON/}
                    <span role="separator" aria-label="&middot;"> &middot; </span>
                    &{APEX.WORKFLOW.DUE_SINCE 0=&DUE_ON.}.
                {endif/}
                {if RETRY_COUNT/}
                    {case RETRY_COUNT/}
                        {when 0/}
                        {when 1/}
                        <span role="separator" aria-label="&middot;"> &middot; </span>
                            &{APEX.WORKFLOW.RETRY_COUNT.EQUALS_ONE 0=&RETRY_COUNT.}.
                        {otherwise/}
                        <span role="separator" aria-label="&middot;"> &middot; </span>
                            &{APEX.WORKFLOW.RETRY_COUNT.NOT_EQUALS_ONE 0=&RETRY_COUNT.}.
                    {endcase/}
                {endif/}
                ```
            displayBadge: true
        }
        plugin-badge {
            label: Status
            value: BADGE_TEXT
            state: BADGE_STATE
            style: outline
        }
        pagination {
            entitiesPerPage: 10
        }

        column ACTIVITY_ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIVITY_ID
                dataType: number
            }
        )

        column BADGE_STATE (
            layout {
                sequence: 110
            }
            source {
                databaseColumn: BADGE_STATE
                dataType: varchar2
            }
        )

        column BADGE_TEXT (
            layout {
                sequence: 100
            }
            source {
                databaseColumn: BADGE_TEXT
                dataType: varchar2
            }
        )

        column DUE_ON (
            layout {
                sequence: 60
            }
            source {
                databaseColumn: DUE_ON
                dataType: timestampWithTimeZone
            }
            appearance {
                formatMask: SINCE
            }
        )

        column END_TIME (
            layout {
                sequence: 90
            }
            source {
                databaseColumn: END_TIME
                dataType: timestampWithTimeZone
            }
            appearance {
                formatMask: SINCE
            }
        )

        column ERROR_MESSAGE (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: ERROR_MESSAGE
                dataType: varchar2
            }
        )

        column INVOKED_WORKFLOW_ID (
            layout {
                sequence: 120
            }
            source {
                databaseColumn: INVOKED_WORKFLOW_ID
                dataType: number
            }
        )

        column NAME (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: NAME
                dataType: varchar2
            }
            accessibility {
                valueIdentifiesRow: true
            }
        )

        column RETRY_COUNT (
            layout {
                sequence: 70
            }
            source {
                databaseColumn: RETRY_COUNT
                dataType: number
            }
        )

        column START_TIME (
            layout {
                sequence: 80
            }
            source {
                databaseColumn: START_TIME
                dataType: timestampWithTimeZone
            }
            appearance {
                formatMask: SINCE
            }
        )

        column STATE (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: STATE
                dataType: varchar2
            }
        )

        column TYPE (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: TYPE
                dataType: varchar2
            }
        )

        action action (
            position: titleLink
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: #
                linkAttributes: class="audit" data-id="&ACTIVITY_ID." aria-haspopup="dialog"
            }
            serverSideCondition {
                type: itemIsNull
                item: INVOKED_WORKFLOW_ID
            }
        )

        action action-2 (
            position: titleLink
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 4001
                    items: {
                        P4001_WORKFLOW_ID: &INVOKED_WORKFLOW_ID.
                    }
                    clearCache: 4001
                    action: resetPagination
                }
            }
            serverSideCondition {
                type: itemIsNotNull
                item: INVOKED_WORKFLOW_ID
            }
        )

    )

    region activity-audit (
        name: Activity Audit
        type: themeTemplateComponent/comments
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select created_by,
                       created_on,
                       action,
                       display_msg
                  from apex_workflow_audit
                 where workflow_id         = :P4001_WORKFLOW_ID
                   and current_activity_id = :P4001_ACTIVITY_ID
                 order by audit_id
                ```
            pageItemsToSubmit: [
                P4001_WORKFLOW_ID
                P4001_ACTIVITY_ID
            ]
        }
        layout {
            sequence: 80
            parentRegion: @activities
            slot: regionBody
        }
        appearance {
            template: @/inline-popup
            templateOptions: [
                #DEFAULT#
                js-dialog-autoheight
                js-dialog-size600x400
            ]
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            commentText: DISPLAY_MSG
            userName: CREATED_BY
            date: CREATED_ON
            displayAvatar: false
        }
        pagination {
            entitiesPerPage: 5
        }

        column ACTION (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: ACTION
                dataType: varchar2
            }
        )

        column CREATED_BY (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: CREATED_BY
                dataType: varchar2
            }
        )

        column CREATED_ON (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: CREATED_ON
                dataType: date
            }
            appearance {
                formatMask: SINCE
            }
        )

        column DISPLAY_MSG (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: DISPLAY_MSG
                dataType: varchar2
            }
        )

    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 200
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--stickToBottom
