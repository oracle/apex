        }
        componentAppearance {
            display: report
        }
        settings {
            overline: &LABEL.
            title: &DISPLAY_VALUE.
        }
        pagination {
            entitiesPerPage: 10
        }

        column DISPLAY_VALUE (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: DISPLAY_VALUE
                dataType: varchar2
            }
        )

        column LABEL (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: LABEL
                dataType: varchar2
            }
            accessibility {
                valueIdentifiesRow: true
            }
        )

        column STATIC_ID (
