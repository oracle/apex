page 144 (
    name: My Profile
    alias: MY-PROFILE
    title: My Profile
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region my-profile (
        name: My Profile
        type: form
        source {
            location: localDatabase
            tableName: SP_TEAM_MEMBERS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P144_COMMENT_NOTIF_PREF (
        type: checkboxGroup
        label {
            label: Comment Alerts
            alignment: left
        }
        settings {
            noOfCols: 3
        }
        lov {
            type: sharedComponent
            lov: @email-alert-pref
            displayExtraValues: false
        }
        layout {
            sequence: 80
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @my-profile
            column: COMMENT_NOTIF_PREF
            dataType: varchar2
        }
        default {
            type: static
            staticValue: APP:EMAIL
        }
        security {
            restrictedChars: webSafe
        }
        help {
            helpText: If no preference is set, comment alerts will be shown within the application and sent via email.
        }
    )

    pageItem P144_COMPETENCIES (
        type: popupLov
        label {
            label: Competencies
            alignment: left
        }
        settings {
            fetchOnSearch: true
        }
        lov {
            type: sqlQuery
            sqlQuery: select competency from SP_COMPETENCIES order by competency
        }
        multipleValues {
            type: delimitedList
            separator: ,
        }
        layout {
            sequence: 100
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @my-profile
            column: COMPETENCIES
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P144_COUNTRY_ID (
        type: popupLov
        label {
            label: Country
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select country_name||' - '||country_code d,
                       id
                from sp_countries
                order by 1
                ```
        }
        layout {
            sequence: 120
            region: @my-profile
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @my-profile
            column: COUNTRY_ID
            dataType: number
        }
        security {
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P144_EMAIL (
        type: displayOnly
        label {
            label: Email
            alignment: left
        }
        layout {
            sequence: 20
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @my-profile
            column: EMAIL
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P144_FIRST_NAME (
        type: textField
        label {
            label: First Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 30
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @my-profile
            column: FIRST_NAME
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P144_ID (
        type: hidden
        layout {
            sequence: 10
            region: @my-profile
            slot: regionBody
        }
        source {
            formRegion: @my-profile
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P144_INITIALS (
        type: textField
        label {
            label: Initials
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 50
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 3
        }
        source {
            formRegion: @my-profile
            column: INITIALS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P144_LAST_NAME (
        type: textField
        label {
            label: Last Name
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 40
            region: @my-profile
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @my-profile
            column: LAST_NAME
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P144_LOCATION (
        type: textField
        label {
            label: Location
            alignment: left
        }
        layout {
            sequence: 110
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            maxLength: 500
        }
        source {
            formRegion: @my-profile
            column: LOCATION
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P144_NOTIFICATION_PREF (
        type: checkboxGroup
        label {
            label: Assignment Alerts
            alignment: left
        }
        settings {
            noOfCols: 3
        }
        lov {
            type: sharedComponent
            lov: @email-alert-pref
            displayExtraValues: false
        }
        layout {
            sequence: 70
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @my-profile
            column: NOTIFICATION_PREF
            dataType: varchar2
        }
        default {
            type: static
            staticValue: APP:EMAIL
        }
        security {
            restrictedChars: webSafe
        }
        help {
            helpText: If no preference is set, assignment alerts will be shown within the application and sent via email.
        }
    )

    pageItem P144_PHOTO (
        type: imageUpload
        label {
            label: Profile Photo
            alignment: left
        }
        display {
            displayAs: inlineDropzone
        }
        cropping {
            allowCropping: true
            aspectRatio: square
        }
        resizeTo {
            maxWidth: 256
            maxHeight: 256
        }
        layout {
            sequence: 130
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @my-profile
            column: PHOTO
            dataType: blob
        }
    )

    pageItem P144_SCREEN_NAME (
        type: textField
        label {
            label: Screen Name
            alignment: left
        }
        settings {
            textCase: lower
        }
        layout {
            sequence: 60
            region: @my-profile
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 50
        }
        source {
            formRegion: @my-profile
            column: SCREEN_NAME
            dataType: varchar2
        }
        security {
            restrictedChars: noSpecialCharNoNewline
        }
        help {
            helpText: This attribute is used to reference another application user in a comment, for example @somename, where "someone" is the screen name.
        }
        config {
            buildOption: @comment-tagging
        }
    )

    pageItem P144_TAGS (
        type: combobox
        label {
            label: Tags
            alignment: left
        }
        settings {
            multiSelection: true
            infiniteScroll: false
            maxValuesInList: 15
        }
        lov {
            type: sqlQuery
            sqlQuery: select tag from SP_DEFAULT_PEOPLE_TAGS order by display_sequence, tag
        }
        multipleValues {
            type: delimitedList
            separator: ,
        }
        layout {
            sequence: 90
            region: @my-profile
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @my-profile
            column: TAGS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P144_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P144_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction when-comment-pref-set-to-none (
        name: when comment pref set to none
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: items
            items: P144_COMMENT_NOTIF_PREF
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression:
                ```javascript-browser
                $v("P144_COMMENT_NOTIF_PREF") == 'APP:NONE' || 
                $v("P144_COMMENT_NOTIF_PREF") == 'APP:EMAIL:NONE' ||
                $v("P144_COMMENT_NOTIF_PREF") == 'EMAIL:NONE'
                ```
        }

        action native-set-value (
            action: setValue
            settings {
                value: NONE
            }
            affectedElements {
                selectionType: items
                items: P144_COMMENT_NOTIF_PREF
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction when-notification-pref-set-to-none (
        name: when notification pref set to none
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: items
            items: P144_NOTIFICATION_PREF
        }
        clientSideCondition {
            type: jsExpression
            javaScriptExpression:
                ```javascript-browser
                $v("P144_NOTIFICATION_PREF") == 'APP:NONE' || 
                $v("P144_NOTIFICATION_PREF") == 'APP:EMAIL:NONE' ||
                $v("P144_NOTIFICATION_PREF") == 'EMAIL:NONE'
                ```
        }

        action native-set-value (
            action: setValue
            settings {
                value: NONE
            }
            affectedElements {
                selectionType: items
                items: P144_NOTIFICATION_PREF
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation no-dup-screen-names (
        name: no dup screen names
        execution {
            sequence: 10
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_team_members
                 where id != :P144_ID
                   and screen_name = lower(:P144_SCREEN_NAME)
                ```
        }
        error {
            errorMessage: This screen name is already in use.
            associatedItem: @P144_SCREEN_NAME
        }
        config {
            buildOption: @comment-tagging
        }
    )

    validation screen-name-no-or-space (
        name: screen name, no #,., @ or space
        execution {
            sequence: 20
        }
        validation {
            plsqlExpression:
                ```plsql
                instr(:P144_SCREEN_NAME,'#') = 0 and
                instr(:P144_SCREEN_NAME,'@') = 0 and
                instr(:P144_SCREEN_NAME,'.') = 0 and
                instr(:P144_SCREEN_NAME,' ') = 0
                ```
        }
        error {
            errorMessage: Screen name cannot contain #, @ or space.
            associatedItem: @P144_SCREEN_NAME
        }
        config {
            buildOption: @comment-tagging
        }
    )

    computation p144-comment-notif-pref (
        itemName: P144_COMMENT_NOTIF_PREF
        execution {
            sequence: 20
            point: afterHeader
        }
        computation {
            type: staticValue
            staticValue: APP:EMAIL
        }
        serverSideCondition {
            type: itemIsNull
            item: P144_COMMENT_NOTIF_PREF
        }
        config {
            buildOption: @email-configured
        }
    )

    computation p144-notification-pref (
        itemName: P144_NOTIFICATION_PREF
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            type: staticValue
            staticValue: APP:EMAIL
        }
        serverSideCondition {
            type: itemIsNull
            item: P144_NOTIFICATION_PREF
        }
        config {
            buildOption: @email-configured
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 4088913367044077691
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE
        }
    )

    process initialize-form-my-profile (
        name: Initialize form My Profile
        type: formInitialization
        formRegion: @my-profile
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 4088912521982077690
        }
    )

    process process-form-my-profile (
        name: Process form My Profile
        type: formAutoRowProcessing
        formRegion: @my-profile
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Changes saved.
        }
        advanced {
            executionMappingIdentifier: 4088912980017077691
        }
    )

)

