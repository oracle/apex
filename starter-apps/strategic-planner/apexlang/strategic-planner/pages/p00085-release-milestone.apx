page 85 (
    name: Release Milestone
    alias: RELEASE-MILESTONE
    title: Release Milestone
    pageGroup: @releases
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region release-milestone (
        name: Release Milestone
        type: form
        source {
            location: localDatabase
            tableName: SP_RELEASE_MILESTONES
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P85_ID (
        type: hidden
        layout {
            sequence: 10
            region: @release-milestone
            slot: regionBody
        }
        source {
            formRegion: @release-milestone
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P85_MILESTONE_COMPLETED_YN (
        type: switch
        label {
            label: Completed
            alignment: left
        }
        layout {
            sequence: 80
            region: @release-milestone
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_COMPLETED_YN
            dataType: varchar2
        }
        security {
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P85_MILESTONE_DATE (
        type: datePicker
        label {
            label: Milestone Date
            alignment: left
        }
        settings {
            minDate: item
            minItem: P85_MILESTONE_START_DATE
        }
        layout {
            sequence: 60
            region: @release-milestone
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_DATE
            dataType: date
        }
    )

    pageItem P85_MILESTONE_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 90
            region: @release-milestone
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P85_MILESTONE_NAME (
        type: textField
        label {
            label: Milestone
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 40
            region: @release-milestone
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_NAME
            dataType: varchar2
        }
    )

    pageItem P85_MILESTONE_START_DATE (
        type: datePicker
        label {
            label: Start Date
            alignment: left
        }
        layout {
            sequence: 50
            region: @release-milestone
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 32
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_START_DATE
            dataType: date
        }
        help {
            helpText: Only used for multi-day milestones.
        }
    )

    pageItem P85_MILESTONE_TYPE_ID (
        type: selectOne
        label {
            label: Type
            alignment: left
        }
        settings {
            infiniteScroll: false
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select milestone_type d, id r
                  from sp_release_milestone_types
                 where (include_yn = 'Y' or 
                        :P85_MILESTONE_TYPE_ID = id)
                 order by display_seq
                ```
        }
        layout {
            sequence: 30
            region: @release-milestone
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        source {
            formRegion: @release-milestone
            column: MILESTONE_TYPE_ID
            dataType: number
        }
    )

    pageItem P85_RELEASE_ID (
        type: hidden
        layout {
            sequence: 20
            region: @release-milestone
            slot: regionBody
        }
        source {
            formRegion: @release-milestone
            column: RELEASE_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P85_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P85_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P85_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 8158756328147960421
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-release-milestone (
        name: Initialize form Release Milestone
        type: formInitialization
        formRegion: @release-milestone
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 8158755544469960419
        }
    )

    process process-form-release-milestone (
        name: Process form Release Milestone
        type: formAutoRowProcessing
        formRegion: @release-milestone
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 8158755939051960420
        }
    )

)

