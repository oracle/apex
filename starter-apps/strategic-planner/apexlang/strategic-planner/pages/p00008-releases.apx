                formatMask: SINCE
            }
        )

        column MILESTONES (
            layout {
                sequence: 240
            }
            source {
                databaseColumn: MILESTONES
                dataType: number
            }
        )

        column NOT_COMPLETED (
            layout {
                sequence: 120
            }
            source {
                databaseColumn: NOT_COMPLETED
