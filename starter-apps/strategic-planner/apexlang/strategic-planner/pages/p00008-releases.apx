                sequence: 220
            }
            source {
                databaseColumn: WINDOW
                dataType: varchar2
            }
        )

        action action (
            position: titleLink
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 117
                    items: {
                        P117_RELEASE_ID: &ID.
                    }
                    clearCache: 117
                    action: resetPagination
                }
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
                cssClasses: t-Button--noUI
            }

            menu ai-summaries (
                label: AI Summaries
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 165
                        items: {
                            P165_RELEASE_ID: &ID.
                        }
                        clearCache: 165
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-ai-sparkle-generate-text
                }
                config {
                    buildOption: @ai-release-summaries
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 40
                }
            )

            menu edit-release (
                label: Edit Release
                layout {
                    sequence: 20
                }
                behavior {
                    target: {
                        page: 27
                        items: {
                            P27_ID: &ID.
                        }
                        clearCache: 27
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-edit
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu release-details (
                label: Release Details
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 117
                        items: {
                            P117_RELEASE_ID: &ID.
                        }
                        clearCache: 117
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-ship
                }
            )

            menu release-nomenclature-projects (
                label: "Release &NOMENCLATURE_PROJECTS. "
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 300
                        items: {
                            P300_RELEASE_ID: &ID.
                        }
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

        )

    )

    pageItem P8_ORDER_BY (
        type: selectList
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Release;RELEASE,Release Open Date;RELEASE_OPEN_DATE,Release Target Date;RELEASE_TARGET_DATE1,Updated - Most Recent First;UPDATED
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @items
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-sort-amount-asc
            height: 1
        }
        validation {
            valueRequired: true
        }
        advanced {
            cssClasses: [
                w300
                no-item-ui
            ]
            warnOnUnsavedChanges: ignore
        }
        default {
            type: static
            staticValue: RELEASE
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction after-edit-closed (
        name: after edit closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @releases
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @faceted-search
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @releases
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-releases-on-dc (
        name: refresh releases on dc
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @releases
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-proj-jump-pg (
        itemName: LAST_PROJ_JUMP_PG
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 8
        }
    )

)

