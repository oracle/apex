page 8 (
    name: Releases
    alias: RELEASES
    title: Releases
    pageGroup: @releases
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .no-item-ui {
              --a-field-input-border-width: 0px;
              --a-field-input-background-color: transparent;
            }
            
            .overline {
              color: var(--ut-region-text-color, var(--ut-component-text-default-color));
            }
            ```
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region faceted-search (
        name: Faceted Search
        type: facetedSearch
        source {
            filteredRegion: @releases
        }
        layout {
            sequence: 30
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            displayChartForTopNValues: 10
        }

        facet P8_RELEASE_OWNER (
            type: checkboxGroup
            label {
                label: Owner
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: RELEASE_OWNER
            }
        )

        facet P8_RELEASE_TARGET_YEAR (
            type: checkboxGroup
            label {
                label: Release Year
            }
            lov {
                type: distinctValues
                sortDirection: desc
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: RELEASE_TARGET_YEAR
            }
        )

        facet P8_RELEASE_TRAIN (
            type: checkboxGroup
            label {
                label: Release Train
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: RELEASE_TRAIN
            }
        )

        facet P8_RELEASE_TYPE (
            type: checkboxGroup
            label {
                label: Release Type
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: RELEASE_TYPE
            }
        )

        facet P8_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P8_WINDOW (
            type: checkboxGroup
            label {
                label: Window
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: WINDOW
            }
        )

    )

    region items (
        name: Items
        type: staticContent
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu about-releases (
                label: About Releases
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 108
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-info
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 40
                }
            )

            menu copy-release (
                label: Copy Release
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 63
                        clearCache: 63
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-copy
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 8
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 8
                        clearCache: 8
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

        action add-release (
            position: primaryActions
            template: button
            label: Add Release
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 27
                    clearCache: 27
                    action: resetPagination
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-plus
                hot: true
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

    )

    region releases (
        name: Releases
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id, 
                       release_train, 
                       release_owner_id,
                       nvl(release_owner,'(No Owner)') release_owner,
                       release,
                       timeline,
                       days_remaining,
                       badge_state,
                       RELEASE_OPEN_DATE,
                       RELEASE_TARGET_DATE,
                       to_char(RELEASE_TARGET_DATE,'YYYY') RELEASE_TARGET_YEAR,
                       UPDATED,
                       duration_in_days,
                       AVG_PCT_COMPLETE,
                       completed,
                       not_completed,
                       contributors,
                       last_updated,
                       projects,
                       --
                       -- release type Full or Patch
                       --
                       initcap(nvl(release_type,'FULL')) release_type,
                       --
                       -- percent of projects fully completed
                       --
                       round(
                           100 *
                           decode(nvl(not_completed,0),
                                  0,0,
                                  completed / (nvl(completed,0) + nvl(not_completed,0))
                                  )
                            ) pct_complete,
                       'fa-pie-chart-'||round(.1 * 
                           AVG_PCT_COMPLETE)*10 icon,
                      window,
                      --
                      -- release milestone counts
                      --
                      milestones,
                      completed_milestones
                from (
                --
                -- Inline Query
                --
                select 
                       r.ID,
                       --
                       -- release attributes
                       --
                       r.RELEASE_OPEN_DATE,
                       r.RELEASE_TARGET_DATE,
                       r.UPDATED,
                       r.RELEASE_TARGET_DATE - r.RELEASE_OPEN_DATE duration_in_days,
                       r.RELEASE_TRAIN,
                       r.RELEASE_OWNER_ID,
                       --
                       -- release owner
                       --
                       (select first_Name||' '||last_name from sp_team_members tm where tm.id =  r.RELEASE_OWNER_ID) release_owner,
                       --
                       -- release
                       --
                       r.RELEASE_TRAIN||' '||r.RELEASE RELEASE, 
                       --
                       -- release date timeline (from open to targeted complete) for display in UI
                       --
                       to_char(r.RELEASE_OPEN_DATE,'Day DD-MON-YYYY')||' to '||to_char(r.RELEASE_TARGET_DATE,'Day DD-MON-YYYY') timeline,
                       --
                       -- Days remaining for release
                       --
                       case 
                           when r.release_completed = 'Y'
                           then 'Completed'
                           else trunc(r.RELEASE_TARGET_DATE) - trunc(sysdate) || ' Days Remaining'
                           end as days_remaining,
                       --
                       -- State of release "danger", "warning", or "success"
                       --
                       case 
                           when r.release_completed = 'Y' then 'success'
                           when trunc(r.release_open_date) > trunc(sysdate) then 'success'
                           when trunc(r.RELEASE_TARGET_DATE) > trunc(sysdate) then 'success'
                           when trunc(r.RELEASE_TARGET_DATE) - trunc(sysdate) < 15 then 'warning'  
                           else 'danger'
                        end as badge_state,
                       --
                       -- Count of projects targeted for release
                       --
                       (select count(*) 
                          from sp_projects p 
                         where p.release_id = r.id  
                           and p.ARCHIVED_YN = 'N'
                           and p.duplicate_of_project_id is null) projects,
                       --
                       -- average percent complete of projects for a release
                       --
                       nvl((select round(avg(p.PCT_COMPLETE))
                              from sp_projects p 
                             where p.release_id = r.id
                               and p.ARCHIVED_YN = 'N'
                               and p.duplicate_of_project_id is null), 0) AVG_PCT_COMPLETE,
                       --
                       -- fully completed projects for a given release
                       --
                       (select count(*) 
                          from sp_projects p 
                         where p.release_id = r.id 
                           and p.pct_complete = 100  
                           and p.ARCHIVED_YN = 'N'
                           and p.duplicate_of_project_id is null) completed,
                       --
                       -- Open (not completed) projects for a given release
                       --
                       (select count(*) 
                          from sp_projects p 
                         where p.release_id = r.id 
                           and p.pct_complete != 100  
                           and p.ARCHIVED_YN = 'N'
                           and p.duplicate_of_project_id is null)  not_completed,
                       --
                       -- Count of distinct team members identified as a task owner
                       --
                       (select count(distinct OWNER_ID) 
                          from SP_TASKS c 
                         where c.PROJECT_ID in (select id 
                                                  from sp_projects p
                                                 where p.release_id = r.id
                                                   and p.ARCHIVED_YN = 'N'
                                                   and p.duplicate_of_project_id is null)) contributors,
                       --
                       -- Most recent update to release project or release train
                       --
                       greatest(nvl((select max(updated) 
                                       from sp_projects p 
                                      where p.release_id = r.id
                                        and p.ARCHIVED_YN = 'N'
                                        and p.duplicate_of_project_id is null),r.updated),r.updated) last_updated,
                       case when release_open_completed = 'Y' and nvl(release_completed,'N') = 'N'
                            then 'Open'
                            when nvl(release_open_completed,'N') = 'N'
                            then 'Future'
                            else 'Closed' 
                            end window,
                       --
                       -- milestone counts
                       --
                       (select count(*) from SP_RELEASE_MILESTONES m where m.RELEASE_ID = r.id) milestones,
                       (select count(*) from SP_RELEASE_MILESTONES m where m.RELEASE_ID = r.id and m.MILESTONE_COMPLETED_YN = 'Y') completed_milestones,
                       release_type
                  from SP_RELEASE_TRAINS r
                ) x
                ```
        }
        orderBy {
            type: item
            item: {
                itemName: P8_ORDER_BY
                orderBys: {
                    RELEASE: release
                    RELEASE_OPEN_DATE: release_open_date
                    RELEASE_TARGET_DATE1: release_target_date
                    UPDATED: updated desc
                }
            }
        }
        layout {
            sequence: 50
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            overline: &TIMELINE!HTML.
            title: &RELEASE!HTML. - &RELEASE_TYPE.
            description: &COMPLETED./&PROJECTS. Completed (&AVG_PCT_COMPLETE.% Progress based on status, &PCT_COMPLETE.% Fully Complete)
            miscellaneous:
                ```html
                Updated: &LAST_UPDATED.<br />
                &MILESTONES. Milestones, &COMPLETED_MILESTONES. completed
                ```
            displayAvatar: true
            displayBadge: true
        }
        plugin-avatar {
            icon: &ICON.
            shape: noShape
            size: medium
        }
        plugin-badge {
            label: &NOMENCLATURE_PROJECTS.
            value: DAYS_REMAINING
            state: BADGE_STATE
            columnWidth: large
        }
        pagination {
            entitiesPerPage: 30
        }

        column AVG_PCT_COMPLETE (
            layout {
                sequence: 100
            }
            source {
                databaseColumn: AVG_PCT_COMPLETE
                dataType: number
            }
        )

        column BADGE_STATE (
            layout {
                sequence: 170
            }
            source {
                databaseColumn: BADGE_STATE
                dataType: varchar2
            }
        )

        column COMPLETED (
            layout {
                sequence: 110
            }
            source {
                databaseColumn: COMPLETED
                dataType: number
            }
        )

        column COMPLETED_MILESTONES (
            layout {
                sequence: 250
            }
            source {
                databaseColumn: COMPLETED_MILESTONES
                dataType: number
            }
        )

        column CONTRIBUTORS (
            layout {
                sequence: 130
            }
            source {
                databaseColumn: CONTRIBUTORS
                dataType: number
            }
        )

        column DAYS_REMAINING (
            layout {
                sequence: 160
            }
            source {
                databaseColumn: DAYS_REMAINING
                dataType: varchar2
            }
        )

        column DURATION_IN_DAYS (
            layout {
                sequence: 80
            }
            source {
                databaseColumn: DURATION_IN_DAYS
                dataType: number
            }
        )

        column ICON (
            layout {
                sequence: 180
            }
            source {
                databaseColumn: ICON
                dataType: varchar2
            }
        )

        column ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
        )

