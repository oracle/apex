            }
        )

        column PCT_COMPLETE (
            layout {
                sequence: 190
            }
            source {
                databaseColumn: PCT_COMPLETE
                dataType: number
            }
        )

        column PROJECTS (
            layout {
                sequence: 200
            }
            source {
                databaseColumn: PROJECTS
                dataType: number
            }
        )

        column RELEASE (
            layout {
                sequence: 40
            }
            source {
                databaseColumn: RELEASE
                dataType: varchar2
            }
        )

        column RELEASE_OPEN_DATE (
            layout {
                sequence: 50
            }
            source {
                databaseColumn: RELEASE_OPEN_DATE
                dataType: date
            }
        )

        column RELEASE_OWNER (
            layout {
                sequence: 230
            }
            source {
