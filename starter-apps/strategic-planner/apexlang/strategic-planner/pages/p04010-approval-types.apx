page 4010 (
    name: Approval Types
    alias: APPROVAL-TYPES
    title: Approval Types
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @approvals
    }

    region approval-types (
        name: Approval Types
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       APPROVAL_TYPE,
                       DESCRIPTION,
                       decode(active_yn,'Y','Active','Inactive') status,
                       DISPLAY_SEQ,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY,
                       (select count(*) from sp_initiative_approvals
                         where approval_type_id = t.id) references
                  from SP_APPROVAL_TYPES t
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        link {
            linkColumn: customTarget
            target: {
                page: 4011
                items: {
                    P4011_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 11752922792887426741
        }

        column APPROVAL_TYPE (
            type: plainText
            heading {
                heading: Approval Type
            }
            layout {
                sequence: 2
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: B
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 42
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: C
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 52
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 22
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: G
            }
        )

        column DISPLAY_SEQ (
            type: plainText
            heading {
                heading: Display Seq
                alignment: end
            }
            layout {
                sequence: 82
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: H
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column REFERENCES (
            type: link
            heading {
                heading: References
                alignment: end
            }
            layout {
                sequence: 32
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            link {
                target: {
                    page: 4012
                    items: {
                        IR_APPROVAL_TYPE_ID: #ID#
                    }
                    clearCache: [
                        4012
                        CIR
                        RIR
                    ]
                }
                linkText: #REFERENCES#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: I
            }
        )

        column STATUS (
            type: plainText
            heading {
                heading: Status
            }
            layout {
                sequence: 12
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 62
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 72
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Initiative Approval Types
        }

        savedReport 117529421 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn APPROVAL_TYPE (
                sequence: 1
            )

            displayColumn DESCRIPTION (
                sequence: 3
            )

            displayColumn REFERENCES (
                sequence: 4
            )

            displayColumn STATUS (
                sequence: 2
            )

            displayColumn UPDATED (
                sequence: 5
            )

            sort (
                column: DISPLAY_SEQ
                sort {
                    sequence: 1
                }
            )

            filter ir-condition (
                column: STATUS
                value: Active
            )

        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button create (
        buttonName: CREATE
        label: Add Approval Type
        layout {
            sequence: 10
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconRight
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 4011
                clearCache: 4011
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 30
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @approval-types
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @approval-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction new-entry-dialog-closed (
        name: new entry - Dialog Closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @approval-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

