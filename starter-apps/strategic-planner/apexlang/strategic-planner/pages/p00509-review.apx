page 509 (
    name: Review
    alias: REVIEW
    title: Review
    pageGroup: @projects
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region task (
        name: Task
        type: form
        source {
            location: localDatabase
            tableName: SP_TASKS
        }
        layout {
            sequence: 40
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P509_CREATED (
        type: hidden
        layout {
            sequence: 170
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: CREATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_CREATED_BY (
        type: hidden
        layout {
            sequence: 180
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 100
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
            height: 2
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @task
            column: DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P509_ID (
        type: hidden
        layout {
            sequence: 40
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_IMPACT (
        type: radioGroup
        label {
            label: Impact
            alignment: left
        }
        settings {
            noOfCols: 6
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Low;Low,Medium;Medium,High;High
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 90
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @task
            column: IMPACT
            dataType: varchar2
        }
    )

    pageItem P509_OLD_OWNER_ID (
        type: hidden
        layout {
            sequence: 120
            region: @task
            slot: regionBody
        }
        default {
            type: sqlQuerySingleValue
            sqlQuerySingleValue:
                ```sql
                select owner_id from sp_tasks
                 where id = :P509_ID
                ```
        }
        security {
            sessionStateProtection: restricted
        }
    )

    pageItem P509_OWNER_ID (
        type: selectOne
        label {
            label: Assigned To
            alignment: left
        }
        settings {
            infiniteScroll: false
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select last_name||', '||first_name||' ('||lower(email)||')' d, id r
                  from SP_TEAM_MEMBERS
                 where is_current_yn = 'Y'
                    or id = :P509_OWNER_ID
                 order by 1
                ```
        }
        layout {
            sequence: 110
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @task
            column: OWNER_ID
            dataType: number
        }
    )

    pageItem P509_PROJECT_ID (
        type: displayOnly
        label {
            label: &NOMENCLATURE_PROJECT.
            alignment: left
        }
        settings {
            basedOn: lov
        }
        lov {
            type: sharedComponent
            lov: @sp-projects-project
        }
        layout {
            sequence: 50
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @task
            column: PROJECT_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P509_START_DATE (
        type: datePicker
        label {
            label: Start Date
            alignment: left
        }
        layout {
            sequence: 130
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 30
        }
        source {
            formRegion: @task
            column: START_DATE
            dataType: date
        }
    )

    pageItem P509_STATUS_ID (
        type: selectList
        label {
            label: Status
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select status || case when include_yn = 'N' 
                                      then ' (no longer used)' 
                                      end d, 
                       id r
                  from SP_TASK_STATUSES
                 where (include_yn = 'Y' or :P509_STATUS_ID = id)
                   and task_type_id = :P509_TASK_TYPE_ID
                  order by is_default_yn desc, display_seq
                ```
            displayNullValue: false
        }
        layout {
            sequence: 80
            region: @task
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @task
            column: STATUS_ID
            dataType: number
        }
    )

    pageItem P509_STATUS_LAST_CHANGED_ON (
        type: hidden
        layout {
            sequence: 160
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: STATUS_LAST_CHANGED_ON
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_TAGS (
        type: textField
        label {
            label: Tags
            alignment: left
        }
        layout {
            sequence: 150
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @task
            column: TAGS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P509_TARGET_COMPLETE (
        type: datePicker
        label {
            label: Target Complete
            alignment: left
        }
        settings {
            minDate: item
            minItem: P509_START_DATE
        }
        layout {
            sequence: 140
            region: @task
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            formatMask: DD-MON-YYYY
            width: 30
        }
        source {
            formRegion: @task
            column: TARGET_COMPLETE
            dataType: date
        }
    )

    pageItem P509_TASK_SUB_TYPE_ID (
        type: selectList
        label {
            label: Review Type
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select task_type d, id r
                  from sp_task_types
                 where parent_type_id = :P509_TASK_TYPE_ID
                   and (include_yn = 'Y' or id = :P509_TASK_SUB_TYPE_ID)
                 order by display_seq
                ```
        }
        cascadingLov {
            parentItems: P509_TASK_TYPE_ID
        }
        layout {
            sequence: 70
            region: @task
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @task
            column: TASK_SUB_TYPE_ID
            dataType: number
        }
    )

    pageItem P509_TASK_TYPE_ID (
        type: hidden
        layout {
            sequence: 60
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: TASK_TYPE_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_UPDATED (
        type: hidden
        layout {
            sequence: 190
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: UPDATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P509_UPDATED_BY (
        type: hidden
        layout {
            sequence: 200
            region: @task
            slot: regionBody
        }
        source {
            formRegion: @task
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P509_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P509_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P509_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation when-review-complete-must-provide-date (
        name: when review complete, must provide date
        execution {
            sequence: 10
        }
        validation {
            type: itemIsNotNull
            item: P509_TARGET_COMPLETE
        }
        error {
            errorMessage: When review is completed, must provide date.
            associatedItem: @P509_TARGET_COMPLETE
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from sp_task_statuses
                 where id = :P509_STATUS_ID
                   and static_id = 'COMPLETED'
                ```
        }
    )

    validation when-review-complete-must-provide-owner (
        name: when review complete, must provide owner
        execution {
            sequence: 20
        }
        validation {
            type: itemIsNotNull
            item: P509_OWNER_ID
        }
        error {
            errorMessage: When review is completed, must provide owner.
            associatedItem: @P509_OWNER_ID
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from sp_task_statuses
                 where id = :P509_STATUS_ID
                   and static_id = 'COMPLETED'
                ```
        }
    )

    computation p509-task-type-id (
        itemName: P509_TASK_TYPE_ID
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            sqlQuery:
                ```sql
                select min(id)
                  from sp_task_types
                 where parent_type_id is null
                   and include_yn = 'Y'
                   and static_id = 'REVIEW'
                ```
        }
        serverSideCondition {
            type: itemIsNull
            item: P509_ID
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 40
        }
        advanced {
            executionMappingIdentifier: 1201404127435387753
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process delete-to-avoid-project-history-table-trigger-mutation (
        name: delete (to avoid project_history table trigger mutation)
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select image_ref_id
                      from sp_task_comments
                     where task_id = :P509_ID
                       and image_ref_id is not null
                ) loop
                    delete from sp_comment_images
                     where image_ref_id = c1.image_ref_id;
                end loop;
                
                delete from sp_task_comments
                 where task_id = :P509_ID;
                
                delete from sp_task_documents
                 where task_id = :P509_ID;
                
                delete from sp_task_links
                 where task_id = :P509_ID;
                
                delete from sp_tasks
                 where id = :P509_ID;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Review deleted.
        }
        advanced {
            executionMappingIdentifier: 1201403791098387753
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process initialize-form (
        name: Initialize form
        type: formInitialization
        formRegion: @task
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 1201200009362387748
        }
    )

    process log (
        name: log
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_log.log_interaction(
                    p_project_id => :P509_PROJECT_ID);
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 1352979786055126410
        }
    )

    process process-form (
        name: Process form
        type: formAutoRowProcessing
        formRegion: @task
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Action processed.
        }
        advanced {
            executionMappingIdentifier: 1201400470696387749
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE, SAVE
        }
    )

    process send-notification-if-task-owner-is-not-project-owner-and-user-is-not-task-owner (
        name: send notification (if task owner is not project owner and user is not task owner)
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_task_link   varchar2(4000);
                begin
                
                for c1 in (
                    select apex_escape.html(p.project) project, p.friendly_identifier fi,
                           apex_escape.html(tt.task_type) task_type, t.target_complete, 
                           apex_escape.html(t.impact) impact, 
                           apex_escape.html(t.description) description,
                           lower(substr(tt.task_type,1,1)) first_letter,
                           apex_escape.html((select first_name
                                               from sp_team_members
                                              where id = :P509_OWNER_ID)) first_name
                      from sp_projects p,
                           sp_tasks t,
                           sp_task_types tt
                     where t.id = :P509_ID
                       and t.project_id = p.id
                       and t.task_sub_type_id = tt.id
                ) loop
                    l_task_link := sp_util.get_setting(p_static_id => 'APP_PREFIX_URL')||
                                      apex_page.get_url (
                                          p_application    => :APP_ID,
                                          p_page           => 'task-details',
                                          p_session        => null,
                                          p_items          => 'P502_PREV_PAGE,P502_TASK_ID,P502_PROJECT_ID',
                                          p_values         => '3,'||:P509_ID||','||:P509_PROJECT_ID,
                                          p_plain_url      => TRUE );
                
                    sp_util.assignment_notification (
                        p_team_member_id => :P509_OWNER_ID,
                        p_app_name       => :NOMENCLATURE_STRATEGIC_PLANNER,
                        p_app_id         => :APP_ID,
                        p_title          => 'You have been assigned '||case when c1.first_letter in ('a','o','i')
                                                                            then 'an '
                                                                            else 'a '
                                                                            end ||
                                             c1.task_type||' Review for '||c1.project,
                        p_project_id     => :P509_PROJECT_ID,
                        p_task_id        => :P509_ID,
                        p_link           => l_task_link,
                        p_view_what      => 'Review',
                        p_email_contents => 'Hi '||c1.first_name||'<br/><br/>'||
                                            'You have been assigned a Review for the following '||:NOMENCLATURE_PROJECT||':<br/><br/>'||
                                            :NOMENCLATURE_PROJECT||': <a  style="font-weight:bold" href="'||l_task_link||'">'||c1.project||'</a><br/>'||
                                            case when c1.task_type is not null 
                                                 then 'Review Type: <strong>'||c1.task_type||'</strong><br/>'
                                                 end ||
                                            case when c1.description is not null 
                                                 then 'Description: '||c1.description||'<br/>'
                                                 end ||
                                            case when c1.target_complete is not null 
                                                 then 'Target Complete: '||to_char(c1.target_complete,'DD-MON-YYYY')||'<br/>'
                                                 end ||
                                            case when c1.impact is not null 
                                                 then 'Impact: '||c1.impact||'<br/>'
                                                 end ||
                                            'Assigned by: '||apex_escape.html(lower(:APP_USER))||'<br/>'||
                                            'Assigned on: '||to_char(sysdate,'DD-MON-YYYY'),
                        p_notification_type => 'ASSIGNMENT' );
                end loop;
                
                end;
                ```
        }
        execution {
            sequence: 30
        }
        advanced {
            executionMappingIdentifier: 3394094199013724048
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from dual
                 where (:P509_ID is null and :P509_OWNER_ID is not null and :P509_OWNER_ID != :APP_USER_ID) 
                    or (:P509_OWNER_ID is not null and :P509_OWNER_ID != :APP_USER_ID and :P509_OWNER_ID != nvl(:P509_OLD_OWNER_ID,'1') )
                ```
        }
    )

)

