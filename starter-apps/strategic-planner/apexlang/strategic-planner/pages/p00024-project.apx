    computation p24-size-help-text (
        itemName: P24_SIZE_HELP_TEXT
        execution {
            sequence: 10
        }
        computation {
            type: functionBody
            plsqlFunctionBody:
                ```plsql
                declare 
                  x varchar2(500) := null;
                begin
                  for c1 in (
                     select PROJECT_SIZE, SIZE_DESCRIPTION, EFFORT_DAYS
                     from   SP_PROJECT_SIZES ps
                     where  include_yn = 'Y'
                     order by 3) loop
                     x := x||apex_escape.html(c1.project_size||': '||c1.SIZE_DESCRIPTION||' ( '||to_char(c1.EFFORT_DAYS,'FM999G999G990')||' days )')||'<br>';
                  end loop;
                  return x;
                end;
                ```
        }
    )

