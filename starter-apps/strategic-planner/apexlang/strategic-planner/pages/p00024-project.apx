    process default-scale-letter-and-min-pc-for-status (
        name: default scale_letter and min_pc_for_status
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select status_scale
                      from sp_initiatives
                     where id = :P24_INITIATIVE_ID
                ) loop
                    :P24_STATUS_SCALE := c1.status_scale;
                end loop;
                
                for c1 in (
                    select min_pc_for_status
                      from sp_project_scales
                     where scale_letter = :P24_STATUS_SCALE
                ) loop
                    :P24_MIN_PC_FOR_STATUS := c1.min_pc_for_status;
                end loop;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 5476375039551247612
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P24_INITIATIVE_ID
        }
    )

