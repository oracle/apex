page 10150 (
    name: Initiative Focus Areas
    alias: INITIATIVE-FOCUS-AREAS
    title: Initiative Focus Areas
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region initiative-focus-areas (
        name: Initiative Focus Areas
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select f.ID,
                       a.area,
                       i.initiative,
                       f.focus_area,
                       f.CREATED,
                       f.CREATED_BY,
                       f.UPDATED,
                       f.UPDATED_BY,
                       f.description,
                       nvl(f.display_sequence,10) display_sequence,
                       decode(f.active_yn,'Y','Yes','N','No',f.active_yn) active,
                       --
                       -- usage
                       --
                       (select count(*) from sp_projects p where p.focus_area_id = f.id and  p.archived_yn = 'N' and p.DUPLICATE_OF_PROJECT_ID is null) usage_count,
                       --
                       -- owners
                       --
                       (select first_name||' '||last_name from SP_TEAM_MEMBERS tm where tm.id = f.development_owner_id) dev_focus_area_lead
                  from SP_INITIATIVE_FOCUS_AREAS f,
                       SP_INITIATIVES i,
                       sp_areas a
                 where f.initiative_id = i.id
                   and i.area_id = a.id
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10151
                items: {
                    P10151_ID: \#ID#\
                }
                clearCache: 10151
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 9057840133157655879
        }

        column ACTIVE (
            type: plainText
            heading {
                heading: Active
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column AREA (
            type: plainText
            heading {
                heading: &NOMENCLATURE_AREA.
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 60
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 70
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 100
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column DEV_FOCUS_AREA_LEAD (
            type: plainText
            heading {
                heading: Lead
            }
            layout {
                sequence: 110
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
        )

        column DISPLAY_SEQUENCE (
            type: plainText
            heading {
                heading: Display Sequence
                alignment: end
            }
            layout {
                sequence: 120
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: Q
            }
        )

        column FOCUS_AREA (
            type: plainText
            heading {
                heading: Focus Area
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column INITIATIVE (
            type: plainText
            heading {
                heading: &NOMENCLATURE_INITIATIVE.
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 80
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 90
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column USAGE_COUNT (
            type: link
            heading {
                heading: Usage
                alignment: end
            }
            layout {
                sequence: 50
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            link {
                target: {
                    page: 23
                    items: {
                        P23_FOCUS_AREA: #AREA#
                        P23_INITIATIVE: #INITIATIVE#
                        P23_INIT_FOCUS_AREA: #FOCUS_AREA#
                    }
                    clearCache: 23
                    action: resetPagination
                }
                linkText: #USAGE_COUNT#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Project Size
        }

        savedReport 56651268 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn AREA (
                sequence: 1
            )

            displayColumn DESCRIPTION (
                sequence: 6
            )

            displayColumn DEV_FOCUS_AREA_LEAD (
                sequence: 4
            )

            displayColumn DISPLAY_SEQUENCE (
                sequence: 5
            )

            displayColumn FOCUS_AREA (
                sequence: 3
            )

            displayColumn INITIATIVE (
                sequence: 2
            )

            displayColumn UPDATED (
                sequence: 8
            )

            displayColumn USAGE_COUNT (
                sequence: 7
            )

            sort (
                column: AREA
                sort {
                    sequence: 1
                }
            )

            sort (
                column: INITIATIVE
                sort {
                    sequence: 2
                }
            )

            sort (
                column: DISPLAY_SEQUENCE
                sort {
                    sequence: 3
                }
            )

            sort (
                column: FOCUS_AREA
                sort {
                    sequence: 4
                }
            )

            filter ir-condition (
                column: ACTIVE
                value: Yes
            )

        )

    )

    region sql (
        name: SQL
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'insert into sp_initiatvie_focus_areas (ID, INITIATIVE_ID, FOCUS_AREA, description, ACTIVE_YN) values ('||
                       id||', '||
                       INITIATIVE_ID||', '''||
                       FOCUS_AREA||''', '''||
                       description||''', '''||
                       ACTIVE_YN||''');' SQL
                  from sp_initiative_focus_areas 
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: SQL
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column SQL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: SQL
            }
            layout {
                sequence: 10
            }
        )

    )

    button add-focus-area (
        buttonName: add_focus_area
        label: Add Focus Area
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconRight
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10151
                clearCache: 10151
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: Up
        label: Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @initiative-focus-areas
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @initiative-focus-areas
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-dialog-close (
        name: refresh on dialog close
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @initiative-focus-areas
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @sql
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

