page 165 (
    name: AI Release Summaries
    alias: AI-RELEASE-SUMMARIES
    title: AI Release Summaries
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @ai-release-summaries
    }

    region ai-summaries (
        name: AI Summaries
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select null user_name,
                       apex_escape.html(SUMMARY) comment_text,
                       '<br/>'||HIGHLIGHTS attribute_1,
                       null attribute_2,
                       null attribute_3,
                       null attribute_4,
                       CREATED comment_date,
                       '*' user_icon,
                       id ai_summary_id,
                       'Details' actions
                  from SP_RELEASE_AI_SUMMARIES
                 where RELEASE_ID = :P165_RELEASE_ID
                   and summary is not null  -- excludes those ending in error
                 order by created desc
                ```
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: No Summaries found
        }

        column ACTIONS (
            reportColumnQueryId: 10
            derivedColumn: N
            type: link
            heading {
                heading: Actions
            }
            layout {
                sequence: 120
            }
            link {
                target: {
                    page: 166
                    items: {
                        P166_ID: #AI_SUMMARY_ID#
                    }
                    clearCache: 166
                }
                linkText: #ACTIONS#
                linkAttributes: title="View Details Sent"
            }
            sorting {
                sortable: false
            }
        )

        column AI_SUMMARY_ID (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Ai Summary Id
                alignment: end
            }
            layout {
                sequence: 180
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_1 (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Attribute 1
            }
            layout {
                sequence: 90
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column ATTRIBUTE_2 (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Attribute 2
            }
            layout {
                sequence: 140
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_3 (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Attribute 3
            }
            layout {
                sequence: 150
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_4 (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Attribute 4
            }
            layout {
                sequence: 160
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_DATE (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Comment Date
            }
            layout {
                sequence: 100
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_TEXT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Comment Text
            }
            layout {
                sequence: 80
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column USER_ICON (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: User Icon
            }
            layout {
                sequence: 130
            }
            sorting {
                sortable: false
            }
        )

        column USER_NAME (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: User Name
            }
            layout {
                sequence: 110
            }
            sorting {
                sortable: false
            }
        )

    )

    region buttons (
        name: buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    pageItem P165_RELEASE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @ai-summaries
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button generate (
        buttonName: GENERATE
        label: Generate Summary
        layout {
            sequence: 20
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button information (
        buttonName: Information
        label: Info
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-info-circle-o
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 78
                items: {
                    P78_TYPE: RELEASE
                }
                clearCache: 78
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process summary (
        name: summary
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_error_yn  varchar2(1);
                begin
                
                sp_summary_util.generate_release_summary (
                    p_release_id => :P165_RELEASE_ID,
                    p_error_yn   => l_error_yn );
                
                end;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 30623618390657697125
        }
        serverSideCondition {
            whenButtonPressed: @generate
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

)

