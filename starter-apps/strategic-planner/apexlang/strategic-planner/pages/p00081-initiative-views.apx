page 81 (
    name: Initiative Views
    alias: INITIATIVE-VIEWS
    title: &NOMENCLATURE_INITIATIVE. Views
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region items (
        name: Items
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 3
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
                margin-bottom-none
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 10
            slot: leftColumn
            columnSpan: 4
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Filters
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P81_APP_USER (
            type: checkboxGroup
            label {
                label: App User
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: APP_USER
            }
        )

        facet P81_AREA (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: AREA
            }
        )

        facet P81_INITIATIVE (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_INITIATIVE.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P81_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: PROJECT_ID,APP_USER,ACTION
            }
        )

    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                       l.APP_USER,
                       max(l.PAGE_RENDERED) most_recent,
                       count(*) view_count,
                       i.initiative,
                       a.area
                  from SP_PROJ_INTERACTIONS_LOG l,
                       sp_projects p,
                       sp_initiatives i,
                       sp_areas a
                where l.project_id = p.id and
                      p.initiative_id = i.id and
                      p.DUPLICATE_OF_PROJECT_ID is null and
                      p.archived_yn = 'N' and
                      i.area_id = a.id and
                      l.page_rendered >= sysdate -90
                group by 
                       l.APP_USER,
                       i.initiative,
                       a.area
                ```
        }
        orderBy {
            type: item
            item: {
                itemName: P81_ORDER_BY
                orderBys: {
                    VIEW_COUNT: view_count desc
                    APP_USER: app_user
                    MOST_RECENT: most_recent desc
                }
            }
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: no data found
        }

        column APP_USER (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: App User
            }
            layout {
                sequence: 4
            }
            sorting {
                sortable: false
            }
        )

        column AREA (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Area
            }
            layout {
                sequence: 14
            }
            sorting {
                sortable: false
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Initiative
            }
            layout {
                sequence: 24
            }
            sorting {
                sortable: false
            }
        )

        column MOST_RECENT (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Last View
            }
            layout {
                sequence: 34
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column VIEW_COUNT (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: View Count
                alignment: end
            }
            layout {
                sequence: 44
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            sorting {
                sortable: false
            }
        )

    )

    pageItem P81_ORDER_BY (
        type: selectList
        label {
            label: Order By
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:View Count;VIEW_COUNT,User;APP_USER,Most Recent;MOST_RECENT
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @items
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-sort-amount-desc
            height: 1
        }
        validation {
            valueRequired: true
        }
        advanced {
            cssClasses: [
                w200
                no-item-ui
            ]
            warnOnUnsavedChanges: ignore
        }
        default {
            type: static
            staticValue: VIEW_COUNT
        }
    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @items
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 81
                clearCache: 81
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

