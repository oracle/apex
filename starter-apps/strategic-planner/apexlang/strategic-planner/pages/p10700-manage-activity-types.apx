page 10700 (
    name: Activity Types
    alias: MANAGE-ACTIVITY-TYPES
    title: Activity Types
    pageGroup: @activities
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region activity-types (
        name: Activity Types
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       DISPLAY_SEQUENCE,
                       ACTIVITY_TYPE,
                       ACTIVITY_TYPE_DESCRIPTION,
                       decode(is_project_yn,'Y','Yes','N','No','Unknown') is_project_related,
                       static_id,
                       decode(is_default_yn,'Y','Yes','N','No','Unknown') is_default,
                       decode(is_active_yn,'Y','Yes','N','No','Unknown') is_active,
                       CREATED,
                       CREATED_BY,
                       UPDATED,
                       UPDATED_BY,
                       (select count(*) from sp_activities a where a.activity_type_id = at.id ) activities
                  from SP_ACTIVITY_TYPES at
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10710
                items: {
                    P10710_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 14200661753129441090
        }

        column ACTIVITIES (
            type: plainText
            heading {
                heading: Activities
                alignment: end
            }
            layout {
                sequence: 48
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: L
            }
        )

        column ACTIVITY_TYPE (
            type: plainText
            heading {
                heading: Activity Type
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column ACTIVITY_TYPE_DESCRIPTION (
            type: plainText
            heading {
                heading: Activity Type Description
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 5
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column DISPLAY_SEQUENCE (
            type: plainText
            heading {
                heading: Display Sequence
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column IS_ACTIVE (
            type: plainText
            heading {
                heading: Is Active
            }
            layout {
                sequence: 68
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column IS_DEFAULT (
            type: plainText
            heading {
                heading: Is Default
            }
            layout {
                sequence: 38
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: K
            }
        )

        column IS_PROJECT_RELATED (
            type: plainText
            heading {
                heading: Is Project Related
            }
            layout {
                sequence: 58
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: M
            }
        )

        column STATIC_ID (
            type: plainText
            heading {
                heading: Static ID
            }
            layout {
                sequence: 28
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Activity Types
        }

        savedReport 142010970 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACTIVITIES (
                sequence: 7
            )

            displayColumn ACTIVITY_TYPE (
                sequence: 2
            )

            displayColumn DISPLAY_SEQUENCE (
                sequence: 1
            )

            displayColumn IS_ACTIVE (
                sequence: 4
            )

            displayColumn IS_DEFAULT (
                sequence: 5
            )

            displayColumn IS_PROJECT_RELATED (
                sequence: 6
            )

            displayColumn STATIC_ID (
                sequence: 3
            )

            displayColumn UPDATED (
                sequence: 8
            )

            sort (
                column: DISPLAY_SEQUENCE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: ACTIVITIES
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 20
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region sql (
        name: SQL
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'insert into SP_ACTIVITY_TYPES '||chr(10)||
                 '    (ID, DISPLAY_SEQUENCE, ACTIVITY_TYPE, ACTIVITY_TYPE_DESCRIPTION, is_default_yn, is_active_yn, static_id ) values ('||chr(10)||
                       id||', '||
                       DISPLAY_SEQUENCE||', '||
                       ''''||ACTIVITY_TYPE||''', '||
                       ''''||replace(ACTIVITY_TYPE_DESCRIPTION,'''','''''')||''', '||
                       ''''||IS_DEFAULT_YN||''', '||
                       ''''||nvl(IS_ACTIVE_YN,'Y')||''', '||
                       ''''||STATIC_ID||''');' sql
                
                  from SP_ACTIVITY_TYPES 
                  order by display_sequence
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column SQL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: SQL
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

    )

    button create (
        buttonName: CREATE
        label: Add Activity Type
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconRight
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10710
                clearCache: 10710
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @activity-types
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @activity-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-dialog-closed (
        name: refresh on dialog closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @activity-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

