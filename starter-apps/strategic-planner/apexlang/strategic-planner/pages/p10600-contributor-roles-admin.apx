page 10600 (
    name: Contributor Roles
    alias: CONTRIBUTOR-ROLES-ADMIN
    title: Contributor Roles
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region resource-types (
        name: Resource Types
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ID,
                       RESOURCE_TYPE,
                       RESOURCE_DESCRIPTION,
                       CREATED,
                       lower(created_by) CREATED_BY,
                       UPDATED,
                       lower(updated_by) UPDATED_BY,
                       decode(IS_DEFAULT_YN,'Y','Yes','No') IS_DEFAULT_YN,
                       (select count(*) 
                        from SP_PROJECT_CONTRIBUTORS pc, 
                             sp_projects p 
                        where pc.RESPONSIBILITY_ID = rt.id and
                              pc.project_id = p.id and
                              p.ARCHIVED_YN = 'N' and
                              p.DUPLICATE_OF_PROJECT_ID is null
                        ) project_contributions,
                        (select count(*) 
                        from SP_PROJECT_CONTRIBUTORS pc, 
                             sp_projects p 
                        where pc.RESPONSIBILITY_ID = rt.id and
                              pc.project_id = p.id and
                              p.ARCHIVED_YN = 'N' and
                              p.DUPLICATE_OF_PROJECT_ID is null and
                              p.pct_complete = 100
                        ) completed_projects
                  from SP_RESOURCE_TYPES rt
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        link {
            linkColumn: customTarget
            target: {
                page: 10610
                items: {
                    P10610_ID: \#ID#\
                }
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 27446493998897261436
        }

        column COMPLETED_PROJECTS (
            type: plainText
            heading {
                heading: Completed &NOMENCLATURE_PROJECTS.
                alignment: end
            }
            layout {
                sequence: 38
                columnAlignment: end
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: K
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
                alignment: center
            }
            layout {
                sequence: 5
                columnAlignment: center
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: E
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 6
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: F
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: B
            }
        )

        column IS_DEFAULT_YN (
            type: plainText
            heading {
                heading: Is Default
                alignment: center
            }
            layout {
                sequence: 18
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: I
            }
        )

        column PROJECT_CONTRIBUTIONS (
            type: link
            heading {
                heading: &NOMENCLATURE_PROJECTS.
                alignment: end
            }
            layout {
                sequence: 28
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            link {
                target: {
                    page: 10601
                    items: {
                        P10601_ID: #ID#
                    }
                    clearCache: 10601
                    action: resetPagination
                }
                linkText: #PROJECT_CONTRIBUTIONS#
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: J
            }
        )

        column RESOURCE_DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 4
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: D
            }
        )

        column RESOURCE_TYPE (
            type: plainText
            heading {
                heading: Role
            }
            layout {
                sequence: 3
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: C
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 7
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 8
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Resource Types
        }

        savedReport 274465218 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn COMPLETED_PROJECTS (
                sequence: 5
            )

            displayColumn IS_DEFAULT_YN (
                sequence: 2
            )

            displayColumn PROJECT_CONTRIBUTIONS (
                sequence: 4
            )

            displayColumn RESOURCE_DESCRIPTION (
                sequence: 3
            )

            displayColumn RESOURCE_TYPE (
                sequence: 1
            )

            displayColumn UPDATED (
                sequence: 6
            )

            sort (
                column: RESOURCE_TYPE
                sort {
                    sequence: 1
                }
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 2
                }
            )

        )

    )

    region sql (
        name: SQL
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'insert into SP_RESOURCE_TYPES (ID, RESOURCE_TYPE, RESOURCE_DESCRIPTION, IS_DEFAULT_YN) values ('||
                        id||', '''||
                        RESOURCE_TYPE||''', '''||
                        replace(RESOURCE_DESCRIPTION,'''','''''')||''', '''||
                        IS_DEFAULT_YN||''');' SQL
                from SP_RESOURCE_TYPES rt
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/collapsible
            templateOptions: [
                #DEFAULT#
                is-collapsed
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--altRowsDefault
                t-Report--rowHighlight
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }

        column SQL (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: SQL
            }
            layout {
                sequence: 10
            }
        )

    )

    button create (
        buttonName: CREATE
        label: Add Role
        layout {
            sequence: 10
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconRight
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10610
                clearCache: 10610
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction dc (
        name: DC
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @resource-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @resource-types
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @resource-types
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

