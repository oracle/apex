page 120 (
    name: Release Document
    alias: RELEASE-DOCUMENT
    title: Release Document
    pageGroup: @projects
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region document (
        name: Document
        type: form
        source {
            location: localDatabase
            tableName: SP_RELEASE_DOCUMENTS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P120_CREATED (
        type: hidden
        layout {
            sequence: 170
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: CREATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P120_CREATED_BY (
        type: hidden
        layout {
            sequence: 180
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P120_DOCUMENT_BLOB (
        type: fileUpload
        label {
            label: Document
            alignment: left
        }
        display {
            displayAs: inlineDropzone
        }
        storage {
            mimeTypeColumn: DOCUMENT_MIMETYPE
            filenameColumn: DOCUMENT_FILENAME
            charSetColumn: DOCUMENT_CHARSET
            bobLastUpdatedColumn: DOCUMENT_LASTUPD
        }
        layout {
            sequence: 50
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
        }
        validation {
            maxLength: 255
        }
        source {
            formRegion: @document
            column: DOCUMENT_BLOB
            dataType: blob
        }
    )

    pageItem P120_DOCUMENT_CHARSET (
        type: hidden
        layout {
            sequence: 120
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_CHARSET
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P120_DOCUMENT_FILENAME (
        type: hidden
        layout {
            sequence: 100
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_FILENAME
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P120_DOCUMENT_LASTUPD (
        type: hidden
        layout {
            sequence: 130
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_LASTUPD
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P120_DOCUMENT_MIMETYPE (
        type: hidden
        layout {
            sequence: 110
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: DOCUMENT_MIMETYPE
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P120_DOC_DESCRIPTION (
        type: richTextEditor
        label {
            label: Description
            alignment: left
        }
        settings {
            minHeight: 180
            allowCustomHtml: true
        }
        layout {
            sequence: 70
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @document
            column: DOC_DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P120_ID (
        type: hidden
        layout {
            sequence: 10
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P120_IMPORTANT_YN (
        type: switch
        label {
            label: Important
            alignment: left
        }
        layout {
            sequence: 90
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @document
            column: IMPORTANT_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: N
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P120_RELEASE_ID (
        type: hidden
        layout {
            sequence: 150
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: RELEASE_ID
            dataType: number
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P120_TAGS (
        type: textField
        label {
            label: Tags
            alignment: left
        }
        layout {
            sequence: 80
            region: @document
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @document
            column: TAGS
            dataType: varchar2
        }
        security {
            restrictedChars: webSafe
        }
    )

    pageItem P120_UPDATED (
        type: hidden
        layout {
            sequence: 190
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: UPDATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P120_UPDATED_BY (
        type: hidden
        layout {
            sequence: 200
            region: @document
            slot: regionBody
        }
        source {
            formRegion: @document
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add Document
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P120_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P120_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P120_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        settings {
            showSuccessMessages: false
        }
        execution {
            sequence: 90
        }
        advanced {
            executionMappingIdentifier: 16035719450946577500
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-document (
        name: Initialize form Document
        type: formInitialization
        formRegion: @document
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 16035716151025577497
        }
    )

    process process-form-document (
        name: Process form Document
        type: formAutoRowProcessing
        formRegion: @document
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 16035716510100577497
        }
    )

)

