        action edit (
            position: primaryActions
            template: button
            label: Edit
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 501
                    items: {
                        P501_ID: &P502_TASK_ID.
                    }
                    clearCache: 501
                    action: resetPagination
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-edit
                hot: true
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery:
                    ```sql
                    select 1
                      from sp_tasks t, sp_task_types tt
                     where t.id = :P502_TASK_ID
                       and t.task_type_id = tt.id
                       and tt.STATIC_ID not in ('MILESTONE','REVIEW')
                    ```
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

        action edit-2 (
            position: primaryActions
            template: button
            label: Edit
            layout {
                sequence: 30
            }
            behavior {
                target: {
