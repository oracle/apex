    region task (
        name: Task
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                with today as (select trunc(sysdate) day from dual)
                select r.ID,
                       p.INITIATIVE_ID,
                       i.initiative,
                       f.area focus_area,
                       f.id focus_area_id,
                       (select project from sp_projects where id = r.project_id) project,
                       r.project_id,
                       (select case when first_name is not null or last_name is not null
                                    then first_name||' '||last_name
                                    else email
                                    end
                               from sp_team_members t where t.id = r.owner_id) the_owner,
                       r.owner_id,
                       s.status,
                       r.start_date,
                       r.target_complete,
                       case when s.indicates_complete_yn = 'N' and
                                 r.target_complete is not null
                            then least(5, trunc(r.target_complete) - trunc(r.target_complete, 'iw') + 1)
                                 - least(5, today.day - trunc(today.day, 'iw') + 1)
                                 + (trunc(r.target_complete, 'iw') - trunc(today.day, 'iw')) * 5 / 7
                       end weekdays_left,
                       r.updated
                  from sp_tasks r,
                       sp_task_statuses s,
                       today,
                       SP_PROJECTS p, 
                       SP_INITIATIVES i,
                       SP_AREAS f
                 where r.id = :P502_TASK_ID
                   and r.status_id = s.id
                   and r.project_id = p.id
                   and p.initiative_id = i.id
                   and i.area_id = f.id
                ```
            pageItemsToSubmit: P502_TASK_ID
        }
        layout {
            sequence: 20
            parentRegion: @details
            slot: regionBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
                t-Report--hideNoPagination
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

