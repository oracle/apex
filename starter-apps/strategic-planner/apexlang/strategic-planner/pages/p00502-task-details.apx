    dynamicAction post-comment-and-do-alerts (
        name: post comment and do alerts
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @post-comment
        }

        action add-comment-and-send-alerts (
            name: Add Comment and send alerts
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_comment_util.add_task_comment (
                        p_app_user_id  => :APP_USER_ID, 
                        p_app_user     => :APP_USER,
                        p_comment      => :P502_COMMENT,
                        p_private_yn   => nvl(:P502_PRIVATE_YN,'N'),
                        p_project_id   => :P502_PROJECT_ID,
                        p_task_id      => :P502_TASK_ID,
                        p_app_id       => :APP_ID,
                        p_link         => :P502_TASK_LINK,
                        p_nomen_sp     => :NOMENCLATURE_STRATEGIC_PLANNER,
                        p_image_ref_id => :P502_IMAGE_REF_ID );
                    
                    :P502_COMMENT      := null;
                    :P502_IMAGE_REF_ID := to_number(sys_guid(), 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX');
                    ```
                itemsToSubmit: [
                    P502_TASK_ID
                    P502_COMMENT
                    P502_PRIVATE_YN
                    P502_PROJECT_ID
                    P502_TASK_LINK
                    P502_IMAGE_REF_ID
                ]
                itemsToReturn: [
                    P502_COMMENT
                    P502_IMAGE_REF_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 10
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 70
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Comment Added Successfully");
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

