    dynamicAction add-link (
        name: add link
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @add-link
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Link Details
                message: Please supply a Link URL and a Link Name.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P502_LINK') === '' || $v('P502_LINK_NAME') === ''
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P502_LINK_NAME is not null and :P502_LINK is not null then
                    insert into SP_TASK_LINKS (
                        task_id, link_name, link_url)
                    values (
                        :P502_TASK_ID, :P502_LINK_NAME, :P502_LINK);
                    :P502_LINK_NAME := null;
                    :P502_LINK := null;
                    end if;
                    ```
                itemsToSubmit: [
                    P502_LINK_NAME
                    P502_LINK
                    P502_TASK_ID
                ]
                itemsToReturn: [
                    P502_LINK_NAME
                    P502_LINK
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @links
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @task
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

