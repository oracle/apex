page 10710 (
    name: Activity Type
    alias: MANAGE-ACTIVITY-TYPE
    title: Activity Type
    pageGroup: @activities
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region activity-type (
        name: Activity Type
        type: form
        source {
            location: localDatabase
            tableName: SP_ACTIVITY_TYPES
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    pageItem P10710_ACTIVITY_TYPE (
        type: textField
        label {
            label: Activity Type
            alignment: left
        }
        settings {
            trimSpaces: none
        }
        layout {
            sequence: 50
            region: @activity-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 50
        }
        source {
            formRegion: @activity-type
            column: ACTIVITY_TYPE
            dataType: varchar2
        }
    )

    pageItem P10710_ACTIVITY_TYPE_DESC (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 60
            region: @activity-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 60
            height: 4
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @activity-type
            column: ACTIVITY_TYPE_DESCRIPTION
            dataType: varchar2
        }
    )

    pageItem P10710_CREATED (
        type: hidden
        layout {
            sequence: 90
            region: @activity-type
            slot: regionBody
        }
        source {
            formRegion: @activity-type
            column: CREATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10710_CREATED_BY (
        type: hidden
        layout {
            sequence: 100
            region: @activity-type
            slot: regionBody
        }
        source {
            formRegion: @activity-type
            column: CREATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10710_DISPLAY_SEQUENCE (
        type: numberField
        label {
            label: Display Sequence
            alignment: left
        }
        layout {
            sequence: 20
            region: @activity-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 32
        }
        validation {
            valueRequired: true
            maxLength: 255
        }
        source {
            formRegion: @activity-type
            column: DISPLAY_SEQUENCE
            dataType: number
        }
    )

    pageItem P10710_ID (
        type: hidden
        layout {
            sequence: 10
            region: @activity-type
            slot: regionBody
        }
        source {
            formRegion: @activity-type
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10710_IS_ACTIVE_YN (
        type: switch
        label {
            label: Is Active
            alignment: left
        }
        layout {
            sequence: 70
            region: @activity-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @activity-type
            column: IS_ACTIVE_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Y
        }
    )

    pageItem P10710_IS_DEFAULT_YN (
        type: switch
        label {
            label: Is Default
            alignment: left
        }
        layout {
            sequence: 40
            region: @activity-type
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @activity-type
            column: IS_DEFAULT_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: N
        }
    )

    pageItem P10710_IS_PROJECT_YN (
        type: switch
        label {
            label: Is Project Related
            alignment: left
        }
        layout {
            sequence: 80
            region: @activity-type
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @activity-type
            column: IS_PROJECT_YN
            dataType: varchar2
        }
    )

    pageItem P10710_STATIC_ID (
        type: textField
        label {
            label: Static ID
            alignment: left
        }
        layout {
            sequence: 30
            region: @activity-type
            slot: regionBody
            alignment: left
            startNewRow: false
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
            maxLength: 30
        }
        source {
            formRegion: @activity-type
            column: STATIC_ID
            dataType: varchar2
        }
    )

    pageItem P10710_UPDATED (
        type: hidden
        layout {
            sequence: 110
            region: @activity-type
            slot: regionBody
        }
        source {
            formRegion: @activity-type
            column: UPDATED
            dataType: date
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P10710_UPDATED_BY (
        type: hidden
        layout {
            sequence: 120
            region: @activity-type
            slot: regionBody
        }
        source {
            formRegion: @activity-type
            column: UPDATED_BY
            dataType: varchar2
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P10710_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10710_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P10710_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 14200661077201441088
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-manage-activity-type (
        name: Initialize form Manage Activity Type
        type: formInitialization
        formRegion: @activity-type
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 14200660218076441087
        }
    )

    process process-form-manage-activity-type (
        name: Process form Manage Activity Type
        type: formAutoRowProcessing
        formRegion: @activity-type
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Action Processed
        }
        advanced {
            executionMappingIdentifier: 14200660665342441088
        }
    )

)

