                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 3
                        items: {
                            FI: &FRIENDLY_IDENTIFIER.
                            PN: &PROJECT_URL_NAME.
                        }
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-glasses
                }
                serverSideCondition {
                    type: itemIsNotNull
                    item: PROJECT_ID
                }
                security {
                    authorizationScheme: @contribution-rights
