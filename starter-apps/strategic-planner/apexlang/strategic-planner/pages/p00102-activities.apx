    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu about-activity (
                label: About Activity
                layout {
                    sequence: 110
                }
                behavior {
                    target: {
                        page: 110
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-info
                }
            )

            menu all-nomenclature-projects (
                label: All &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 23
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 120
                }
            )

            menu comp_menu_entry-2 (
                type: separator
                layout {
                    sequence: 100
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 130
                }
                behavior {
                    target: {
                        page: 102
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu releases (
                label: Releases
                layout {
                    sequence: 80
                }
                behavior {
                    target: {
                        page: 8
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-ship
                }
                config {
                    buildOption: @releases
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 140
                }
                behavior {
                    target: {
                        page: 102
                        clearCache: 102
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

        action add-activity (
            position: primaryActions
            template: button
            label: Add Activity
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 101
                    items: {
                        P101_TEAM_MEMBER_ID: &APP_USER_ID.
                    }
                    clearCache: 101
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-plus
                hot: true
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

    )

    pageItem P102_ORDER_BY (
        type: selectList
        label {
            label: Order By
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Last Updated;LASTUPD,Created;CREATED,Person;PERSON,Project;PROJECT,Start Date;START_DATE,End Date;END_DATE
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @buttons-container
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-sort-amount-asc
            height: 1
        }
        validation {
            valueRequired: true
        }
        advanced {
            cssClasses: [
                w200
                no-item-ui
            ]
            warnOnUnsavedChanges: ignore
        }
        default {
            type: static
            staticValue: LASTUPD
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction on-dc (
        name: on dc
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @activities
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @faceted-search
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-ar-on-dialog-close (
        name: refresh ar on dialog close
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @activities
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @activities
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation last-project-view (
        itemName: LAST_PROJECT_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 102
        }
    )

    computation p102-order-by (
        itemName: P102_ORDER_BY
        execution {
            sequence: 40
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: CREATED
        }
        serverSideCondition {
            type: itemIsNull
            item: P102_ORDER_BY
        }
    )

)

