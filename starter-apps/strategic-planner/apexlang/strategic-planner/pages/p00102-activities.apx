        action action (
            position: titleLink
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 140
                    items: {
                        P140_ID: &ID.
                    }
                    clearCache: 140
                    action: resetPagination
                }
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
                cssClasses: t-Button--noUI
            }

            menu activity-quick-look (
                label: Activity Quick Look
                layout {
                    sequence: 20
                }
                behavior {
                    target: {
                        page: 140
                        items: {
                            P140_ID: &ID.
                        }
                        clearCache: 140
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-badge-check
                }
            )

