page 12135 (
    name: AI Prompts
    alias: AI-PROMPTS
    title: AI Prompts
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @ai-project-summaries
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region prompts (
        name: Prompts
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       static_id,
                       description,
                       dbms_lob.substr(prompt,255,1)||'...' prompt,
                       created,
                       lower(created_by) created_by,
                       updated,
                       lower(updated_by) updated_by
                  from SP_AI_PROMPTS
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            controlBreak: false
            compute: false
            aggregate: false
            chart: false
            groupBy: false
            pivot: false
            flashback: false
            saveReport: false
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 75599737263948314940
        }

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 30
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: G
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column PROMPT (
            type: plainText
            heading {
                heading: Prompt
            }
            layout {
                sequence: 70
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
        )

        column STATIC_ID (
            type: link
            heading {
                heading: Static ID
            }
            layout {
                sequence: 10
            }
            link {
                target: {
                    page: 12136
                    items: {
                        P12136_ID: #ID#
                    }
                    clearCache: 12136
                }
                linkText: #STATIC_ID#
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column UPDATED (
            type: plainText
            heading {
                heading: Updated
            }
            layout {
                sequence: 50
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: I
            }
        )

        column UPDATED_BY (
            type: plainText
            heading {
                heading: Updated By
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Countries
        }

        savedReport 108310478 (
            visibility: primaryDefault
            view {
                rowsPerPage: 1000
            }

            displayColumn DESCRIPTION (
                sequence: 2
            )

            displayColumn PROMPT (
                sequence: 3
            )

            displayColumn STATIC_ID (
                sequence: 1
            )

            displayColumn UPDATED (
                sequence: 4
            )

            sort (
                column: STATIC_ID
                sort {
                    sequence: 1
                }
            )

            sort (
                column: COUNTRY_NAME
                sort {
                    sequence: 2
                }
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 3
                }
            )

        )

    )

    button reset (
        buttonName: reset
        label: Reset
        layout {
            sequence: 10
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 12135
                clearCache: [
                    12135
                    CIR
                    RIR
                ]
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @prompts
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @prompts
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

