page 7 (
    name: Comments Filter Report
    alias: COMMENTS-FILTER-REPORT
    title: Comments Filter Report
    pageGroup: @users
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .no-item-ui {
              --a-field-input-border-width: 0px;
              --a-field-input-background-color: transparent;
            }
            
            .overline {
              color: var(--ut-region-text-color, var(--ut-component-text-default-color));
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region facets (
        name: Facets
        type: facetedSearch
        source {
            filteredRegion: @nomenclature-project-comments
        }
        layout {
            sequence: 810
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            displayChartForTopNValues: 10
        }

        facet P7_AREA (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: AREA
            }
        )

        facet P7_AUTHOR (
            type: checkboxGroup
            label {
                label: Author
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: AUTHOR
            }
        )

        facet P7_COMMENT_TYPE (
            type: checkboxGroup
            label {
                label: Comment Type
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: COMMENT_TYPE
            }
        )

        facet P7_CREATED_YYYYMM (
            type: checkboxGroup
            label {
                label: Month
            }
            lov {
                type: distinctValues
                sortDirection: desc
            }
            layout {
                sequence: 50
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: CREATED_YYYYMM
            }
        )

        facet P7_INITIATIVE (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_INITIATIVE.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 90
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P7_PRIVATE_YN (
            type: checkboxGroup
            label {
                label: My Private
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: PRIVATE_YN
            }
        )

        facet P7_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: CONTEXT,BODY
            }
        )

    )

    region nomenclature-project-comments (
        name: &NOMENCLATURE_PROJECT. Comments
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select
                       initials user_icon,
                       created comment_date,
                       author user_name,
                       '' attribute_1,
                       '' attribute_2,
                       '' attribute_3,
                       '' attribute_4,
                       --
                       body_html comment_text,
                       decode(private_yn,'Yes',' Private Comment',null) private_comment_label,
                       action actions,
                       comment_type,
                       area,
                       initiative,
                       release,
                       author,
                       private_yn,
                       created_yyyyMM,
                       context,
                       body
                from (
                select :NOMENCLATURE_PROJECT comment_type,
                       'project' internal_type,
                       a.area,
                       i.id initiative_id,
                       i.initiative,
                       null release_id,
                       '' Release,
                       c.PROJECT_ID,
                       p.project,
                       null task_id,
                       p.project context,
                       c.body_no_images body,
                       c.body_html,
                       nvl((select first_name||' '||last_name from sp_team_members tm where tm.id = c.author_id),'system') author,
                       (select initials from sp_team_members tm where tm.id = c.author_id) initials,
                       c.AUTHOR_ID,
                       c.CREATED,
                       to_char(c.created,'YYYY.MM') created_yyyyMM,
                       decode(nvl(c.private_yn,'N'),'N','No','Y','Yes','Unknown') private_yn,
                       :NOMENCLATURE_PROJECT||': '||
                           '<a href="'||apex_util.prepare_URL(
                                            p_url => 'f?p='||:APP_ID||':3:'||:APP_SESSION||'::NO:3:P3_PROJECT_ID:'||p.id,
                                            p_checksum_type => '3')||'">'||apex_escape.html(p.project)||'</a>' action
                  from SP_PROJECT_COMMENTS_V c,
                       sp_projects p,
                       sp_initiatives i,
                       sp_areas a 
                 where c.author_id is not null and
                       p.id = c.project_id and
                       p.initiative_id = i.id and
                       i.area_id = a.id and
                       p.DUPLICATE_OF_PROJECT_ID is null and
                       p.ARCHIVED_YN = 'N' and 
                       (nvl(c.private_yn,'N') = 'N' or lower(c.created_by) = lower(:app_user) )
                 union all
                select :NOMENCLATURE_INITIATIVE comment_type,
                       'initiative' internal_type,
                       a.area,
                       i.id initiative_id,
                       i.initiative,
                       null release_id,
                       '' Release,
                       null PROJECT_ID,
                       '' project,
                       null task_id,
                       i.initiative context,
                       c.body_no_images body,
                       c.body_html,
                       (select first_name||' '||last_name from sp_team_members tm where tm.id = c.author_id) author,
                       (select initials from sp_team_members tm where tm.id = c.author_id) initials,
                       c.AUTHOR_ID,
                       c.CREATED,
                       to_char(c.created,'YYYY.MM') created_yyyyMM,
                       decode(nvl(c.private_yn,'N'),'N','No','Y','Yes','Unknown') private_yn,
                       :NOMENCLATURE_INITIATIVE||': '||
                           '<a href="'||apex_util.prepare_URL(
                                            p_url => 'f?p='||:APP_ID||':94:'||:APP_SESSION||'::NO:94:P94_INITIATIVE_ID:'||i.id,
                                            p_checksum_type => '3')||'">'||apex_escape.html(i.initiative)||'</a>' action
                from SP_INITIATIVE_COMMENTS_V c,
                     sp_initiatives i,
                     sp_areas a 
                 where c.author_id is not null and
                       c.initiative_id = i.id and
                       i.area_id = a.id and
                       (nvl(c.private_yn,'N') = 'N' or lower(c.created_by) = lower(:app_user) )
                union all
                select 'Release' comment_type,
                       'release' internal_type,
                       '' area,
                       null initiative_id,
                       '' initiative,
                       r.id release_id,
                       r.release_train||' '||release release,
                       null PROJECT_ID,
                       '' project,
                       null task_id,
                       r.release_train||' '||release context,
                       c.body_no_images body,
                       c.body_html,
                       (select first_name||' '||last_name from sp_team_members tm where tm.id = c.author_id) author,
                       (select initials from sp_team_members tm where tm.id = c.author_id) initials,
                       c.AUTHOR_ID,
                       c.CREATED,
                       to_char(c.created,'YYYY.MM') created_yyyyMM,
                       decode(nvl(c.private_yn,'N'),'N','No','Y','Yes','Unknown') private_yn,
                       'Release: '||
                           '<a href="'||apex_util.prepare_URL(
                                            p_url => 'f?p='||:APP_ID||':117:'||:APP_SESSION||'::NO:117:P117_RELEASE_ID:'||r.id,
                                            p_checksum_type => '3')||'">'||apex_escape.html(r.release_train||' '||release)||'</a>' action
                from SP_RELEASE_COMMENTS_V c,
                     sp_release_trains r
                 where c.release_id = r.id and
                       c.author_id is not null and
                       (nvl(c.private_yn,'N') = 'N' or lower(c.created_by) = lower(:app_user) )
                union all
                select 'Task' comment_type,
                       'task' internal_type,
                       a.area,
                       i.id initiative_id,
                       i.initiative,
                       null release_id,
                       '' Release,
                       t.PROJECT_ID,
                       p.project,
                       t.id task_id,
                       (select task_type from sp_task_types rt where rt.id = t.task_type_id)||
                           case when t.task_sub_type_id is not null then ': ' end ||
                           (select task_type from sp_task_types rt where rt.id = t.task_sub_type_id) ||
                           case when t.task is not null then ' - '||t.task end context,
                       c.body_no_images body,
                       c.body_html,
                       (select first_name||' '||last_name from sp_team_members tm where tm.id = c.author_id) author,
                       (select initials from sp_team_members tm where tm.id = c.author_id) initials,
                       c.AUTHOR_ID,
                       c.CREATED,
                       to_char(c.created,'YYYY.MM') created_yyyyMM,
                       decode(nvl(c.private_yn,'N'),'N','No','Y','Yes','Unknown') private_yn,
                       '<a href="'||apex_util.prepare_URL(
                                            p_url => 'f?p='||:APP_ID||':502:'||:APP_SESSION||'::NO:502:P502_PREV_PAGE,P502_PROJECT_ID,P502_TASK_ID:3,'||p.id||','||t.id,
                                            p_checksum_type => '3')||'">'||
                           (select apex_escape.html(task_type) from sp_task_types rt where rt.id = t.task_type_id)||
                           case when t.task_sub_type_id is not null then ': ' end ||
                           (select apex_escape.html(task_type) from sp_task_types rt where rt.id = t.task_sub_type_id) ||
                           case when t.task is not null then ' - '||apex_escape.html(t.task) end ||'</a>' action
                  from SP_TASK_COMMENTS_V c,
                       sp_tasks t,
                       sp_projects p,
                       sp_initiatives i,
                       sp_areas a 
                 where c.author_id is not null and
                       t.id = c.task_id and
                       t.project_id = p.id and
                       p.initiative_id = i.id and
                       i.area_id = a.id and
                       p.DUPLICATE_OF_PROJECT_ID is null and
                       p.ARCHIVED_YN = 'N' and 
                       (nvl(c.private_yn,'N') = 'N' or lower(c.created_by) = lower(:app_user) )
                
                ) order by comment_date desc
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: COMMENTS
            regionDisplaySelector: true
        }
        reportLayout {
            numberOfRows: 100
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
                t-Comments--iconsRounded
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No Comments
        }

        column ACTIONS (
            reportColumnQueryId: 10
            derivedColumn: N
            heading {
                heading: Actions
            }
            layout {
                sequence: 60
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column AREA (
            reportColumnQueryId: 12
            derivedColumn: N
            heading {
                heading: Area
            }
            layout {
                sequence: 100
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_1 (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Attribute 1
            }
            layout {
                sequence: 40
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_2 (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Attribute 2
            }
            layout {
                sequence: 70
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_3 (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Attribute 3
            }
            layout {
                sequence: 80
            }
            sorting {
                sortable: false
            }
        )

        column ATTRIBUTE_4 (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Attribute 4
            }
            layout {
                sequence: 90
            }
            sorting {
                sortable: false
            }
        )

        column AUTHOR (
            reportColumnQueryId: 15
            derivedColumn: N
            heading {
                heading: Author
            }
            layout {
                sequence: 130
            }
            sorting {
                sortable: false
            }
        )

        column BODY (
            reportColumnQueryId: 19
            derivedColumn: N
            heading {
                heading: Body
            }
            layout {
                sequence: 200
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_DATE (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Comment Date
            }
            layout {
                sequence: 20
            }
            appearance {
                formatMask: SINCE
            }
            sorting {
                sortable: false
            }
        )

        column COMMENT_TEXT (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Comment Text
            }
            layout {
                sequence: 50
            }
            columnFormatting {
                htmlExpression:
                    ```html
                    {if PRIVATE_COMMENT_LABEL/}<strong class="u-danger-text">#PRIVATE_COMMENT_LABEL#</strong><br />{endif/}
                    #COMMENT_TEXT#
                    ```
            }
            sorting {
                sortable: false
            }
            security {
                escapeSpecialChars: false
            }
        )

        column COMMENT_TYPE (
            reportColumnQueryId: 11
            derivedColumn: N
            heading {
                heading: Comment Type
            }
            layout {
                sequence: 160
            }
            sorting {
                sortable: false
            }
        )

        column CONTEXT (
            reportColumnQueryId: 18
            derivedColumn: N
            heading {
                heading: Context
            }
            layout {
                sequence: 190
            }
            sorting {
                sortable: false
            }
        )

        column CREATED_YYYYMM (
            reportColumnQueryId: 17
            derivedColumn: N
            heading {
                heading: Created Yyyymm
            }
            layout {
                sequence: 170
            }
            sorting {
                sortable: false
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 13
            derivedColumn: N
            heading {
                heading: Initiative
            }
            layout {
                sequence: 110
            }
            sorting {
                sortable: false
            }
        )

        column PRIVATE_COMMENT_LABEL (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Private Comment Label
            }
            layout {
                sequence: 180
            }
            sorting {
                sortable: false
            }
        )

        column PRIVATE_YN (
            reportColumnQueryId: 16
            derivedColumn: N
            heading {
                heading: Private Yn
            }
            layout {
                sequence: 140
            }
            sorting {
                sortable: false
            }
        )

        column RELEASE (
            reportColumnQueryId: 14
            derivedColumn: N
            heading {
                heading: Release
            }
            layout {
                sequence: 120
            }
            sorting {
                sortable: false
            }
        )

        column USER_ICON (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: User Icon
            }
            layout {
                sequence: 10
            }
            sorting {
                sortable: false
            }
        )

        column USER_NAME (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: User Name
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

    )

    button interactive-report (
        buttonName: Interactive-Report
        label: Interactive Report
        layout {
            sequence: 20
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 158
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button reset (
        buttonName: Reset
        label: Reset
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 7
                clearCache: 7
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 41
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction links-in-comments-in-new-tab (
        name: links in comments in new tab
        execution {
            sequence: 20
        }
        when {
            event: ready
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $('#COMMENTS a').attr('target','_blank');
            }
            execution {
                sequence: 10
            }
        )

    )

    dynamicAction refresh (
        name: refresh
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }
    )

)

