page 91 (
    name: Favorite Projects
    alias: FAVORITE-PROJECTS
    title: Favorite &NOMENCLATURE_PROJECTS.
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 10
            slot: leftColumn
            columnSpan: 4
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Filters
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P91_AREA (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: AREA
            }
        )

        facet P91_INITIATIVE (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_INITIATIVE.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P91_PRIORITY (
            type: checkboxGroup
            label {
                label: Priority
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: PRIORITY
            }
        )

        facet P91_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: PROJECT,AREA,INITIATIVE,PCT_COMPLETE
            }
        )

    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select 
                       f.PROJECT_ID,
                       max(f.CREATED) last_added,
                       replace(p.project,':',' ') project,
                       replace(i.initiative,':',' ') initiative,
                       (select 'P'||PRIORITY from SP_PROJECT_PRIORITIES x where x.ID = p.PRIORITY_ID) priority,
                       p.PCT_COMPLETE,
                       a.area,
                       p.FRIENDLY_IDENTIFIER,
                       p.PROJECT_URL_NAME,
                       count(*) favorites
                  from SP_FAVORITES f,
                       sp_projects p,
                       SP_TEAM_MEMBERS tm,
                       sp_initiatives i,
                       sp_areas a
                where  f.project_id = p.id and
                       f.TEAM_MEMBER_ID = tm.id and
                       p.initiative_id = i.id and
                       i.area_id = a.id and
                       nvl(p.ARCHIVED_YN,'N') = 'N' and 
                       p.DUPLICATE_OF_PROJECT_ID is null
                 group by f.project_id, 
                       p.project, 
                       i.initiative, 
                       p.PRIORITY_ID,
                       p.PCT_COMPLETE,
                       a.area,
                       p.FRIENDLY_IDENTIFIER,
                       p.PROJECT_URL_NAME
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: no data found
        }

        column AREA (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_AREA.
            }
            layout {
                sequence: 43
            }
        )

        column FAVORITES (
            reportColumnQueryId: 10
            derivedColumn: N
            type: link
            heading {
                heading: Favorites
                alignment: end
            }
            layout {
                sequence: 133
                columnAlignment: end
            }
            link {
                target: {
                    page: 15
                    items: {
                        P15_SEARCH: #PROJECT#
                    }
                    clearCache: 15
                    action: resetPagination
                }
                linkText: #FAVORITES#
            }
            sorting {
                defaultSequence: 1
                direction: desc
            }
        )

        column FRIENDLY_IDENTIFIER (
            reportColumnQueryId: 8
            derivedColumn: N
            type: hidden
            layout {
                sequence: 103
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_INITIATIVE.
            }
            layout {
                sequence: 53
            }
        )

        column LAST_ADDED (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Last Added
            }
            layout {
                sequence: 123
            }
            appearance {
                formatMask: SINCE
            }
        )

        column PCT_COMPLETE (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: % Complete
                alignment: end
            }
            layout {
                sequence: 83
                columnAlignment: end
            }
        )

        column PRIORITY (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Priority
            }
            layout {
                sequence: 63
            }
        )

        column PROJECT (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 23
            }
            link {
                target: {
                    page: 3
                    items: {
                        FI: #FRIENDLY_IDENTIFIER#
                        PN: #PROJECT_URL_NAME#
                    }
                    clearCache: 3
                    action: resetPagination
                }
                linkText: #PROJECT#
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 2
            }
        )

        column PROJECT_URL_NAME (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 113
            }
        )

    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 91
                clearCache: 15
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

