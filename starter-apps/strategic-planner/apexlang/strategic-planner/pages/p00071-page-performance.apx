page 71 (
    name: Page Performance
    alias: PAGE-PERFORMANCE
    title: Page Performance
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region page-performance (
        name: Page Performance
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select step_id page,
                    nvl((   select p.page_title||' ('||p.PAGE_FUNCTION||')' page_name
                        from apex_application_pages p
                        where p.page_id = l.step_id
                            and p.application_id = :app_id ),'No longer exists') page_name,
                    median(elap)                   median_elapsed,
                    count(*) * median(elap)        weighted_performance,
                    sum(decode(sqlerrm,null,0,1))  errors,
                    count(distinct userid)         distinct_users,
                    count(distinct session_id)     application_sessions,
                    count(*)                       page_views,
                    max(elap)                      max_elapsed,
                    sum(nvl(num_rows,0))           total_rows,
                    sum(decode(page_mode,'P',1,0)) partial_page_views,
                    sum(decode(page_mode,'D',1,0)) full_page_views,
                    min(elap)                      min_elapsed,
                    avg(elap)                      avg_elapsed
                from apex_activity_log l
                where flow_id = :app_id
                    and time_stamp >= sysdate - ( 1/24/60/60 * :P71_TIMEFRAME )
                    and userid is not null
                    and l.step_id is not null
                group by l.step_id
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 6302862546809629777
        }

        column APPLICATION_SESSIONS (
            type: plainText
            heading {
                heading: Application Sessions
                alignment: end
            }
            layout {
                sequence: 7
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: G
            }
        )

        column AVG_ELAPSED (
            type: plainText
            heading {
                heading: Avg Elapsed
                alignment: end
            }
            layout {
                sequence: 14
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990D000
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: N
            }
        )

        column DISTINCT_USERS (
