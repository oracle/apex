    region timeframe (
        name: Timeframe
        type: staticContent
        layout {
            sequence: 2
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    pageItem P71_TIMEFRAME (
        type: selectList
        label {
            label: Timeframe
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select disp,
                       val as seconds
                  from table( apex_util.get_timeframe_lov_data )
                 order by insert_order
                ```
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @timeframe
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            height: 1
        }
        default {
            type: static
            staticValue: 900
        }
    )

    button page-views (
        buttonName: Page_Views
        label: Page Views
        layout {
            sequence: 10
            region: @breadcrumb
