page 136 (
    name: Description
    alias: DESCRIPTION1
    title: &NOMENCLATURE_PROJECT. Desription
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 80
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region p136-project-name (
        name: &P136_PROJECT_NAME.
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                    x clob;
                begin
                x := 'No description provided.';
                for c1 in (select description from sp_projects d where d.id = :P136_ID and description is not null) loop
                    x := apex_markdown.to_html(c1.description);
                end loop;
                return x;
                end;
                ```
        }
        layout {
            sequence: 70
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
    )

    pageItem P136_ID (
        type: hidden
        layout {
            sequence: 10
            region: @p136-project-name
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    pageItem P136_LOG (
        type: hidden
        layout {
            sequence: 20
            region: @p136-project-name
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P136_PROJECT_NAME (
        type: hidden
        layout {
            sequence: 30
            region: @p136-project-name
            slot: regionBody
        }
        security {
            sessionStateProtection: restricted
        }
    )

    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button view-project (
        buttonName: view_project
        label: View &NOMENCLATURE_PROJECT.
        layout {
            sequence: 20
            region: @buttons
            slot: edit
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
            icon: fa-chevron-left
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 36
                items: {
                    P36_ID: &P136_ID.
                }
                clearCache: 36
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-close (
            action: closeDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p136-log (
        itemName: P136_LOG
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: functionBody
            plsqlFunctionBody: return sp_log.log_and_summarize(:P136_ID);
        }
    )

    computation p136-project-name (
        itemName: P136_PROJECT_NAME
        execution {
            sequence: 20
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select project
                from SP_PROJECTS p
                where p.id = :P136_ID
                ```
        }
    )

)

