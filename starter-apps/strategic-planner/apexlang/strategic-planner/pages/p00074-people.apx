                    }
                }
                appearance {
                    icon: fa-users
                }
                security {
                    authorizationScheme: @administration-rights
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 60
                }
            )

            menu comp_menu_entry-2 (
                type: separator
                layout {
                    sequence: 30
                }
            )

            menu manage-groups (
                label: Manage Groups
