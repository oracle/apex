                label: &NOMENCLATURE_PROJECT. Owner
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 110
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: PROJECT_LEAD
            }
        )

        facet P74_REGION (
            type: checkboxGroup
            label {
                label: Region
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: REGION
            }
        )

        facet P74_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P74_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

    )

