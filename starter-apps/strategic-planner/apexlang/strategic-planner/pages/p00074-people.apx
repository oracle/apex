                    target: {
                        page: 103
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-users
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu nomenclature-users-details (
                label: &NOMENCLATURE_USERS. Details
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 19
                        action: resetPagination
                    }
                }
