page 74 (
    name: People
    alias: PEOPLE
    title: &NOMENCLATURE_USERS.
    pageGroup: @users
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .no-item-ui {
              --a-field-input-border-width: 0px;
              --a-field-input-background-color: transparent;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region faceted-search (
        name: Faceted Search
        type: facetedSearch
        source {
            filteredRegion: @users
        }
        layout {
            sequence: 30
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            displayChartForTopNValues: 20
        }

        facet P74_APP_ROLE (
            type: checkboxGroup
            label {
                label: App Role
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: APP_ROLE
            }
        )

        facet P74_COMPETENCIES (
            type: checkboxGroup
            label {
                label: Competencies
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: COMPETENCIES
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P74_COUNTRY (
            type: checkboxGroup
            label {
                label: Country
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: COUNTRY
            }
        )

        facet P74_EMAIL_DOMAIN (
            type: checkboxGroup
            label {
                label: Email Domain
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 100
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: EMAIL_DOMAIN
            }
        )

        facet P74_GROUP_MEMBERSHIP (
            type: checkboxGroup
            label {
                label: Groups
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: GROUP_MEMBERSHIP
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P74_HAS_ACTIVITIES (
            type: checkboxGroup
            label {
                label: Current or Future Activities
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 90
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: HAS_ACTIVITIES
            }
        )

        facet P74_HAS_OPEN_REVIEWS (
            type: checkboxGroup
            label {
                label: Open Reviews
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: HAS_OPEN_REVIEWS
            }
        )

        facet P74_HAS_PROFILE_PHOTO (
            type: checkboxGroup
            label {
                label: Has Profile Photo
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 130
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: HAS_PROFILE_PHOTO
            }
        )

        facet P74_HAS_SCREEN_NAME (
            type: checkboxGroup
            label {
                label: Has Screen Name
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 140
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: HAS_SCREEN_NAME
            }
            config {
                buildOption: @comment-tagging
            }
        )

        facet P74_PROJECT_LEAD (
            type: checkboxGroup
