        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: "&NOMENCLATURE_PROJECTS. "
        }

        savedReport 46976301 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ACTIONS (
                sequence: 9
            )

            displayColumn PCT_COMPLETE (
                sequence: 4
            )

            displayColumn PRIORITY (
                sequence: 3
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn PROJECT_SIZE (
                sequence: 7
            )

            displayColumn RELEASE (
                sequence: 5
            )

            displayColumn TARGET_COMPLETE (
                sequence: 6
            )

            displayColumn THE_OWNER (
                sequence: 2
            )

            displayColumn UPDATED (
                sequence: 8
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            sort (
                column: PCT_COMPLETE
                sort {
                    sequence: 2
                }
            )

        )

    )

    region rds (
        name: RDS
        type: regionDisplaySelector
        layout {
            sequence: 30
            slot: fullWidthContent
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: [
                u-padding-inline-dynamic
                project-rds-region
            ]
        }
        settings {
            includeShowAll: false
        }
    )

    pageItem P119_PROJECT_GROUP (
        type: hidden
        layout {
            sequence: 10
            slot: body
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P119_PROJECT_GROUP_ID (
        type: hidden
        layout {
            sequence: 20
            slot: body
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 70
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction links-in-comments-in-new-tab (
        name: links in comments in new tab
        execution {
            sequence: 10
        }
        when {
            event: ready
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $('#COMMENTS a').attr('target','_blank');
            }
            execution {
                sequence: 10
            }
        )

    )

    computation p119-project-group (
        itemName: P119_PROJECT_GROUP
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select GROUP_NAME 
                from SP_PROJECT_GROUPS g 
                where g.id = :P119_PROJECT_GROUP_ID
                ```
        }
    )

)

