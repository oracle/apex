        action action (
            position: titleLink
            layout {
                sequence: 40
            }
            behavior {
                target: {
                    page: 3
                    items: {
                        FI: &FRIENDLY_IDENTIFIER1.
                        PN: &PROJECT_URL_NAME.
                    }
                    clearCache: 3
                    action: resetPagination
                }
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
                cssClasses: t-Button--noUI
            }

            menu activity-quick-look (
                label: Activity Quick Look
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 130
                        items: {
                            P130_PROJECT_ID: &ID.
                        }
                        clearCache: 130
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-badge-check
                }
            )

            menu add-activity (
                label: Add Activity
                layout {
                    sequence: 70
                }
                behavior {
                    target: {
                        page: 101
                        items: {
                            P101_PROJECT_ID: &ID.
                        }
                        clearCache: 101
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-plus
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu change-history (
                label: Change History
                layout {
                    sequence: 100
                }
                behavior {
                    target: {
                        page: 124
                        items: {
                            P124_ID: &ID.
                        }
                        clearCache: 124
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-clock-o
                }
            )

            menu comment (
                label: Comment
                layout {
                    sequence: 90
                }
                behavior {
                    target: {
                        page: 100
                        items: {
                            P100_PROJECT_ID: &ID.
                        }
                        clearCache: 100
                    }
                }
                appearance {
                    icon: fa-comment-o
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 30
                }
            )

            menu edit (
                label: "Edit "
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 24
                        items: {
                            P24_ID: &ID.
                        }
                        clearCache: 24
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-edit
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu nomenclature-project-details (
                label: &NOMENCLATURE_PROJECT. Details
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 3
                        items: {
                            FI: &FRIENDLY_IDENTIFIER1.
                            PN: &PROJECT_URL_NAME.
                        }
                        clearCache: 3
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu nomenclature-project-quick-look (
                label: &NOMENCLATURE_PROJECT. Quick Look
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 36
                        items: {
                            P36_ID: &ID.
                        }
                        clearCache: 36
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu view-owner (
                label: View Owner
                layout {
                    sequence: 80
                }
                behavior {
                    target: {
                        page: 5
                        items: {
                            P5_ID: &OWNER_ID.
                        }
                        clearCache: 5
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-user
                }
            )

        )

        action favorite (
            position: primaryActions
            template: button
            label: Favorite
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: #action$favoriteProject?id=&ID.
            }
            appearance {
                displayType: icon
                icon: &FAVORITE_ICON.
                cssClasses: t-Button--noUI
            }
        )

    )

    region filter (
        name: Filter
        type: facetedSearch
        source {
            filteredRegion: @content-row
        }
        layout {
            sequence: 30
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            renderComponents: belowContent
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            displayChartForTopNValues: 10
        }

        facet P113_ACTIVE_ACTIVITY (
            type: checkboxGroup
            label {
                label: Current Activity
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ACTIVE_ACTIVITY
            }
        )

        facet P113_ACTIVITY_STATUS (
            type: checkboxGroup
            label {
                label: Activity Status
            }
            lov {
                type: staticValues
                staticValues: STATIC2:Open Actions;Open Actions,Completed;Completed
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ACTIVITY_STATUS
            }
        )

        facet P113_COMPLETE_MONTH (
            type: checkboxGroup
            label {
                label: Complete Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: COMPLETE_MONTH
            }
        )

        facet P113_FAVORITE (
            type: checkboxGroup
            label {
                label: My Favorite
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: FAVORITE
            }
        )

        facet P113_FOCUS_AREA (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 110
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: FOCUS_AREA
            }
        )

        facet P113_INITIATIVE (
            type: checkboxGroup
            label {
                label: Initiative
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 120
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P113_PCT_COMPLETE (
            type: checkboxGroup
            label {
                label: Pct Complete
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 90
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: PCT_COMPLETE
            }
        )

        facet P113_PROJECT_STATUS (
            type: checkboxGroup
            label {
                label: Status
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 100
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: PROJECT_STATUS
            }
        )

        facet P113_RELEASE (
            type: checkboxGroup
            label {
                label: Release
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: RELEASE
            }
        )

        facet P113_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P113_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P113_USER_ASSOCIATION (
            type: checkboxGroup
            label {
                label: Association
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: USER_ASSOCIATION
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu about-nomenclature-projects (
                label: About &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 100
                }
                behavior {
                    target: {
                        page: 107
                    }
                }
                appearance {
                    icon: fa-info
                }
            )

            menu add-nomenclature-project (
                label: Add &NOMENCLATURE_PROJECT.
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 104
                        clearCache: 104
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-plus
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu all-nomenclature-projects (
                label: All &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 23
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 60
                }
            )

            menu comp_menu_entry-2 (
                type: separator
                layout {
                    sequence: 110
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 130
                }
                behavior {
                    target: {
                        page: 113
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 120
                }
                behavior {
                    target: {
                        page: 113
                        items: {
                            P113_USER: &P113_USER.
                        }
                        clearCache: 113
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

    )

    region sort (
        name: Sort
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
    )

    region user (
        name: User
        type: staticContent
        layout {
            sequence: 4
            slot: leftColumn
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--removeHeader js-removeLandmark
                t-Region--scrollBody
            ]
        }
    )

    pageItem P113_ORDER_BY (
        type: selectList
        label {
            label: Order By
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Updated;UPDATED,Created;CREATED,Project;PROJECT
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @sort
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            icon: fa-sort-amount-asc
            height: 1
        }
        advanced {
            cssClasses: [
                w200
                no-item-ui
            ]
        }
    )

    pageItem P113_PROJECT_TO_FAVORITE (
        type: hidden
        layout {
            sequence: 20
            region: @content-row
            slot: regionBody
        }
    )

    pageItem P113_USER (
        type: popupLov
        label {
            label: User
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select first_name||' '||last_name d,
                       id
                from sp_team_members
                order by last_name, last_name
                ```
        }
        layout {
            sequence: 10
            region: @user
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-content (
        name: Refresh content
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P113_USER
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @content-row
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @filter
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action set-state (
            name: set state
            action: executeServerSideCode
            settings {
                plsqlCode: null;
                itemsToSubmit: P113_USER
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

