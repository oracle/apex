            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @filter
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-dialog-closed (
        name: refresh on dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @content-row
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @content-row
            }
            execution {
