page 129 (
    name: Developer Detail Views
    alias: DEVELOPER-DETAIL-VIEWS
    title: Developer Detail Views (31 Days)
    pageGroup: @reporting
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 10
            }
            appearance {
                displayType: textWithIcon
                icon: fa-ellipsis-v
            }

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 100
                }
            )

            menu comp_menu_entry-2 (
                type: separator
                layout {
                    sequence: 50
                }
            )

            menu my-favorite-nomenclature-projects (
                label: My Favorite &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 23
                        items: {
                            P23_FAVORITE: Yes
                        }
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-heart
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 110
                }
                behavior {
                    target: {
                        page: 129
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 120
                }
                behavior {
                    target: {
                        page: 129
                        clearCache: 129
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

            menu view-activity (
                label: View Activity
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 102
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-badge-check
                }
                config {
                    buildOption: @activity-planning
                }
            )

            menu view-nomenclature-projects (
                label: View &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 23
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu view-nomenclature-users (
                label: View &NOMENCLATURE_USERS.
                layout {
                    sequence: 80
                }
                behavior {
                    target: {
                        page: 19
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-users
                }
            )

            menu view-releases (
                label: View Releases
                layout {
                    sequence: 70
                }
                behavior {
                    target: {
                        page: 63
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-ship
                }
            )

        )

    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 10
            slot: leftColumn
            columnSpan: 4
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Filters
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P129_APP_USER (
            type: checkboxGroup
            label {
                label: App User
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: APP_USER
            }
        )

        facet P129_AREA (
            type: checkboxGroup
            label {
                label: Area
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: AREA
            }
        )

        facet P129_INITIATIVE (
            type: checkboxGroup
            label {
                label: Initiative
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P129_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: APP_USER
            }
        )

        facet P129_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select decode(t.first_name,null,l.app_user,t.first_name||' '||t.last_name) app_user, 
                       p.id PROJECT_ID,
                       p.project,
                       p.RELEASE_ID,
                       p.tags,
                       count(*) interactions,
                       i.initiative,
                       a.area,
                       p.FRIENDLY_IDENTIFIER,
                       p.PROJECT_URL_NAME,
                       t.id team_member_id
                from   sp_proj_interactions_log l,
                       sp_projects p,
                       SP_INITIATIVES i,
                       SP_AREAS a,
                       sp_team_members t
                where  l.PAGE_RENDERED > (sysdate - 31) and
                       l.project_id = p.id and
                       p.DUPLICATE_OF_PROJECT_ID is null and
                       p.ARCHIVED_YN = 'N' and
                       p.initiative_id = i.id and
                       i.area_id = a.id and
                       l.app_user = t.email(+)
                group  by decode(t.first_name,null,l.app_user,t.first_name||' '||t.last_name), p.id, p.project, p.release_id, p.tags, i.initiative, a.area, p.FRIENDLY_IDENTIFIER, p.PROJECT_URL_NAME, t.id
                ```
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: no data found
        }

        column APP_USER (
            reportColumnQueryId: 1
            derivedColumn: N
            type: link
            heading {
                heading: App User
            }
            layout {
                sequence: 1
            }
            link {
                target: {
                    page: 73
                    items: {
                        P73_TEAM_MEMBER_ID: #TEAM_MEMBER_ID#
                    }
                    clearCache: 73
                    action: resetPagination
                }
                linkText: #APP_USER#
            }
        )

        column AREA (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_AREA.
            }
            layout {
                sequence: 72
            }
        )

        column FRIENDLY_IDENTIFIER (
            reportColumnQueryId: 9
            derivedColumn: N
            type: hidden
            layout {
                sequence: 82
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: &NOMENCLATURE_INITIATIVE.
            }
            layout {
                sequence: 62
            }
        )

        column INTERACTIONS (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Interactions
                alignment: end
            }
            layout {
                sequence: 2
                columnAlignment: end
            }
        )

        column PROJECT (
            reportColumnQueryId: 3
            derivedColumn: N
            type: link
            heading {
                heading: Project
            }
            layout {
                sequence: 22
            }
            link {
                target: {
                    page: 3
                    items: {
                        FI: #FRIENDLY_IDENTIFIER#
                        PN: #PROJECT_URL_NAME#
                    }
                    clearCache: 3
                    action: resetPagination
                }
                linkText: #PROJECT#
            }
        )

        column PROJECT_ID (
            reportColumnQueryId: 2
            derivedColumn: N
            type: hidden
            layout {
                sequence: 12
            }
        )

        column PROJECT_URL_NAME (
            reportColumnQueryId: 10
            derivedColumn: N
            type: hidden
            layout {
                sequence: 92
            }
        )

        column RELEASE_ID (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 42
            }
        )

        column TAGS (
            reportColumnQueryId: 5
            derivedColumn: N
            type: hidden
            layout {
                sequence: 52
            }
        )

        column TEAM_MEMBER_ID (
            reportColumnQueryId: 11
            derivedColumn: N
            type: hidden
            layout {
                sequence: 102
            }
        )

    )

    button reset (
        buttonName: RESET
        label: Reset
        layout {
            sequence: 10
            region: @button-bar
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 129
                clearCache: 129
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

)

