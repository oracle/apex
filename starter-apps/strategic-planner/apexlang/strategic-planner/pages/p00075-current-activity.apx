        column TAGGED_BACKLOG (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Tagged Backlog
                alignment: end
            }
            layout {
                sequence: 53
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            advanced {
                computeSum: true
            }
        )

        column TAGGED_CANDIDATE (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: Tagged Candidate
                alignment: end
