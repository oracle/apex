    )

    region filter (
        name: Filter
        type: staticContent
        layout {
            sequence: 2
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 10
            }
            appearance {
                displayType: textWithIcon
                icon: fa-ellipsis-v
            }

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 20
                }
            )

            menu nomenclature-projects (
                label: &NOMENCLATURE_PROJECTS.
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 23
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 75
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 40
                }
                behavior {
                    target: {
                        page: 75
                        clearCache: 75
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

    )

    pageItem P75_RELEASE (
        type: radioGroup
        label {
            label: Release
            alignment: left
        }
        settings {
            noOfCols: 8
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select release_train||' '||release release_train, id 
                  from SP_RELEASE_TRAINS
                 where id in (select release_id 
                                from sp_projects p, sp_activities ap
                               where ap.project_id = p.id 
                                 and p.ARCHIVED_YN = 'N' 
                                 and p.DUPLICATE_OF_PROJECT_ID is null)
                ```
            nullDisplayValue: - All Releases -
            nullReturnValue: 0
        }
        layout {
            sequence: 10
            region: @filter
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-above
            templateOptions: [
                #DEFAULT#
                t-Form-fieldContainer--stretchInputs
                t-Form-fieldContainer--radioButtonGroup
            ]
        }
        default {
            type: static
            staticValue: 0
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 1
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction release-change (
        name: release change
        execution {
            sequence: 10
        }
        when {
            selectionType: items
            items: P75_RELEASE
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode: null;
                itemsToSubmit: P75_RELEASE
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @current-activity
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

)

