    dynamicAction refresh-after-add (
        name: refresh after add
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @subscriptions
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process update (
        name: Update
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for i in 1..apex_application.g_f01.count loop
                
                    if apex_application.g_f02(i) = 'Y' then
                        sp_util.notification_opt_in (
                            p_team_member_id  => apex_application.g_f03(i),
                            p_notification_id => apex_application.g_f01(i),
                            p_frequency       => upper(apex_application.g_f05(i)),
                            p_release_id      => apex_application.g_f04(i));
                    else
                        sp_util.notification_opt_out (
                            p_team_member_id  => apex_application.g_f03(i),
                            p_notification_id => apex_application.g_f01(i),
                            p_release_id      => apex_application.g_f04(i));
                    end if;
                
                end loop;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: "Notification Subscriptions updated. "
        }
        advanced {
            executionMappingIdentifier: 11125615639027171228
        }
    )

