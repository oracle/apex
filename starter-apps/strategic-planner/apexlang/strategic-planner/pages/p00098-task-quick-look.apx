    region documents (
        name: Documents
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select d.ID,
                       d.DOCUMENT_FILENAME || case when important_yn = 'Y' then ' (Important)' end document_filename,
                       'added by '||lower(created_by) ||' '||apex_util.get_since(created) created_details
                  from SP_TASK_DOCUMENTS d
                 where task_id = :P98_TASK_ID
                order by created desc
                ```
            pageItemsToSubmit: P98_TASK_ID
        }
        layout {
            sequence: 100
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from SP_TASK_DOCUMENTS
                 where task_id = :P98_TASK_ID
                ```
        }
        reportLayout {
            numberOfRows: 150
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--noBorders
            ]
        }
