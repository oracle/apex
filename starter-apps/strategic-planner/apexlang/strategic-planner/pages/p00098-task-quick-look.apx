                page: 508
                items: {
                    P508_ID: &P98_TASK_ID.
                }
                clearCache: 508
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_tasks t, sp_task_types tt
                 where t.id = :P98_TASK_ID
                   and t.task_type_id = tt.id
                   and tt.STATIC_ID = 'MILESTONE'
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button edit-review (
        buttonName: Edit-review
        label: Edit
        layout {
            sequence: 50
            region: @p98-task-type
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-edit
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 509
                items: {
                    P509_ID: &P98_TASK_ID.
                }
                clearCache: 509
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_tasks t, sp_task_types tt
                 where t.id = :P98_TASK_ID
                   and t.task_type_id = tt.id
                   and tt.STATIC_ID = 'REVIEW'
                ```
        }
        security {
            authorizationScheme: @contribution-rights
        }
    )

    button task-history (
        buttonName: task_history
        label: History
        layout {
            sequence: 20
            region: @p98-task-type
            slot: edit
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-clock-o
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 507
                items: {
                    P507_TASK_ID: &P98_TASK_ID.
                }
                clearCache: 507
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction close-dialog (
        name: close dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-dialog-close (
            action: closeDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction links-in-comments-in-new-tab (
        name: links in comments in new tab
        execution {
            sequence: 20
        }
        when {
            event: ready
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: $('#COMMENTS a').attr('target','_blank');
            }
            execution {
                sequence: 10
            }
        )

    )

    computation p98-project-id (
        itemName: P98_PROJECT_ID
        execution {
            sequence: 10
            point: afterHeader
        }
        computation {
            sqlQuery:
                ```sql
                select project_id
                  from sp_tasks
                 where id = :P98_TASK_ID
                ```
        }
    )

    computation p98-task-type (
        itemName: P98_TASK_TYPE
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select tt.task_type 
                  from sp_tasks t,
                       sp_task_types tt
                 where t.id = :P98_TASK_ID
                   and t.task_type_id = tt.id
                ```
        }
    )

)

