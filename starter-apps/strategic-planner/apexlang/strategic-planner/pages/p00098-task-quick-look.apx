page 98 (
    name: Task Quick Look
    alias: TASK-QUICK-LOOK
    title: Quick Look
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        resizable: false
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .sp-tag {
                padding: 2px 4px;
                display: inline-block;
                vertical-align: text-bottom;
                border-radius: 3px;
                background-color: rgba(0,0,0,.1);
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .sp-tags-container {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 4px;
                justify-content: flex-start;
            }
            
            .resize-region {
              resize: vertical;
              overflow: auto;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 80
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region comments (
        name: Comments
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ic.ID,
                       -- Display Columns
                       tm.initials user_icon,
                       apex_util.get_since(ic.created) comment_date,
                       tm.first_name || ' ' || tm.last_name user_name,
                       --
                       ic.body_html comment_text,
                       null actions,
                       ' ' attribute_1,
                       ' ' attribute_2,
                       ' ' attribute_3,
                       ' ' attribute_4,
                       'u-color-'||ora_hash(ic.created_by,45) icon_modifier,
                       --
                       --
                       --
                       decode(ic.private_yn,null,null,'N',null,'Y',' Private Comment') private_comment_label,
                       --
                       -- Data Columns
                       --
                       ic.BODY,
                       ic.BODY_HTML,
                       ic.AUTHOR_ID,
                       --
                       ic.CREATED,
                       ic.CREATED_BY,
                       ic.UPDATED,
                       ic.UPDATED_BY,
                       tm.id team_member_id
                  from sp_task_comments ic, 
                       sp_team_members tm
                where ic.author_id = tm.id and
                      ic.task_id = :P98_TASK_ID and  
                      (nvl(ic.private_yn,'N') = 'N' or lower(ic.created_by) = lower(:APP_USER) )
                order by created desc
                ```
            pageItemsToSubmit: P98_TASK_ID
        }
        layout {
            sequence: 110
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noUI
                t-Region--scrollBody
            ]
        }
        advanced {
            htmlDomId: COMMENTS
            regionDisplaySelector: true
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_task_comments
                 where task_id = :P98_TASK_ID 
                   and (nvl(private_yn,'N') = 'N' or lower(created_by) = lower(:APP_USER))
                ```
        }
        componentAppearance {
            template: @/comments
            templateOptions: [
                #DEFAULT#
                t-Comments--chat
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        messages {
            whenNoDataFound: No comments
        }

