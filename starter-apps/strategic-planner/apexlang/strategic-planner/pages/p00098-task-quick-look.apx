        label: View Details
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-package
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 502
                items: {
                    P502_TASK_ID: &P98_TASK_ID.
                    P502_PROJECT_ID: &P98_PROJECT_ID.
                    P502_PREV_PAGE: 3
                }
                clearCache: 502
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button edit (
        buttonName: Edit
