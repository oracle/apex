    region links (
        name: Links
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select l.id, 
                       case when lower(l.link_url) not like 'http%' then 'http://' end || l.link_url link_url,
                       l.created, 
                       l.updated, 
                       decode(
                           greatest(length(l.link_url),80),
                           length(l.link_url),
                           substr(l.link_url,1,37)||'...'||substr(l.link_url,length(l.link_url)-40),
                           l.link_url
                           ) link_url_display
                from SP_task_LINKS l 
                where task_id = :P98_TASK_ID
                order by created desc
                ```
            pageItemsToSubmit: P98_TASK_ID
        }
        layout {
            sequence: 90
            slot: contentBody
