    process set-items (
        name: set Items
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                ---------------------------------------------
                -- Set items for breadcrumb and navication --
                ---------------------------------------------
                select initiative, area_id
                into :P160_INITIATIVE, :P160_AREA_ID
                from   sp_initiatives i
                where  id = :P160_INITIATIVE_ID;
                ```
        }
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 15381615865746187598
        }
    )

)

