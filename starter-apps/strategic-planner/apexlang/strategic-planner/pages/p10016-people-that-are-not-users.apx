page 10016 (
    name: People that are not Users
    alias: PEOPLE-THAT-ARE-NOT-USERS
    title: &NOMENCLATURE_USERS. that are not Users
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @approvals
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region people (
        name: People
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id, first_name, last_name, lower(email) email
                  from SP_TEAM_MEMBERS
                 where lower(email) not in (select user_name_lc
                                              from APEX_APPL_ACL_USERS
                                             where APPLICATION_ID = :APP_ID)
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        actionsMenu {
            controlBreak: false
            compute: false
            aggregate: false
            chart: false
            groupBy: false
            pivot: false
            flashback: false
            saveReport: false
            subscription: false
        }
        advanced {
            savedReportMappingIdentifier: 107122792691298969235
        }

        column EMAIL (
            type: plainText
            heading {
                heading: Email
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: P
            }
        )

        column FIRST_NAME (
            type: plainText
            heading {
                heading: First Name
            }
            layout {
                sequence: 10
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: N
            }
        )

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 0
            }
            source {
                primaryKey: true
                dataType: NUMBER
            }
            advanced {
                endUserAlias: A
            }
        )

        column LAST_NAME (
            type: plainText
            heading {
                heading: Last Name
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: O
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Initiative Approval Types
        }

        savedReport 117529421 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn EMAIL (
                sequence: 1
            )

            displayColumn FIRST_NAME (
                sequence: 2
            )

            displayColumn LAST_NAME (
                sequence: 3
            )

            sort (
                column: EMAIL
                sort {
                    sequence: 1
                }
            )

            sort (
                column: USERNAME
                sort {
                    sequence: 2
                }
            )

        )

    )

    button reset (
        buttonName: reset
        label: Reset
        layout {
            sequence: 40
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10016
                clearCache: [
                    CIR
                    RIR
                ]
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 30
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction edit-report-dialog-closed (
        name: Edit Report - Dialog Closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @people
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @people
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction new-entry-dialog-closed (
        name: new entry - Dialog Closed
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @people
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

