    dynamicAction dismiss-notif (
        name: dismiss notif
        execution {
            sequence: 70
        }
        when {
            selectionType: items
            items: P1_NOTIF_TO_DISMISS
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    update sp_team_member_notifications
                       set dismissed_yn = 'Y'
                     where id = :P1_NOTIF_TO_DISMISS
                       and team_member_id =  :APP_USER_ID;
                    ```
                itemsToSubmit: P1_NOTIF_TO_DISMISS
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.items.P1_NOTIF_TO_DISMISS.setValue('',undefined,true);
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

