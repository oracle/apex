page 1 (
    name: home
    alias: HOME
    title: &NOMENCLATURE_STRATEGIC_PLANNER. home
    pageGroup: @home
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    javaScript {
        functionAndGlobalVariableDeclaration:
            ```javascript-browser
            $(() => { 
                apex.actions.add({
                    name: 'favoriteProject',
                    action: function(event, focusElement, args) {
                        $(event.currentTarget).addClass('js-project-to-favorite');
                        apex.item('P1_PROJECT_TO_FAVORITE').setValue(args.id);
                        return true;
                        }
                });
            });
            ```
    }
    css {
        inline:
            ```css
            .sp-tag {
                padding: 2px 4px;
                display: inline-block;
                vertical-align: text-bottom;
                border-radius: 3px;
                background-color: rgba(0,0,0,.1);
                text-overflow: ellipsis;
                white-space: nowrap;
            }
            .sp-tags-container {
                display: flex;
                align-items: center;
                flex-wrap: wrap;
                gap: 4px;
                justify-content: flex-start;
            }
            
            .resize-region {
              resize: vertical;
              overflow: auto;
            }
            
            .a-CardView-iconWrap,
            .a-CardView-badge { align-self: flex-start; }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    comments {
        comments: home
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 75
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 40
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu refresh (
                label: Refresh
                layout {
                    sequence: 150
                }
                behavior {
                    target: {
                        page: 1
                        clearCache: 1
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

        )

        action my-favorites (
            position: primaryActions
            template: button
            label: My Favorites
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 23
                    items: {
                        P23_FAVORITE: Yes
                    }
                    action: resetPagination
                }
            }
            appearance {
                displayType: icon
                icon: fa-heart
                cssClasses: t-Button--noUI
            }
        )

        action view-nomenclature-projects (
            position: primaryActions
            template: button
            label: View &NOMENCLATURE_PROJECTS.
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 23
                    action: resetPagination
                }
            }
            appearance {
                hot: true
            }
        )

    )

    region my-activities (
        name: My Activities
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select ap.id, 
                       ap.project_id,
                       --
                       -- activity core information
                       --
                       at.activity_type,
                       decode(greatest(length(ap.comments),80),80,ap.comments,substr(ap.comments,1,80)||'...') comments,
                       ap.url,
                       apex_util.get_since(ap.updated) last_updated,
                       ap.created,
                       ap.tags,
                       ap.updated,
                       --
                       -- activity date fields
                       --
                       ap.start_date,
                       ap.end_date,
                       to_char(start_date,'YYYY.MM') start_month,
                       to_char(end_date,'YYYY.MM') end_month,
                       to_char(ap.start_date,'DD-MON-YYYY')||' to '||to_char(ap.end_date,'DD-MON-YYYY') TIMELINE,
                       ap.end_date - ap.start_date days,
                       round(ap.end_date - sysdate) days_remaining,
                       --
                       -- team member info
                       --
                       tm.first_name||' '||tm.last_name name,
                       --
                       -- optional initiative
                       --
                       decode(ap.initiative_id,null,null,(
                           select initiative from sp_initiatives where id = ap.initiative_id
                       )) initiative,
                       ap.initiative_id,
                       --
                       -- optional project 
                       --
                       decode(ap.project_id,null,null,(
                           select decode(greatest(length(p.project),80),80,p.PROJECT,substr(p.project,1,80)||'...') project 
                           from sp_projects p 
                           where p.id = ap.project_id and 
                                 p.DUPLICATE_OF_PROJECT_ID is null and
                                 p.ARCHIVED_YN = 'N')
                           ) project,
                       decode(ap.project_id,null,null,(
                           select friendly_identifier 
                           from sp_projects p 
                           where p.id = ap.project_id and 
                                 p.DUPLICATE_OF_PROJECT_ID is null and
                                 p.ARCHIVED_YN = 'N')
                           ) friendly_identifier,
                       decode(ap.project_id,null,null,(
                           select PROJECT_URL_NAME 
                           from sp_projects p 
                           where p.id = ap.project_id and 
                                 p.DUPLICATE_OF_PROJECT_ID is null and
                                 p.ARCHIVED_YN = 'N')
                           ) PROJECT_URL_NAME,
                       --
                       -- badge status is red if past due and green if within begin and and dates
                       --
                       decode (trunc(sysdate),trunc(ap.end_date),'success',
                       decode (trunc(sysdate),trunc(ap.start_date),'success',
                       decode(
                           greatest(to_char(ap.end_date,'YYYY.MM.DD'),to_char(sysdate,'YYYY.MM.DD')),
                           to_char(sysdate,'YYYY.MM.DD'),
                           'danger',
                           decode(
                               greatest(to_char(ap.start_date,'YYYY.MM.DD'),to_char(sysdate,'YYYY.MM.DD')),
                               to_char(sysdate,'YYYY.MM.DD'),
                               'success','info')))) as badge_class,       
                       --
                       -- pie chart icon in 10% chunks that show time percent complete
                       --
                       'fa-pie-chart-'||sp_date_range_pct_comp(ap.start_date, ap.end_date) icon,
                       --
                       -- current or future
                       --
                       --case when trunc(sysdate) <= trunc(ap.end_date) and trunk
                       decode (trunc(sysdate),trunc(ap.end_date),'Current',
                       decode (trunc(sysdate),trunc(ap.start_date),'Current',
                       decode(
                           greatest(trunc(sysdate),trunc(ap.end_date)),
                           trunc(sysdate),
                           'Past',
                           decode(
                               greatest(trunc(sysdate),trunc(ap.start_date)),
                               trunc(sysdate),
                               'Current',
                               'Future')
                           ))) timeframe
                           
                from sp_activities ap,
                     sp_activity_types at,
                     sp_team_members tm
                where 
                      --
                      -- activity to activity type join
                      --
                      ap.activity_type_id = at.id and
                      --
                      -- show only current logged in user
                      --
                      tm.id = (select id from sp_team_members where email = lower(:APP_USER)) and
                      --
                      -- join team member detail
                      --
                      ap.team_member_id = tm.id and
                      --
                      --
                      --
                      trunc(sysdate) <= trunc(ap.end_date)
                ```
        }
        orderBy {
            type: staticValue
            orderByClause: end_date
        }
        layout {
            sequence: 31
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--scrollBody
            ]
            icon: " "
        }
        accessibility {
            landmarkType: region
        }
        security {
            authorizationScheme: @contribution-rights
        }
        config {
            buildOption: @activity-planning
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &COMMENTS.
            description:
                ```html
                <strong>&ACTIVITY_TYPE.</strong>: &TIMELINE.<br>
                {if PROJECT/}<strong>&NOMENCLATURE_PROJECT.</strong>: &PROJECT.<br>{endif/}
                {if INITIATIVE/}<strong>&NOMENCLATURE_INITIATIVE.</strong>: &INITIATIVE.<br>{endif/}
                ```
            miscellaneous: &LAST_UPDATED.
            displayAvatar: true
            displayBadge: true
        }
        plugin-avatar {
            icon: &ICON.
            description: Percentage of time elapsed
            shape: noShape
            size: small
        }
        plugin-badge {
            label: &NOMENCLATURE_PROJECTS.
            value: TIMEFRAME
            state: BADGE_CLASS
        }
        pagination {
            entitiesPerPage: 5
        }
        messages {
            whenNoDataFound: You have no current of future activities identified.
        }

