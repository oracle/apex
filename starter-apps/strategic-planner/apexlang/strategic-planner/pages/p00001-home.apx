    dynamicAction toggle-favorite (
        name: toggle favorite
        execution {
            sequence: 60
        }
        when {
            selectionType: items
            items: P1_PROJECT_TO_FAVORITE
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_favorite_toggle(
                        p_project_id => :P1_PROJECT_TO_FAVORITE, 
                        p_app_user_id => :APP_USER_ID
                        );
                    ```
                itemsToSubmit: P1_PROJECT_TO_FAVORITE
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    var favButton$ = $(".js-project-to-favorite");
                    var favButtonIcon$ = favButton$.find(".t-Icon");
                    
                    // we use the class to get the active element, can be cleared now
                    favButton$.removeClass("js-project-to-favorite"); 
                    
                    if ( favButtonIcon$.hasClass("fa-heart") ) {
                        favButtonIcon$.removeClass("fa-heart u-danger-text").addClass("fa-heart-o");
                        // hide success message, no API to do this so done with classes
                        $( "#APEX_SUCCESS_MESSAGE" ).removeClass("u-visible").addClass("u-hidden"); 
                    } else if ( favButtonIcon$.hasClass("fa-heart-o") ) {
                        favButtonIcon$.removeClass("fa-heart-o").addClass("fa-heart u-danger-text");
                        apex.message.showPageSuccess('Project favorited!');
                    }
                    apex.items.P1_PROJECT_TO_FAVORITE.setValue('',undefined,true); //third parameter used to suppress change event
                    ```
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    computation last-proj-jump-pg (
        itemName: LAST_PROJ_JUMP_PG
        execution {
            sequence: 30
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

    computation last-project-view (
        itemName: LAST_PROJECT_VIEW
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            type: staticValue
            staticValue: 1
        }
    )

    branch (
        name: search projects
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 23
                items: {
                    P23_SEARCH: &P1_SEARCH.
                }
                clearCache: 23
                action: resetPagination
            }
        }
    )

)

