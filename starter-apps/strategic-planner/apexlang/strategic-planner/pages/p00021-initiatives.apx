                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: FOCUS_AREA
            }
        )

        facet P21_HIDDEN_BY_DEFAULT (
            type: checkboxGroup
            label {
                label: Default Display
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: HIDDEN_BY_DEFAULT
            }
        )

        facet P21_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P21_SPONSOR (
            type: checkboxGroup
            label {
                label: Owner
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: SPONSOR
            }
        )

        facet P21_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P21_UPDATED_MONTH (
            type: checkboxGroup
            label {
                label: Updated Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: UPDATED_MONTH
            }
        )

    )

    region items (
        name: items
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 2
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
                margin-bottom-none
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu about-nomenclature-initiatives (
                label: About &NOMENCLATURE_INITIATIVES.
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 106
                    }
                }
                appearance {
                    icon: fa-info
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 40
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 21
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 21
                        clearCache: 21
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

        action add-nomenclature-initiative (
            position: primaryActions
            template: button
            label: Add &NOMENCLATURE_INITIATIVE.
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 170
                    clearCache: [
                        170
                        171
                        172
                        173
                        174
                        175
                    ]
                    action: resetPagination
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-plus
                hot: true
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

    )

    region nomenclature-initiatives (
        name: &NOMENCLATURE_INITIATIVES.
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select i.ID,
                       --
                       i.AREA_ID,
                       i.INITIATIVE,
                       --
                       --shortened objective
                       --
                       decode(i.OBJECTIVE,null,'No description provided',substr(i.OBJECTIVE,1,80)||decode(greatest(length(i.objective),80),80,null,'...')) OBJECTIVE,
                       --
                       -- owner
                       --
                       tm.id owner_id,
                       case when tm.id is null then '(No Owner)' else tm.first_name||' '||tm.last_name end SPONSOR,
                       --
                       -- updated and created dates
                       --
                       i.CREATED,
                       i.CREATED_BY,
                       greatest(i.updated,nvl((
                           select max(updated) 
                           from sp_projects p 
                           where p.initiative_id = i.id and
                                 p.DUPLICATE_OF_PROJECT_ID is null and
                                 ARCHIVED_YN = 'N'),
                                 i.updated)) updated,
                       i.UPDATED_BY,
                       to_char(i.created,'YYYY.MM') created_month,
                       to_char(i.updated,'YYYY.MM') updated_month,
                       --
                       -- project counts
                       --
                       (select count(*) 
                       from sp_projects p 
                       where p.initiative_id = i.id and 
                             p.DUPLICATE_OF_PROJECT_ID is null and
                             ARCHIVED_YN = 'N') projects,
                       --
                       (select count(*) 
                       from sp_projects p 
                       where p.initiative_id = i.id and 
                             p.DUPLICATE_OF_PROJECT_ID is null and
                             p.pct_complete != 0 and 
                             p.pct_complete != 100 and
                             ARCHIVED_YN = 'N') open_projects,
                       --
                       (select count(*) 
                       from sp_projects p 
                       where p.initiative_id = i.id and 
                             p.DUPLICATE_OF_PROJECT_ID is null and
                             p.pct_complete = 100 and
                             ARCHIVED_YN = 'N') projects_100,
                       --
                       -- last project update
                       --
                       nvl((select max(p.updated) 
                        from sp_projects p 
                        where p.initiative_id = i.id and 
                              p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null ),i.updated) last_project_update,
                       --
                       -- image
                       --
                       case when i.image is not null then i.image else f.image end image,
                       case when i.image is not null then i.image_mimetype else f.image_mimetype end image_mimetype,
                       case when i.image is not null then i.image_name else f.image_name end image_name, 
                       case when i.image is not null then i.image_last_updated else f.image_last_updated end image_last_updated,  
                       --
                       -- other
                       --
                       f.AREA focus_area,
                       i.tags,
                       decode(i.hidden_by_default_yn,'Y','Hidden','N','Visible','Visible') hidden_by_default
                  from SP_INITIATIVES i, 
                       sp_areas f,
                       sp_team_members tm
                  where i.area_id = f.id and
                        i.SPONSOR_ID = tm.id(+)
                ```
        }
        orderBy {
            type: item
            item: {
                itemName: P21_ORDER_BY
                orderBys: {
                    INITIATIVE: initiative
                    UPDATED: updated desc
                    PROJECTS: projects desc
                    OPEN_PROJECTS: open_projects desc
                    LAST_PROJECT_UPDATE: last_project_update desc nulls last
                }
            }
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: clear-avatar-icons
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &INITIATIVE!HTML.
            description:
                ```html
                &NOMENCLATURE_AREA!HTML.: <strong>&FOCUS_AREA!HTML.</strong><br>
                &NOMENCLATURE_PROJECTS!HTML.: <strong>&PROJECTS.</strong>, with &OPEN_PROJECTS. open, and &PROJECTS_100. resolved<br>
                &OBJECTIVE!HTML.
                
                ```
            miscellaneous:
                ```html
                &SPONSOR!HTML.<br>
                &LAST_PROJECT_UPDATE.
                ```
            displayAvatar: true
        }
        plugin-avatar {
            type: image
            image: {
                type: blobColumn
                blobColumn: IMAGE
                filenameColumn: IMAGE_NAME
                mimeTypeColumn: IMAGE_MIMETYPE
                lastUpdatedColumn: IMAGE_LAST_UPDATED
            }
            description: &NOMENCLATURE_INITIATIVES. Icon
            size: medium
        }

