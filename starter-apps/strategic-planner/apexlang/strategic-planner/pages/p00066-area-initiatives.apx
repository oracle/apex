        layout {
            sequence: 10
            region: @nomenclature-initiatives
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P66_IMAGE (
        type: displayImage
        label {
            label: Image
            alignment: left
        }
        settings {
            basedOn: blobColSql
            sqlQuery:
                ```sql
                select image,
                       image_name alt_text,
                       image_name,
                       image_mimetype
                  from sp_areas
                 where id = :P66_AREA_ID
                ```
        }
        layout {
            sequence: 10
            region: @area-details
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            cssClasses: initiative-icon
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                 
                select 1
                  from sp_areas
                 where id = :P66_AREA_ID
                   and image is not null
                ```
        }
    )

    pageItem P66_ORDER_BY (
        type: selectList
        label {
            label: Order By
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:&NOMENCLATURE_INITIATIVE. Name;INITIATIVE,Updated most recent first;UPDATED,Created most recent first;CREATED,&NOMENCLATURE_PROJECTS. count;PROJECTS,Open &NOMENCLATURE_PROJECTS.;OPEN_PROJECTS,Last Project Updated;LAST_PROJECT_UPDATE
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            region: @sort-container
            slot: next
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            cssClasses: u-pullRight
            icon: fa-sort-amount-desc
            height: 1
        }
        validation {
            valueRequired: true
        }
        advanced {
            cssClasses: [
                w240
                no-item-ui
            ]
            warnOnUnsavedChanges: ignore
        }
        default {
            type: static
            staticValue: LAST_PROJECT_UPDATE
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 17
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-dc (
        name: refresh on DC
        execution {
            sequence: 30
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @nomenclature-initiatives
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @nomenclature-initiatives
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @faceted-search
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-dialog-closed (
        name: refresh on dialog closed
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @breadcrumb
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @faceted-search
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    dynamicAction refresh-on-dialog-menubar (
        name: refresh on dialog menubar
        execution {
            sequence: 20
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @breadcrumb
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @contextual-information
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-refresh-2 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @faceted-search
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh-3 (
            action: refresh
            affectedElements {
                selectionType: region
                region: @nomenclature-initiatives
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

    computation p66-area (
        itemName: P66_AREA
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery: select area from sp_areas where id = :P66_AREA_ID
        }
    )

)

