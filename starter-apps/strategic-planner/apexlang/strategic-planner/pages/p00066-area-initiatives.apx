    region nomenclature-initiatives (
        name: &NOMENCLATURE_INITIATIVES.
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select i.ID,
                       'No' Favorite,
                       i.area_id FOCUS_AREA_ID,
                       i.INITIATIVE,
                       --
                       -- shortened objective
                       --
                       decode(i.objective,null,'No description provided',substr(i.OBJECTIVE,1,100)||decode(greatest(length(i.objective),100),100,null,'...')) OBJECTIVE,
                       --
                       -- owner
                       --
                       nvl(tm.first_name||' '||tm.last_name,'Unknown') SPONSOR,
                       tm.id sponsor_id,
                       --
                       -- dates
                       --
                       i.CREATED,
                       i.CREATED_BY,
                       greatest(i.updated,nvl((select max(updated) from sp_projects p where p.initiative_id = i.id and ARCHIVED_YN = 'N'),i.updated)) updated,
                       --
                       -- projects
                       --
                       (select count(*) 
                        from sp_projects p 
                        where p.initiative_id = i.id and 
                              p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null ) projects,
                       --
                       -- last project update
                       --
                       nvl((select max(p.updated) 
                        from sp_projects p 
                        where p.initiative_id = i.id and 
                              p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null ),i.updated) last_project_update,
                       --
                       -- open projects
                       --
                       (select count(*) 
                        from sp_projects p 
                        where p.initiative_id = i.id and 
                              p.ARCHIVED_YN = 'N' and 
                              p.pct_complete != 0 and 
                              p.pct_complete != 100 and
                              p.DUPLICATE_OF_PROJECT_ID is null ) open_projects,
                       f.area focus_area,
                       to_char(i.created,'YYYY.MM') created_month,
                       to_char(i.updated,'YYYY.MM') updated_month,
                       nvl((select scale_name from sp_project_scales where scale_letter = nvl(i.status_scale,'A')),i.status_scale) status_scale,
                       --
                       -- activities
                       --
                       (select count(*) 
                        from sp_activities ap 
                        where ap.initiative_id = i.id) initiative_activities,
                       --
                       -- image
                       --
                       i.image,
                       i.image_mimetype,
                       i.image_name, 
                       i.image_last_updated,
                       --
                       -- other
                       --
                       i.tags,
                       decode(nvl(i.hidden_by_default_yn,'N'),'Y','Hidden','N','Visible','Visible') hidden_by_default
                  from SP_INITIATIVES i, 
                       sp_areas f,
                       sp_team_members tm
                  where i.area_id = f.id and
                        f.id = :P66_AREA_ID and
                        i.sponsor_id = tm.id(+)
                ```
            pageItemsToSubmit: P66_AREA_ID
        }
        orderBy {
            type: item
            item: {
                itemName: P66_ORDER_BY
                orderBys: {
                    INITIATIVE: initiative
                    UPDATED: updated desc
                    CREATED: created desc
                    PROJECTS: projects desc
                    OPEN_PROJECTS: open_projects desc
                    LAST_PROJECT_UPDATE: last_Project_update desc nulls last
                }
            }
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
            cssClasses: clear-avatar-icons
        }
        accessibility {
            landmarkType: region
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &INITIATIVE.
            description:
                ```html
                &NOMENCLATURE_AREA.: <strong>&FOCUS_AREA.</strong><br>
                &NOMENCLATURE_PROJECTS.: <strong>&PROJECTS.</strong>, with &OPEN_PROJECTS. open<br>
                &NOMENCLATURE_INITIATIVE. Activities: <strong>&INITIATIVE_ACTIVITIES.<br>
                </strong>&OBJECTIVE.
                ```
            miscellaneous:
                ```html
                &SPONSOR.<br>
                &LAST_PROJECT_UPDATE.
                ```
            displayAvatar: true
        }
        plugin-avatar {
            type: image
            image: {
                type: blobColumn
                blobColumn: IMAGE
                filenameColumn: IMAGE_NAME
                mimeTypeColumn: IMAGE_MIMETYPE
                lastUpdatedColumn: IMAGE_LAST_UPDATED
            }
            description: &NOMENCLATURE_INITIATIVE. Icon
            size: medium
        }
        pagination {
            entitiesPerPage: 20
        }

