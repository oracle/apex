            }
        )

        column PHOTO (
            layout {
                sequence: 190
            }
            source {
                databaseColumn: PHOTO
                dataType: blob
            }
        )

        column PHOTO_FILENAME (
            layout {
                sequence: 220
            }
            source {
                databaseColumn: PHOTO_FILENAME
                dataType: varchar2
            }
        )

        column PHOTO_MIMETYPE (
            layout {
                sequence: 200
            }
            source {
                databaseColumn: PHOTO_MIMETYPE
