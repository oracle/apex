            layout {
                sequence: 60
            }
            source {
                databaseColumn: CREATED
                dataType: date
            }
        )

        column CREATED_BY (
            layout {
                sequence: 70
            }
            source {
                databaseColumn: CREATED_BY
                dataType: varchar2
            }
        )

        column CREATED_MONTH (
