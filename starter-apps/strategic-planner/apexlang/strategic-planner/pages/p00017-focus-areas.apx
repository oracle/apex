                sequence: 100
            }
            source {
                databaseColumn: CREATED_MONTH
                dataType: varchar2
            }
        )

        column DESCRIPTION (
            layout {
                sequence: 30
            }
            source {
                databaseColumn: DESCRIPTION
                dataType: varchar2
            }
        )

        column FOCUS_AREA (
            layout {
                sequence: 20
            }
            source {
                databaseColumn: FOCUS_AREA
                dataType: varchar2
            }
        )

        column HIDDEN_BY_DEFAULT (
            layout {
                sequence: 160
            }
            source {
                databaseColumn: HIDDEN_BY_DEFAULT
                dataType: varchar2
            }
        )

        column ID (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ID
                dataType: number
                primaryKey: true
            }
        )

        column IMAGE (
            layout {
                sequence: 240
            }
            source {
                databaseColumn: IMAGE
                dataType: blob
            }
        )

        column IMAGE_LAST_UPDATED (
            layout {
                sequence: 270
            }
            source {
                databaseColumn: IMAGE_LAST_UPDATED
                dataType: date
            }
        )

        column IMAGE_MIMETYPE (
            layout {
                sequence: 250
            }
            source {
                databaseColumn: IMAGE_MIMETYPE
                dataType: varchar2
            }
        )

        column IMAGE_NAME (
            layout {
                sequence: 260
            }
            source {
                databaseColumn: IMAGE_NAME
                dataType: varchar2
            }
        )

        column INITIATIVES (
            layout {
                sequence: 130
            }
            source {
                databaseColumn: INITIATIVES
                dataType: number
            }
        )

        column LAST_CREATED_PROJECT (
            layout {
                sequence: 150
            }
