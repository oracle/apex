page 17 (
    name: Focus Areas
    alias: FOCUS-AREAS
    title: &NOMENCLATURE_AREA.
    pageGroup: @areas
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: [
            #DEFAULT#
            t-PageBody--noContentPadding
        ]
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    css {
        inline:
            ```css
            .a-CardView-actions {
              --a-cv-actions-padding-x: .5rem;
              --a-cv-actions-padding-y: .5rem;
              --a-cv-actions-background-color: transparent;
            }
            
            .no-item-ui {
              --a-field-input-border-width: 0px;
              --a-field-input-background-color: transparent;
            }
            
            .a-CardView-iconWrap {
              align-self: flex-start;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region faceted-search (
        name: faceted search
        type: facetedSearch
        source {
            filteredRegion: @nomenclature-areas
        }
        layout {
            sequence: 20
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            displayChartForTopNValues: 10
        }

        facet P17_CREATED_MONTH (
            type: checkboxGroup
            label {
                label: Created Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: CREATED_MONTH
            }
        )

        facet P17_HIDDEN_BY_DEFAULT (
            type: checkboxGroup
            label {
                label: Default Display
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: HIDDEN_BY_DEFAULT
            }
        )

        facet P17_LAST_CREATED_PROJECT (
            type: checkboxGroup
            label {
                label: Last Created Project
            }
            lov {
                type: distinctValues
                sortDirection: desc
            }
            layout {
                sequence: 60
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: LAST_CREATED_PROJECT
            }
        )

        facet P17_OWNER (
            type: checkboxGroup
            label {
                label: Owner
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: OWNER
            }
        )

        facet P17_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
        )

        facet P17_TAGS (
            type: checkboxGroup
            label {
                label: Tags
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: TAGS
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
        )

        facet P17_UPDATED_MONTH (
            type: checkboxGroup
            label {
                label: Updated Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: UPDATED_MONTH
            }
        )

    )

    region menubar (
        name: Menubar
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery: select 1 as actions from dual
        }
        layout {
            sequence: 10
            parentRegion: @breadcrumb
            slot: subRegions
        }
        componentAppearance {
            display: partial
            cssClasses: header-actions
        }

        column ACTIONS (
            layout {
                sequence: 10
            }
            source {
                databaseColumn: ACTIONS
                dataType: number
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
            }

            menu about-nomenclature-areas (
                label: About &NOMENCLATURE_AREAS.
                layout {
                    sequence: 30
                }
                behavior {
                    target: {
                        page: 105
                    }
                }
                appearance {
                    icon: fa-info
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 40
                }
            )

            menu refresh (
                label: Refresh
                layout {
                    sequence: 60
                }
                behavior {
                    target: {
                        page: 17
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-refresh
                }
            )

            menu reset (
                label: Reset
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 17
                        items: {
                            P17_HIDDEN_BY_DEFAULT: Visible
                        }
                        clearCache: 17
                        action: clearRegions
                    }
                }
                appearance {
                    icon: fa-undo-alt
                }
            )

        )

        action add-nomenclature-area (
            position: primaryActions
            template: button
            label: Add &NOMENCLATURE_AREA.
            layout {
                sequence: 10
            }
            behavior {
                target: {
                    page: 18
                    clearCache: 18
                    action: resetPagination
                }
            }
            appearance {
                displayType: textWithIcon
                icon: fa-plus
                hot: true
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

    )

    region nomenclature-areas (
        name: &NOMENCLATURE_AREAS.
        type: themeTemplateComponent/contentRow
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select f.ID,
                       f.area FOCUS_AREA,
                       substr(f.DESCRIPTION,1,80)||decode(greatest(length(f.DESCRIPTION),80),80,null,'...') DESCRIPTION,
                       case when tm.id is null then '(No Owner)' else tm.first_name||' '||tm.last_name end OWNER,
                       --
                       -- created
                       --
                       f.CREATED,
                       f.CREATED_BY,
                       --
                       to_char(f.updated,'YYYY.MM') updated_month,
                       to_char(f.created,'YYYY.MM') created_month,
                       f.updated upd_date,
                       f.UPDATED_BY,
                       f.tags,
                       --
                       -- profile photo
                       --
                       tm.photo,
                       tm.photo_mimetype, 
                       tm.id team_member_id,
                       tm.photo_filename,   
                       tm.updated profile_updated,  
                       --
                       -- image
                       --
                       f.image,
                       f.image_mimetype,
                       f.image_name, 
                       f.image_last_updated,  
                       --
                       -- initiatives
                       --
                       (select count(*) 
                        from SP_INITIATIVES i 
                        where i.AREA_ID = f.id) initiatives,
                       --
                       -- projects
                       --
                       (select count(*) 
                        from SP_PROJECTS p 
                        where ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null and
                              p.initiative_id in 
                          (select distinct id 
                           from SP_INITIATIVES i 
                            where i.AREA_ID = f.id)) projects,
                       --
                       (select count(*) 
                        from SP_PROJECTS p 
                        where ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null and
                              p.pct_complete != 0 and 
                              p.pct_complete != 100 and
                              p.initiative_id in 
                          (select distinct id 
                           from SP_INITIATIVES i 
                            where i.AREA_ID = f.id)) open_projects,
                       --
                       nvl((select max(p.updated) 
                        from SP_PROJECTS p 
                        where ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null and
                              p.initiative_id in 
                          (select distinct id 
                           from SP_INITIATIVES i 
                            where i.AREA_ID = f.id)),f.updated) last_project_update,
                       --
                       -- most recently created project
                       --
                       (select max(to_char(created,'YYYY.MM')) 
                        from SP_PROJECTS p 
                        where p.ARCHIVED_YN = 'N' and 
                              p.DUPLICATE_OF_PROJECT_ID is null and
                              p.initiative_id in 
                              (select distinct id from SP_INITIATIVES i where i.AREA_ID = f.id)) last_created_project,
                       --
                       decode(f.hidden_by_default_yn,'Y','Hidden','N','Visible','Visible') hidden_by_default
                  from SP_AREAS f,
                       sp_team_members tm
                  where f.OWNER_ID = tm.id(+)
                ```
        }
        orderBy {
            type: item
            item: {
                itemName: P17_ORDER_BY
                orderBys: {
                    FOCUS_AREA: FOCUS_AREA
                    PROJECTS: projects desc
                    OPEN_PROJECTS: open_projects desc
                    UPDATED: upd_date desc
                    UPD_DATE: upd_date asc
                    INITIATIVES: initiatives desc
                    LAST_PROJECT_UPDATE: LAST_PROJECT_UPDATE desc nulls last
                }
            }
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes-no-grid
            templateOptions: #DEFAULT#
            cssClasses: clear-avatar-icons
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &FOCUS_AREA!HTML.
            description:
                ```html
                &NOMENCLATURE_INITIATIVES.: <strong>&INITIATIVES.</strong><br>
                &NOMENCLATURE_PROJECTS.: <strong>&PROJECTS.</strong>, with &OPEN_PROJECTS. open<br>
                &DESCRIPTION!HTML.
                ```
            miscellaneous:
                ```html
                &OWNER.<br>
                &LAST_PROJECT_UPDATE.
                ```
            displayAvatar: true
        }
        plugin-avatar {
            type: image
            image: {
                type: blobColumn
                blobColumn: IMAGE
                filenameColumn: IMAGE_NAME
                mimeTypeColumn: IMAGE_MIMETYPE
                lastUpdatedColumn: IMAGE_LAST_UPDATED
            }
            description: &NOMENCLATURE_AREAS. Icon
            size: medium
        }

