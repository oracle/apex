            layout {
                sequence: 190
                columnAlignment: center
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: S
            }
        )

        column DOCUMENTS (
            type: plainText
            heading {
                heading: Documents
                alignment: end
            }
            layout {
                sequence: 170
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: Q
            }
        )

        column DUPLICATE_OF (
            type: plainText
