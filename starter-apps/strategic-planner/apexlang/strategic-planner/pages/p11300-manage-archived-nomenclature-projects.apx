            }
            advanced {
                endUserAlias: G
            }
        )

        page {
            borderWidth: 0.5
            borderColor: #666666
        }
        pageHeader {
            pageHeaderText: Archived &NOMENCLATURE_PROJECTS.
        }

        savedReport 118157234 (
            visibility: primaryDefault
            view {
                rowsPerPage: 50
            }

            displayColumn ARCHIVED_DATE (
                sequence: 3
            )

            displayColumn COMMENTS (
                sequence: 5
            )

            displayColumn CONTRIBUTORS (
                sequence: 6
            )

            displayColumn CREATED (
                sequence: 8
            )

            displayColumn DOCUMENTS (
                sequence: 7
            )

            displayColumn PRIORITY (
                sequence: 4
            )

            displayColumn PROJECT (
                sequence: 1
            )

            displayColumn THE_OWNER (
                sequence: 2
            )

            displayColumn UPDATED (
                sequence: 9
            )

            sort (
                column: UPDATED
                sort {
                    direction: desc
                    sequence: 1
                }
            )

            filter ir-condition (
                column: ARCHIVED_YN
                value: Y
            )

        )

    )

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button reset (
        buttonName: reset
        label: Reset
        layout {
            sequence: 20
            region: @breadcrumb
            slot: change
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-undo-alt
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 11300
                clearCache: 11300
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 10000
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-on-close (
        name: refresh on close
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @archived-nomenclature-projects
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @archived-nomenclature-projects
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)

