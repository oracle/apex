page 11300 (
    name: Manage Archived Projects
    alias: MANAGE-ARCHIVED-NOMENCLATURE-PROJECTS
    title: Manage Archived &NOMENCLATURE_PROJECTS.
    pageGroup: @administrative-utilities
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
        cssClasses: rw-pillar--sienna
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        authorizationScheme: @administration-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region archived-nomenclature-projects (
        name: Archived &NOMENCLATURE_PROJECTS.
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select a.ID,
                       a.PROJECT,
                       a.friendly_identifier,
                       (select FIRST_NAME ||' '||last_name from SP_TEAM_MEMBERS x where x.ID = a.OWNER_ID) the_owner,
                       (select 'P'||PRIORITY from SP_PROJECT_PRIORITIES x where x.ID = a.PRIORITY_ID) priority,
                       a.PROJECT_SIZE,
                       a.UPDATED,
                       a.created,
                       null attributes,
                       a.owner_id,
                       ARCHIVED_YN,
                       ARCHIVED_DATE,
                       ARCHIVED_BY,
                       (select project from sp_projects b where b.id = a.DUPLICATE_OF_PROJECT_ID) duplicate_of,
                       a.DUPLICATE_OF_PROJECT_ID,
                       (select count(*) from sp_project_comments c where c.project_id = a.id) comments,
                       (select count(*) from sp_project_contributors c2 where c2.project_id = a.id) contributors,
                       (select count(*) from SP_PROJECT_DOCUMENTS d where d.project_id = a.id) documents
                from SP_PROJECTS a
                where ARCHIVED_YN = 'Y'
                
                
                
                
                ```
        }
        layout {
            sequence: 30
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        link {
            linkColumn: customTarget
            target: {
                page: 11310
                items: {
                    P11310_ID: #ID#
                }
                clearCache: 11310
                action: resetPagination
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 1000000
        }
        advanced {
            savedReportMappingIdentifier: 11815539336042369901
        }

        column ARCHIVED_BY (
            type: plainText
            heading {
                heading: Archived By
            }
            layout {
                sequence: 120
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: L
            }
        )

        column ARCHIVED_DATE (
            type: plainText
            heading {
                heading: Archived
            }
            layout {
                sequence: 110
                columnAlignment: center
            }
            appearance {
                formatMask: DD-MON-YYYY HH24:MI
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: K
            }
        )

        column ARCHIVED_YN (
            type: plainText
            heading {
                heading: Archived
            }
            layout {
                sequence: 100
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: J
            }
        )

        column ATTRIBUTES (
            type: plainText
            heading {
                heading: Attributes
                alignment: center
            }
            layout {
                sequence: 80
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: H
            }
        )

        column COMMENTS (
            type: plainText
            heading {
                heading: Comments
                alignment: end
            }
            layout {
                sequence: 150
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: O
            }
        )

        column CONTRIBUTORS (
            type: plainText
            heading {
                heading: Contributors
                alignment: end
            }
            layout {
                sequence: 160
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            advanced {
                endUserAlias: P
