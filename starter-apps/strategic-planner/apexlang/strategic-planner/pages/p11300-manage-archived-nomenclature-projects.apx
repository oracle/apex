            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: E
            }
        )

        column PROJECT (
            type: link
            heading {
                heading: &NOMENCLATURE_PROJECT.
            }
            layout {
                sequence: 20
            }
            link {
                target: {
                    page: 3
