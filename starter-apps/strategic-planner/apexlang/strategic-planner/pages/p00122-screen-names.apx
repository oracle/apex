page 122 (
    name: Screen Names
    alias: SCREEN-NAMES
    title: Screen Names
    pageGroup: @reporting
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: The short hand screen name assigned to &NOMENCLATURE_USERS. within the application.  These are used to tag a &NOMENCLATURE_USER. in a comment which results in a notification.
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region screen-names (
        name: Screen Names
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                SELECT 
                    ID, 
                    FIRST_NAME, 
                    LAST_NAME, 
                    FIRST_NAME||' '||last_name name,
                    INITIALS, 
                    EMAIL, 
                    EMAIL_DOMAIN, 
                    TAGS, 
                    HASH_TAG_REFERENCE, 
                    PHOTO_FILENAME, 
                    IS_CURRENT_YN, 
                    CREATED, 
                    CREATED_BY, 
                    UPDATED, 
                    UPDATED_BY, 
                    APP_ROLE, 
                    LOCATION, 
                    COMPETENCIES, 
                    SCREEN_NAME 
                FROM SP_TEAM_MEMBERS;
                ```
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/interactive-report
            templateOptions: [
                #DEFAULT#
                t-IRR-region--hideHeader js-addHiddenHeadingRoleDesc
            ]
        }
        pagination {
            type: rowRangesXToY
        }
        messages {
            whenNoDataFound: No data found.
            whenMoreDataFound: The maximum row count for this report is #MAX_ROW_COUNT# rows.  Please apply a filter to reduce the number of records in your query.
        }
        advanced {
            savedReportMappingIdentifier: 9815976501146382704
        }

        column APP_ROLE (
            type: plainText
            heading {
                heading: App Role
            }
            layout {
                sequence: 133
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: U
            }
        )

        column COMPETENCIES (
            type: plainText
            heading {
                heading: Competencies
            }
            layout {
                sequence: 153
            }
            source {
                dataType: STRING
            }
            advanced {
                endUserAlias: X
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 93
            }
            appearance {
                formatMask: SINCE
            }
            source {
                dataType: DATE
            }
            advanced {
                endUserAlias: Q
            }
        )

        column CREATED_BY (
            type: plainText
            heading {
                heading: Created By
            }
            layout {
                sequence: 103
            }
