            }
            layout {
                sequence: 13
            }
            link {
                target: {
                    page: 73
                    items: {
                        P73_TEAM_MEMBER_ID: #ID#
                    }
                    clearCache: 73
                    action: resetPagination
                }
                linkText: #NAME#
            }
            source {
                dataType: STRING
            }
            advanced {
