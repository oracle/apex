page 54 (
    name: Add Multiple &NOMENCLATURE_USERS.
    alias: ADD-MULTIPLE-PEOPLE
    title: Add Multiple &NOMENCLATURE_USERS.
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
        resizable: false
    }
    security {
        authorizationScheme: @contribution-rights
        deepLinking: false
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @access-control
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 10
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
    )

    region wizard-container (
        name: Wizard Container
        type: staticContent
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                t-Form--stretchInputs
            ]
        }
    )

    pageItem P54_PRELIM_USERS (
        type: textarea
        label {
            label: &NOMENCLATURE_USERS.
            alignment: left
        }
        layout {
            sequence: 30
            region: @wizard-container
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 80
            height: 10
            valuePlaceholder: Enter usernames here
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        security {
            sessionStateProtection: restricted
        }
        help {
            inlineHelpText: Type or paste text that contains emails above
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: previous
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
            executeValidations: false
        }
    )

    button next (
        buttonName: NEXT
        label: Next
        layout {
            sequence: 10
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconRight
            ]
            icon: fa-chevron-right
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process create-collections (
        name: Create Collections
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_line      varchar2(32767);
                    l_emails    apex_t_varchar2;
                    l_username  varchar2(4000);
                    l_at        number;
                    l_dot       number;
                    l_valid     boolean := true;
                    l_domain    varchar2(4000);
                begin
                    -- create collections
                    apex_collection.create_or_truncate_collection('BULK_USER_INVALID');
                    apex_collection.create_or_truncate_collection('BULK_USER_VALID');
                
                    -- replace delimiting characters with commas
                    l_line := :P54_PRELIM_USERS;
                    l_line := replace(l_line, chr(10), ' ');
                    l_line := replace(l_line, chr(13), ' ');
                    l_line := replace(l_line, chr(9),  ' ');
                    l_line := replace(l_line, '<', ' ');
                    l_line := replace(l_line, '>', ' ');
                    l_line := replace(l_line, ';', ' ');
                    l_line := replace(l_line, ':', ' ');
                    l_line := replace(l_line, '(', ' ');
                    l_line := replace(l_line, ')', ' ');
                    l_line := replace(l_line, ' ', ',');
                
                    -- get one comma separated line of emails
                    for j in 1 .. 1000 loop
                        if instr(l_line, ',,') > 0 then
                            l_line := replace(l_line, ',,', ',');
                        else
                            exit;
                        end if;
                    end loop;
                
                    -- get an array of emails
                    l_emails := apex_string.split(l_line, ',');
                
                    -- add emails to a collection
                    l_username := null;
                    l_domain   := null;
                    l_at       := 0;
                    l_dot      := 0;
                    for j in 1..l_emails.count loop
                        l_valid    := true;
                        l_username := upper(trim(l_emails(j)));
                        l_username := trim(both '.' from l_username);
                        l_username := replace(l_username, ' ', null);
                        l_username := replace(l_username, chr(10), null);
                        l_username := replace(l_username, chr(9), null);
                        l_username := replace(l_username, chr(13), null);
                        l_username := replace(l_username, chr(49824), null);
                
                        --
                        -- format must be email
                        --
                        if l_username is not null then
                              -- Validate
                              l_at     := instr(nvl(l_username, 'x'), '@');
                              l_domain := substr(l_username, l_at+1);
                              l_dot    := instr(l_domain, '.');
                              if l_at < 2 then
                                  -- invalid email
                                  apex_collection.add_member(
                                      p_collection_name => 'BULK_USER_INVALID',
                                      p_c001            => l_username,
                                      p_c002            => apex_lang.message('APEX.FEATURE.ACL.BULK_USER.MISSING_AT_SIGN'));
                                  commit;
                                  l_valid := false;
                              end if;
                
                              if l_dot = 0 and l_valid then
                                  apex_collection.add_member(
                                      p_collection_name => 'BULK_USER_INVALID',
                                      p_c001            => l_username,
                                      p_c002            => apex_lang.message('APEX.FEATURE.ACL.BULK_USER.MISSING_DOT'));
                                  commit;
                                  l_valid := false;
                              end if;
                
                            if l_valid and length(l_username) > 255 then
                                apex_collection.add_member(
                                    p_collection_name => 'BULK_USER_INVALID',
                                    p_c001            => l_username,
                                    p_c002            => apex_lang.message('APEX.FEATURE.ACL.BULK_USER.USERNAME_TOO_LONG'));
                                commit;
                                l_valid := false;
                            end if;
                
                            --
                            -- check to see if user exists
                            -- emails in table SP_TEAM_MEMBERS are lower case
                            --
                            if l_valid then
                                for c1 in (select EMAIL
                                             from SP_TEAM_MEMBERS
                                            where email = lower(l_username))
                                loop
                                    apex_collection.add_member(
                                        p_collection_name => 'BULK_USER_INVALID',
                                        p_c001            => l_username,
                                        p_c002            => apex_lang.message('APEX.FEATURE.ACL.BULK_USER.ALREADY_IN_ACL'));
                                    commit;
                                    l_valid := false;
                                    exit;
                                end loop;
                            end if;
                            
                            --
                            -- check if to see if email is begin attempted to be added more than once
                            --
                            if l_valid then
                                for c1 in (select c001
                                             from apex_collections
                                            where collection_name = 'BULK_USER_VALID'
                                              and c001            = l_username)
                                loop
                                    apex_collection.add_member(
                                        p_collection_name => 'BULK_USER_INVALID',
                                        p_c001            => l_username,
                                        p_c002            => apex_lang.message('APEX.FEATURE.ACL.BULK_USER.DUPLICATE_USER'));
                                        commit;
                                    l_valid := false;
                                    exit;
                                end loop;
                            end if;
                
                            --
                            -- Add email to candidate list to add
                            --
                            if l_valid then
                                apex_collection.add_member(
                                    p_collection_name => 'BULK_USER_VALID',
                                    p_c001            => l_username,
                                    p_c002            => null);
                                    commit;
                            end if;
                
                        end if;
                        l_username := null;
                    end loop;
                end;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 982267655419026383
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

    branch (
        name: "Go To Page "
        execution {
            sequence: 10
        }
        behavior {
            target: {
                page: 58
                clearCache: 58
                action: resetPagination
            }
        }
        serverSideCondition {
            whenButtonPressed: @next
        }
    )

)

