page 4013 (
    name: Initiative Approval Type
    alias: INITIATIVE-APPROVAL-TYPE
    title: &NOMENCLATURE_INITIATIVE. Approval Type
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    security {
        authorizationScheme: @contribution-rights
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    config {
        buildOption: @approvals
    }

    region approvers (
        name: Approvers
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.approval_seq, 
                       case when c.alternate_team_member_id is not null and   
                                 (c.alternate_start_date <= sysdate or c.alternate_start_date is null) and 
                                 (c.alternate_end_date+1 > sysdate or c.alternate_end_date is null)
                            then 'Alternate - '||
                                 (select last_name||', '||first_name||' ('||lower(email)||')'
                                    from sp_team_members
                                   where id = c.alternate_team_member_id)
                            else tm.last_name||', '||tm.first_name||' ('||lower(tm.email)||')' 
                        end name, 
                       decode(c.active_yn,'Y','Active','Inactive') status
                  from sp_initiative_approval_chain c,
                       sp_team_members tm
                 where c.initiative_approval_id = :P4013_ID
                   and c.team_member_id = tm.id
                 order by c.approval_seq
                ```
        }
        layout {
            sequence: 20
            slot: contentBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_initiative_approval_chain
                 where initiative_approval_id = :P4013_ID
                ```
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--altRowsDefault
                t-Report--rowHighlight
                t-Report--horizontalBorders
            ]
        }

        column APPROVAL_SEQ (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Approval Sequence
                alignment: end
            }
            layout {
                sequence: 10
                columnAlignment: end
            }
            sorting {
                sortable: false
            }
        )

        column NAME (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Name
            }
            layout {
                sequence: 20
            }
            sorting {
                sortable: false
            }
        )

        column STATUS (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Status
            }
            layout {
                sequence: 30
            }
            sorting {
                sortable: false
            }
        )

    )

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: dialogFooter
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region nomenclature-initiative-approval-type (
        name: &NOMENCLATURE_INITIATIVE. Approval Type
        type: form
        source {
            location: localDatabase
            tableName: SP_INITIATIVE_APPROVALS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
            allowedOperations: [
                add
                update
                delete
            ]
        }
    )

    pageItem P4013_ACTIVE_YN (
        type: switch
        label {
            label: Active
            alignment: left
        }
        layout {
            sequence: 80
            region: @nomenclature-initiative-approval-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @nomenclature-initiative-approval-type
            column: ACTIVE_YN
            dataType: varchar2
        }
        default {
            type: static
            staticValue: Y
        }
    )

    pageItem P4013_APPROVAL_TYPE_ID (
        type: selectOne
        label {
            label: Approval Type
            alignment: left
        }
        settings {
            infiniteScroll: false
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select approval_type d, id r
                  from sp_approval_types
                 where id not in (select approval_type_id
                                    from sp_initiative_approvals
                                   where initiative_id = :P4013_INITIATIVE_ID)
                   or id = :P4013_APPROVAL_TYPE_ID
                 order by display_seq
                ```
        }
        cascadingLov {
            parentItems: P4013_INITIATIVE_ID
        }
        layout {
            sequence: 30
            region: @nomenclature-initiative-approval-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @nomenclature-initiative-approval-type
            column: APPROVAL_TYPE_ID
            dataType: number
        }
    )

    pageItem P4013_ID (
        type: hidden
        layout {
            sequence: 10
            region: @nomenclature-initiative-approval-type
            slot: regionBody
        }
        source {
            formRegion: @nomenclature-initiative-approval-type
            column: ID
            dataType: number
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P4013_INITIATIVE_ID (
        type: selectOne
        label {
            label: &NOMENCLATURE_INITIATIVE.
            alignment: left
        }
        settings {
            infiniteScroll: false
        }
        lov {
            type: sharedComponent
            lov: @sp-initiatives-initiative
        }
        layout {
            sequence: 20
            region: @nomenclature-initiative-approval-type
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @nomenclature-initiative-approval-type
            column: INITIATIVE_ID
            dataType: number
        }
        readOnly {
            type: itemIsNotNull
            item: P4013_ID
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Add
        layout {
            sequence: 40
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P4013_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: delete
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4013_ID
        }
    )

    button save (
        buttonName: SAVE
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: next
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P4013_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    validation no-dups (
        name: no dups
        execution {
            sequence: 10
        }
        validation {
            type: noRowsReturned
            sqlQuery:
                ```sql
                select 1
                  from sp_initiative_approvals
                 where initiative_id = :P4013_INITIATIVE_ID
                   and approval_type_id = :P4013_APPROVAL_TYPE_ID
                   and (:P4013_ID is null or :P4013_ID != id)
                ```
        }
        error {
            errorMessage: Duplicate entry found.
        }
    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 11754677440101631846
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-initiative-approvals (
        name: Initialize form Initiative Approvals
        type: formInitialization
        formRegion: @nomenclature-initiative-approval-type
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 11754674528605631841
        }
    )

    process process-form-initiative-approvals (
        name: Process form Initiative Approvals
        type: formAutoRowProcessing
        formRegion: @nomenclature-initiative-approval-type
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 11754674985993631842
        }
    )

)

