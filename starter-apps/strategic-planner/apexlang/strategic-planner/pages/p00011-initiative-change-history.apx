page 11 (
    name: Initiative Change History
    alias: INITIATIVE-CHANGE-HISTORY
    title: &NOMENCLATURE_INITIATIVE. Change History
    pageGroup: @initiatives
    appearance {
        pageTemplate: @/left-side-column
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 10
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    region button-bar (
        name: Button Bar
        type: staticContent
        source {
            htmlCode: <div id="active_facets"></div>
        }
        layout {
            sequence: 10
            slot: body
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noPadding
                t-ButtonRegion--noUI
            ]
        }
    )

    region details (
        name: details
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select i.ID,
                       i.initiative,
                       (select t.first_name||' '||t.last_name
                       from SP_TEAM_MEMBERS t 
                       where t.id = i.sponsor_ID) sponsor,
                       i.created,
                       lower(i.created_by) created_by
                  from SP_INITIATIVES i,
                       SP_AREAS f
                where 
                      i.area_id = f.id and
                      i.id = :P11_INITIATIVE_ID
                ```
        }
        layout {
            sequence: 30
            slot: breadcrumbBar
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: [
                #DEFAULT#
                margin-left-md
                margin-right-md
            ]
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/contextual-info
            templateOptions: [
                #DEFAULT#
                t-ContextualInfo-label--stacked
                t-Report--hideNoPagination
            ]
        }
        performance {
            maxRowsToProcess: 500
        }
        messages {
            whenNoDataFound: no data found
        }

        column CREATED (
            reportColumnQueryId: 4
            derivedColumn: N
            heading {
                heading: Created
            }
            layout {
                sequence: 60
            }
            appearance {
                formatMask: SINCE_SHORT
            }
        )

        column CREATED_BY (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Created By
            }
            layout {
                sequence: 70
            }
        )

        column ID (
            reportColumnQueryId: 1
            derivedColumn: N
            type: hidden
            layout {
                sequence: 10
            }
        )

        column INITIATIVE (
            reportColumnQueryId: 2
            derivedColumn: N
            type: link
            heading {
                heading: Initiative
                alignment: center
            }
            layout {
                sequence: 40
            }
            link {
                target: {
                    page: 94
                    items: {
                        P94_INITIATIVE_ID: #ID#
                    }
                    request: 94
                }
                linkText: #INITIATIVE#
            }
        )

        column SPONSOR (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: Sponsor
            }
            layout {
                sequence: 50
            }
        )

    )

    region search (
        name: Search
        type: facetedSearch
        source {
            filteredRegion: @search-results
        }
        layout {
            sequence: 10
            slot: leftColumn
            columnSpan: 4
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--noPadding
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        accessibility {
            landmarkLabel: Filters
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            showTotalRowCount: true
            displayChartForTopNValues: 10
        }

        facet P11_ATTRIBUTE_CHANGE_MONTH (
            type: checkboxGroup
            label {
                label: Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ATTRIBUTE_CHANGE_MONTH
            }
        )

        facet P11_ATTRIBUTE_COLUMN (
            type: checkboxGroup
            label {
                label: Attribute
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 30
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: ATTRIBUTE_COLUMN
            }
        )

        facet P11_CHANGED_BY (
            type: checkboxGroup
            label {
                label: Changed By
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 70
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: CHANGED_BY
            }
        )

        facet P11_CHANGE_TO (
            type: radioGroup
            label {
                label: Attribute
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 20
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: CHANGE_TO
            }
        )

        facet P11_CHANGE_TYPE (
            type: checkboxGroup
            label {
                label: Change
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 60
            }
            listEntries {
                zeroCountEntries: disable
                sortByTopCounts: false
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: CHANGE_TYPE
            }
        )

        facet P11_FOCUS_AREA (
            type: checkboxGroup
            label {
                label: Focus Area
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: FOCUS_AREA
            }
        )

        facet P11_SEARCH (
            type: search
            label {
                label: Search
            }
            layout {
                sequence: 10
            }
            source {
                dbColumns: ATTRIBUTE_DATATYPE,PROJECT_ID,ATTRIBUTE_COLUMN,OLD_VALUE,NEW_VALUE
            }
        )

    )

    region search-results (
        name: Search Results
        type: classicReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select :NOMENCLATURE_INITIATIVE change_to,
                       null focus_area,
                       CHANGED_ON               ATTRIBUTE_CHANGE_DATE,
                       to_char(CHANGED_ON,'YYYY.MM') ATTRIBUTE_CHANGE_Month,
                       case change_type when 'CREATE' then 'Added'
                                        when 'UPDATE' then 'Updated'
                                        when 'DELETE' then 'Deleted'
                                        else change_type
                            end change_type,
                       --
                       initcap(replace(attribute_column,'_',' ')) ATTRIBUTE_COLUMN,
                       decode(old_value,'Y','Yes','N','No',old_value) OLD_VALUE,
                       decode(new_value,'Y','Yes','N','No',new_value) NEW_VALUE,
                       changed_by
                  from SP_INITIATIVE_HISTORY
                 where INITIATIVE_id = :P11_INITIATIVE_ID
                union all
                select :NOMENCLATURE_INITIATIVE ||' Focus Area' change_to,
                       t.focus_area,
                       h.CHANGED_ON             ATTRIBUTE_CHANGE_DATE,
                       to_char(h.CHANGED_ON,'YYYY.MM') ATTRIBUTE_CHANGE_Month,
                       case h.change_type when 'CREATE' then 'Added'
                                        when 'UPDATE' then 'Updated'
                                        when 'DELETE' then 'Deleted'
                                        else change_type
                            end change_type,
                       --
                       initcap(replace(h.attribute_column,'_',' ')) ATTRIBUTE_COLUMN,
                       decode(h.old_value,'Y','Yes','N','No',h.old_value) OLD_VALUE,
                       decode(h.new_value,'Y','Yes','N','No',h.new_value) NEW_VALUE,
                       h.changed_by
                  from sp_init_focus_area_history h,
                       sp_initiative_focus_areas t
                 where h.init_focus_area_id = t.id
                   and t.initiative_id = :P11_INITIATIVE_ID
                ```
            pageItemsToSubmit: P11_INITIATIVE_ID
        }
        layout {
            sequence: 20
            slot: body
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        reportLayout {
            numberOfRows: 50
        }
        componentAppearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Report--stretch
                t-Report--staticRowColors
                t-Report--rowHighlight
                t-Report--inline
                t-Report--hideNoPagination
            ]
        }
        pagination {
            type: nextAndPreviousLinks
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No history found
        }

        column ATTRIBUTE_CHANGE_DATE (
            reportColumnQueryId: 3
            derivedColumn: N
            heading {
                heading: When
            }
            layout {
                sequence: 92
            }
            appearance {
                formatMask: SINCE_SHORT
            }
            sorting {
                defaultSequence: 1
                direction: desc
            }
        )

        column ATTRIBUTE_CHANGE_MONTH (
            reportColumnQueryId: 4
            derivedColumn: N
            type: hidden
            layout {
                sequence: 102
            }
        )

        column ATTRIBUTE_COLUMN (
            reportColumnQueryId: 6
            derivedColumn: N
            heading {
                heading: Attribute
            }
            layout {
                sequence: 32
            }
        )

        column CHANGED_BY (
            reportColumnQueryId: 9
            derivedColumn: N
            heading {
                heading: Changed By
            }
            layout {
                sequence: 82
            }
        )

        column CHANGE_TO (
            reportColumnQueryId: 1
            derivedColumn: N
            heading {
                heading: Change To
            }
            layout {
                sequence: 12
            }
        )

        column CHANGE_TYPE (
            reportColumnQueryId: 5
            derivedColumn: N
            heading {
                heading: Change
            }
            layout {
                sequence: 52
            }
        )

        column FOCUS_AREA (
            reportColumnQueryId: 2
            derivedColumn: N
            heading {
                heading: Focus Area
            }
            layout {
                sequence: 22
            }
        )

        column NEW_VALUE (
            reportColumnQueryId: 8
            derivedColumn: N
            heading {
                heading: New Value
            }
            layout {
                sequence: 72
            }
        )

        column OLD_VALUE (
            reportColumnQueryId: 7
            derivedColumn: N
            heading {
                heading: Old Value
            }
            layout {
                sequence: 62
            }
        )

    )

    pageItem P11_INITIATIVE_ID (
        type: hidden
        layout {
            sequence: 10
            region: @breadcrumb
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: alphanumWithSpace
        }
    )

    button refresh (
        buttonName: refresh
        label: Refresh
        layout {
            sequence: 30
            region: @breadcrumb
            slot: next
        }
        appearance {
            buttonTemplate: @/text-with-icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
                t-Button--iconLeft
            ]
            icon: fa-undo
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 11
                items: {
                    P11_PROJECT_ID: &P11_PROJECT_ID.
                }
                clearCache: 64
                action: resetRegions
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 20
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 94
                items: {
                    P94_INITIATIVE_ID: &P11_INITIATIVE_ID.
                }
                clearCache: 94
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process new (
        name: New
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_log.log_interaction(
                    p_project_id => :P11_PROJECT_ID);
                ```
        }
        execution {
            sequence: 10
            point: beforeRegions
        }
        advanced {
            executionMappingIdentifier: 16910603562584522306
        }
    )

)

