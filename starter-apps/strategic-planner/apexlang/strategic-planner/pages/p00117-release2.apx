    dynamicAction post-comment (
        name: post comment
        execution {
            sequence: 30
        }
        when {
            event: click
            selectionType: button
            button: @post-comment
        }

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 60
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Comment Added Successfully");
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

        action post-comment-on-server (
            name: post comment on server
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_comment_util.add_release_comment (
                        p_app_user_id     => :APP_USER_ID,
                        p_comment         => :P117_COMMENT,
                        p_release_id      => :P117_RELEASE_ID,
                        p_private_yn      => :P117_PRIVATE_YN,
                        p_image_ref_id    => :P117_IMAGE_REF_ID );
                    
                    :P117_COMMENT      := null;
                    :P117_IMAGE_REF_ID := to_number(sys_guid(), 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX');
                    ```
                itemsToSubmit: [
                    P117_COMMENT
                    P117_RELEASE_ID
                    P117_PRIVATE_YN
                    P117_IMAGE_REF_ID
                ]
                itemsToReturn: [
                    P117_COMMENT
                    P117_IMAGE_REF_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

    )

