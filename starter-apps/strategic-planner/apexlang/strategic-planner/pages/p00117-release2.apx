    dynamicAction on-add-link-click (
        name: on add link click
        execution {
            sequence: 90
        }
        when {
            event: click
            selectionType: button
            button: @add-link
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Link Details
                message: Please supply a Link URL and a Link Name.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P117_LINK') === '' || $v('P117_LINK_NAME') === ''
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P117_LINK_NAME is not null and :P117_LINK is not null then
                        insert into SP_RELEASE_LINKS (release_id, link_name, link_url) 
                            values (:P117_RELEASE_ID, :P117_LINK_NAME, :P117_LINK);
                    :P117_LINK_NAME := null;
                    :P117_LINK := null;
                    end if;
                    ```
                itemsToSubmit: [
                    P117_LINK_NAME
                    P117_LINK
                    P117_RELEASE_ID
                ]
                itemsToReturn: [
                    P117_LINK
                    P117_LINK_NAME
                ]
                showProcessing: true
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @links
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

