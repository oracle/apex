        headerAndFooter {
            footerText: <p>This list of contributors includes anyone who is identified as a &NOMENCLATURE_PROJECT. owner, contributor, reviewer, or who has activity logged against a &NOMENCLATURE_PROJECT. identified for this release.
        }
        componentAppearance {
            display: report
        }
        settings {
            title: &NAME.
            description: &NOMENCLATURE_PROJECT. Owner: <strong>&PROJECT_OWNER_COUNT.</strong>, Contributor: <strong>&IS_CONTRIBUTOR.</strong>, Milestones: <strong>&HAS_MILESTONES.</strong>, Reviews: <strong>&HAS_REVIEWS.</strong>, Tasks: <strong>&HAS_TASKS.</strong>, Activity: <strong>&PROJECT_ACTIVIVITY_CONTRIBUTOR.</strong>
            miscellaneous: &EMAIL.
            displayAvatar: true
        }
