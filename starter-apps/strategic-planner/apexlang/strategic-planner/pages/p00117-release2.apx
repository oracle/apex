    process email-exceptions-to-me (
        name: Email exceptions to me
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_summary      clob;
                begin
                
                    l_summary := sp_release_timeline.release_exceptions (
                                     p_release_id              => :P117_RELEASE_ID,
                                     p_links                   => 'EMAIL' );
                
                    apex_mail.send ( 
                            p_to                 => :APP_USER,   
                            p_from               => :APP_USER,  
                            p_application_id     => :APP_ID,  
                            p_template_static_id => 'EMAIL_ME',  
                            p_placeholders       => '{' || '"APPLICATION_LINK": "' || sp_util.get_setting(p_static_id => 'APP_HOME_URL') ||'", '|| 
                                                           '"APP_NAME": '   || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER ) ||', '||
                                                           '"SUBJECT": '    || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER || ' ' || :P117_RELEASE ||' Release Exceptions' ) ||', '||
                                                           '"SUMMARY": '    || apex_json.stringify( l_summary ) ||
                                                     '}' ); 
                
                end;
                ```
        }
        execution {
            sequence: 20
        }
        successMessage {
            successMessage: Release Exceptions email sent.
        }
        advanced {
            executionMappingIdentifier: 11121216298102701745
        }
        serverSideCondition {
            whenButtonPressed: @email-exceptions-to-me
        }
    )

    process email-timeline-to-me (
        name: Email timeline to me
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_summary      clob;
                begin
                
                    l_summary := sp_release_timeline.show_week (
                                     p_release_id          => :P117_RELEASE_ID,
                                     p_exclude_complete_yn => nvl(:P117_EXCLUDE_COMPLETE_YN,'N'));
                
                    apex_mail.send ( 
                            p_to                 => :APP_USER,   
                            p_from               => :APP_USER,  
                            p_application_id     => :APP_ID,  
                            p_template_static_id => 'EMAIL_ME',  
                            p_placeholders       => '{' || '"APPLICATION_LINK": "' || sp_util.get_setting(p_static_id => 'APP_HOME_URL') ||'", '|| 
                                                           '"APP_NAME": '   || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER ) ||', '||
                                                           '"SUBJECT": '    || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER || ' ' || :P117_RELEASE ||' Release Timeline' ) ||', '||
                                                           '"SUMMARY": '    || apex_json.stringify( l_summary ) ||
                                                     '}' ); 
                
                end;
                ```
        }
        execution {
            sequence: 10
        }
        successMessage {
            successMessage: Timeline email sent.
        }
        advanced {
            executionMappingIdentifier: 11308913649559009265
        }
        serverSideCondition {
            whenButtonPressed: @email-to-me
        }
    )

    process subscribe-to-exceptions (
        name: Subscribe to Exceptions
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_util.notification_opt_in (
                    p_team_member_id => :APP_USER_ID,
                    p_notification_id => sp_util.get_notification_id('RELEASE_EXCEPTIONS'),
                    p_release_id      => :P117_RELEASE_ID );
                ```
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Subscribed to Release Exceptions.
        }
        advanced {
            executionMappingIdentifier: 11501710570630050902
        }
        serverSideCondition {
            whenButtonPressed: @subscribe-to-exceptions
        }
    )

    process unsubscribe-exceptions (
        name: Unsubscribe Exceptions
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_util.notification_opt_out (
                    p_team_member_id  => :APP_USER_ID,
                    p_notification_id => sp_util.get_notification_id('RELEASE_EXCEPTIONS'),
                    p_release_id      => :P117_RELEASE_ID );
                ```
        }
        execution {
            sequence: 40
