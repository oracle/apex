page 148 (
    name: Weekly Summary
    alias: WEEKLY-SUMMARY
    title: Weekly Summary
    pageGroup: @users
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
        warnOnUnsavedChanges: false
    }
    css {
        inline:
            ```css
            .sp-tag {
              padding: .125rem .25rem;
              display: inline-block;
              vertical-align: text-bottom;
              border-radius: .1875rem;
              background-color: rgba(0, 0, 0, .1);
              text-overflow: ellipsis;
              white-space: nowrap;
            }
            
            .sp-tags-container {
              display: flex;
              align-items: center;
              flex-wrap: wrap;
              gap: .25rem;
              justify-content: flex-start;
            }
            
            h3:first-of-type {
              margin-block-start: 0;
            }
            ```
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }

    region breadcrumb (
        name: Breadcrumb
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 7
            slot: breadcrumbBar
        }
        appearance {
            template: @/title-bar
            templateOptions: [
                #DEFAULT#
                t-BreadcrumbRegion--useBreadcrumbTitle
            ]
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
            cssClasses: has-header-actions
        }
    )

    region buttons (
        name: buttons
        type: staticContent
        layout {
            sequence: 10
            parentRegion: @weekly-summary
            slot: regionBody
        }
        appearance {
            template: @/buttons-container
            templateOptions: [
                #DEFAULT#
                t-ButtonRegion--noUI
            ]
        }
        config {
            buildOption: @email-configured
        }
    )

    region hidden-stuff (
        name: hidden stuff
        type: staticContent
        layout {
            sequence: 1
            slot: body
        }
    )

    region weekly-summary (
        name: Weekly Summary
        type: staticContent
        layout {
            sequence: 101
            slot: body
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
        advanced {
            regionDisplaySelector: true
        }
    )

    region weekly-summary-content (
        name: Weekly Summary content
        title: Weekly Summary
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                return sp_contributor_summary.generate (
                           p_team_member_id   => :P148_ID,
                           p_show_approvals   => case when apex_application_admin.get_build_option_status (
                                                             p_application_id    => :APP_ID,
                                                             p_build_option_name => 'Approvals' ) = 'INCLUDE'
                                                      then 'Y'
                                                      else 'N'
                                                      end,
                           p_links            => 'APP',
                           p_include_title_yn => 'N',
                           p_apex_session     => :APP_SESSION );
                ```
            pageItemsToSubmit: P148_ID
        }
        layout {
            sequence: 81
            parentRegion: @weekly-summary
            slot: regionBody
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--noBorder
                t-Region--scrollBody
            ]
        }
    )

    pageItem P148_EMAIL (
        type: hidden
        layout {
            sequence: 40
            region: @hidden-stuff
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P148_FIRST_NAME (
        type: hidden
        layout {
            sequence: 50
            region: @hidden-stuff
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    pageItem P148_ID (
        type: hidden
        layout {
            sequence: 10
            region: @hidden-stuff
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P148_LAST_NAME (
        type: hidden
        layout {
            sequence: 60
            region: @hidden-stuff
            slot: regionBody
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
            restrictedChars: webSafe
        }
    )

    button email-me-summary (
        buttonName: EMAIL_ME_SUMMARY
        label: Email to me
        layout {
            sequence: 60
            region: @breadcrumb
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--primary
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
    )

    button subscribe-me-summary (
        buttonName: SUBSCRIBE_ME_SUMMARY
        label: Subscribe me
        layout {
            sequence: 40
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--link
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from sp_notifications n
                 where static_id = 'WEEKLY_SUMMARY'
                   and is_active_yn = 'Y'
                   and not exists (select 1 from sp_notification_subscriptions
                                    where notification_id = n.id
                                      and team_member_id = :APP_USER_ID
                                      and opted_in_yn = 'Y')
                   and :APP_USER_ID is not null
                   and :P148_ID = :APP_USER_ID
                ```
        }
        config {
            buildOption: @subscriptions
        }
    )

    button unsubscribe-me-summary (
        buttonName: UNSUBSCRIBE_ME_SUMMARY
        label: Unsubscribe
        layout {
            sequence: 50
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: [
                #DEFAULT#
                t-Button--link
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
        }
        serverSideCondition {
            type: rowsReturned
            sqlQuery:
                ```sql
                select 1 from sp_notifications n
                 where static_id = 'WEEKLY_SUMMARY'
                   and is_active_yn = 'Y'
                   and exists (select 1 from sp_notification_subscriptions
                                where notification_id = n.id
                                  and team_member_id = :APP_USER_ID
                                  and opted_in_yn = 'Y')
                   and :P148_ID = :APP_USER_ID
                ```
        }
        config {
            buildOption: @subscriptions
        }
    )

    button up (
        buttonName: UP
        label: Navigate Up
        layout {
            sequence: 10
            region: @breadcrumb
            slot: up
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--noUI
            ]
            icon: fa-arrow-up
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 5
                items: {
                    P5_ID: &P148_ID.
                }
                clearCache: 5
                action: resetPagination
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    process email-summary (
        name: Email summary
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                declare
                    l_summary      clob;
                begin
                
                    l_summary := sp_contributor_summary.generate (
                                     p_team_member_id    => :P148_ID,
                                     p_show_activities   => 'Y',
                                     p_show_projects     => 'Y',
                                     p_links             => 'EMAIL'
                                     );
                
                    apex_mail.send ( 
                            p_to                 => :APP_USER,   
                            p_from               => :APP_USER,  
                            p_application_id     => :APP_ID,  
                            p_template_static_id => 'EMAIL_ME',  
                            p_placeholders       => '{' || '"APPLICATION_LINK": "' || sp_util.get_setting(p_static_id => 'APP_HOME_URL') ||'", '|| 
                                                           '"APP_NAME": '   || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER ) ||', '||
                                                           '"SUBJECT": '    || apex_json.stringify( :NOMENCLATURE_STRATEGIC_PLANNER ||' Weekly Summary') ||', '||
                                                           '"SUMMARY": '    || apex_json.stringify( l_summary ) ||
                                                     '}' ); 
                
                end;
                ```
        }
        execution {
            sequence: 30
        }
        successMessage {
            successMessage: Weekly Summary email sent.
        }
        advanced {
            executionMappingIdentifier: 20623619193662027392
        }
        serverSideCondition {
            whenButtonPressed: @email-me-summary
        }
    )

    process set-name-details-in-session-state (
        name: set name details in session state
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select first_name, last_name, email
                      from sp_team_members
                     where id = :P148_ID
                ) loop
                    :P148_FIRST_NAME := c1.first_name;
                    :P148_LAST_NAME  := c1.last_Name;
                    :P148_EMAIL      := c1.email;
                end loop;
                ```
        }
        execution {
            sequence: 20
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 20623618393946027391
        }
    )

    process subscribe-summary (
        name: Subscribe summary
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_util.notification_opt_in (
                    p_team_member_id  => :APP_USER_ID,
                    p_notification_id => sp_util.get_notification_id('WEEKLY_SUMMARY') );
                ```
        }
        execution {
            sequence: 60
        }
        successMessage {
            successMessage: Subscribed to Weekly Summary.
        }
        advanced {
            executionMappingIdentifier: 20623619558699027392
        }
        serverSideCondition {
            whenButtonPressed: @subscribe-me-summary
        }
    )

    process unsubscribe-summary (
        name: Unsubscribe summary
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                sp_util.notification_opt_out (
                    p_team_member_id  => :APP_USER_ID,
                    p_notification_id => sp_util.get_notification_id('WEEKLY_SUMMARY') );
                ```
        }
        execution {
            sequence: 80
        }
        successMessage {
            successMessage: Unsubscribed from Weekly Summary.
        }
        advanced {
            executionMappingIdentifier: 20623620736302027394
        }
        serverSideCondition {
            whenButtonPressed: @unsubscribe-me-summary
        }
    )

)

