        action action (
            position: titleLink
            layout {
                sequence: 30
            }
            behavior {
                target: {
                    page: 3
                    items: {
                        FI: &FRIENDLY_IDENTIFIER1.
                        PN: &PROJECT_URL_NAME.
                    }
                    clearCache: 3
                    action: resetPagination
                }
            }
        )

        action actions (
            position: primaryActions
            template: menu
            label: Actions
            layout {
                sequence: 20
            }
            appearance {
                displayType: icon
                icon: fa-ellipsis-v
                cssClasses: t-Button--noUI
            }

            menu ai-summaries (
                label: AI Summaries
                layout {
                    sequence: 100
                }
                behavior {
                    target: {
                        page: 26
                        items: {
                            P26_PROJECT_ID: &ID.
                        }
                        clearCache: 26
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-ai-sparkle-generate-text
                }
                config {
                    buildOption: @ai-project-summaries
                }
            )

            menu archive (
                label: Archive
                layout {
                    sequence: 110
                }
                behavior {
                    target: {
                        page: 47
                        items: {
                            P47_PROJECT_ID: &ID.
                        }
                        clearCache: 47
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-remove
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu change-history (
                label: Change History
                layout {
                    sequence: 120
                }
                behavior {
                    target: {
                        page: 124
                        items: {
                            P124_ID: &ID.
                        }
                        clearCache: 124
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-clock-o
                }
            )

            menu comp_menu_entry (
                type: separator
                layout {
                    sequence: 30
                }
            )

            menu edit (
                label: "Edit "
                layout {
                    sequence: 10
                }
                behavior {
                    target: {
                        page: 24
                        items: {
                            P24_ID: &ID.
                        }
                        clearCache: 24
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-edit
                }
                security {
                    authorizationScheme: @contribution-rights
                }
            )

            menu nomenclature-project-quick-look (
                label: &NOMENCLATURE_PROJECT. Quick Look
                layout {
                    sequence: 90
                }
                behavior {
                    target: {
                        page: 36
                        items: {
                            P36_ID: &ID.
                        }
                        clearCache: 36
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

            menu owner-quick-look (
                label: Owner Quick Look
                layout {
                    sequence: 80
                }
                behavior {
                    target: {
                        page: 73
                        items: {
                            P73_TEAM_MEMBER_ID: &OWNER_ID.
                        }
                        clearCache: 73
                        action: resetPagination
                    }
                }
                appearance {
                    icon: fa-user
                }
            )

            menu view-details (
                label: View Details
                layout {
                    sequence: 50
                }
                behavior {
                    target: {
                        page: 3
                        items: {
                            FI: &FRIENDLY_IDENTIFIER1.
                            PN: &PROJECT_URL_NAME.
                        }
                        clearCache: 3
                    }
                }
                appearance {
                    icon: fa-package
                }
            )

        )

        action favorite-project (
            position: primaryActions
            template: button
            label: Favorite Project
            layout {
                sequence: 10
            }
            behavior {
                type: redirectUrl
                targetUrl: #action$favoriteProject?id=&ID.
            }
            appearance {
                displayType: icon
                icon: &FAVORITE_ICON.
                cssClasses: t-Button--noUI
            }
        )

    )

    region faceted-search (
        name: Faceted Search
        type: facetedSearch
        source {
            filteredRegion: @content-row
        }
        layout {
            sequence: 30
            slot: leftColumn
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        advanced {
            regionDisplaySelector: true
        }
        settings {
            compactNosThreshold: 10000
            showCurrentFacets: selector
            currentFacetsSelector: #active_facets
            displayChartForTopNValues: 10
        }

        facet P23_ACTIVE_ACTIVITY (
            type: checkboxGroup
            label {
                label: Current Activity
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 200
            }
            appearance {
                display: addFilterDialog
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: ACTIVE_ACTIVITY
            }
        )

        facet P23_APPROVALS (
            type: checkboxGroup
            label {
                label: Approvals
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 120
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: APPROVAL_FACET
            }
            multipleValues {
                type: delimitedList
                separator: ,
                trimWhitespace: true
            }
            config {
                buildOption: @approvals
            }
        )

        facet P23_COMPLETE_MONTH (
            type: checkboxGroup
            label {
                label: Complete Month
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 80
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            source {
                databaseColumn: COMPLETE_MONTH
            }
        )

        facet P23_FAVORITE (
            type: checkboxGroup
            label {
                label: My Favorite
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 130
            }
            listEntries {
                maxDisplayedEntries: 7
            }
            source {
                databaseColumn: FAVORITE
            }
        )

        facet P23_FOCUS_AREA (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_AREA.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 40
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            advanced {
                showChartInitially: true
                collapsible: true
                initiallyCollapsed: true
            }
            source {
                databaseColumn: FOCUS_AREA
            }
        )

        facet P23_INITIATIVE (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_INITIATIVE.
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 50
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            advanced {
                showChartInitially: true
                collapsible: true
                initiallyCollapsed: true
            }
            source {
                databaseColumn: INITIATIVE
            }
        )

        facet P23_INIT_FOCUS_AREA (
            type: checkboxGroup
            label {
                label: Focus Area
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 110
            }
            listEntries {
                maxDisplayedEntries: 5
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: INIT_FOCUS_AREA
            }
            serverSideCondition {
                type: rowsReturned
                sqlQuery: select 1 from sp_initiative_focus_areas
            }
        )

        facet P23_PRIORITY (
            type: checkboxGroup
            label {
                label: Priority
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 150
            }
            listEntries {
                sortByTopCounts: false
                maxDisplayedEntries: 5
            }
            advanced {
                collapsible: true
            }
            source {
                databaseColumn: PRIORITY
            }
        )

        facet P23_PROJECT_GROUP (
            type: checkboxGroup
            label {
                label: &NOMENCLATURE_PROJECT. Group
            }
            lov {
                type: distinctValues
            }
            layout {
                sequence: 210
            }
            listEntries {
                maxDisplayedEntries: 5
