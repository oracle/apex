    computation p3-approval-type (
        itemName: P3_APPROVAL_TYPE
        execution {
            sequence: 120
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select approval_type   
                  from sp_approval_types
                 where id = (select approval_type_id
                               from sp_project_approvals p,
                                    sp_project_approval_chain c    
                              where p.id = c.project_approval_id   
                                and c.id = :P3_PROJECT_APPROVAL_CHAIN_ID)
                ```
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P3_PROJECT_APPROVAL_CHAIN_ID
        }
        config {
            buildOption: @approvals
        }
    )

    computation p3-dup-project (
        itemName: P3_DUP_PROJECT
        execution {
            sequence: 50
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select (select b.project from sp_projects b where b.id = a.DUPLICATE_OF_PROJECT_ID) project
                from sp_projects a
                where a.id = :P3_PROJECT_ID
                ```
        }
    )

    computation p3-dup-project-id (
        itemName: P3_DUP_PROJECT_ID
        execution {
            sequence: 60
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select DUPLICATE_OF_PROJECT_ID
                from sp_projects
                where id = :P3_PROJECT_ID
                ```
        }
    )

    computation p3-include-future (
        itemName: P3_INCLUDE_FUTURE
        execution {
            sequence: 70
            point: beforeHeader
