    dynamicAction remove-tag (
        name: Remove Tag
        execution {
            sequence: 140
            eventScope: dynamic
        }
        when {
            event: click
            selectionType: jQuerySelector
            jquerySelector: .js-remove-tag
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_util.remove_project_tag (
                        p_project_id => :P3_PROJECT_ID, 
                        p_tag => :P3_TAG_TO_REMOVE);
                    :P3_TAG_TO_REMOVE := null;
                    ```
                itemsToSubmit: P3_PROJECT_ID
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

        action native-set-value (
            action: setValue
            settings {
                type: jsExpression
                jsExpression: $(this.triggeringElement).data('tag');
            }
            affectedElements {
                selectionType: items
                items: P3_TAG_TO_REMOVE
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

