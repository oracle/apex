                }
            }
            appearance {
                hot: true
                cssClasses: w140
            }
            serverSideCondition {
                type: expression
                plsqlExpression: :STATUS_VALUE = 'CLARIFICATION-REQUESTED' and :CLARIFICATION_ID is not null
            }
        )

        action review-2 (
            position: primaryActions
            template: button
            label: Review
            layout {
                sequence: 20
            }
            behavior {
                target: {
                    page: 125
                    items: {
                        P125_PROJECT_APPROVAL_CHAIN_ID: &P3_PROJECT_APPROVAL_CHAIN_ID.
                        P125_APPROVAL_TYPE: &P3_APPROVAL_TYPE.
                    }
                    clearCache: 125
                }
            }
            appearance {
                hot: true
                cssClasses: w140
            }
            serverSideCondition {
                type: expression
                plsqlExpression: :STATUS_VALUE in ('CLARIFICATION-REQUESTED','PENDING') and :USER_HAS_PENDING_REVIEW is not null
            }
        )

        action view-details (
            position: primaryActions
            template: button
            label: View Details
            layout {
                sequence: 40
            }
            behavior {
                target: {
                    page: 125
                    items: {
                        P125_PROJECT_APPROVAL_ID: &ID.
                    }
                    clearCache: 125
                }
            }
            appearance {
                cssClasses: w140
            }
            serverSideCondition {
                type: expression
                plsqlExpression: :STATUS_VALUE in ('APPROVED','REJECTED','WITHDRAWN') or (:USER_HAS_PENDING_REVIEW is null and :CLARIFICATION_ID is null)
            }
        )

    )

