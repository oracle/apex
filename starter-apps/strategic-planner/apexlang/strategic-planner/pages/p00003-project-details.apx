    dynamicAction add-comment (
        name: Add Comment
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @post-comment
        }
        clientSideCondition {
            type: itemIsNotNull
            item: P3_COMMENT
        }

        action add-comment-and-do-alerts (
            name: add comment and do alerts
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    sp_comment_util.add_project_comment (
                        p_app_user_id   => :APP_USER_ID,
                        p_app_user      => :APP_USER,
                        p_comment       => :P3_COMMENT,
                        p_project_id    => :P3_PROJECT_ID,
                        p_private_yn    => nvl(:P3_PRIVATE_YN,'N'),
                        p_app_id        => :APP_ID,
                        p_permalink_pre => :P3_PERMALINK_PREFIX,
                        p_nomen_sp      => :NOMENCLATURE_STRATEGIC_PLANNER,
                        p_nomen_project => :NOMENCLATURE_PROJECT,
                        p_image_ref_id  => :P3_IMAGE_REF_ID );
                    
                    :P3_COMMENT      := null;
                    :P3_IMAGE_REF_ID := to_number(sys_guid(), 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX');
                    ```
                itemsToSubmit: [
                    P3_COMMENT
                    P3_PRIVATE_YN
                    P3_PROJECT_ID
                    P3_PERMALINK_PREFIX
                    P3_IMAGE_REF_ID
                ]
                itemsToReturn: [
                    P3_COMMENT
                    P3_IMAGE_REF_ID
                ]
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action confirmation-message (
            name: confirmation message
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Comment Added Successfully");
            }
            execution {
                sequence: 70
                fireOnInit: false
            }
        )

        action native-disable (
            action: disable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

        action native-enable (
            action: enable
            affectedElements {
                selectionType: button
                button: @post-comment
            }
            execution {
                sequence: 80
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @comments-report
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

    dynamicAction add-contributor (
        name: add contributor
        execution {
            sequence: 260
        }
        when {
            event: click
            selectionType: button
            button: @add-contributor
        }

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    declare 
                       c int := 0;
                    begin
                       select count(*) into c from SP_PROJECT_CONTRIBUTORS where project_id = :P3_PROJECT_ID and TEAM_MEMBER_ID = :P3_CONTRIBUTOR;
                       if c = 0 then 
                          insert into SP_PROJECT_CONTRIBUTORS
                          (PROJECT_ID, TEAM_MEMBER_ID, RESPONSIBILITY_ID)
                          values
                          (:P3_PROJECT_ID, :P3_CONTRIBUTOR, :P3_CONTRIBUTOR_ROLE);
                       end if;
                    
                       :P3_CONTRIBUTOR := null;
                       for c1 in (select max(id) id from SP_RESOURCE_TYPES where IS_DEFAULT_YN = 'Y') loop
                           :P3_CONTRIBUTOR_ROLE := c1.id;
                       end loop;
                    end;
                    ```
                itemsToSubmit: [
                    P3_PROJECT_ID
                    P3_CONTRIBUTOR
                    P3_CONTRIBUTOR_ROLE
                ]
                itemsToReturn: [
                    P3_CONTRIBUTOR
                    P3_CONTRIBUTOR_ROLE
                ]
                showProcessing: true
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            security {
                authorizationScheme: @contribution-rights
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Contributor Added Successfully");
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @contributors-content
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
        )

    )

    dynamicAction add-link (
        name: add link
        execution {
            sequence: 80
        }
        when {
            event: click
            selectionType: button
            button: @add-link
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Link Details
                message: Please supply a Link URL and a Link Name.
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P3_LINK') === '' || $v('P3_LINK_NAME') === ''
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P3_LINK_NAME is not null and :P3_LINK is not null
                    then sp_util.add_project_link (
                             p_project_id    => :P3_PROJECT_ID,
                             p_link_name     => :P3_LINK_NAME,
                             p_link_url      => :P3_LINK );
                        :P3_LINK_NAME := null;
                        :P3_LINK := null;
                    end if;
                    ```
                itemsToSubmit: [
                    P3_LINK_NAME
                    P3_LINK
                    P3_PROJECT_ID
                ]
                itemsToReturn: [
                    P3_LINK
                    P3_LINK_NAME
                ]
                showProcessing: true
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode: apex.message.ariaAlertMessage("Link Added Successfully");
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @links
            }
            execution {
                sequence: 40
                fireOnInit: false
            }
        )

    )

    dynamicAction add-related (
        name: add related
        execution {
            sequence: 110
        }
        when {
            event: click
            selectionType: button
            button: @add-related-project
        }

        action native-alert (
            action: alert
            settings {
                title: Missing Related &NOMENCLATURE_PROJECT. Details
                message: Please select a related &NOMENCLATURE_PROJECT..
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
            clientSideCondition {
                type: jsExpression
                javaScriptExpression: $v('P3_RELATED_PROJECT_ID') === ''
            }
        )

        action native-clear (
            action: clear
            affectedElements {
                selectionType: items
                items: P3_RELATED_PROJECT_ID
            }
            execution {
                sequence: 30
                fireOnInit: false
            }
        )

        action native-execute-plsql-code (
            action: executeServerSideCode
            settings {
                plsqlCode:
                    ```plsql
                    if :P3_RELATED_PROJECT_ID is not null then
                        sp_util.add_related_project (
                            p_related_project_id => :P3_RELATED_PROJECT_ID,
                            p_project_id => :P3_PROJECT_ID );
                    end if;
                    ```
                itemsToSubmit: [
                    P3_RELATED_PROJECT_ID
                    P3_PROJECT_ID
                ]
            }
            execution {
                sequence: 20
                fireOnInit: false
            }
            clientSideCondition {
                type: itemIsNotNull
                item: P3_RELATED_PROJECT_ID
            }
        )

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @related
            }
            execution {
                sequence: 50
                fireOnInit: false
            }
        )

    )

