    region description-content (
        name: description content
        title: Description
        type: dynamicContent
        source {
            plsqlFunctionBody:
                ```plsql
                declare
                    x clob;
                begin
                x := 'No description provided.';
                for c1 in (select description from sp_projects d 
                            where d.id = :P3_PROJECT_ID
                              and description is not null) loop
                    x := apex_markdown.to_html(c1.description);
                end loop;
                return x;
                end;
                ```
        }
        layout {
            sequence: 120
            parentRegion: @description
            slot: regionBody
        }
        appearance {
            template: @/standard
            templateOptions: [
                #DEFAULT#
                t-Region--hideHeader js-addHiddenHeadingRoleDesc
                t-Region--scrollBody
            ]
        }
    )

    region documents (
        name: Documents
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select case doc_type when 'Project'
                            then :NOMENCLATURE_PROJECT
                            when 'Task'
                            then name
                            end type,
                       case doc_type when 'Project'
                            then '12' 
                            when 'Task'
                            then '504'
                            end edit_page,
                       case doc_type when 'Project'
                            then '30' 
                            when 'Task'
                            then '505'
                            end display_page,
                       document_id,
                       DOCUMENT_FILENAME,
                       UPDATED,
                       created,
                       doc_description,
                       tags,
                       added_by created_by,
                       filesize doc_size,
                       created date_created,
                       file_extension,
                       important,
                       filesize document
                  from SP_DOCUMENTS_V
                 where project_id = :P3_PROJECT_ID
                   and doc_type in ('Project','Task')
                ```
            pageItemsToSubmit: P3_PROJECT_ID
        }
        layout {
            sequence: 140
            slot: body
            startNewRow: false
            newColumn: false
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: DOCUMENTS
            regionDisplaySelector: true
        }
