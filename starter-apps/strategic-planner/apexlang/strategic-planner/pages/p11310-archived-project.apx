    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 10
            region: @buttons
            slot: create
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--danger
                t-Button--simple
            ]
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: &APP_TEXT$DELETE_MSG!RAW.
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P11310_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        advanced {
            executionMappingIdentifier: 11817717116486445447
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,SAVE,DELETE
        }
    )

    process initialize-form-nomenclature-project (
        name: Initialize form &NOMENCLATURE_PROJECT.
        type: formInitialization
        formRegion: @archived-nomenclature-project
        execution {
            sequence: 10
            point: beforeHeader
        }
        advanced {
            executionMappingIdentifier: 11817716397484445445
        }
    )

    process process-form-nomenclature-project (
        name: Process form &NOMENCLATURE_PROJECT.
        type: formAutoRowProcessing
        formRegion: @archived-nomenclature-project
        execution {
            sequence: 40
        }
        successMessage {
            successMessage: Action Processed
        }
        advanced {
            executionMappingIdentifier: 11817716743606445446
        }
    )

    process remove-dependent-data-to-avoid-project-history-table-trigger-mutation (
        name: remove dependent data (to avoid project_history table trigger mutation)
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                for c1 in (
                    select id
                      from sp_tasks
                     where project_id = :P11310_ID
                ) loop
                
                    for c2 in (
                        select image_ref_id
                          from sp_task_comments
                         where task_id = c1.id
                           and image_ref_id is not null
                    ) loop
                        delete from sp_comment_images
                         where image_ref_id = c2.image_ref_id;
                    end loop;
                
                    delete from sp_task_comments
                     where task_id = c1.id;
                
                    delete from sp_task_documents
                     where task_id = c1.id;
                
                    delete from sp_task_links
                     where task_id = c1.id;
                
                    delete from sp_task_history
                     where task_id = c1.id;
                end loop;
                
                delete from SP_TASKS
                 where project_id = :P11310_ID;
                
                for c1 in (
                    select image_ref_id
                      from sp_project_comments
                     where project_id = :P11310_ID
                       and image_ref_id is not null
                ) loop
                    delete from sp_comment_images
                     where image_ref_id = c1.image_ref_id;
                end loop;
                
                delete from sp_project_comments
                 where project_id = :P11310_ID;
                
                delete from SP_PROJECT_DOCUMENTS
                 where project_id = :P11310_ID;
                
                delete from SP_PROJECT_LINKS
                 where project_id = :P11310_ID;
                
                delete from SP_PROJECT_RELATED
                 where project_id = :P11310_ID
                    or related_project_id = :P11310_ID;
                
                delete from SP_PROJECT_HISTORY
                 where project_id = :P11310_ID;
                ```
        }
        execution {
            sequence: 20
        }
        advanced {
            executionMappingIdentifier: 14926172825344381522
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

    process remove-log-rows (
        name: remove log rows
        type: executeCode
        source {
            plsqlCode:
                ```plsql
                delete from SP_PROJ_INTERACTIONS_LOG
                 where project_id = :P11310_ID;
                ```
        }
        execution {
            sequence: 10
        }
        advanced {
            executionMappingIdentifier: 13594465955952793337
        }
        serverSideCondition {
            whenButtonPressed: @delete
        }
    )

)

