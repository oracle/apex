    region child-objects (
        name: Child Objects
        type: interactiveReport
        source {
            location: localDatabase
            tableName: EBA_UTIL_FAREST_ENDPOINT_CHOBJ
            whereClause: endpoint_id = :P3_ID
            orderByClause: obj_name
            pageItemsToSubmit: P3_ID
