    pageItem P3_SHOW_HIDDEN_ATTRS (
        type: selectList
        label {
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC2:Show Only Visible Attributes;N,Show All Attributes;Y
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            slot: beforeNavigationBar
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            cssClasses: u-nowrap
            height: 1
        }
        default {
            type: static
            staticValue: N
        }
    )

    button close (
        buttonName: Close
        label: Close
        layout {
            sequence: 20
            region: @help
            slot: close
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button help (
        buttonName: Help
        label: Help
        layout {
            sequence: 60
            slot: beforeNavigationBar
        }
        appearance {
            buttonTemplate: @/icon
            templateOptions: [
                #DEFAULT#
                t-Button--primary
            ]
            icon: fa-info-circle-o
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    dynamicAction on-close-clicked (
        name: On Close Clicked
        execution {
            sequence: 20
        }
        when {
            event: click
            selectionType: button
            button: @close
        }

        action native-close-region (
            action: closeRegion
            affectedElements {
                selectionType: region
                region: @help
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction on-help-clicked (
        name: On Help Clicked
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @help
        }

        action native-open-region (
            action: openRegion
            affectedElements {
                selectionType: region
                region: @help
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction when-change-hidden-switch (
        name: When Change Hidden Switch
        execution {
            sequence: 30
        }
        when {
            selectionType: items
            items: P3_SHOW_HIDDEN_ATTRS
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @attributes
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction when-tab-changed (
        name: When Tab Changed
        execution {
            sequence: 40
        }
        when {
            event: custom
            customEvent: atabsactivate
            selectionType: jQuerySelector
            jquerySelector: #tabs
        }

        action native-javascript-code (
            action: executeJsCode
            settings {
                jsCode:
                    ```javascript-browser
                    // Find the active tab and its associated region
                    let active_tab = apex.region(this.triggeringElement.id).widget().aTabs("getActive");
                    let active_region = $('[id$=-tab]',$(active_tab.panel$));
                    
                    // If we have region, find its ID and record that for use in the regions
                    if(active_region){
                        let active_id = $(active_region).attr('id');
                        if ( active_id == "attributes-tab" ) {
                            apex.items.P3_SHOW_HIDDEN_ATTRS.show();
                        }
                        else {
                            apex.items.P3_SHOW_HIDDEN_ATTRS.hide();
                        }
                    }
                    ```
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    computation p3-name (
        itemName: P3_NAME
        execution {
            sequence: 10
            point: beforeHeader
        }
        computation {
            sqlQuery:
                ```sql
                select wsm.module_name
                from eba_util_farest_endpoints e
                left join apex_appl_web_src_modules wsm on wsm.module_static_id = e.module_static_id
                                                        and wsm.application_id  = e.application_id
                where e.id = :P3_ID
                
                ```
        }
    )

)

