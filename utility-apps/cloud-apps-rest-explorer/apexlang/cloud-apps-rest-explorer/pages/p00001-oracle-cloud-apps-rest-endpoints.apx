    dynamicAction on-refresh-progress (
        name: On Refresh Progress
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @refresh-progress-display
        }

        action native-refresh (
            action: refresh
            affectedElements {
                selectionType: region
                region: @show-progress
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    dynamicAction on-tree-selection-changed (
        name: On Tree Selection Changed
        execution {
