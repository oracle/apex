    pageItem P1_RELEASE_ID (
        type: selectList
        label {
            label: Release Id
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select 'Release '||name as name, id
                from eba_util_facat_releases
                union all
                select '< No Catalog >', -1
                from dual
                where not exists (
                    select null
                      from eba_util_facat_endpoints
                      fetch first row only)
                order by name
                ```
            displayExtraValues: false
            displayNullValue: false
        }
        layout {
            sequence: 10
            slot: beforeNavigationBar
            alignment: left
        }
        appearance {
            template: @/hidden
            templateOptions: #DEFAULT#
            height: 1
        }
        sessionState {
            storage: user
        }
    )

