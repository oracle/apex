        action assign-selected-bo-id (
            name: Assign Selected BO ID
            action: setValue
            settings {
                type: jsExpression
                jsExpression: "apex.region(\"bo-tree\").call(\"getSelectedNodes\")[0]?.id"
            }
            affectedElements {
                selectionType: items
                items: P1_SELECTED_BO_ID
            }
            execution {
                sequence: 20
                fireOnInit: false
                stopExecutionOnError: false
                waitForResult: false
            }
        )

